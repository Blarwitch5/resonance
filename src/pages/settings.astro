---
import DashboardLayout from '../components/layouts/DashboardLayout.astro'
import ThemeSwitcher from '../components/ui/ThemeSwitcher.astro'
import LanguageSwitcher from '../components/ui/LanguageSwitcher.astro'
import Avatar from '../components/ui/Avatar.astro'
import Camera from '@lucide/astro/icons/camera'
import Pencil from '@lucide/astro/icons/pencil'
import Check from '@lucide/astro/icons/check'
import X from '@lucide/astro/icons/x'
import ArrowLeft from '@lucide/astro/icons/arrow-left'
import Eye from '@lucide/astro/icons/eye'
import EyeOff from '@lucide/astro/icons/eye-off'
import { getSettingsMessages } from '../i18n/settings'
import { getLayoutMessages } from '../i18n/layout'
import { normalizeLocale } from '../i18n/config'

const session = Astro.locals.session
const user = Astro.locals.user

if (!session || !user) {
  return Astro.redirect('/login')
}

import { db } from '../lib/db'
const dbUser = await db.user.findUnique({
  where: { id: user.id },
  select: { isPrivate: true, notificationPrefs: true },
})
const isPrivate = dbUser?.isPrivate ?? false
const notifPrefs = (dbUser?.notificationPrefs ?? {}) as {
  push?: { follower?: boolean; shelfAdd?: boolean; like?: boolean; comment?: boolean }
  email?: { follower?: boolean; comment?: boolean }
}

const locale = normalizeLocale(Astro.cookies.get('locale')?.value ?? Astro.request.headers.get('accept-language')?.split(',')[0]?.slice(0, 2))
const t = getSettingsMessages(locale)
const layoutT = getLayoutMessages(locale)
type UserWithImageUrl = typeof user & { imageUrl?: string }
function resolveUserImageUrl(userValue: UserWithImageUrl): string | null {
  const sessionImage = userValue.image?.trim()
  if (sessionImage) return sessionImage
  const databaseImage = userValue.imageUrl?.trim()
  if (databaseImage) return databaseImage
  return null
}
const userImage = resolveUserImageUrl(user as UserWithImageUrl)
---

<DashboardLayout title={t.meta.title} description={t.meta.description}>
  <div class="mx-auto max-w-4xl space-y-8">
    <!-- Header -->
    <div>
      <a
        href="/profile"
        class="mb-3 inline-flex items-center gap-2 text-sm text-muted transition-colors hover:text-primary"
      >
        <ArrowLeft size={16} />
        <span>{t.header.backToProfile}</span>
      </a>
      <h1 class="text-3xl font-bold text-neutral mb-1">{t.header.title}</h1>
      <p class="text-muted">{t.header.subtitle}</p>
    </div>

    <!-- Appearance section -->
    <section class="glass-card rounded-2xl p-6">
      <h2 class="text-xl font-semibold text-neutral mb-4">{t.appearance.title}</h2>
      
      <div class="space-y-4">
        <!-- Theme -->
        <div class="flex items-center justify-between p-4 rounded-xl border border-border/50 bg-surface hover:bg-surface-elevated transition-colors">
          <div>
            <h3 class="font-medium text-neutral mb-1">{t.appearance.theme.title}</h3>
            <p class="text-sm text-muted">{t.appearance.theme.description}</p>
          </div>
          <div class="shrink-0">
            <ThemeSwitcher size="lg" ariaLabel={layoutT.sidebar.themeChangeAria} />
          </div>
        </div>

        <!-- Language (select prêt pour d'autres langues plus tard) -->
        <div class="flex items-center justify-between p-4 rounded-xl border border-border/50 bg-surface hover:bg-surface-elevated transition-colors">
          <div>
            <h3 class="font-medium text-neutral mb-1">{t.language.title}</h3>
            <p class="text-sm text-muted">{t.language.description}</p>
          </div>
          <div class="shrink-0">
            <LanguageSwitcher
              currentLocale={locale}
              variant="settings"
              languageLabel={t.language.title}
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Account section -->
    <section class="glass-card rounded-2xl p-6">
      <h2 class="text-xl font-semibold text-neutral mb-4">{t.account.title}</h2>
      
      <div class="space-y-6">
        <!-- Avatar -->
        <div>
          <h3 class="font-medium text-neutral mb-3">{t.account.profilePicture}</h3>
          <div class="flex items-center gap-4">
            <div class="relative" id="user-avatar-container">
              <Avatar
                userName={user.name}
                userEmail={user.email}
                imageUrl={userImage ? `${userImage}?t=${Date.now()}` : undefined}
                size="xl"
                id="user-avatar"
              />
              <label
                for="avatar-upload"
                class="absolute bottom-0 right-0 flex h-11 w-11 cursor-pointer items-center justify-center rounded-full bg-primary text-white shadow-lg transition-all hover:scale-110"
                title={t.account.changePictureTitle}
              >
                <Camera size={16} />
                <input
                  type="file"
                  id="avatar-upload"
                  name="avatar"
                  accept="image/jpeg,image/jpg,image/png,image/webp,image/gif"
                  class="hidden"
                />
              </label>
            </div>
            <div class="flex-1">
              <p class="text-sm text-muted mb-1">
                {t.account.changePictureHint}
              </p>
              <p class="text-xs text-muted">
                {t.account.acceptedFormats}
              </p>
            </div>
          </div>
        </div>

        <!-- User info -->
        <div>
          <h3 class="font-medium text-neutral mb-4">{t.account.personalInfo}</h3>
          <div class="space-y-4">
            <!-- Name -->
            <div>
              <label for="profile-name" class="block text-sm font-medium text-neutral mb-2">
                {t.account.name}
              </label>
              <div class="flex items-center gap-2">
                <input
                  type="text"
                  id="profile-name"
                  name="name"
                  value={user.name || ''}
                  placeholder={t.account.namePlaceholder}
                  readonly
                  class="flex-1 rounded-lg border border-border bg-surface px-4 py-2 text-neutral focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 read-only:cursor-default read-only:opacity-75"
                />
                <button
                  type="button"
                  id="edit-name-btn"
                  class="btn-icon-secondary flex h-11 w-11 items-center justify-center rounded-lg"
                  aria-label={t.account.editName}
                >
                  <Pencil size={18} />
                </button>
                <button
                  type="button"
                  id="save-name-btn"
                  class="btn-icon-colored hidden h-11 w-11 items-center justify-center rounded-lg"
                  aria-label={t.account.saveName}
                >
                  <Check size={18} />
                </button>
                <button
                  type="button"
                  id="cancel-name-btn"
                  class="btn-icon-secondary hidden h-11 w-11 items-center justify-center rounded-lg"
                  aria-label={t.account.cancel}
                >
                  <X size={18} />
                </button>
              </div>
            </div>

            <!-- Email -->
            <div>
              <label for="profile-email" class="block text-sm font-medium text-neutral mb-2">
                {t.account.email}
              </label>
              <div class="flex items-center gap-2">
                <input
                  type="email"
                  id="profile-email"
                  name="email"
                  value={user.email || ''}
                  placeholder={t.account.emailPlaceholder}
                  readonly
                  class="flex-1 rounded-lg border border-border bg-surface px-4 py-2 text-neutral focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 read-only:cursor-default read-only:opacity-75"
                />
                <button
                  type="button"
                  id="edit-email-btn"
                  class="btn-icon-secondary flex h-11 w-11 items-center justify-center rounded-lg"
                  aria-label={t.account.editEmail}
                >
                  <Pencil size={18} />
                </button>
                <button
                  type="button"
                  id="save-email-btn"
                  class="btn-icon-colored hidden h-11 w-11 items-center justify-center rounded-lg"
                  aria-label={t.account.saveEmail}
                >
                  <Check size={18} />
                </button>
                <button
                  type="button"
                  id="cancel-email-btn"
                  class="btn-icon-secondary hidden h-11 w-11 items-center justify-center rounded-lg"
                  aria-label={t.account.cancel}
                >
                  <X size={18} />
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Change password -->
        <div class="border-t border-border pt-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-medium text-neutral">{t.account.password}</h3>
            <button
              type="button"
              id="show-password-form-btn"
              class="btn-secondary-surface px-4 py-2 rounded-lg text-sm"
            >
              {t.account.changePassword}
            </button>
          </div>
          
          <form id="password-form" class="space-y-4 hidden" novalidate>
            <input
              type="text"
              name="username"
              value={user?.email ?? ''}
              autocomplete="username"
              class="sr-only"
              tabindex={-1}
              aria-hidden="true"
            />
            <div>
              <label for="current-password" class="block text-sm font-medium text-neutral mb-2">
                {t.account.currentPassword}
              </label>
              <div class="relative">
                <input
                  type="password"
                  id="current-password"
                  name="currentPassword"
                  placeholder={t.account.currentPasswordPlaceholder}
                  class="w-full rounded-lg border border-border bg-surface px-4 py-2 pr-11 text-neutral focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                  required
                  autocomplete="current-password"
                />
                <button
                  type="button"
                  id="toggle-current-password"
                  class="absolute inset-y-0 right-0 flex h-11 w-11 items-center justify-center text-muted transition-colors hover:text-neutral"
                  aria-label={t.account.showCurrentPassword}
                >
                  <Eye id="eye-current" size={18} class="hidden" />
                  <EyeOff id="eye-off-current" size={18} />
                </button>
              </div>
            </div>
            <div>
              <label for="new-password" class="block text-sm font-medium text-neutral mb-2">
                {t.account.newPassword}
              </label>
              <div class="relative">
                <input
                  type="password"
                  id="new-password"
                  name="newPassword"
                  placeholder={t.account.newPasswordPlaceholder}
                  class="w-full rounded-lg border border-border bg-surface px-4 py-2 pr-11 text-neutral focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                  required
                  autocomplete="new-password"
                  aria-describedby="password-requirements"
                />
                <button
                  type="button"
                  id="toggle-new-password"
                  class="absolute inset-y-0 right-0 flex h-11 w-11 items-center justify-center text-muted transition-colors hover:text-neutral"
                  aria-label={t.account.showNewPassword}
                >
                  <Eye id="eye-new" size={18} class="hidden" />
                  <EyeOff id="eye-off-new" size={18} />
                </button>
              </div>
              <p class="mt-2 text-xs text-muted">
                {t.account.passwordHint}
              </p>
              <div id="password-requirements" class="mt-2 space-y-1 text-xs" aria-live="polite" aria-atomic="true">
                <div id="req-length" class="text-muted">• {t.account.reqLength}</div>
                <div id="req-lowercase" class="text-muted">• {t.account.reqLowercase}</div>
                <div id="req-uppercase" class="text-muted">• {t.account.reqUppercase}</div>
                <div id="req-number" class="text-muted">• {t.account.reqNumber}</div>
                <div id="req-special" class="text-muted">• {t.account.reqSpecial}</div>
              </div>
            </div>
            <div>
              <label for="confirm-password" class="block text-sm font-medium text-neutral mb-2">
                {t.account.confirmPassword}
              </label>
              <div class="relative">
                <input
                  type="password"
                  id="confirm-password"
                  name="confirmPassword"
                  placeholder={t.account.confirmPasswordPlaceholder}
                  class="w-full rounded-lg border border-border bg-surface px-4 py-2 pr-11 text-neutral focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                  required
                  autocomplete="new-password"
                  aria-describedby="password-match"
                />
                <button
                  type="button"
                  id="toggle-confirm-password"
                  class="absolute inset-y-0 right-0 flex h-11 w-11 items-center justify-center text-muted transition-colors hover:text-neutral"
                  aria-label={t.account.showConfirmPassword}
                >
                  <Eye id="eye-confirm" size={18} class="hidden" />
                  <EyeOff id="eye-off-confirm" size={18} />
                </button>
              </div>
              <div id="password-match" class="mt-2 text-xs text-muted" aria-live="polite" aria-atomic="true"></div>
            </div>
            <div
              id="password-error"
              class="hidden rounded-lg border border-red-500 bg-red-500/10 p-3 text-xs text-red-500"
              role="alert"
            ></div>
            <div class="flex justify-end gap-2">
              <button
                type="button"
                id="cancel-password-btn"
                class="btn-secondary-surface px-4 py-2 rounded-lg"
              >
                {t.account.cancel}
              </button>
              <button
                type="submit"
                id="save-password-btn"
                class="btn-primary-gradient px-6 py-2 rounded-lg"
              >
                {t.account.changePassword}
              </button>
            </div>
          </form>
        </div>
      </div>
    </section>

    <!-- Data section -->
    <section class="glass-card rounded-2xl p-6">
      <h2 class="text-xl font-semibold text-neutral mb-4">{t.data.title}</h2>
      
      <div class="space-y-4">
        <!-- Export data -->
        <div class="flex flex-col gap-3 border-b border-border/60 pb-4 md:flex-row md:items-center md:justify-between md:border-b-0 md:pb-0">
          <div>
            <h3 class="font-medium text-neutral mb-1">{t.data.exportTitle}</h3>
            <p class="text-sm text-muted">{t.data.exportDescription}</p>
          </div>
          <div>
            <button
              type="button"
              id="export-data-btn"
              class="btn-secondary-surface w-full px-4 py-2 rounded-lg md:w-auto"
            >
              {t.data.exportButton}
            </button>
          </div>
        </div>

        <!-- Delete all data -->
        <div class="flex flex-col gap-3 border-b border-border/60 pt-4 pb-4 md:flex-row md:items-center md:justify-between md:border-b-0 md:pt-4 md:pb-0">
          <div>
            <h3 class="font-medium text-neutral mb-1">{t.data.deleteAllTitle}</h3>
            <p class="text-sm text-muted">{t.data.deleteAllDescription}</p>
          </div>
          <div>
            <button
              type="button"
              id="delete-all-data-btn"
              class="btn-danger w-full px-4 py-2 rounded-lg md:w-auto"
            >
              {t.data.deleteAllButton}
            </button>
          </div>
        </div>

        <!-- Delete account -->
        <div class="flex flex-col gap-3 border-t border-border pt-4 md:flex-row md:items-center md:justify-between">
          <div>
            <h3 class="font-medium text-neutral mb-1">{t.data.deleteAccountTitle}</h3>
            <p class="text-sm text-muted">
              {t.data.deleteAccountDescription}
            </p>
          </div>
          <div>
            <button
              type="button"
              id="delete-account-btn"
              class="btn-danger w-full px-4 py-2 rounded-lg md:w-auto"
            >
              {t.data.deleteAccountButton}
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Privacy -->
    <section class="glass-card rounded-2xl p-6">
      <h2 class="text-xl font-semibold text-neutral mb-4">{t.privacy.title}</h2>
      <label class="flex items-center justify-between p-4 rounded-xl border border-border cursor-pointer">
        <div>
          <p class="text-sm font-medium">{t.privacy.privateAccount}</p>
          <p class="text-xs text-muted mt-0.5">{t.privacy.privateAccountHint}</p>
        </div>
        <input
          type="checkbox"
          id="privacy-toggle"
          class="sr-only"
          checked={isPrivate}
          aria-label={t.privacy.privateAccountAria}
        />
        <div class={`w-10 h-6 rounded-full border-2 relative transition-colors ${isPrivate ? 'bg-accent border-accent' : 'border-border'}`} aria-hidden="true">
          <div class={`w-4 h-4 rounded-full absolute top-0.5 transition-transform ${isPrivate ? 'bg-white translate-x-4' : 'bg-muted translate-x-0.5'}`}></div>
        </div>
      </label>
      <div class="mt-4">
        <p class="text-sm font-medium mb-2">{t.privacy.blockedAccounts}</p>
        <a href="/settings/blocked" class="text-sm text-accent hover:underline">{t.privacy.manageBlocked}</a>
      </div>
    </section>

    <!-- Notifications -->
    <section class="glass-card rounded-2xl p-6">
      <h2 class="text-xl font-semibold text-neutral mb-4">{t.notifications.title}</h2>
      <div class="space-y-6">
        <div>
          <h3 class="text-sm font-medium text-muted uppercase tracking-wide mb-3">Push</h3>
          <div class="space-y-3">
            {[
              { key: 'follower', label: t.privacy.notifFollower, checked: notifPrefs.push?.follower !== false },
              { key: 'shelfAdd', label: t.privacy.notifShelfAdd, checked: notifPrefs.push?.shelfAdd !== false },
              { key: 'like', label: t.privacy.notifLike, checked: notifPrefs.push?.like !== false },
              { key: 'comment', label: t.privacy.notifComment, checked: notifPrefs.push?.comment !== false },
            ].map(({ key, label, checked }) => (
              <label class="flex items-center justify-between">
                <span class="text-sm">{label}</span>
                <input type="checkbox" class="push-pref" data-key={key} checked={checked} aria-label={label} />
              </label>
            ))}
          </div>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted uppercase tracking-wide mb-3">Email</h3>
          <div class="space-y-3">
            {[
              { key: 'follower', label: t.privacy.notifFollower, checked: notifPrefs.email?.follower !== false },
              { key: 'comment', label: t.privacy.notifComment, checked: notifPrefs.email?.comment !== false },
            ].map(({ key, label, checked }) => (
              <label class="flex items-center justify-between">
                <span class="text-sm">{label}</span>
                <input type="checkbox" class="email-pref" data-key={key} checked={checked} aria-label={label} />
              </label>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- About section -->
    <section class="glass-card rounded-2xl p-6">
      <h2 class="text-xl font-semibold text-neutral mb-4">{t.about.title}</h2>
      
      <div class="space-y-2 text-sm text-muted">
        <p><strong class="text-neutral">Resonance</strong> — {t.about.tagline}</p>
        <p>{t.about.version}</p>
      </div>
    </section>
  </div>
</DashboardLayout>

<script
  type="application/json"
  id="settings-page-messages"
  set:html={JSON.stringify({ script: t.script, account: t.account }).replace(/<\/script/gi, '<\\/script')}
></script>

<script>
  import './Settings.client'
</script>

<script>
  // Privacy toggle
  const privacyToggle = document.getElementById('privacy-toggle') as HTMLInputElement | null
  privacyToggle?.addEventListener('change', async () => {
    await fetch('/api/profile/privacy', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ isPrivate: privacyToggle.checked }),
    })
  })

  // Notification prefs — debounce saves
  let prefTimer: ReturnType<typeof setTimeout>
  function saveNotifPrefs() {
    clearTimeout(prefTimer)
    prefTimer = setTimeout(async () => {
      const pushPrefs: Record<string, boolean> = {}
      document.querySelectorAll<HTMLInputElement>('.push-pref').forEach((cb) => {
        if (cb.dataset.key) pushPrefs[cb.dataset.key] = cb.checked
      })
      const emailPrefs: Record<string, boolean> = {}
      document.querySelectorAll<HTMLInputElement>('.email-pref').forEach((cb) => {
        if (cb.dataset.key) emailPrefs[cb.dataset.key] = cb.checked
      })
      await fetch('/api/profile/notification-prefs', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ push: pushPrefs, email: emailPrefs }),
      })
    }, 800)
  }
  document.querySelectorAll('.push-pref, .email-pref').forEach((el) =>
    el.addEventListener('change', saveNotifPrefs),
  )
</script>

