---
import ArrowLeft from '@lucide/astro/icons/arrow-left'
import Lock from '@lucide/astro/icons/lock'
import Layout from '../components/layouts/Layout.astro'
import Logo from '../components/ui/Logo.astro'
import { getResetPasswordMessages } from '../i18n/resetPassword'
import { normalizeLocale } from '../i18n/config'

export const prerender = false

// Get token from URL
const token = Astro.url.searchParams.get('token')

const locale = normalizeLocale(Astro.cookies.get('locale')?.value ?? Astro.request.headers.get('accept-language')?.split(',')[0]?.slice(0, 2))
const t = getResetPasswordMessages(locale)
---

<Layout
  title={t.meta.title}
  showDashboardHeader={false}
  showBottomBar={false}
  showFooter={false}
>
  <div class="flex min-h-screen items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
      <!-- Logo and slogan -->
      <div class="mb-12 text-center">
        <Logo size="2xl" showSlogan={true} showText={true} noHover={true} className="mb-2" />
      </div>

      <!-- Back button -->
      <div class="mb-8">
        <a
          href="/login"
          class="inline-flex items-center gap-2 text-muted no-underline transition-colors hover:text-primary"
        >
          <ArrowLeft size={18} />
          <span class="text-sm">{t.backToSignIn}</span>
        </a>
      </div>

      {!token ? (
        <div class="glass-card rounded-2xl p-8">
          <div class="text-center">
            <h1 class="text-2xl font-bold text-neutral mb-4">
              {t.noToken.title}
            </h1>
            <p class="text-muted mb-6">
              {t.noToken.description}
            </p>
            <a
              href="/forgot-password"
              class="btn-primary-gradient inline-block rounded-xl px-6 py-3"
            >
              {t.noToken.requestNew}
            </a>
          </div>
        </div>
      ) : (
        <div class="glass-card space-y-6 rounded-2xl p-8">
          <div>
            <h1 class="text-2xl font-bold text-neutral mb-2">
              {t.title}
            </h1>
            <p class="text-sm text-muted">
              {t.description}
            </p>
          </div>

          <form id="reset-password-form" class="space-y-6">
            <input type="hidden" id="token" name="token" value={token} />

            <div>
              <label
                for="password"
                class="mb-2 block text-sm font-medium text-neutral"
              >
                {t.form.newPasswordLabel}
              </label>
              <div class="relative">
                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                  <Lock size={20} class="text-muted" />
                </div>
                <input
                  type="password"
                  id="password"
                  name="password"
                  autocomplete="new-password"
                  required
                  minlength="8"
                  class="w-full rounded-xl border border-border bg-surface py-3 pr-4 pl-10 text-neutral placeholder-muted transition-colors focus:border-primary focus:ring-2 focus:ring-primary/50 focus:outline-none"
                  placeholder={t.form.passwordPlaceholder}
                />
              </div>
              <p class="mt-1 text-xs text-muted">
                {t.form.passwordHint}
              </p>
            </div>

            <div>
              <label
                for="confirm-password"
                class="mb-2 block text-sm font-medium text-neutral"
              >
                {t.form.confirmPasswordLabel}
              </label>
              <div class="relative">
                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                  <Lock size={20} class="text-muted" />
                </div>
                <input
                  type="password"
                  id="confirm-password"
                  name="confirmPassword"
                  autocomplete="new-password"
                  required
                  minlength="8"
                  class="w-full rounded-xl border border-border bg-surface py-3 pr-4 pl-10 text-neutral placeholder-muted transition-colors focus:border-primary focus:ring-2 focus:ring-primary/50 focus:outline-none"
                  placeholder={t.form.passwordPlaceholder}
                />
              </div>
            </div>

            <div
              id="error-message"
              class="hidden rounded-lg border border-red-500 bg-red-500/10 p-4 text-red-500"
              role="alert"
              aria-live="assertive"
            ></div>

            <div
              id="success-message"
              class="hidden rounded-lg border border-green-500 bg-green-500/10 p-4 text-green-500"
              role="status"
              aria-live="polite"
            >
              <p class="font-medium">{t.success.title}</p>
              <p class="text-sm mt-1">{t.success.redirecting}</p>
            </div>

            <button
              type="submit"
              id="submit-btn"
              class="bg-gradient-resonance hover:bg-gradient-resonance-hover flex w-full items-center justify-center gap-2 rounded-xl px-4 py-3 font-medium text-white transition-all duration-300"
            >
              {t.form.submit}
            </button>
          </form>
        </div>
      )}
    </div>
  </div>
</Layout>

<script type="text/plain" id="reset-password-messages" data-encoding="base64" set:html={Buffer.from(JSON.stringify({
  errorMinLength: t.errors.minLength,
  errorLowercase: t.errors.lowercase,
  errorUppercase: t.errors.uppercase,
  errorNumber: t.errors.number,
  errorSpecial: t.errors.special,
  errorNoMatch: t.errors.noMatch,
  errorGeneric: t.errors.generic,
  errorTryAgain: t.errors.tryAgain,
  submittingLabel: t.submitting,
}), 'utf8').toString('base64')}></script>
<script>
  import './ResetPassword.client'
</script>
