---
import DashboardLayout from '../components/layouts/DashboardLayout.astro'
import FavoritesByGenre from '../components/profile/FavoritesByGenre.astro'
import ImportExport from '../components/profile/ImportExport.astro'
import ProfileHeader from '../components/profile/ProfileHeader.astro'
import ProfileTabs from '../components/profile/ProfileTabs.astro'
import RecentCollections from '../components/profile/RecentCollections.astro'
import StatsCharts from '../components/profile/StatsCharts.astro'
import StatsGrid from '../components/profile/StatsGrid.astro'
import WishlistGrid from '../components/profile/WishlistGrid.astro'
import ActivityTimeline from '../components/profile/ActivityTimeline.astro'
import { getProfileMessages } from '../i18n/profile'
import { getItemMessages } from '../i18n/item'
import { normalizeLocale } from '../i18n/config'
import { itemRepository } from '../repositories/item-repository'
import { userRepository } from '../repositories/user-repository'
import { wishlistRepository } from '../repositories/wishlist-repository'
import { statsService } from '../services/stats-service'

export const prerender = false

// Use session from middleware (Astro.locals)
const session = Astro.locals.session
const user = Astro.locals.user

if (!session || !user) return Astro.redirect('/login')

const locale = normalizeLocale(Astro.locals.userPreferences?.locale ?? Astro.cookies.get('locale')?.value ?? Astro.request.headers.get('accept-language')?.split(',')[0]?.slice(0, 2))
const profileT = getProfileMessages(locale)
const itemT = getItemMessages(locale)

const [stats, favorites, wishlistItems, recentActivities] = await Promise.all([
  statsService.getUserStats(user.id),
  itemRepository.getFavoritesByUserId(user.id),
  wishlistRepository.findByUserId(user.id),
  userRepository.getRecentActivity(user.id, 15),
])
---

<DashboardLayout title={profileT.meta.title}>
  <!-- Profile content when authenticated -->
  <div class="min-w-0 space-y-8">
    <!-- Header with avatar, display name, gradient background -->
    <ProfileHeader user={user} stats={stats} settingsLabel={profileT.header.settings} />

      <!-- Quick stats -->
      <StatsGrid stats={stats} />

      <!-- Tabs: Favorites | Wishlist | Statistics | All Formats -->
      <ProfileTabs
        tabsAriaLabel={profileT.tabs.ariaLabel}
        favoritesLabel={profileT.tabs.favorites}
        wishlistLabel={profileT.tabs.wishlist}
        statisticsLabel={profileT.tabs.statistics}
        allFormatsLabel={profileT.tabs.allFormats}
      >
        <div slot="favorites" data-tab-content="favorites">
          <FavoritesByGenre favorites={favorites} emptyLabels={profileT.favoritesEmpty} actionLabels={itemT.actions} />
        </div>

        <div slot="wishlist" data-tab-content="wishlist">
          <WishlistGrid wishlistItems={wishlistItems} wishlist={profileT.wishlist} />
        </div>

        <div slot="statistics" data-tab-content="statistics">
          <div class="min-w-0 space-y-8">
            <!-- Recent activity -->
            <div>
              <h2 class="mb-4 text-xl font-bold text-neutral">{profileT.sections.recentActivity}</h2>
              <ActivityTimeline activities={recentActivities} activity={profileT.activity} />
            </div>

            <!-- Import/Export -->
            <ImportExport labels={profileT.importExport} />

            <!-- Quick stats -->
            <div>
              <h2 class="mb-4 text-xl font-bold text-neutral">{profileT.sections.quickStatistics}</h2>
              <StatsGrid stats={stats} />
            </div>
            
            <!-- Charts -->
            <div>
              <h2 class="mb-4 text-xl font-bold text-neutral">{profileT.sections.visualStatistics}</h2>
              <StatsCharts userId={user.id} chartsLabels={profileT.charts} />
            </div>
          </div>
        </div>

        <div slot="all-formats" data-tab-content="all-formats">
          <RecentCollections userId={user.id} labels={profileT.recentCollections} />
        </div>
      </ProfileTabs>
  </div>
</DashboardLayout>

<style>
  .glass-card {
    transition: all 0.3s ease;
  }

  .glass-card:hover {
    transform: translateY(-2px);
  }
</style>

