---
import Layout from '../components/layouts/Layout.astro'
import Disc3 from '@lucide/astro/icons/disc-3'
import ScanBarcode from '@lucide/astro/icons/scan-barcode'
import Heart from '@lucide/astro/icons/heart'
import Users from '@lucide/astro/icons/users'
import { staticPagesI18n } from '../i18n/static-pages'
import { normalizeLocale } from '../i18n/config'

const locale = normalizeLocale(
  Astro.cookies.get('locale')?.value ??
  Astro.request.headers.get('accept-language')?.split(',')[0]?.slice(0, 2)
)
const t = staticPagesI18n[locale].about

const featureIcons = [Disc3, ScanBarcode, Heart, Users]
---

<Layout title={t.title} description={t.tagline}>
  <div class="max-w-2xl mx-auto px-4 py-12">

    <header class="mb-12">
      <h1 class="text-3xl font-bold mb-3">{t.title}</h1>
      <p class="text-lg text-accent font-medium">{t.tagline}</p>
    </header>

    <section class="mb-12">
      <p class="text-base text-neutral leading-relaxed">{t.intro}</p>
    </section>

    <section class="mb-12" aria-labelledby="features-heading">
      <h2 id="features-heading" class="text-xl font-semibold mb-6">{t.featuresHeading}</h2>
      <ul class="space-y-6">
        {t.features.map((feature, index) => {
          const Icon = featureIcons[index]
          return (
            <li class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center">
                <Icon size={20} class="text-accent" aria-hidden="true" />
              </div>
              <div>
                <h3 class="font-medium mb-1">{feature.heading}</h3>
                <p class="text-sm text-muted leading-relaxed">{feature.body}</p>
              </div>
            </li>
          )
        })}
      </ul>
    </section>

    <footer class="border-t border-border pt-8">
      <p class="text-sm text-muted italic">{t.madeBy}</p>
    </footer>

  </div>
</Layout>
