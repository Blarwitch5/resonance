---
export const prerender = false
import Layout from '../../components/layouts/Layout.astro'
import { shelfItemRepository } from '../../repositories/shelf-item-repository'
import { releaseRepository } from '../../repositories/release-repository'
import { followRepository } from '../../repositories/follow-repository'
import { collectionRepository } from '../../repositories/collection-repository'
import { itemsI18n } from '../../i18n/items'
import { normalizeLocale } from '../../i18n/config'
import Play from '@lucide/astro/icons/play'
import Pause from '@lucide/astro/icons/pause'
import LoaderCircle from '@lucide/astro/icons/loader-circle'
import Star from '@lucide/astro/icons/star'

const locale = normalizeLocale(Astro.cookies.get('locale')?.value ?? Astro.request.headers.get('accept-language')?.split(',')[0]?.slice(0, 2))
const t = itemsI18n[locale]

const { id } = Astro.params
if (!id) return Astro.redirect('/shelf')

const currentUser = Astro.locals.user
const currentUserId = currentUser?.id ?? null

const shelfItem = await shelfItemRepository.findByIdWithRelease(id)
if (!shelfItem) return Astro.redirect('/shelf')

const isOwner = currentUserId === shelfItem.userId

// Backfill release metadata if incomplete — covers items added before the
// tracklist bug fix and seed data with missing Discogs fields.
let release = shelfItem.release
const tracklistArray = Array.isArray(release.tracklist) ? (release.tracklist as unknown[]) : null
const needsBackfill = !tracklistArray || tracklistArray.length === 0 || release.label === null
if (needsBackfill && release.discogsId) {
  const backfilled = await releaseRepository.findOrCreateFromDiscogs(release.discogsId)
  if (backfilled) release = backfilled
}

// If owner's account is private and viewer is not a follower, block access
if (!isOwner && shelfItem.user.isPrivate) {
  const canView = currentUserId
    ? await followRepository.isFollowing(currentUserId, shelfItem.userId)
    : false
  if (!canView) return Astro.redirect('/explore')
}

// Who among my follows also has this release?
const friendsWithRelease = currentUserId && !isOwner
  ? await shelfItemRepository.getFriendsWithRelease(currentUserId, release.id)
  : []

const friendsLabel = friendsWithRelease.length === 1
  ? '1 personne que tu suis a ce disque'
  : friendsWithRelease.length + ' personnes que tu suis ont ce disque'

const releaseTitle = release.artist + ' — ' + release.title

// Community avg rating (show only if 3+ ratings)
const showCommunityRating = (release.ratingCount ?? 0) >= 3

type TrackItem = { position: string; title: string; duration?: string }
const tracklist = Array.isArray(release.tracklist) && (release.tracklist as unknown[]).length > 0
  ? (release.tracklist as unknown as TrackItem[])
  : null

// Owner's collections (for "add to collection" modal)
const userCollections = isOwner && currentUserId
  ? await collectionRepository.findByUser(currentUserId)
  : []
---

<Layout title={releaseTitle} showBottomBar={true}>
  <div class="item-detail max-w-2xl mx-auto px-4 py-6">

    <!-- Cover + meta -->
    <div class="flex items-start gap-4 mb-6">
      <div class="flex-shrink-0">
        {release.coverUrl
          ? <img
              src={release.coverUrl}
              alt={releaseTitle}
              width="120"
              height="120"
              class="rounded-lg w-28 h-28 object-cover shadow"
            />
          : <div class="w-28 h-28 rounded-lg bg-surface-raised flex items-center justify-center text-muted text-xs">{t.nocover}</div>
        }
      </div>
      <div class="flex-1 min-w-0">
        <h1 class="text-lg font-semibold leading-tight">{release.title}</h1>
        <p class="text-sm text-muted">{release.artist}</p>
        {release.label && <p class="text-xs text-muted">{release.label}</p>}
        <div class="flex items-center gap-2 mt-1 text-xs text-muted">
          {release.year && <span>{release.year}</span>}
          {release.country && <span>· {release.country}</span>}
          <span>· {release.format}</span>
        </div>

        <!-- Owner rating -->
        {shelfItem.rating && (
          <div class="flex items-center gap-0.5 mt-2" aria-label={`${t.rating}: ${shelfItem.rating}/5`}>
            {Array.from({ length: 5 }).map((_, starIndex) => (
              <Star
                size={14}
                class={starIndex < shelfItem.rating! ? 'text-accent fill-accent' : 'text-muted'}
                aria-hidden="true"
              />
            ))}
          </div>
        )}

        <!-- Community rating -->
        {showCommunityRating && (
          <p class="text-xs text-muted mt-1">
            {t.communityRating(release.avgRating?.toFixed(1) ?? '0', release.ratingCount ?? 0)}
          </p>
        )}
      </div>
    </div>

    <!-- Social: friends who have this -->
    {friendsWithRelease.length > 0 && (
      <div class="friends-section mb-4 p-3 bg-surface-raised rounded-lg">
        <p class="text-xs text-muted mb-2">{t.friendsHaveIt(friendsWithRelease.length)}</p>
        <div class="flex -space-x-2">
          {friendsWithRelease.slice(0, 5).map((f) => (
            <a href={`/u/${f.user.username}`} aria-label={f.user.name ?? f.user.username ?? ''}>
              {f.user.imageUrl
                ? <img src={f.user.imageUrl} alt={f.user.name ?? ''} width="28" height="28" class="w-7 h-7 rounded-full border-2 border-background object-cover" />
                : <div class="w-7 h-7 rounded-full border-2 border-background bg-accent flex items-center justify-center text-xs font-bold">{(f.user.name ?? 'U')[0]}</div>
              }
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Personal info (owner only) -->
    {isOwner && (
      <section class="personal-info mb-6 p-4 bg-surface border border-border rounded-xl">
        <h2 class="text-sm font-medium mb-3">{t.ownerSection}</h2>
        <dl class="space-y-2 text-sm">
          <div class="flex justify-between">
            <dt class="text-muted">{t.condition}</dt>
            <dd>{shelfItem.condition}</dd>
          </div>
          {shelfItem.acquiredAt && (
            <div class="flex justify-between">
              <dt class="text-muted">{t.acquiredAt}</dt>
              <dd>{new Date(shelfItem.acquiredAt).toLocaleDateString('fr-FR')}</dd>
            </div>
          )}
          {shelfItem.note && (
            <div>
              <dt class="text-muted mb-1">{t.personalNote}</dt>
              <dd class="text-sm">{shelfItem.note}</dd>
            </div>
          )}
        </dl>
      </section>
    )}

    <!-- Tracklist -->
    {tracklist && tracklist.length > 0 && (
      <section class="tracklist mb-6" aria-labelledby="tracklist-heading">
        <h2 id="tracklist-heading" class="text-sm font-medium text-muted mb-2">{t.tracklist}</h2>
        {currentUserId && <audio id="track-preview-audio" preload="none" class="hidden" />}
        <ol class="space-y-0">
          {tracklist.map((track) => (
            <li class="track-row flex items-center gap-2 py-2 border-b border-border/40 last:border-0">
              {currentUserId
                ? (
                  <button
                    class="track-play-btn flex-shrink-0 flex h-7 w-7 items-center justify-center rounded-full text-muted hover:text-primary hover:bg-primary/10 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/60"
                    data-artist={release.artist}
                    data-track={track.title}
                    aria-label={`Écouter ${track.title}`}
                  >
                    <Play size={13} class="play-icon" aria-hidden="true" />
                    <Pause size={13} class="pause-icon hidden" aria-hidden="true" />
                    <LoaderCircle size={13} class="loading-icon hidden animate-spin" aria-hidden="true" />
                  </button>
                )
                : <span class="flex-shrink-0 w-7" />
              }
              <span class="text-muted w-7 flex-shrink-0 text-xs">{track.position}</span>
              <span class="flex-1 text-sm truncate">{track.title}</span>
              {track.duration && <span class="text-muted text-xs tabular-nums">{track.duration}</span>}
            </li>
          ))}
        </ol>
      </section>
    )}

    <!-- Actions -->
    <div class="actions flex gap-2 flex-wrap">
      {!isOwner && currentUserId && (
        <button
          class="btn-secondary want-btn"
          data-release-id={release.id}
          data-text-want={t.addWant}
          data-text-in-wants={t.inWants}
        >
          {t.addWant}
        </button>
      )}
      {isOwner && (
        <>
          {userCollections.length > 0 && (
            <button
              id="add-to-collection-btn"
              class="btn-secondary"
              aria-haspopup="dialog"
            >
              + Collection
            </button>
          )}
          <a href={`/items/${id}/edit`} class="btn-secondary">{t.edit}</a>
          <button class="btn-ghost text-red-500 delete-btn" data-id={id} data-text-confirm={t.deleteConfirm}>{t.delete}</button>
        </>
      )}
    </div>
  </div>

  <!-- Modal : ajouter à une collection -->
  {isOwner && userCollections.length > 0 && (
    <dialog
      id="add-to-collection-dialog"
      class="rounded-2xl p-6 max-w-sm w-full shadow-xl backdrop:bg-black/40"
    >
      <h2 class="font-semibold mb-1">Ajouter à une collection</h2>
      <p class="text-sm text-muted mb-4">Choisir une de tes collections</p>
      <ul class="space-y-2 mb-4 max-h-72 overflow-y-auto">
        {userCollections.map((collection) => (
          <li>
            <button
              class="collection-pick-btn w-full text-left flex items-center justify-between p-3 rounded-xl border border-border hover:bg-surface-raised transition-colors"
              data-collection-id={collection.id}
              data-shelf-item-id={id}
            >
              <span class="font-medium text-sm">{collection.name}</span>
              <span class="text-xs text-muted">{collection._count.items} disque{collection._count.items !== 1 ? 's' : ''}</span>
            </button>
          </li>
        ))}
      </ul>
      <button id="add-to-collection-close" class="btn-ghost w-full">Fermer</button>
    </dialog>
  )}
</Layout>

<script>
  // Want button
  const wantBtn = document.querySelector('.want-btn') as HTMLButtonElement | null
  wantBtn?.addEventListener('click', async () => {
    const releaseId = wantBtn.dataset.releaseId
    wantBtn.disabled = true
    try {
      const res = await fetch('/api/wants/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ releaseId }),
      })
      if (res.ok) {
        wantBtn.textContent = wantBtn.dataset.textInWants ?? '✓ Dans mes Wants'
        wantBtn.disabled = true
      }
    } catch {
      wantBtn.disabled = false
    }
  })

  // Delete button
  const deleteBtn = document.querySelector('.delete-btn') as HTMLButtonElement | null
  deleteBtn?.addEventListener('click', async () => {
    if (!confirm(deleteBtn.dataset.textConfirm ?? 'Supprimer ce disque de ta shelf ?')) return
    const itemId = deleteBtn.dataset.id
    const response = await fetch('/api/shelf-items/' + itemId + '/delete', { method: 'DELETE' })
    if (response.ok) window.location.href = '/shelf'
  })

  // Add to collection modal
  const addToCollectionBtn = document.getElementById('add-to-collection-btn') as HTMLButtonElement | null
  const addToCollectionDialog = document.getElementById('add-to-collection-dialog') as HTMLDialogElement | null
  const addToCollectionClose = document.getElementById('add-to-collection-close') as HTMLButtonElement | null

  addToCollectionBtn?.addEventListener('click', () => addToCollectionDialog?.showModal())
  addToCollectionClose?.addEventListener('click', () => addToCollectionDialog?.close())
  addToCollectionDialog?.addEventListener('click', (event) => {
    if (event.target === addToCollectionDialog) addToCollectionDialog.close()
  })

  document.querySelectorAll<HTMLButtonElement>('.collection-pick-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const collectionId = btn.dataset.collectionId
      const shelfItemId = btn.dataset.shelfItemId
      btn.disabled = true
      try {
        const response = await fetch(`/api/collections/${collectionId}/items/add`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ shelfItemId }),
        })
        if (response.ok) {
          btn.textContent = '✓ Ajouté'
          btn.classList.add('opacity-60')
        } else {
          const data = await response.json() as { error?: string }
          alert(data.error ?? 'Erreur lors de l\'ajout')
          btn.disabled = false
        }
      } catch {
        btn.disabled = false
      }
    })
  })

  // ── Track preview player ──────────────────────────────────────────────────
  const previewAudio = document.getElementById('track-preview-audio') as HTMLAudioElement | null
  if (previewAudio) {
    let activeBtn: HTMLButtonElement | null = null

    function setTrackState(btn: HTMLButtonElement, state: 'idle' | 'loading' | 'playing' | 'unavailable') {
      btn.querySelector('.play-icon')?.classList.toggle('hidden', state !== 'idle' && state !== 'unavailable')
      btn.querySelector('.pause-icon')?.classList.toggle('hidden', state !== 'playing')
      btn.querySelector('.loading-icon')?.classList.toggle('hidden', state !== 'loading')
      btn.classList.toggle('text-muted', state === 'unavailable')
      btn.classList.toggle('opacity-40', state === 'unavailable')
    }

    function resetActive() {
      if (activeBtn) {
        setTrackState(activeBtn, 'idle')
        activeBtn = null
      }
    }

    previewAudio.addEventListener('ended', resetActive)

    document.querySelectorAll<HTMLButtonElement>('.track-play-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        // Toggle pause/resume on the same track
        if (activeBtn === btn) {
          if (previewAudio.paused) {
            previewAudio.play()
            setTrackState(btn, 'playing')
          } else {
            previewAudio.pause()
            setTrackState(btn, 'idle')
            activeBtn = null
          }
          return
        }

        // Stop any currently playing track
        previewAudio.pause()
        resetActive()

        activeBtn = btn
        setTrackState(btn, 'loading')
        btn.disabled = true

        const artist = btn.dataset.artist ?? ''
        const track = btn.dataset.track ?? ''

        try {
          const response = await fetch(
            `/api/deezer/search-track?artist=${encodeURIComponent(artist)}&track=${encodeURIComponent(track)}`,
          )
          const data = await response.json() as { track?: { preview_url: string } }

          if (!response.ok || !data.track?.preview_url) {
            setTrackState(btn, 'unavailable')
            btn.disabled = true
            activeBtn = null
            return
          }

          previewAudio.src = data.track.preview_url
          previewAudio.currentTime = 0
          previewAudio.play()
          setTrackState(btn, 'playing')
          btn.disabled = false
        } catch {
          setTrackState(btn, 'idle')
          btn.disabled = false
          activeBtn = null
        }
      })
    })
  }
</script>
