---
import DashboardLayout from '../../components/layouts/DashboardLayout.astro'
import Folder from '@lucide/astro/icons/folder'
import Plus from '@lucide/astro/icons/plus'
import { collectionRepository } from '../../repositories/collection-repository'
import EmptyState from '../../components/ui/EmptyState.astro'
import { getCollectionsMessages } from '../../i18n/collections'
import { normalizeLocale } from '../../i18n/config'
import AlertCircle from '@lucide/astro/icons/circle-alert'

export const prerender = false

// Utiliser la session depuis le middleware (Astro.locals)
const session = Astro.locals.session
if (!session) return Astro.redirect('/login')

const locale = normalizeLocale(Astro.locals.userPreferences?.locale ?? Astro.cookies.get('locale')?.value ?? Astro.request.headers.get('accept-language')?.split(',')[0]?.slice(0, 2))
const collectionT = getCollectionsMessages(locale)

const MAX_COLLECTIONS = 2
const collectionsCount = await collectionRepository.countByUserId(Astro.locals.user!.id)
const canCreateNewCollection = collectionsCount < MAX_COLLECTIONS

if (!canCreateNewCollection) {
  // Rediriger vers la page des collections si la limite est atteinte
  return Astro.redirect('/collections')
}
---

<DashboardLayout title={collectionT.meta.newTitle}>
  <div class="mx-auto max-w-2xl">
    <div class="mb-8">
      <h1 class="text-2xl font-bold">{collectionT.new.title}</h1>
      <p class="text-muted">{collectionT.new.subtitle}</p>
    </div>

    <form class="glass-card space-y-6 rounded-2xl p-8" id="create-collection-form">
      <div>
        <label for="name" class="mb-2 block text-sm font-medium text-neutral">
          {collectionT.new.form.nameLabel}
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full rounded-xl border border-border bg-surface p-3 text-neutral placeholder-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
          placeholder={collectionT.new.form.namePlaceholder}
        />
      </div>

      <div>
        <label for="description" class="mb-2 block text-sm font-medium text-neutral">
          {collectionT.new.form.descriptionLabel}
        </label>
        <textarea
          id="description"
          name="description"
          rows={4}
          class="w-full rounded-xl border border-border bg-surface p-3 text-neutral placeholder-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
          placeholder={collectionT.new.form.descriptionPlaceholder}
        ></textarea>
      </div>

      <div class="flex items-center gap-3">
        <input
          type="checkbox"
          id="isPublic"
          name="isPublic"
          class="h-5 w-5 rounded border-border text-primary focus:ring-2 focus:ring-primary"
        />
        <label for="isPublic" class="text-sm text-neutral">
          {collectionT.new.form.isPublicLabel}
        </label>
      </div>

      <div
        id="create-collection-error"
        class="error-message hidden rounded-lg border border-red-500 bg-red-500/10 p-4 text-sm text-red-500"
        role="alert"
        aria-live="polite"
      ></div>

      <div class="flex gap-3">
        <button
          type="submit"
          class="btn-primary-gradient flex flex-1 items-center justify-center gap-2 rounded-xl px-6 py-3"
        >
          <Plus size={20} />
          <span>{collectionT.new.form.submit}</span>
        </button>
        <a
          href="/collections"
          class="flex items-center justify-center rounded-xl border border-border bg-surface px-6 py-3 font-medium text-neutral transition-colors hover:bg-surface-elevated"
        >
          {collectionT.new.form.cancel}
        </a>
      </div>
    </form>
  </div>
  <!-- Messages en script text/plain pour éviter tout problème de guillemets/attribut (= en base64, apostrophes) -->
  <script type="text/plain" id="collection-new-messages" data-encoding="base64">
    {Buffer.from(JSON.stringify({
      provideName: collectionT.new.errors.provideName,
      creating: collectionT.new.creating,
      submit: collectionT.new.form.submit,
      success: collectionT.new.success,
      createError: collectionT.new.errors.createError,
      createErrorGeneric: collectionT.new.errors.createErrorGeneric,
    }), 'utf8').toString('base64')}
  </script>

<script>
  import '../CollectionNew.client'
</script>

<style>
  .glass-card {
    transition: all 0.3s ease;
  }
</style>

