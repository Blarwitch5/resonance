---
import Layout from '../components/layouts/Layout.astro'
import { normalizeLocale } from '../i18n/config'

const locale = normalizeLocale(
  Astro.cookies.get('locale')?.value ??
  Astro.request.headers.get('accept-language')?.split(',')[0]?.slice(0, 2)
)

const title = locale === 'fr' ? 'Page introuvable' : 'Page not found'
const heading = locale === 'fr' ? 'Page introuvable' : 'Page not found'
const body = locale === 'fr'
  ? 'Cette page n\'existe pas ou a été supprimée.'
  : 'This page doesn\'t exist or has been removed.'
const backLabel = locale === 'fr' ? '← Retour à l\'accueil' : '← Back to home'

Astro.response.status = 404
---

<Layout title={title}>
  <main class="flex min-h-[60vh] flex-col items-center justify-center px-4 text-center">
    <p class="text-6xl font-bold text-accent mb-4" aria-hidden="true">404</p>
    <h1 class="text-2xl font-semibold mb-2">{heading}</h1>
    <p class="text-muted mb-8 max-w-sm">{body}</p>
    <a href="/" class="btn-primary">{backLabel}</a>
  </main>
</Layout>
