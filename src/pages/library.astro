---
import CassetteTape from '@lucide/astro/icons/cassette-tape'
import Disc from '@lucide/astro/icons/disc-2'
import Package from '@lucide/astro/icons/package-open'
import Turntable from '@lucide/astro/icons/turntable'
import CollectionSearch from '../components/collections/CollectionSearch.astro'
import SortFilter from '../components/collections/SortFilter.astro'
import AddItemButton from '../components/items/AddItemButton.astro'
import ItemGrid from '../components/items/ItemGrid.astro'
import DashboardLayout from '../components/layouts/DashboardLayout.astro'
import Pagination from '../components/ui/Pagination.astro'
import { getLibraryMessages } from '../i18n/library'
import { getLayoutMessages } from '../i18n/layout'
import { getItemMessages } from '../i18n/item'
import { normalizeLocale } from '../i18n/config'
import { collectionRepository } from '../repositories/collection-repository'
import { itemRepository } from '../repositories/item-repository'

export const prerender = false

const session = Astro.locals.session
const user = Astro.locals.user

if (!session || !user) {
  return Astro.redirect('/login')
}

const locale = normalizeLocale(Astro.locals.userPreferences?.locale ?? Astro.cookies.get('locale')?.value ?? Astro.request.headers.get('accept-language')?.split(',')[0]?.slice(0, 2))
const libraryT = getLibraryMessages(locale)
const layoutT = getLayoutMessages(locale)
const itemT = getItemMessages(locale)

// Get format from query params (default: 'ALL')
const formatParam = Astro.url.searchParams.get('format') || 'ALL'
const validFormats = ['ALL', 'VINYL', 'CASSETTE', 'CD']
const selectedFormat = validFormats.includes(formatParam.toUpperCase()) 
  ? formatParam.toUpperCase() 
  : 'ALL'

// Get pagination params
const page = Number.parseInt(Astro.url.searchParams.get('page') || '1')
const perPage = 24

// Get sort and filter params
const sort = Astro.url.searchParams.get('sort') || 'addedAt-desc'
const genre = Astro.url.searchParams.get('genre') || undefined
const year = Astro.url.searchParams.get('year') || undefined
const collectionParam = Astro.url.searchParams.get('collection') || undefined
// Support "none" to filter items without collection
const collectionId = collectionParam === 'none' ? 'none' : collectionParam
const favoritesOnly = Astro.url.searchParams.get('favorites') === 'true'
const showUncategorizedOnly = collectionParam === 'none'

// Get user's enabled formats (from settings - for now, all formats enabled)
const enabledFormats = ['VINYL', 'CASSETTE', 'CD'] // TODO: Get from user settings

// Get all user items to extract available filters
const allUserItems = await itemRepository.findByUserId(user.id)
const availableGenres = Array.from(new Set(allUserItems.map((item) => item.genre).filter(Boolean)))
const availableYears = Array.from(new Set(allUserItems.map((item) => item.year).filter(Boolean)))
const userCollections = await collectionRepository.findByUserId(user.id)

// Get items with pagination
type ItemWithMetadata = {
  id: string
  title: string
  artist: string
  year: number | null
  genre: string | null
  format: string
  coverUrl: string | null
  metadata: unknown
  collectionId: string | null
}

let paginatedResult: {
  items: ItemWithMetadata[]
  pagination: {
    page: number
    perPage: number
    total: number
    totalPages: number
    hasNext: boolean
    hasPrev: boolean
  }
}

// Build filter options
const filterOptions = {
  sort: sort as 'addedAt-desc' | 'addedAt-asc' | 'title-asc' | 'title-desc' | 'artist-asc' | 'artist-desc' | 'year-desc' | 'year-asc',
  genre,
  year,
  collectionId,
  favoritesOnly,
}

if (selectedFormat === 'ALL') {
  paginatedResult = await itemRepository.findByUserIdPaginated(
    user.id,
    page,
    perPage,
    undefined,
    filterOptions,
  )
} else {
  paginatedResult = await itemRepository.findByUserIdPaginated(
    user.id,
    page,
    perPage,
    selectedFormat as 'VINYL' | 'CD' | 'CASSETTE',
    filterOptions,
  )
}

// Group items by collection
const itemsByCollection = paginatedResult.items.reduce((acc, item) => {
  const key = item.collectionId || 'no-collection'
  if (!acc[key]) {
    acc[key] = []
  }
  acc[key].push(item)
  return acc
}, {} as Record<string, ItemWithMetadata[]>)

// Add empty collections
userCollections.forEach((collection) => {
  if (!itemsByCollection[collection.id]) {
    itemsByCollection[collection.id] = []
  }
})

const totalItems = paginatedResult.pagination.total

const formatInfo = {
  VINYL: { label: libraryT.formats.vinyl, icon: Turntable, color: 'format-vinyl' },
  CASSETTE: { label: libraryT.formats.cassette, icon: CassetteTape, color: 'format-cassette' },
  CD: { label: libraryT.formats.cd, icon: Disc, color: 'format-cd' },
}
---

<DashboardLayout title={libraryT.meta.title}>
  <div class="space-y-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-3xl font-bold text-neutral mb-2">
          {libraryT.header.title}
        </h1>
        <p class="text-muted text-sm sm:text-base">
          {totalItems} {totalItems === 1 ? 'album' : 'albums'}
          {Object.keys(itemsByCollection).length > 0 && (
            <span class="mx-2">•</span>
            <span>{Object.keys(itemsByCollection).length} {Object.keys(itemsByCollection).length === 1 ? 'collection' : 'collections'}</span>
          )}
        </p>
      </div>
      <div class="flex gap-3">
        <AddItemButton format={selectedFormat === 'ALL' ? 'VINYL' : selectedFormat} />
      </div>
    </div>

    <!-- Format Selector (Chips/Pills) -->
    <div class="flex flex-wrap gap-3">
      <a
        href="/library?format=ALL"
        aria-current={selectedFormat === 'ALL' && !showUncategorizedOnly ? 'page' : undefined}
        class={`inline-flex min-h-11 items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-background ${
          selectedFormat === 'ALL'
            ? 'bg-gradient-resonance text-white shadow-lg shadow-primary/20'
            : 'glass-card text-muted hover:bg-surface-elevated hover:text-neutral'
        }`}
      >
        <span>{libraryT.formats.all}</span>
      </a>
      {totalItems > 0 && (
        <a
          href="/library?format=ALL&collection=none"
          aria-current={showUncategorizedOnly ? 'page' : undefined}
          class={`inline-flex min-h-11 items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-background ${
            showUncategorizedOnly
              ? 'bg-gradient-resonance text-white shadow-lg shadow-primary/20'
              : 'glass-card text-muted hover:bg-surface-elevated hover:text-neutral'
          }`}
        >
          <Package size={18} class="fill-none stroke-2" />
          <span>{libraryT.formats.uncategorized}</span>
        </a>
      )}
      {enabledFormats.map((format) => {
        const info = formatInfo[format as keyof typeof formatInfo]
        const Icon = info.icon
        return (
          <a
            href={`/library?format=${format}`}
            aria-current={selectedFormat === format ? 'page' : undefined}
            class={`inline-flex min-h-11 items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-background ${
              selectedFormat === format
                ? `bg-gradient-resonance text-white shadow-lg shadow-primary/20`
                : 'glass-card text-muted hover:bg-surface-elevated hover:text-neutral'
            }`}
          >
            <Icon size={18} class="fill-none stroke-2" />
            <span>{info.label}</span>
          </a>
        )
      })}
    </div>

    <!-- Search Bar -->
    {totalItems > 0 && (
      <div class="max-w-md">
        <CollectionSearch labels={libraryT.collectionSearch} />
      </div>
    )}

    <!-- Filters -->
    {totalItems > 0 && (
      <SortFilter
        genres={availableGenres}
        years={availableYears}
        collections={userCollections}
        sortFilter={libraryT.sortFilter}
      />
    )}

    <!-- Items grouped by collection -->
    {totalItems === 0 ? (
      <div class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-5">
        <article class="glass-card overflow-hidden rounded-xl border border-border p-4">
          <div class="flex aspect-square flex-col items-center justify-center gap-3 text-center">
            <span class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-surface">
              <Package size={20} class="fill-none stroke-2 text-muted stroke-muted" />
            </span>
            <p class="text-base font-semibold text-neutral">Collection vide</p>
          </div>
        </article>
        <a
          href="/explorer"
          class="group block overflow-hidden rounded-xl border border-primary/30 bg-linear-to-br from-primary to-secondary p-4 text-white no-underline transition-all hover:-translate-y-0.5 hover:border-primary/60"
        >
          <div class="flex aspect-square flex-col items-center justify-center gap-3 text-center">
            <span class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-white/20 backdrop-blur-sm">
              <svg class="h-5 w-5 text-white stroke-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
            </span>
            <p class="text-sm font-medium text-white/95">Rechercher et ajouter un album</p>
          </div>
        </a>
      </div>
    ) : (
      <>
        <div data-items-container class="space-y-10">
          {Object.entries(itemsByCollection).map(([collectionId, items]) => {
            const collection = collectionId === 'no-collection'
              ? null
              : userCollections.find((c) => c.id === collectionId)
            
            return (
              <section class="space-y-5" data-item-section>
                <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between pb-2 border-b border-border">
                  <div class="flex items-center gap-3">
                    <h2 class="text-xl font-bold text-neutral">
                      {collectionId === 'no-collection'
                        ? libraryT.collections.uncategorized
                        : collection?.name}
                    </h2>
                    {items.length > 0 && (
                      <span class="inline-flex items-center justify-center rounded-full bg-surface px-3 py-1 text-xs font-medium text-muted">
                        {items.length} {items.length === 1 ? libraryT.header.albumsCount.one.replace('{count}', String(items.length)) : libraryT.header.albumsCount.other.replace('{count}', String(items.length))}
                      </span>
                    )}
                  </div>
                  {collection && (
                    <a
                      href={`/collections/${collection.slug}`}
                      class="inline-flex min-h-11 items-center gap-1 px-2 text-sm font-medium text-primary transition-colors hover:text-primary/80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-background"
                    >
                      <span>{libraryT.collections.viewCollection}</span>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                  )}
                </div>
                {items.length === 0 ? (
                  <div class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-5">
                    <article class="glass-card overflow-hidden rounded-xl border border-border p-4">
                      <div class="flex aspect-square flex-col items-center justify-center gap-3 text-center">
                        <span class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-surface">
                          <Package size={20} class="fill-none stroke-2 text-muted stroke-muted" />
                        </span>
                        <p class="text-base font-semibold text-neutral">Collection vide</p>
                      </div>
                    </article>
                    <a
                      href={collectionId === 'no-collection' ? '/explorer' : '/explorer'}
                      class="group block overflow-hidden rounded-xl border border-primary/30 bg-linear-to-br from-primary to-secondary p-4 text-white no-underline transition-all hover:-translate-y-0.5 hover:border-primary/60"
                    >
                      <div class="flex aspect-square flex-col items-center justify-center gap-3 text-center">
                        <span class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-white/20 backdrop-blur-sm">
                          <svg class="h-5 w-5 text-white stroke-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                          </svg>
                        </span>
                        <p class="text-sm font-medium text-white/95">Rechercher et ajouter un album</p>
                      </div>
                    </a>
                  </div>
                ) : (
                  <ItemGrid items={items} columns={5} actionLabels={itemT.actions} />
                )}
              </section>
            )
          })}
        </div>

        <!-- Pagination -->
        {paginatedResult.pagination.totalPages > 1 && (
          <div class="mt-12 pt-8 border-t border-border">
            <Pagination
              currentPage={paginatedResult.pagination.page}
              totalPages={paginatedResult.pagination.totalPages}
              baseUrl="/library"
              queryParams={{
                format: selectedFormat,
                sort,
                ...(genre && { genre }),
                ...(year && { year }),
                ...(collectionId && { collection: collectionId }),
                ...(favoritesOnly && { favorites: 'true' }),
              }}
              previousPage={layoutT.common.previousPage}
              nextPage={layoutT.common.nextPage}
              previousPageAria={layoutT.common.previousPageAria}
              nextPageAria={layoutT.common.nextPageAria}
              paginationAria={layoutT.common.paginationAria}
            />
          </div>
        )}
      </>
    )}
  </div>
</DashboardLayout>

<style>
  .glass-card {
    transition: all var(--transition-base);
  }

  .glass-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  [data-item-section] {
    animation: fadeInUp 0.4s ease-out;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

