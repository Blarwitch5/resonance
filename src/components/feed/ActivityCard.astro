---
import Heart from '@lucide/astro/icons/heart'
import MessageCircle from '@lucide/astro/icons/message-circle'
import Star from '@lucide/astro/icons/star'
import type { FeedActivity } from '../../repositories/activity-repository'
import Avatar from '../ui/Avatar.astro'

type ActivityCardProps = {
  activity: FeedActivity
  currentUserId: string
}

const { activity, currentUserId } = Astro.props as ActivityCardProps

const isLikedByCurrentUser = activity.likes.some((like) => like.userId === currentUserId)
const likeCount = activity.likes.length
const commentCount = activity._count.comments

function getActivityLabel(type: FeedActivity['type']): string {
  const labels: Record<FeedActivity['type'], string> = {
    ADD_ITEM: 'a ajouté',
    ADD_WANT: 'veut',
    RATE_ITEM: 'a noté',
    CREATE_LIST: 'a créé la liste',
    ADD_TO_LIST: 'a ajouté à une liste',
  }
  return labels[type]
}

function getRelativeTime(date: Date): string {
  const nowMs = Date.now()
  const diffSeconds = Math.floor((nowMs - date.getTime()) / 1000)
  if (diffSeconds < 60) return 'à l\'instant'
  if (diffSeconds < 3600) return `${Math.floor(diffSeconds / 60)}min`
  if (diffSeconds < 86400) return `${Math.floor(diffSeconds / 3600)}h`
  if (diffSeconds < 604800) return `${Math.floor(diffSeconds / 86400)}j`
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' })
}

const actorName = activity.user.name || activity.user.username
const actorUsername = activity.user.username
const activityLabel = getActivityLabel(activity.type)
const relativeTime = getRelativeTime(activity.createdAt)
---

<article
  class="glass-card rounded-xl border border-border p-4 transition-colors"
  aria-label={`Activité de ${actorName}`}
  data-activity-id={activity.id}
>
  <div class="flex gap-3">

    <!-- Avatar -->
    <a
      href={`/u/${actorUsername}`}
      class="shrink-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 rounded-xl"
      aria-label={`Voir le profil de ${actorName}`}
    >
      <Avatar
        userName={activity.user.name}
        userEmail={null}
        imageUrl={activity.user.imageUrl}
        size="md"
        class="rounded-xl"
      />
    </a>

    <!-- Contenu -->
    <div class="min-w-0 flex-1">

      <!-- En-tête -->
      <div class="flex items-baseline justify-between gap-2">
        <p class="text-sm">
          <a
            href={`/u/${actorUsername}`}
            class="font-semibold text-neutral hover:text-primary transition-colors focus-visible:outline-none focus-visible:underline"
          >
            {actorName}
          </a>
          <span class="text-muted"> {activityLabel}</span>
        </p>
        <time
          datetime={activity.createdAt.toISOString()}
          class="shrink-0 text-xs text-muted"
          title={activity.createdAt.toLocaleString('fr-FR')}
        >
          {relativeTime}
        </time>
      </div>

      <!-- Item associé -->
      {activity.item && (
        <a
          href={`/item/${activity.item.slug}`}
          class="mt-2 flex items-center gap-3 rounded-lg border border-border bg-surface p-2.5 transition-colors hover:border-primary/40 hover:bg-surface-elevated focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50"
          aria-label={`${activity.item.albumTitle} — ${activity.item.artistName}`}
        >
          <!-- Pochette -->
          <div class="h-12 w-12 shrink-0 overflow-hidden rounded-lg bg-surface-elevated">
            {activity.item.coverUrl ? (
              <img
                src={activity.item.coverUrl}
                alt={`Pochette de ${activity.item.albumTitle}`}
                width={48}
                height={48}
                loading="lazy"
                class="h-full w-full object-cover"
              />
            ) : (
              <div class="flex h-full w-full items-center justify-center text-lg" aria-hidden="true">🎵</div>
            )}
          </div>

          <!-- Infos -->
          <div class="min-w-0 flex-1">
            <p class="truncate text-sm font-semibold text-neutral">{activity.item.albumTitle}</p>
            <p class="truncate text-xs text-muted">{activity.item.artistName}</p>
            <div class="mt-0.5 flex items-center gap-2">
              {activity.item.format && (
                <span class="rounded-full bg-surface-elevated px-1.5 py-0.5 text-xs text-muted">
                  {activity.item.format}
                </span>
              )}
              {activity.item.rating && (
                <span class="flex items-center gap-0.5">
                  {Array.from({ length: activity.item.rating }).map((_, starIndex) => (
                    <Star
                      size={10}
                      class="fill-amber-400 stroke-none"
                      aria-hidden={starIndex > 0 ? 'true' : undefined}
                    />
                  ))}
                  <span class="sr-only">{activity.item.rating} étoiles sur 5</span>
                </span>
              )}
            </div>
          </div>
        </a>
      )}

      <!-- Actions -->
      <div class="mt-3 flex items-center gap-4">
        <button
          type="button"
          class={`activity-like-btn flex items-center gap-1.5 text-sm transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 rounded ${
            isLikedByCurrentUser
              ? 'text-red-500 hover:text-red-400'
              : 'text-muted hover:text-red-500'
          }`}
          data-activity-id={activity.id}
          data-liked={isLikedByCurrentUser ? 'true' : 'false'}
          aria-pressed={isLikedByCurrentUser ? 'true' : 'false'}
          aria-label={`${isLikedByCurrentUser ? 'Ne plus aimer' : 'Aimer'} cette activité (${likeCount})`}
        >
          <Heart
            size={15}
            class={`stroke-2 ${isLikedByCurrentUser ? 'fill-current' : 'fill-none'}`}
            aria-hidden="true"
          />
          <span class="activity-like-count" aria-live="polite" aria-atomic="true">
            {likeCount > 0 ? likeCount : ''}
          </span>
        </button>

        <button
          type="button"
          class="flex items-center gap-1.5 text-sm text-muted transition-colors hover:text-neutral focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 rounded"
          aria-label={`${commentCount} commentaire${commentCount !== 1 ? 's' : ''}`}
        >
          <MessageCircle size={15} class="stroke-2 fill-none" aria-hidden="true" />
          {commentCount > 0 && <span>{commentCount}</span>}
        </button>
      </div>
    </div>
  </div>
</article>

<script>
  import { onAstroPageLoad, onDomReady } from '../../scripts/client/runtime'

  function initActivityLikes(): void {
    document.addEventListener('click', async (event) => {
      const button = (event.target as Element)?.closest('.activity-like-btn')
      if (!(button instanceof HTMLButtonElement)) return

      const activityId = button.dataset.activityId
      if (!activityId) return

      const isLiked = button.dataset.liked === 'true'
      const countEl = button.querySelector('.activity-like-count')
      const heartIcon = button.querySelector('svg')

      // Optimistic UI
      const currentCount = Number.parseInt(countEl?.textContent?.trim() || '0')
      const newCount = isLiked ? currentCount - 1 : currentCount + 1

      button.dataset.liked = isLiked ? 'false' : 'true'
      button.setAttribute('aria-pressed', isLiked ? 'false' : 'true')
      if (countEl) countEl.textContent = newCount > 0 ? String(newCount) : ''
      heartIcon?.classList.toggle('fill-current', !isLiked)
      heartIcon?.classList.toggle('fill-none', isLiked)
      button.classList.toggle('text-red-500', !isLiked)
      button.classList.toggle('text-muted', isLiked)

      try {
        const response = await fetch(`/api/activities/${activityId}/like`, { method: 'POST' })
        if (!response.ok) throw new Error('Like failed')
      } catch {
        // Revert on error
        button.dataset.liked = isLiked ? 'true' : 'false'
        button.setAttribute('aria-pressed', isLiked ? 'true' : 'false')
        if (countEl) countEl.textContent = currentCount > 0 ? String(currentCount) : ''
        heartIcon?.classList.toggle('fill-current', isLiked)
        heartIcon?.classList.toggle('fill-none', !isLiked)
        button.classList.toggle('text-red-500', isLiked)
        button.classList.toggle('text-muted', !isLiked)
      }
    })
  }

  onDomReady(initActivityLikes)
  onAstroPageLoad(initActivityLikes)
</script>
