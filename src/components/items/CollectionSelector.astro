---
import ChevronDown from '@lucide/astro/icons/chevron-down'
import type { Collection } from '@prisma/client'
import { getItemMessages } from '../../i18n/item'

type CollectionSelectorLabels = {
  label: string
  uncategorized: string
  hint: string
}

type CollectionSelectorProps = {
  itemId: string
  currentCollection: Collection | null
  collections: Collection[]
  labels?: CollectionSelectorLabels
}

const defaultLabels = getItemMessages('en').collectionSelector
const { itemId, currentCollection, collections, labels = defaultLabels } = Astro.props as CollectionSelectorProps
---

<div
  class="collection-selector-wrapper"
  data-toast-moved-template="Album moved to {collectionName}"
  data-toast-error-generic="Error while changing collection"
>
  <label class="mb-2 block text-sm font-medium text-neutral">
    {labels.label}
  </label>
  <div class="relative">
    <select
      id={`collection-select-${itemId}`}
      data-item-id={itemId}
      class="w-full appearance-none rounded-xl border border-border bg-surface px-4 py-3 pr-10 text-neutral transition-colors focus:border-primary focus:ring-2 focus:ring-primary/50 focus:outline-none"
    >
      <option value="" selected={currentCollection === null}>
        {labels.uncategorized}
      </option>
      {collections.map((collection) => (
        <option
          value={collection.id}
          selected={currentCollection?.id === collection.id}
        >
          {collection.name}
        </option>
      ))}
    </select>
    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
      <ChevronDown size={20} class="fill-none stroke-2 text-muted stroke-muted" />
    </div>
  </div>
  <p class="mt-1 text-xs text-muted">
    {labels.hint}
  </p>
</div>

<script>
  import './CollectionSelector.client'
</script>

<style>
  .collection-selector-wrapper select {
    cursor: pointer;
  }

  .collection-selector-wrapper select:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
</style>
