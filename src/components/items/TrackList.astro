---
import Music from '@lucide/astro/icons/music'

type Track = {
  position: string
  title: string
  duration?: string
}

type TrackListProps = {
  tracks: Track[]
  albumTitle: string
  albumArtist: string
  coverUrl?: string | null
  discogsId?: string | null
  tracklistTitle?: string
  trackCountOne?: string
  trackCountOther?: string
  audioLabels?: {
    playPreview: string
    pausePreview: string
    mute: string
    unmute: string
  }
  noPreviewForTrack?: string
  closeLabel?: string
  previewButtonAriaLabel?: string
  previewsUnavailableLabel?: string
  loadPreviewErrorLabel?: string
}

const {
  tracks,
  albumTitle,
  albumArtist,
  coverUrl,
  discogsId,
  tracklistTitle = 'Tracklist',
  trackCountOne = 'track',
  trackCountOther = 'tracks',
  audioLabels,
  noPreviewForTrack,
  closeLabel = 'Close',
  previewButtonAriaLabel,
  previewsUnavailableLabel = 'Audio previews are temporarily unavailable.',
  loadPreviewErrorLabel = 'Error while loading preview',
} = Astro.props as TrackListProps

const noPreviewForTrackLabel = noPreviewForTrack ?? 'No preview available for this track'
const playPreviewTemplate = audioLabels?.playPreview ?? 'Play preview of {name}'
const pausePreviewTemplate = audioLabels?.pausePreview ?? 'Pause preview of {name}'
const muteLabel = audioLabels?.mute ?? 'Mute'
const unmuteLabel = audioLabels?.unmute ?? 'Unmute'

// Vérifier si Spotify est configuré (via variable d'environnement côté client)
// Note: On ne peut pas vérifier directement dans Astro, donc on le fera côté client
const spotifyEnabled = true // Sera vérifié côté client
---

{tracks.length > 0 && (
  <div class="glass-card rounded-2xl p-4 md:p-6">
    <div class="mb-4 flex items-center gap-2">
      <Music size={20} class="fill-none stroke-2 text-primary stroke-primary" />
      <h2 class="text-xl font-bold text-neutral">{tracklistTitle}</h2>
      <span class="ml-auto text-sm text-muted">
        {tracks.length} {tracks.length === 1 ? trackCountOne : trackCountOther}
      </span>
    </div>
    <div class="space-y-2" data-tracklist>
      {tracks.map((track, index) => {
        const trackId = `track-${index}-${track.title.replace(/\s+/g, '-').toLowerCase()}`
        return (
          <div
            class="track-item group flex items-center gap-2 rounded-lg border border-border bg-surface p-2.5 transition-colors hover:bg-surface-elevated sm:gap-4 sm:p-4"
            data-track-index={index}
            data-track-title={track.title}
            data-track-artist={albumArtist}
          >
            <div class="flex min-w-0 flex-1 items-center gap-2 sm:gap-4">
              <span class="w-7 shrink-0 text-sm font-medium text-muted">
                {track.position || `${index + 1}.`}
              </span>
              <div class="min-w-0 flex-1">
                <p class="truncate text-sm font-medium text-neutral sm:text-base">
                  {track.title}
                  {track.duration && <span class="ml-2 text-xs text-muted">{track.duration}</span>}
                </p>
              </div>
            </div>
            <div class="flex shrink-0 justify-end" data-preview-container>
              <button
                type="button"
                class="track-preview-btn flex h-9 w-9 items-center justify-center rounded-full border border-border bg-surface text-muted transition-all hover:border-primary hover:bg-primary/10 hover:text-primary"
                data-track-name={track.title}
                data-track-artist={albumArtist}
                data-track-index={index}
                aria-label={previewButtonAriaLabel ?? (audioLabels ? audioLabels.playPreview.replace('{name}', track.title) : `Listen to a preview of ${track.title}`)}
              >
                <svg
                  class="h-5 w-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  data-play-icon
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                  />
                </svg>
                <svg
                  class="h-5 w-5 hidden"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  data-loading-icon
                >
                  <circle
                    class="opacity-25"
                    cx="12"
                    cy="12"
                    r="10"
                    stroke="currentColor"
                    stroke-width="4"
                  ></circle>
                  <path
                    class="opacity-75"
                    fill="currentColor"
                    d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                  ></path>
                </svg>
              </button>
            </div>
          </div>
        )
      })}
    </div>
  </div>
)}

<script
  type="application/json"
  id="tracklist-messages"
  set:html={JSON.stringify({
    albumTitle,
    albumArtist,
    coverUrl,
    noPreviewForTrackLabel,
    playPreviewTemplate,
    pausePreviewTemplate,
    muteLabel,
    unmuteLabel,
    closeLabel,
    previewsUnavailableLabel,
    loadPreviewErrorLabel,
  }).replace(/<\/script/gi, '<\\/script')}
></script>

<script>
  import './TrackList.client'
</script>
