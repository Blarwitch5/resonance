---
import type { Item } from '@prisma/client'
import ItemCard from './ItemCard.astro'

type ItemGridProps = {
  items: Item[]
  columns?: 3 | 4 | 5 | 6
}

const { items, columns = 4 } = Astro.props as ItemGridProps

const gridCols = {
  3: 'grid-cols-3 md:grid-cols-3',
  4: 'grid-cols-4 md:grid-cols-4',
  5: 'grid-cols-4 md:grid-cols-5',
  6: 'grid-cols-4 md:grid-cols-6',
}
---

<div class={`grid gap-1.5 ${gridCols[columns]}`}>
  {items.map((item) => (
    <ItemCard item={item} />
  ))}
</div>
