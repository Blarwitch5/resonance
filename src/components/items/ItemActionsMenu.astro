---
import Heart from '@lucide/astro/icons/heart'
import HeartOff from '@lucide/astro/icons/heart-off'
import Package from '@lucide/astro/icons/package-open'
import Trash2 from '@lucide/astro/icons/trash-2'
import EllipsisVertical from '@lucide/astro/icons/ellipsis-vertical'
import type { Collection } from '@prisma/client'

type ActionLabels = {
  favorite: string
  addToFavorites: string
  moreActions: string
  removeFromCollection: string
  removeFromLibrary: string
}

type ToastMessages = {
  addedToFavorites: string
  removedFromFavorites: string
  updateError: string
  removeFromCollectionConfirm: string
  removedFromCollection: string
  deleteConfirm: string
  deleted: string
}

type ItemActionsMenuProps = {
  itemId: string
  itemTitle: string
  currentCollection: Collection | null
  collections: Collection[]
  isFavorite: boolean
  actionLabels?: ActionLabels
  toastMessages?: ToastMessages
}

const { itemId, itemTitle, currentCollection, collections, isFavorite, actionLabels, toastMessages } =
  Astro.props as ItemActionsMenuProps

const actions = actionLabels ?? {
  favorite: 'Favorite',
  addToFavorites: 'Add to favorites',
  moreActions: 'More actions',
  removeFromCollection: 'Remove from collection',
  removeFromLibrary: 'Remove from library',
}
const toasts = toastMessages ?? {
  addedToFavorites: 'Added to favorites',
  removedFromFavorites: 'Removed from favorites',
  updateError: 'Error while updating',
  removeFromCollectionConfirm: 'Remove this album from the collection?',
  removedFromCollection: 'Album removed from collection',
  deleteConfirm: 'Delete this album?',
  deleted: 'Album removed from library',
}
---

<div
  class="item-actions-menu"
  data-label-favorite={actions.favorite}
  data-label-add-to-favorites={actions.addToFavorites}
  data-toast-added={toasts.addedToFavorites}
  data-toast-removed={toasts.removedFromFavorites}
  data-toast-update-error={toasts.updateError}
  data-confirm-remove-collection={toasts.removeFromCollectionConfirm}
  data-toast-removed-from-collection={toasts.removedFromCollection}
>
  <div class="flex items-center gap-2">
    <!-- Bouton Favoris -->
    <button
      type="button"
      class="favorite-btn flex items-center gap-2 rounded-xl border border-border bg-surface px-4 py-2 text-sm font-medium transition-all hover:bg-surface-elevated hover:border-primary/30 md:px-5 md:py-2.5"
      data-item-id={itemId}
      data-is-favorite={isFavorite}
    >
      <Heart
        size={18}
        class:list={[
          'favorite-icon',
          'fill-red-500',
          'stroke-2',
          'stroke-primary',
          isFavorite ? 'text-primary' : 'hidden',
        ]}
        aria-hidden="true"
      />
      <HeartOff
        size={18}
        class:list={[
          'favorite-icon',
          'fill-none',
          'stroke-2',
          'stroke-muted',
          isFavorite ? 'hidden text-primary' : 'text-muted',
        ]}
        aria-hidden="true"
      />
      <span class:list={[isFavorite ? 'text-primary' : 'text-muted']} data-favorite-label>
        {isFavorite ? actions.favorite : actions.addToFavorites}
      </span>
    </button>

    <!-- Menu contextuel -->
    <div class="relative">
      <button
        type="button"
        class="menu-trigger flex items-center justify-center rounded-xl border border-border bg-surface p-2 text-muted transition-all hover:bg-surface-elevated hover:text-neutral md:p-2.5"
        data-menu-trigger
        aria-label={actions.moreActions}
      >
        <EllipsisVertical size={18} class="fill-none stroke-2" />
      </button>

      <!-- Menu dropdown -->
      <div
        class="menu-dropdown absolute right-0 top-full z-50 mt-2 hidden w-64 rounded-xl border border-border bg-surface shadow-xl backdrop-blur-sm md:w-72"
        data-menu-dropdown
      >
        <div class="p-2">
          {currentCollection && (
            <button
              type="button"
              class="menu-item group flex w-full items-center gap-3 rounded-lg px-4 py-2.5 text-left text-sm text-neutral transition-all hover:bg-surface-elevated hover:text-primary"
              data-action="remove-from-collection"
            >
              <Package size={16} class="fill-none stroke-2 text-muted stroke-muted transition-colors group-hover:text-primary group-hover:stroke-primary" />
              <span>{actions.removeFromCollection}</span>
            </button>
          )}
          <button
            type="button"
            class="menu-item group flex w-full items-center gap-3 rounded-lg px-4 py-2.5 text-left text-sm text-red-500 transition-all hover:bg-red-500/10 hover:text-red-600"
            data-action="delete"
          >
            <Trash2 size={16} class="fill-none stroke-2 transition-colors group-hover:stroke-red-600" />
            <span>{actions.removeFromLibrary}</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import './ItemActionsMenu.client'
</script>

<style>
  /* Desktop dropdown menu improvements */
  @media (min-width: 768px) {
    .menu-dropdown {
      min-width: 280px;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
    }
    
    .menu-item {
      padding: 0.625rem 1rem;
    }
    
    .favorite-btn {
      min-width: 180px;
    }
  }
  
  /* Transition pour l'ouverture du menu */
  .menu-dropdown {
    animation: fadeInDown 0.2s ease-out;
  }
  
  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
