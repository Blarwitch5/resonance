---
import Pencil from '@lucide/astro/icons/pencil'
import Star from '@lucide/astro/icons/star'
import FileText from '@lucide/astro/icons/file-text'
import type { ItemMetadata } from '@prisma/client'

type PersonalDataLabels = {
  sectionTitle: string
  editLabel: string
  editAria: string
  emptyHint: string
  notes: string
  notesPlaceholder?: string
  purchaseDate: string
  purchasePrice: string
  purchaseLocation: string
  purchaseLocationPlaceholder?: string
  condition: string
  myRating: string
  tags: string
  tagsPlaceholder?: string
  tagHint: string
  dataSaved: string
  saving?: string
  saveLabel?: string
  removeTagAria?: string
  errorSaving?: string
  errorGeneric?: string
  cancel?: string
  conditionMint: string
  conditionNearMint: string
  conditionVeryGood: string
  conditionGood: string
  conditionFair: string
  conditionPoor: string
}

type PersonalDataSectionProps = {
  itemId: string
  metadata: ItemMetadata | null
  personalDataT?: PersonalDataLabels
}

const { itemId, metadata, personalDataT } = Astro.props as PersonalDataSectionProps

const t = personalDataT ?? {
  sectionTitle: 'Personal data',
  editLabel: 'Edit',
  editAria: 'Edit',
  emptyHint: 'No personal data yet. Click "Edit" to add some.',
  notes: 'Notes',
  notesPlaceholder: 'Anecdotes, memories...',
  purchaseDate: 'Purchase date',
  purchasePrice: 'Purchase price (€)',
  purchaseLocation: 'Purchase location',
  purchaseLocationPlaceholder: 'Record store, flea market...',
  condition: 'Condition',
  myRating: 'My rating (1–5)',
  tags: 'Custom tags',
  tagsPlaceholder: 'E.g. vinyl, limited edition, 2024',
  tagHint: 'Type a tag then press Enter or , to add it.',
  dataSaved: 'Data saved',
  saving: 'Saving...',
  saveLabel: 'Save',
  removeTagAria: 'Remove tag "{tag}"',
  errorSaving: 'Error while saving',
  errorGeneric: 'Error',
  cancel: 'Cancel',
  conditionMint: 'Mint',
  conditionNearMint: 'Near mint',
  conditionVeryGood: 'Very good',
  conditionGood: 'Good',
  conditionFair: 'Fair',
  conditionPoor: 'Poor',
}

const CONDITION_LABELS: Record<string, string> = {
  MINT: t.conditionMint,
  NEAR_MINT: t.conditionNearMint,
  VERY_GOOD: t.conditionVeryGood,
  GOOD: t.conditionGood,
  FAIR: t.conditionFair,
  POOR: t.conditionPoor,
}

const tags: string[] = metadata?.customTags
  ? (typeof metadata.customTags === 'string'
      ? (() => {
          try {
            return JSON.parse(metadata.customTags)
          } catch {
            return []
          }
        })()
      : [])
  : []

const scriptSaving = t.saving ?? 'Saving...'
const scriptSaveLabel = t.saveLabel ?? 'Save'
const scriptRemoveTagAria = t.removeTagAria ?? 'Remove tag "{tag}"'
const scriptErrorSaving = t.errorSaving ?? 'Error while saving'
const scriptErrorGeneric = t.errorGeneric ?? 'Error'

const acquisitionDateStr =
  metadata?.acquisitionDate instanceof Date
    ? metadata.acquisitionDate.toISOString().slice(0, 10)
    : metadata?.acquisitionDate
      ? new Date(metadata.acquisitionDate).toISOString().slice(0, 10)
      : ''
---

<section class="personal-data-section glass-card rounded-2xl p-4 md:p-6" data-item-id={itemId} data-data-saved={t.dataSaved}>
  <div class="mb-4 flex items-center justify-between gap-3">
    <h2 class="flex items-center gap-2 text-lg md:text-xl font-bold text-neutral">
      <FileText size={20} class="fill-none stroke-2 text-primary stroke-primary" />
      {t.sectionTitle}
    </h2>
    <button
      type="button"
      class="edit-toggle ml-auto inline-flex shrink-0 items-center gap-2 rounded-lg px-3 py-2 text-sm font-medium text-muted transition-colors hover:bg-surface-elevated hover:text-primary"
      data-action="toggle-edit"
      aria-label={t.editAria}
    >
      <Pencil size={16} />
      <span class="hidden sm:inline">{t.editLabel}</span>
    </button>
  </div>

  <div class="view-mode space-y-4" data-mode="view">
    {!metadata ? (
      <p class="text-sm text-muted">
        {t.emptyHint}
      </p>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2">
        {metadata.personalNotes && (
          <div>
            <span class="text-sm font-medium text-muted">{t.notes}</span>
            <p class="mt-1 whitespace-pre-wrap text-neutral">
              {metadata.personalNotes}
            </p>
          </div>
        )}
        {metadata.acquisitionDate && (
          <div>
            <span class="text-sm font-medium text-muted">{t.purchaseDate}</span>
            <p class="mt-1 text-neutral">
              {new Date(metadata.acquisitionDate).toLocaleDateString('fr-FR', {
                day: 'numeric',
                month: 'long',
                year: 'numeric',
              })}
            </p>
          </div>
        )}
        {metadata.purchasePrice != null && (
          <div>
            <span class="text-sm font-medium text-muted">{t.purchasePrice}</span>
            <p class="mt-1 text-neutral">
              {Number(metadata.purchasePrice).toFixed(2)} €
            </p>
          </div>
        )}
        {metadata.condition && (
          <div>
            <span class="text-sm font-medium text-muted">{t.condition}</span>
            <p class="mt-1 text-neutral">
              {CONDITION_LABELS[metadata.condition] ?? metadata.condition}
            </p>
          </div>
        )}
        {metadata.purchaseLocation && (
          <div>
            <span class="text-sm font-medium text-muted">{t.purchaseLocation}</span>
            <p class="mt-1 text-neutral">{metadata.purchaseLocation}</p>
          </div>
        )}
        {metadata.personalRating != null && (
          <div>
            <span class="text-sm font-medium text-muted">{t.myRating}</span>
            <p class="mt-1 flex items-center gap-1 text-neutral">
              {[1, 2, 3, 4, 5].map((ratingValue) => (
                <Star
                  size={18}
                  class={`fill-none stroke-2 ${ratingValue <= Math.round(metadata!.personalRating!) ? 'text-primary stroke-primary' : 'text-muted stroke-muted'}`}
                />
              ))}
              <span class="ml-1 text-sm">
                {Math.round(Number(metadata.personalRating))}/5
              </span>
            </p>
          </div>
        )}
        {tags.length > 0 && (
          <div class="sm:col-span-2">
            <span class="text-sm font-medium text-muted">{t.tags}</span>
            <div class="mt-2 flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span
                  class="inline-flex items-center rounded-full border border-primary/40 bg-primary/15 px-3 py-1 text-sm text-primary"
                >
                  {tag}
                </span>
              ))}
            </div>
          </div>
        )}
      </div>
    )}
  </div>

  <form class="edit-mode hidden space-y-4" data-mode="edit">
    <div>
      <label for="personal-notes" class="mb-2 block text-sm font-medium text-neutral">
        {t.notes}
      </label>
      <textarea
        id="personal-notes"
        name="personalNotes"
        rows="3"
        class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-neutral placeholder-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
        placeholder={t.notesPlaceholder ?? 'Anecdotes, memories...'}
      >
        {metadata?.personalNotes ?? ''}
      </textarea>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label for="acquisition-date" class="mb-2 block text-sm font-medium text-neutral">
          {t.purchaseDate}
        </label>
        <input
          type="date"
          id="acquisition-date"
          name="acquisitionDate"
          value={acquisitionDateStr}
          class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-neutral focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
        />
      </div>
      <div>
        <label for="purchase-price" class="mb-2 block text-sm font-medium text-neutral">
          {t.purchasePrice}
        </label>
        <input
          type="number"
          id="purchase-price"
          name="purchasePrice"
          min="0"
          step="0.01"
          value={metadata?.purchasePrice != null ? Number(metadata.purchasePrice) : ''}
          class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-neutral focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
        />
      </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label for="condition" class="mb-2 block text-sm font-medium text-neutral">
          {t.condition}
        </label>
        <select
          id="condition"
          name="condition"
          class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-neutral focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
        >
          <option value="">—</option>
          {Object.entries(CONDITION_LABELS).map(([value, label]) => (
            <option value={value} selected={metadata?.condition === value}>
              {label}
            </option>
          ))}
        </select>
      </div>
      <div>
        <label for="purchase-location" class="mb-2 block text-sm font-medium text-neutral">
          {t.purchaseLocation}
        </label>
        <input
          type="text"
          id="purchase-location"
          name="purchaseLocation"
          value={metadata?.purchaseLocation ?? ''}
          placeholder={t.purchaseLocationPlaceholder ?? 'Record store, flea market...'}
          class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-neutral placeholder-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
        />
      </div>
    </div>

    <div>
      <label class="mb-2 block text-sm font-medium text-neutral">
        {t.myRating}
      </label>
      <div class="star-rating-container flex items-center gap-1" data-star-rating>
        {[1, 2, 3, 4, 5].map((ratingValue) => (
          <button
            type="button"
            class="star-btn star-outlined rounded p-1 transition-colors duration-150"
            data-value={ratingValue}
            aria-label={`${ratingValue} star${ratingValue > 1 ? 's' : ''}`}
          >
            <Star size={28} class="pointer-events-none" />
          </button>
        ))}
        <input type="hidden" name="personalRating" id={`personal-rating-value-${itemId}`} value={metadata?.personalRating != null ? Math.round(Number(metadata.personalRating)) : ''} />
      </div>
    </div>

    <div>
      <label for="tags-input" class="mb-2 block text-sm font-medium text-neutral">
        {t.tags}
      </label>
      <p class="mb-2 text-xs text-muted">
        {t.tagHint}
      </p>
      <div class="tags-container flex flex-wrap items-center gap-2 rounded-xl border border-border bg-surface p-3 min-h-[44px]">
        <div class="tags-badges-container flex flex-wrap gap-2 empty:hidden" data-tags-badges-container></div>
        <input
          type="text"
          id="tags-input"
          class="min-w-[140px] flex-1 rounded-lg border-0 bg-transparent px-2 py-1.5 text-sm text-neutral placeholder-muted focus:outline-none focus:ring-2 focus:ring-primary/50"
          placeholder={t.tagsPlaceholder ?? 'E.g. vinyl, limited edition, 2024'}
          maxlength="50"
          data-tags-input
          autocomplete="off"
        />
      </div>
      <input type="hidden" name="customTags" id={`custom-tags-value-${itemId}`} value={JSON.stringify(tags)} />
    </div>

    <div class="flex gap-3 pt-2">
      <button
        type="submit"
        class="bg-gradient-resonance hover:bg-gradient-resonance-hover rounded-xl px-4 py-2.5 text-sm font-medium text-white transition-all"
      >
        {t.saveLabel ?? 'Save'}
      </button>
      <button
        type="button"
        class="cancel-edit rounded-xl border border-border bg-surface px-4 py-2.5 text-sm font-medium text-neutral transition-colors hover:bg-surface-elevated"
        data-action="cancel-edit"
      >
        {t.cancel ?? 'Cancel'}
      </button>
    </div>
  </form>
</section>

<script
  type="application/json"
  id="personal-data-messages"
  set:html={JSON.stringify({
    saving: scriptSaving,
    saveLabel: scriptSaveLabel,
    removeTagAria: scriptRemoveTagAria,
    errorSaving: scriptErrorSaving,
    errorGeneric: scriptErrorGeneric,
  }).replace(/<\/script/gi, '<\\/script')}
></script>

<script>
  import './PersonalDataSection.client'
</script>

<style>
  /* Outlined : pas de note ou étoile non sélectionnée */
  .star-btn.star-outlined svg {
    fill: none;
    stroke: var(--color-muted);
    stroke-width: 2;
  }
  .star-btn.star-outlined:hover svg {
    stroke: var(--color-primary);
  }

  /* Filled primary : sélectionné */
  .star-btn.star-filled-primary svg {
    fill: var(--color-primary);
    stroke: var(--color-primary);
    stroke-width: 2;
  }

  /* Filled secondary : prévisualisation au hover (au-delà de la note actuelle) */
  .star-btn.star-filled-secondary svg {
    fill: var(--color-secondary);
    stroke: var(--color-secondary);
    stroke-width: 2;
  }

  /* Tags : masquer le conteneur des badges quand vide */
  [data-tags-badges-container]:empty {
    display: none;
  }
  .tag-pill {
    max-width: 100%;
  }
  .tag-pill > span:first-child {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
