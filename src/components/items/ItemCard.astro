---
import Heart from '@lucide/astro/icons/heart'
import OptimizedImage from '../ui/OptimizedImage.astro'
import type { Item, ItemMetadata } from '@prisma/client'

type ItemCardProps = {
  item: Item & { metadata: ItemMetadata | null }
  actionLabels?: {
    addToFavorites: string
    moreActions: string
  }
}

const { item, actionLabels } = Astro.props as ItemCardProps
const addToFavoritesLabel = actionLabels?.addToFavorites ?? 'Add to favorites'
---

<article
  class="glass-card group relative overflow-hidden rounded-xl transition-all md:hover:scale-105"
  data-item-card
  data-item-title={item.title}
  data-item-artist={item.artist}
  data-item-genre={item.genre || ''}
  data-item-year={item.year?.toString() || ''}
>
  <!-- Lien vers la page de détails -->
  <a href={`/items/${item.slug}`} class="block no-underline">
    <!-- Cover -->
    <div class="overflow-hidden bg-surface">
      <OptimizedImage
        src={item.coverUrl}
        alt={`${item.title} - ${item.artist}`}
        width={400}
        height={400}
        loading="lazy"
        aspectRatio="square"
        class="h-full w-full object-cover"
      />
    </div>

    <!-- Info -->
    <div class="p-3">
      <h3 class="truncate font-medium text-neutral">{item.title}</h3>
      <p class="truncate text-sm text-muted">{item.artist}</p>
      {item.year && <p class="text-xs text-muted">{item.year}</p>}
    </div>
  </a>

  <!-- Actions -->
  <div
    class="item-card-actions mt-2 flex gap-2 md:absolute md:top-2 md:right-2 md:z-10 md:mt-0 md:opacity-0 md:transition-opacity md:group-hover:opacity-100 md:group-focus-within:opacity-100 md:focus-within:opacity-100"
  >
    <button
      type="button"
      class:list={[
        'item-favorite-btn favorite-action-button flex h-11 w-11 items-center justify-center rounded-full border-0 bg-amber-500/90 p-0 text-white shadow-lg backdrop-blur-sm transition-all hover:bg-amber-500',
        item.metadata?.isFavorite && 'favorite-action-button--saved',
      ]}
      aria-label={addToFavoritesLabel}
      aria-pressed={item.metadata?.isFavorite ? 'true' : 'false'}
      data-item-id={item.id}
      data-favorite={item.metadata?.isFavorite ? 'true' : 'false'}
    >
      <Heart
        size={16}
        class={`favorite-icon stroke-2 text-white stroke-white ${item.metadata?.isFavorite ? 'fill-current' : 'fill-none'}`}
      />
    </button>
  </div>
</article>

<script>
  // Empêcher les clics sur les boutons d'action de déclencher le lien parent
  document.addEventListener('click', (event) => {
    const target = event.target instanceof Element ? event.target : null
    if (!target) return
    const button = target.closest('.item-favorite-btn')
    
    if (button) {
      event.stopPropagation()
      event.preventDefault()
    }
  })

  // Favorite toggle handling
  document.addEventListener('click', async (event) => {
    const target = event.target instanceof Element ? event.target : null
    if (!target) return
    const button = target.closest('.item-favorite-btn')

    if (!button) return

    const itemId = button.getAttribute('data-item-id')
    const isFavorite = button.getAttribute('data-favorite') === 'true'

    if (!itemId) return

    try {
      const response = await fetch(`/api/items/${itemId}/toggle-favorite`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
      })

      if (response.ok) {
        // Update icon + style
        const heartIcon = button.querySelector('svg')
        if (heartIcon) {
          heartIcon.classList.toggle('fill-current')
          heartIcon.classList.toggle('fill-none')
        }

        // Update data attribute
        button.setAttribute('data-favorite', (!isFavorite).toString())
        button.setAttribute('aria-pressed', (!isFavorite).toString())
        button.classList.toggle('favorite-action-button--saved', !isFavorite)

        // En contexte "Profil -> Favoris", forcer un refresh pour que la liste se mette à jour.
        // (La liste est rendue côté serveur, donc un simple toggle local ne suffit pas.)
        try {
          const url = new URL(window.location.href)
          const tabParam = url.searchParams.get('tab')
          const isProfileFavoritesContext = url.pathname.includes('/profile') && (!tabParam || tabParam === 'favorites')
          if (isProfileFavoritesContext) setTimeout(() => window.location.reload(), 200)
        } catch {
          // no-op
        }
      }
    } catch (error) {
      console.error('Error toggling favorite:', error)
    }
  })
</script>

<style>
  .favorite-action-button--saved {
    background-color: #d97706;
  }
</style>
