---
import EllipsisVertical from '@lucide/astro/icons/ellipsis-vertical'
import Star from '@lucide/astro/icons/star'
import type { Item } from '@prisma/client'
import OptimizedImage from '../ui/OptimizedImage.astro'

type ItemCardProps = {
  item: Item
}

const { item } = Astro.props as ItemCardProps
---

<article
  class="item-card group relative aspect-square overflow-hidden rounded-xl bg-surface cursor-pointer"
  data-item-id={item.id}
  data-item-title={item.albumTitle}
  data-item-artist={item.artistName}
>
  <!-- Cover -->
  <a href={`/item/${item.slug}`} class="block h-full w-full no-underline" tabindex="-1" aria-hidden="true">
    <OptimizedImage
      src={item.coverUrl}
      alt={`${item.albumTitle} — ${item.artistName}`}
      width={400}
      height={400}
      loading="lazy"
      aspectRatio="square"
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
    />
  </a>

  <!-- Overlay (tap mobile / hover desktop) -->
  <div
    class="item-overlay absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-black/85 via-black/30 to-transparent opacity-0 transition-opacity duration-200 group-hover:opacity-100 group-focus-within:opacity-100"
    aria-hidden="true"
  >
    <div class="p-3">
      <!-- Rating -->
      {item.rating && (
        <div class="mb-1 flex gap-0.5">
          {Array.from({ length: 5 }).map((_, i) => (
            <Star
              size={10}
              class={`stroke-none ${i < item.rating! ? 'fill-amber-400' : 'fill-white/20'}`}
            />
          ))}
        </div>
      )}

      <!-- Title + Artist -->
      <p class="truncate text-sm font-semibold leading-tight text-white">{item.albumTitle}</p>
      <p class="truncate text-xs text-white/70">{item.artistName}</p>

      <!-- Actions -->
      <div class="mt-2 flex gap-2">
        <a
          href={`/item/${item.slug}`}
          class="flex-1 rounded-lg bg-white/20 px-3 py-1.5 text-center text-xs font-semibold text-white backdrop-blur-sm transition-colors hover:bg-white/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/60"
        >
          Voir
        </a>
        <button
          type="button"
          class="item-menu-btn flex h-7 w-7 items-center justify-center rounded-lg bg-white/20 text-white backdrop-blur-sm transition-colors hover:bg-white/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/60"
          aria-label={`Plus d'options pour ${item.albumTitle}`}
          aria-haspopup="menu"
          data-item-id={item.id}
          data-item-slug={item.slug}
          data-item-title={item.albumTitle}
        >
          <EllipsisVertical size={14} class="stroke-2" />
        </button>
      </div>
    </div>
  </div>
</article>

<script>
  // Tap sur mobile : toggle overlay
  document.addEventListener('click', (event) => {
    const card = (event.target as Element)?.closest('.item-card') as HTMLElement | null
    if (!card) {
      // Tap hors d'une carte : ferme toutes les overlays ouvertes
      document.querySelectorAll('.item-card.overlay-open').forEach((openCard) => {
        openCard.classList.remove('overlay-open')
        openCard.querySelector('.item-overlay')?.classList.remove('opacity-100')
        openCard.querySelector('.item-overlay')?.classList.add('opacity-0')
      })
      return
    }

    const overlay = card.querySelector('.item-overlay')
    const isLink = (event.target as Element)?.closest('a, button')
    if (isLink) return // laisser passer les clics sur liens/boutons

    const isOpen = card.classList.contains('overlay-open')
    // Ferme les autres
    document.querySelectorAll('.item-card.overlay-open').forEach((c) => {
      if (c !== card) {
        c.classList.remove('overlay-open')
        c.querySelector('.item-overlay')?.classList.remove('opacity-100')
        c.querySelector('.item-overlay')?.classList.add('opacity-0')
      }
    })
    // Toggle celle-ci
    card.classList.toggle('overlay-open', !isOpen)
    overlay?.classList.toggle('opacity-100', !isOpen)
    overlay?.classList.toggle('opacity-0', isOpen)
  })
</script>
