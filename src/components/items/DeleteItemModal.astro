---
import AlertTriangle from '@lucide/astro/icons/triangle-alert'
import X from '@lucide/astro/icons/x'
import { getItemMessages } from '../../i18n/item'
import type { ItemMessages } from '../../i18n/item'

type DeleteItemModalProps = {
  itemId: string
  itemTitle: string
  deleteModal?: ItemMessages['deleteModal']
  toasts?: Pick<ItemMessages, 'toasts'>['toasts']
}

const defaultMessages = getItemMessages('en')
const { itemId, itemTitle, deleteModal: deleteModalLabels = defaultMessages.deleteModal, toasts: toastLabels = defaultMessages.toasts } = Astro.props as DeleteItemModalProps
---

<div
  id="delete-item-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4"
  data-modal
  role="dialog"
  aria-modal="true"
  aria-labelledby="delete-item-modal-title"
  aria-describedby="delete-item-modal-description"
  tabindex="-1"
>
  <div class="glass-card w-full max-w-md rounded-2xl p-6">
    <div class="mb-4 flex items-start justify-between">
      <div class="flex items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-full bg-red-500/20">
          <AlertTriangle size={20} class="fill-none stroke-2 text-red-500 stroke-red-500" />
        </div>
        <div>
          <h3 id="delete-item-modal-title" class="text-lg font-bold text-neutral">
            {deleteModalLabels.title}
          </h3>
        </div>
      </div>
      <button
        type="button"
        class="close-btn flex h-8 w-8 items-center justify-center rounded-lg text-muted transition-colors hover:bg-surface-elevated hover:text-neutral"
        data-action="close"
        aria-label={deleteModalLabels.closeAria}
      >
        <X size={18} />
      </button>
    </div>

    <p id="delete-item-modal-description" class="mb-6 text-sm text-muted">
      {deleteModalLabels.description}
    </p>

    <div class="flex gap-3">
      <button
        type="button"
        class="cancel-btn flex-1 rounded-xl border border-border bg-surface px-4 py-2.5 text-sm font-medium text-neutral transition-colors hover:bg-surface-elevated"
        data-action="cancel"
      >
        {deleteModalLabels.cancel}
      </button>
      <button
        type="button"
        class="delete-btn flex-1 rounded-xl bg-red-500 px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-red-600"
        data-action="confirm"
        data-item-id={itemId}
      >
        {deleteModalLabels.delete}
      </button>
    </div>
  </div>
</div>

<script define:vars={{ deleteModalLabels, toastLabels }}>
  (function() {
    const modal = document.getElementById('delete-item-modal')
    if (!modal) return

    const closeBtn = modal.querySelector('[data-action="close"]')
    const cancelBtn = modal.querySelector('[data-action="cancel"]')
    const deleteBtn = modal.querySelector('[data-action="confirm"]')

    const itemId = deleteBtn?.dataset.itemId
    if (!itemId) return

    let lastActiveElement = null

    function closeModal() {
      modal.classList.add('hidden')
      modal.classList.remove('flex')

      if (lastActiveElement && typeof lastActiveElement.focus === 'function') {
        lastActiveElement.focus()
      }
      lastActiveElement = null
    }
    
    // Exposer la fonction pour ouvrir le modal depuis l'extérieur
    function openModal() {
      modal.classList.remove('hidden')
      modal.classList.add('flex')

      // Mémoriser l'élément actif avant ouverture pour restaurer le focus ensuite
      lastActiveElement = document.activeElement instanceof HTMLElement ? document.activeElement : null

      // Focus initial sur le bouton de suppression (action principale)
      if (deleteBtn && deleteBtn instanceof HTMLElement && typeof deleteBtn.focus === 'function') {
        deleteBtn.focus()
      } else if (typeof modal.focus === 'function') {
        modal.focus()
      }
    }
    
    // Exposer globalement pour être appelé depuis ItemActionsMenu
    if (typeof window !== 'undefined') {
      window.openDeleteItemModal = openModal
    }

    // Fermer le modal
    if (closeBtn) {
      closeBtn.addEventListener('click', closeModal)
    }

    if (cancelBtn) {
      cancelBtn.addEventListener('click', closeModal)
    }

    // Fermer en cliquant sur le fond
    modal.addEventListener('click', (event) => {
      if (event.target === modal) {
        closeModal()
      }
    })

    // Gestion du clavier (Escape + boucle de focus)
    modal.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        event.stopPropagation()
        if (!modal.classList.contains('hidden')) {
          closeModal()
        }
        return
      }

      if (event.key === 'Tab') {
        const focusableSelectors = [
          'button',
          '[href]',
          'input',
          'select',
          'textarea',
          '[tabindex]:not([tabindex="-1"])',
        ]
        const focusable = Array.from(
          modal.querySelectorAll(focusableSelectors.join(','))
        ).filter((element) => {
          const htmlElement = element
          return (
            htmlElement instanceof HTMLElement &&
            !htmlElement.hasAttribute('disabled') &&
            htmlElement.tabIndex !== -1 &&
            htmlElement.offsetParent !== null
          )
        })

        if (focusable.length === 0) {
          event.preventDefault()
          return
        }

        const firstElement = focusable[0]
        const lastElement = focusable[focusable.length - 1]
        const current = document.activeElement

        if (event.shiftKey) {
          if (current === firstElement || !modal.contains(current)) {
            event.preventDefault()
            ;(lastElement as HTMLElement).focus()
          }
        } else {
          if (current === lastElement || !modal.contains(current)) {
            event.preventDefault()
            ;(firstElement as HTMLElement).focus()
          }
        }
      }
    })

    // Supprimer l'item
    if (deleteBtn) {
      deleteBtn.addEventListener('click', async () => {
        deleteBtn.disabled = true
        deleteBtn.textContent = deleteModalLabels.deleting

        try {
          const response = await fetch(`/api/items/${itemId}`, {
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json',
            },
          })

          if (!response.ok) {
            throw new Error('Failed to delete item')
          }

          const data = await response.json()

          if (window.toast) {
            window.toast.success(toastLabels.deleted)
          }

          // Rediriger vers la bibliothèque
          setTimeout(() => {
            window.location.href = '/library'
          }, 500)
        } catch (error) {
          console.error('Error deleting item:', error)
          deleteBtn.disabled = false
          deleteBtn.textContent = deleteModalLabels.delete

          if (window.toast) {
            window.toast.error(toastLabels.updateError)
          }
        }
      })
    }
  })()
</script>
