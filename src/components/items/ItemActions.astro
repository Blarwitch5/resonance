---
import Heart from '@lucide/astro/icons/heart'
import Pencil from '@lucide/astro/icons/pencil'
import Trash2 from '@lucide/astro/icons/trash-2'

type ItemActionsLabels = {
  addToFavorites: string
  removeFromFavorites: string
  editAria: string
  deleteAria: string
}

type DeleteModalLabels = {
  title: string
  description: string
  delete: string
  cancel: string
}

const defaultActions: ItemActionsLabels = {
  addToFavorites: 'Add to favorites',
  removeFromFavorites: 'Remove from favorites',
  editAria: 'Edit',
  deleteAria: 'Delete',
}

const defaultDeleteModal: DeleteModalLabels = {
  title: 'Delete this album?',
  description: 'Are you sure you want to delete this album? This action is irreversible.',
  delete: 'Delete',
  cancel: 'Cancel',
}

type ItemActionsProps = {
  itemId: string
  isFavorite?: boolean
  actionLabels?: ItemActionsLabels
  deleteModal?: DeleteModalLabels
}

const { itemId, isFavorite = false, actionLabels = defaultActions, deleteModal: deleteModalLabels = defaultDeleteModal } = Astro.props as ItemActionsProps
const actions = actionLabels
const deleteModal = deleteModalLabels
---

<div class="absolute right-2 top-2 flex gap-2">
  <button
    type="button"
    class="btn-icon rounded-full p-2 shadow-lg"
    aria-label={isFavorite ? actions.removeFromFavorites : actions.addToFavorites}
    data-action="favorite"
    data-item-id={itemId}
  >
    <Heart size={16} class={`stroke-2 ${isFavorite ? 'fill-red-500 text-red-500 stroke-red-500' : 'fill-none text-muted stroke-muted'}`} />
  </button>
  
  <button
    type="button"
    class="btn-icon rounded-full p-2 shadow-lg"
    aria-label={actions.editAria}
    data-action="edit"
    data-item-id={itemId}
  >
    <Pencil size={16} class="fill-none stroke-2" />
  </button>
  
  <button
    type="button"
    class="btn-icon rounded-full p-2 shadow-lg"
    aria-label={actions.deleteAria}
    data-action="delete"
    data-item-id={itemId}
  >
    <Trash2 size={16} class="fill-none stroke-2" />
  </button>
</div>

<script type="application/json" id="item-actions-delete-messages" set:html={JSON.stringify({
  title: deleteModal.title,
  description: deleteModal.description,
  delete: deleteModal.delete,
  cancel: deleteModal.cancel,
}).replace(/<\/script/gi, '<\\/script')}></script>

<script>
  import './ItemActions.client'
</script>

