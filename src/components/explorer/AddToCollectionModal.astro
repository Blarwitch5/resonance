---
import X from '@lucide/astro/icons/x'
import Heart from '@lucide/astro/icons/heart'
import type { Collection } from '@prisma/client'
import { getExplorerMessages } from '../../i18n/explorer'
import type { ExplorerMessages } from '../../i18n/explorer'

type AddToCollectionModalProps = {
  collections: Collection[]
  itemId?: string
  addToCollection?: ExplorerMessages['addToCollection']
  client?: ExplorerMessages['client']
}

const defaultMessages = getExplorerMessages('en')
const { collections, itemId, addToCollection: addToCollectionLabels = defaultMessages.addToCollection, client: clientMessages = defaultMessages.client } = Astro.props as AddToCollectionModalProps
---

<!-- Modal backdrop -->
<div
  id="add-to-collection-modal"
  class="add-to-collection-modal fixed inset-0 z-50 hidden items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="add-to-collection-title"
>
  <!-- Overlay glass -->
  <div class="modal-overlay absolute inset-0 bg-black/60 backdrop-blur-md"></div>
  
  <!-- Modal content -->
  <div class="modal-content glass-card relative z-10 w-full max-w-md rounded-2xl p-6 shadow-2xl">
    <div class="mb-6 flex items-center justify-between">
      <h2 id="add-to-collection-title" class="text-2xl font-bold text-neutral">{addToCollectionLabels.title}</h2>
      <button type="button" class="close-modal text-muted hover:text-neutral" aria-label={addToCollectionLabels.closeModalAria}>
        <X size={24} />
      </button>
    </div>

    <div class="space-y-3">
      <!-- Add to wishlist button -->
      <button
        type="button"
        class="wishlist-add-btn w-full rounded-xl border-2 border-pink-500/30 bg-pink-500/10 p-4 text-left transition-all hover:border-pink-500/50 hover:bg-pink-500/20 disabled:opacity-50 disabled:cursor-not-allowed"
        data-original-text={addToCollectionLabels.addToWishlist}
      >
        <div class="flex items-center gap-3">
          <Heart size={20} class="fill-none stroke-2 text-pink-500 stroke-pink-500" />
          <div>
            <h3 class="font-medium text-neutral">{addToCollectionLabels.addToWishlist}</h3>
            <p class="text-sm text-muted">{addToCollectionLabels.saveForLater}</p>
          </div>
        </div>
      </button>

      <div class="my-4 border-t border-border"></div>

      {collections.length === 0 ? (
        <div class="rounded-xl border border-dashed border-border bg-surface p-8 text-center">
          <p class="mb-4 font-medium text-neutral">{addToCollectionLabels.noCollectionAvailable}</p>
          <p class="mb-4 text-sm text-muted">
            {addToCollectionLabels.noCollectionHint}
          </p>
          <a
            href="/collections/new"
            class="btn-primary-gradient inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm"
          >
            {addToCollectionLabels.createCollection}
          </a>
        </div>
      ) : (
        collections.map((collection) => (
          <button
            type="button"
            class="collection-add-btn btn-secondary-surface w-full rounded-xl p-4 text-left disabled:opacity-50 disabled:cursor-not-allowed"
            data-collection-id={collection.id}
            data-original-text={addToCollectionLabels.add}
          >
            <h3 class="font-medium">{collection.name}</h3>
            {collection.description && (
              <p class="text-sm text-muted">{collection.description}</p>
            )}
          </button>
        ))
      )}
    </div>

    <div class="mt-6 flex justify-end gap-3">
      <button
        type="button"
        class="btn-secondary-surface close-modal rounded-xl px-4 py-2"
      >
        {addToCollectionLabels.cancel}
      </button>
      <a
        href="/collections/new"
        class="btn-primary-gradient rounded-xl px-4 py-2"
      >
        {addToCollectionLabels.newCollection}
      </a>
    </div>
  </div>
</div>

<script type="application/json" id="add-to-collection-modal-messages" set:html={JSON.stringify({
  addToCollectionLabels,
  clientMessages,
}).replace(/<\/script/gi, '<\\/script')}></script>

<script is:inline>
  (function() {
    let addToCollectionLabels = {}
    let clientMessages = {}
    try {
      const el = document.getElementById('add-to-collection-modal-messages')
      if (el && el.textContent) {
        const parsed = JSON.parse(el.textContent)
        addToCollectionLabels = parsed.addToCollectionLabels || {}
        clientMessages = parsed.clientMessages || {}
      }
    } catch (e) { console.warn('Could not parse add-to-collection-modal-messages', e) }

    const modal = document.getElementById('add-to-collection-modal')
    if (!modal) return

    const closeButtons = document.querySelectorAll('.close-modal')
    let lastActiveElement = null

    function closeModal() {
      const currentModal = document.getElementById('add-to-collection-modal')
      if (!currentModal) return
      currentModal.classList.add('hidden')
      currentModal.style.display = ''
      currentModal.removeAttribute('data-redirect-on-success')

      if (lastActiveElement && typeof lastActiveElement.focus === 'function') {
        lastActiveElement.focus()
      }
      lastActiveElement = null
    }

    closeButtons.forEach(function(btn) {
      btn.addEventListener('click', closeModal)
    })

    modal.addEventListener('keydown', function(event) {
      if (event.key === 'Escape') {
        event.stopPropagation()
        if (!modal.classList.contains('hidden')) {
          closeModal()
        }
        return
      }

      if (event.key === 'Tab') {
        const focusableSelectors = [
          'button',
          '[href]',
          'input',
          'select',
          'textarea',
          '[tabindex]:not([tabindex="-1"])',
        ]
        const focusable = Array.from(
          modal.querySelectorAll(focusableSelectors.join(','))
        ).filter((element) => {
          const htmlElement = element
          return (
            htmlElement instanceof HTMLElement &&
            !htmlElement.hasAttribute('disabled') &&
            htmlElement.tabIndex !== -1 &&
            htmlElement.offsetParent !== null
          )
        })

        if (focusable.length === 0) {
          event.preventDefault()
          return
        }

        const firstElement = focusable[0]
        const lastElement = focusable[focusable.length - 1]
        const current = document.activeElement

        if (event.shiftKey) {
          if (current === firstElement || !modal.contains(current)) {
            event.preventDefault()
            if (lastElement && lastElement.focus) lastElement.focus()
          }
        } else {
          if (current === lastElement || !modal.contains(current)) {
            event.preventDefault()
            if (firstElement && firstElement.focus) firstElement.focus()
          }
        }
      }
    })

    // Fermer en cliquant sur l'overlay
    const modalOverlay = document.querySelector('.modal-overlay')
    if (modalOverlay) {
      modalOverlay.addEventListener('click', closeModal)
    }

    // Empêcher la fermeture en cliquant sur le contenu du modal
    const modalContent = document.querySelector('.modal-content')
    if (modalContent) {
      modalContent.addEventListener('click', function(event) {
        event.stopPropagation()
      })
    }

    function attachButtonListeners() {
      const wishlistButton = document.querySelector('.wishlist-add-btn')
      if (wishlistButton && !wishlistButton.hasAttribute('data-listener-attached')) {
        wishlistButton.setAttribute('data-listener-attached', 'true')
        wishlistButton.addEventListener('click', async function(event) {
          event.preventDefault()
          event.stopPropagation()
          
          if (!modal) return
          const discogsId = modal.getAttribute('data-discogs-id')
          if (!discogsId) {
            console.warn('No discogsId set on modal')
            return
          }

          // Set loading state
          const originalText = wishlistButton.getAttribute('data-original-text') || addToCollectionLabels.addToWishlist
          if (window.setButtonLoading) {
            window.setButtonLoading(wishlistButton, true, originalText)
          } else {
            wishlistButton.disabled = true
            wishlistButton.textContent = addToCollectionLabels.adding
          }

          try {
            // Récupérer les détails de la release Discogs
            const releaseResponse = await fetch('/api/discogs/release/' + discogsId)
            if (!releaseResponse.ok) {
              throw new Error(addToCollectionLabels.fetchReleaseError)
            }

            const release = await releaseResponse.json()
            let format = 'VINYL'
            const formatNames = (release.formats && release.formats.map(function(f) { return f.name.toUpperCase() })) || []
            if (formatNames.some(function(n) { return n.includes('CD') })) format = 'CD'
            else if (formatNames.some(function(n) { return n.includes('CASSETTE') })) format = 'CASSETTE'
            const primaryArtist = (release.artists && release.artists[0] && release.artists[0].name) || clientMessages.unknownArtist
            const year = release.year || parseInt(release.released || '0', 10) || null
            function getBestCoverUrl(rd) {
              if (rd.images && rd.images.length > 0) {
                const primaryImage = rd.images.find(function(img) { return img.type === 'primary' }) || rd.images[0]
                return primaryImage.uri || primaryImage.resource_url || null
              }
              return rd.cover_image || rd.thumb || null
            }

            // Add to wishlist
            const wishlistResponse = await fetch('/api/wishlist/create', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                discogsId: release.id,
                title: release.title,
                artist: primaryArtist,
                year,
                genre: (release.genres && release.genres[0]) || (release.styles && release.styles[0]) || null,
                coverUrl: getBestCoverUrl(release),
                format,
                priority: 1,
              }),
            })

            if (!wishlistResponse.ok) {
              const error = await wishlistResponse.json()
              throw new Error(error.error || addToCollectionLabels.failedToAddToWishlist)
            }

            // Success
            modal.classList.add('hidden')
            modal.style.display = ''
            modal.removeAttribute('data-discogs-id')
            modal.removeAttribute('data-redirect-on-success')
            
            if (window.toast) {
              window.toast.success(addToCollectionLabels.addedToWishlistToast)
            }
          } catch (error) {
            console.error('Error adding to wishlist:', error)
            if (window.toast) {
              window.toast.error(clientMessages.generalSearchError)
            }
            // Reset loading state
            if (window.setButtonLoading) {
              window.setButtonLoading(wishlistButton, false)
            } else {
              wishlistButton.disabled = false
              wishlistButton.textContent = originalText
            }
          }
        })
      }

      const collectionButtons = document.querySelectorAll('.collection-add-btn')
      collectionButtons.forEach(function(button) {
        if (button.hasAttribute('data-listener-attached')) return
        button.setAttribute('data-listener-attached', 'true')
        button.addEventListener('click', async function(event) {
          event.preventDefault()
          event.stopPropagation()
          
          if (!modal) return
          const collectionId = button.getAttribute('data-collection-id')
          const discogsId = modal.getAttribute('data-discogs-id')

          if (!collectionId || !discogsId) {
            console.warn('Missing collectionId or discogsId', { collectionId, discogsId })
            return
          }

          // Set loading state
          const originalText = button.getAttribute('data-original-text') || addToCollectionLabels.add
          if (window.setButtonLoading) {
            window.setButtonLoading(button, true, originalText)
          } else {
            button.disabled = true
            button.textContent = addToCollectionLabels.adding
          }

          try {
            // Récupérer les détails de la release Discogs
            const releaseResponse = await fetch('/api/discogs/release/' + discogsId)
            if (!releaseResponse.ok) {
              throw new Error(addToCollectionLabels.fetchReleaseError)
            }

            const release = await releaseResponse.json()
            let format = 'VINYL'
            const formatNames = (release.formats && release.formats.map(function(f) { return f.name.toUpperCase() })) || []
            if (formatNames.some(function(n) { return n.includes('CD') })) format = 'CD'
            else if (formatNames.some(function(n) { return n.includes('CASSETTE') })) format = 'CASSETTE'
            const primaryArtist = (release.artists && release.artists[0] && release.artists[0].name) || clientMessages.unknownArtist
            const year = release.year || parseInt(release.released || '0', 10) || null
            function getBestCoverUrl(rd) {
              if (rd.images && rd.images.length > 0) {
                const primaryImage = rd.images.find(function(img) { return img.type === 'primary' }) || rd.images[0]
                return primaryImage.uri || primaryImage.resource_url || null
              }
              return rd.cover_image || rd.thumb || null
            }
            const barcodeVal = null
            if (release.identifiers && release.identifiers.length) {
              const barcodeId = release.identifiers.find(function(id) { return id.type === 'Barcode' })
              if (barcodeId) barcodeVal = barcodeId.value
            }
            const releasePayload = {
              discogsId: release.id,
              title: release.title,
              artist: primaryArtist,
              year,
              genre: (release.genres && release.genres[0]) || (release.styles && release.styles[0]) || null,
              country: release.country || null,
              label: (release.labels && release.labels[0] && release.labels[0].name) || null,
              format,
              barcode: barcodeVal,
              coverUrl: getBestCoverUrl(release),
            }

            const addResponse = await fetch('/api/collections/' + collectionId + '/add-by-discogs', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify(releasePayload),
            })

            if (!addResponse.ok) {
              const error = await addResponse.json()
              throw new Error(error.error || addToCollectionLabels.failedToAddToCollection)
            }

            const result = await addResponse.json()
            const item = result.item
            const alreadyInCollection = result.alreadyInCollection === true

            if (!modal) return
            const redirectOnSuccess = modal.getAttribute('data-redirect-on-success')

            if (window.toast) {
              if (alreadyInCollection) {
                window.toast.info(addToCollectionLabels.alreadyInCollectionToast)
              } else {
                window.toast.success(addToCollectionLabels.addedToCollectionToast)
              }
            }

            if (redirectOnSuccess === 'true' && item && item.slug) {
              modal.classList.add('hidden')
              modal.style.display = ''
              modal.removeAttribute('data-discogs-id')
              modal.removeAttribute('data-redirect-on-success')
              setTimeout(function() {
                window.location.href = '/items/' + item.slug
              }, 500)
            } else {
              // Garder le modal ouvert pour ajouter d'autres albums à des collections
              if (window.setButtonLoading) {
                window.setButtonLoading(button, false)
              } else {
                button.disabled = false
                button.textContent = originalText
              }
            }
          } catch (error) {
            console.error('Error adding to collection:', error)
            if (window.toast) {
              window.toast.error('Error: ' + (error && error.message ? error.message : clientMessages.genericError))
            }
            if (window.setButtonLoading) {
              window.setButtonLoading(button, false)
            } else {
              button.disabled = false
              button.textContent = originalText
            }
          }
        })
      })
    }

    // Attacher les listeners au chargement initial
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', attachButtonListeners)
    } else {
      attachButtonListeners()
    }

    const observer = new MutationObserver(function() {
      if (modal && !modal.classList.contains('hidden')) {
        if (!lastActiveElement && document.activeElement) {
          lastActiveElement = document.activeElement
        }
        const firstInteractive =
          modal.querySelector('.wishlist-add-btn') ||
          modal.querySelector('.collection-add-btn') ||
          modal.querySelector('button')
        if (firstInteractive && typeof firstInteractive.focus === 'function') {
          firstInteractive.focus()
        }

        attachButtonListeners()
      }
    })
    if (modal) {
      observer.observe(modal, { attributes: true, attributeFilter: ['class'], childList: true, subtree: true })
    }
  })()
</script>

<style>
  .add-to-collection-modal:not(.hidden) {
    display: flex;
  }

  .modal-overlay {
    transition: opacity 0.3s ease, backdrop-filter 0.3s ease;
  }

  .modal-content {
    animation: modalSlideIn 0.3s ease-out;
    transform-origin: center;
  }

  @keyframes modalSlideIn {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(-10px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  #add-to-collection-modal:not(.hidden) .modal-overlay {
    animation: fadeIn 0.3s ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>
