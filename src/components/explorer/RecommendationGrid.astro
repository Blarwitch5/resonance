---
import ResultCard from './ResultCard.astro'

type RecommendationGridProps = {
  recommendations: Array<{
    id: number
    title: string
    cover_image?: string
    thumb?: string
    year?: number
  }>
  addToCollectionAria?: string
  addToWishlistAria?: string
  unknownArtistLabel?: string
  scriptLabels?: {
    unknownArtist: string
    addedToWishlistToast: string
    failedToAddToWishlist: string
    fetchReleaseError?: string
    genericError: string
  }
}

const { recommendations, addToCollectionAria, addToWishlistAria, unknownArtistLabel, scriptLabels } = Astro.props as RecommendationGridProps
---

<div class="recommendations-scroll -mx-4 overflow-x-auto px-4 pt-2 pb-6 md:-mx-6 md:px-6 md:pb-7 lg:-mx-8 lg:px-8 lg:pb-8">
  <div class="flex w-max items-stretch gap-4">
    {recommendations.map((result) => (
      <div class="recommendations-scroll-item shrink-0">
        <ResultCard
        result={result}
        addToCollectionAria={addToCollectionAria}
        addToWishlistAria={addToWishlistAria}
        unknownArtistLabel={unknownArtistLabel}
        scriptLabels={scriptLabels}
      />
      </div>
    ))}
  </div>
</div>

<style>
  .recommendations-scroll {
    scroll-behavior: smooth;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
    scrollbar-gutter: stable;
  }
  .recommendations-scroll::-webkit-scrollbar {
    height: 8px;
  }
  .recommendations-scroll::-webkit-scrollbar-track {
    background: transparent;
    margin: 0 0.5rem;
  }
  .recommendations-scroll::-webkit-scrollbar-thumb {
    background-color: var(--color-border);
    border-radius: 4px;
  }

  /* Même hauteur pour toutes les cartes + layout flex pour remplir */
  .recommendations-scroll-item {
    height: 280px;
    width: calc(50vw - 1.5rem);
    min-width: 120px;
    max-width: 160px;
  }
  .recommendations-scroll-item > a {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    transform: none !important;
  }
  .recommendations-scroll-item > a:hover {
    transform: none !important;
  }
  .recommendations-scroll-item > a > div:first-child {
    flex-shrink: 0;
    aspect-ratio: 1;
    width: 100%;
  }
  .recommendations-scroll-item > a > div:first-child img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .recommendations-scroll-item > a > div:nth-child(2) {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media (min-width: 640px) {
    .recommendations-scroll-item {
      height: 300px;
      width: calc(33.333vw - 1.5rem);
      min-width: 140px;
      max-width: 180px;
    }
  }
  @media (min-width: 768px) {
    .recommendations-scroll-item {
      height: 320px;
      width: calc(25vw - 1.5rem);
      min-width: 150px;
      max-width: 200px;
    }
  }
  @media (min-width: 1024px) {
    .recommendations-scroll-item {
      height: 340px;
      width: calc(20vw - 1.25rem);
      min-width: 160px;
      max-width: 220px;
    }
  }
  @media (min-width: 1280px) {
    .recommendations-scroll-item {
      height: 360px;
      width: calc(16.666vw - 1.25rem);
      min-width: 170px;
      max-width: 240px;
    }
  }
</style>

