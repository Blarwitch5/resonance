---
import ResultCard from './ResultCard.astro'

type RecommendationGridProps = {
  recommendations: Array<{
    id: number
    title: string
    cover_image?: string
    thumb?: string
    year?: number
  }>
  wishlistDiscogsIds?: number[]
  addToCollectionAria?: string
  addToWishlistAria?: string
  inWishlistAria?: string
  unknownArtistLabel?: string
  scriptLabels?: {
    unknownArtist: string
    addedToWishlistToast: string
    alreadyInWishlistToast?: string
    failedToAddToWishlist: string
    fetchReleaseError?: string
    genericError: string
  }
}

const {
  recommendations,
  wishlistDiscogsIds = [],
  addToCollectionAria,
  addToWishlistAria,
  inWishlistAria,
  unknownArtistLabel,
  scriptLabels,
} = Astro.props as RecommendationGridProps

const wishlistDiscogsIdSet = new Set(wishlistDiscogsIds)
---

<div class="recommendations-scroll -mx-4 overflow-x-auto px-4 pt-2 pb-6 md:-mx-6 md:px-6 md:pb-7 lg:-mx-8 lg:px-8 lg:pb-8">
  <div class="flex w-max items-stretch gap-3 sm:gap-4">
    {recommendations.map((result) => (
      <div class="recommendations-scroll-item shrink-0">
        <ResultCard
        result={result}
        inWishlist={wishlistDiscogsIdSet.has(result.id)}
        addToCollectionAria={addToCollectionAria}
        addToWishlistAria={addToWishlistAria}
        inWishlistAria={inWishlistAria}
        unknownArtistLabel={unknownArtistLabel}
        scriptLabels={scriptLabels}
      />
      </div>
    ))}
  </div>
</div>

<style>
  .recommendations-scroll {
    scroll-behavior: smooth;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
    scrollbar-gutter: stable;
    scroll-snap-type: none;
    scroll-padding-inline: 0;
  }
  .recommendations-scroll::-webkit-scrollbar {
    height: 8px;
  }
  .recommendations-scroll::-webkit-scrollbar-track {
    background: transparent;
    margin: 0 0.5rem;
  }
  .recommendations-scroll::-webkit-scrollbar-thumb {
    background-color: var(--color-border);
    border-radius: 4px;
  }

  /* Même hauteur pour toutes les cartes + layout flex pour remplir */
  .recommendations-scroll-item {
    height: 256px;
    width: clamp(126px, 36vw, 148px);
    scroll-snap-align: none;
  }
  .recommendations-scroll-item > a {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    transform: none !important;
  }
  .recommendations-scroll-item > a:hover {
    transform: none !important;
  }
  .recommendations-scroll-item > a > div:first-child {
    flex-shrink: 0;
    aspect-ratio: 1;
    width: 100%;
  }
  .recommendations-scroll-item > a > div:first-child img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .recommendations-scroll-item > a > div:nth-child(2) {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media (min-width: 640px) {
    .recommendations-scroll {
      scroll-padding-inline: 1rem;
    }
    .recommendations-scroll-item {
      height: 300px;
      width: clamp(154px, 28vw, 188px);
    }
  }
  @media (min-width: 768px) {
    .recommendations-scroll {
      scroll-snap-type: x proximity;
      scroll-padding-inline: 1.5rem;
    }
    .recommendations-scroll-item {
      height: 328px;
      width: clamp(168px, 22vw, 208px);
      scroll-snap-align: start;
    }
  }
  @media (min-width: 1024px) {
    .recommendations-scroll {
      scroll-padding-inline: 2rem;
    }
    .recommendations-scroll-item {
      height: 344px;
      width: clamp(176px, 18vw, 224px);
    }
  }
  @media (min-width: 1280px) {
    .recommendations-scroll-item {
      height: 360px;
      width: clamp(184px, 15vw, 240px);
    }
  }
</style>

