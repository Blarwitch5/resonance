---
import SearchResultCard from './SearchResultCard.astro'

type SearchResultsGridProps = {
  results: Array<{
    id: string | number
    slug?: string
    title: string
    cover_image?: string
    thumb?: string
    year?: string | number
    format?: string[]
  }>
  addToCollectionAria?: string
  addToWishlistAria?: string
  resultsCountLabel?: string
  noImageLabel?: string
  unknownArtistLabel?: string
  scriptLabels?: {
    unknownArtist: string
    addedToWishlistToast: string
    failedToAddToWishlist: string
    fetchReleaseError?: string
    genericError: string
  }
}

const { results, addToCollectionAria, addToWishlistAria, resultsCountLabel, noImageLabel, unknownArtistLabel, scriptLabels } = Astro.props as SearchResultsGridProps

// Fonction pour vérifier si un format est valide (Vinyl, CD, Cassette)
function isValidFormat(formats: string[] | undefined): boolean {
  if (!formats || formats.length === 0) return false
  
  // Normaliser les formats en majuscules pour la comparaison
  const normalizedFormats = formats.map(format => format.toUpperCase())
  
  // Vérifier si au moins un format est Vinyl, CD, ou Cassette
  const validFormats = ['VINYL', 'CD', 'CASSETTE', 'LP', '12"', '7"', '45 RPM', '33 RPM', 'CASSETTE TAPE', 'COMPACT DISC']
  
  return normalizedFormats.some(format => {
    return validFormats.some(validFormat => format.includes(validFormat))
  })
}

// Filtrer les résultats pour ne garder que les formats valides
const filteredResults = results.filter((item) => {
  return isValidFormat(item.format)
})
---

{filteredResults.length > 0 && (
  <div id="search-results-content">
    <h3 class="mb-4 text-lg font-semibold">{resultsCountLabel != null ? resultsCountLabel.replace('{count}', String(filteredResults.length)) : `${filteredResults.length} results`}</h3>
    <div class="grid grid-cols-2 gap-4 md:grid-cols-4 lg:grid-cols-6">
      {filteredResults.map((result) => (
        <SearchResultCard
          result={result}
          addToCollectionAria={addToCollectionAria}
          addToWishlistAria={addToWishlistAria}
          noImageLabel={noImageLabel}
          unknownArtistLabel={unknownArtistLabel}
          scriptLabels={scriptLabels}
        />
      ))}
    </div>
  </div>
)}
