---
import Search from '@lucide/astro/icons/search'
import Loader from '@lucide/astro/icons/loader'
import { getExplorerMessages } from '../../i18n/explorer'
import type { ExplorerMessages } from '../../i18n/explorer'

type SearchBarProps = {
  search?: ExplorerMessages['search']
  client?: ExplorerMessages['client']
  addToCollection?: ExplorerMessages['addToCollection']
}

const defaultMessages = getExplorerMessages('en')
const { search = defaultMessages.search, client = defaultMessages.client, addToCollection: addToCollectionMessages = defaultMessages.addToCollection } = Astro.props as SearchBarProps
---

<div class="relative">
  <label for="discogs-search" class="sr-only">{search.placeholder}</label>
  <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
    <Search size={20} class="fill-none stroke-2 text-muted stroke-muted" />
  </div>
  <input
    type="text"
    id="discogs-search"
    aria-label={search.placeholder}
    placeholder={search.placeholder}
    class="w-full rounded-xl border border-border bg-surface pl-12 pr-20 py-4 text-neutral placeholder-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50 transition-colors"
  />
  <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none">
    <Loader
      id="search-loader"
      size={20}
      class="text-primary animate-spin hidden"
    />
  </div>
</div>

<!-- Config en base64 pour le script compilé (évite define:vars qui inlinerait du TS non compilé en view transitions) -->
<script type="text/plain" id="search-bar-messages" data-encoding="base64" set:html={Buffer.from(JSON.stringify({ search, client, addToCollectionMessages }), 'utf8').toString('base64')}></script>
<script>
  import './SearchBar.client'
</script>

