---
import { statsService } from '../../services/stats-service'

type ChartsLabels = {
  noData: string
  noDataHint: string
  noDataDevHint: string
  formatBreakdown: string
  formatBreakdownDescription: string
  albumsLabel: string
  topGenres: string
  collectionByDecade: string
  formatBreakdownAria: string
  topGenresAria: string
  collectionByDecadeAria: string
}

const defaultChartsLabels: ChartsLabels = {
  noData: 'No data yet',
  noDataHint: 'Add some items to your collection to see statistics and charts.',
  noDataDevHint: 'Or use the "Seed Test Data" button above to add sample data.',
  formatBreakdown: 'Format Breakdown',
  formatBreakdownDescription: 'Your collection by format: Vinyl, CD, and Cassette.',
  albumsLabel: 'Albums',
  topGenres: 'Top Genres',
  collectionByDecade: 'Collection by Decade',
  formatBreakdownAria: 'Pie chart showing the share of your collection by format: Vinyl, CD, and Cassette.',
  topGenresAria: 'Bar chart showing the most represented genres in your recent collection.',
  collectionByDecadeAria: 'Bar chart showing how many albums you have for each decade.',
}

type StatsChartsProps = {
  userId: string
  chartsLabels?: ChartsLabels
}

const { userId, chartsLabels = defaultChartsLabels } = Astro.props as StatsChartsProps
const charts = chartsLabels

// Récupérer les données pour les graphiques
const formatDistribution = await statsService.getFormatDistribution(userId)
const yearDistribution = await statsService.getYearDistribution(userId)
const genreStats = await statsService.getRecentItemsByGenre(userId, 100)

// Préparer les données pour Chart.js
const formatData = {
  labels: ['Vinyl', 'CD', 'Cassette'],
  data: [formatDistribution.vinyl.count, formatDistribution.cd.count, formatDistribution.cassette.count],
  colors: [
    'rgb(234, 88, 12)', // orange-500 (vinyl)
    'rgb(16, 185, 129)', // emerald-500 (cd)
    'rgb(251, 191, 36)', // amber-400 (cassette)
  ],
}

// Top 10 genres pour le graphique
const topGenres = genreStats.slice(0, 10)
const genreData = {
  labels: topGenres.map((g) => g.genre),
  data: topGenres.map((g) => g.count),
}

// Décennies (trier par décennie croissante pour l'affichage)
const decadesData = yearDistribution
  .sort((a, b) => a.decade - b.decade)
  .slice(-10) // Dernières 10 décennies
const decadesChartData = {
  labels: decadesData.map((d) => `${d.decade}s`),
  data: decadesData.map((d) => d.count),
}
---

<div class="space-y-8">
  <!-- Message si pas de données -->
  {!formatData.data.some((count: number) => count > 0) && genreData.labels.length === 0 && decadesChartData.labels.length === 0 && (
    <div class="glass-card min-w-0 rounded-xl p-6 text-center sm:p-8">
      <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-surface-elevated">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted">
          <path d="M3 3v18h18"></path>
          <path d="M7 12h10"></path>
          <path d="M7 8h10"></path>
          <path d="M7 16h10"></path>
        </svg>
      </div>
      <h3 class="mb-2 text-lg font-semibold text-neutral">{charts.noData}</h3>
      <p class="text-muted mb-4">
        {charts.noDataHint}
      </p>
      {import.meta.env.DEV && (
        <p class="text-sm text-muted">
          {charts.noDataDevHint}
        </p>
      )}
    </div>
  )}

  <!-- Format Breakdown (Pie Chart) -->
  {formatData.data.some((count: number) => count > 0) && (
    <div class="glass-card min-w-0 rounded-xl p-4 sm:p-6">
      <h3 class="mb-2 text-lg font-semibold text-neutral">{charts.formatBreakdown}</h3>
      <p class="mb-4 text-xs text-muted">
        {charts.formatBreakdownDescription}
      </p>
      <div class="relative max-w-full overflow-hidden">
        <div class="flex min-h-[200px] items-center justify-center sm:min-h-[256px]">
          <canvas
            id="format-chart"
            class="max-h-64 w-full max-w-full"
            data-chart={JSON.stringify(formatData)}
            role="img"
            aria-label={charts.formatBreakdownAria}
          ></canvas>
        </div>
      </div>
    </div>
  )}

  <!-- Genre Distribution (Bar Chart) -->
  {genreData.labels.length > 0 && (
    <div class="glass-card min-w-0 rounded-xl p-4 sm:p-6">
      <h3 class="mb-2 text-lg font-semibold text-neutral">{charts.topGenres}</h3>
      <p class="mb-4 text-xs text-muted">
        Your most represented genres based on the last 100 items added.
      </p>
      <div class="relative max-w-full overflow-hidden">
        <div class="flex min-h-[200px] items-center justify-center sm:min-h-[256px]">
          <canvas
            id="genre-chart"
            class="max-h-64 w-full max-w-full"
            data-chart={JSON.stringify(genreData)}
            role="img"
            aria-label={charts.topGenresAria}
          ></canvas>
        </div>
      </div>
    </div>
  )}

  <!-- Decades Distribution (Bar Chart) -->
  {decadesChartData.labels.length > 0 && (
    <div class="glass-card min-w-0 rounded-xl p-4 sm:p-6">
      <h3 class="mb-2 text-lg font-semibold text-neutral">{charts.collectionByDecade}</h3>
      <p class="mb-4 text-xs text-muted">
        How your albums are distributed across decades.
      </p>
      <div class="relative max-w-full overflow-hidden">
        <div class="flex min-h-[200px] items-center justify-center sm:min-h-[256px]">
          <canvas
            id="decades-chart"
            class="max-h-64 w-full max-w-full"
            data-chart={JSON.stringify(decadesChartData)}
            role="img"
            aria-label={charts.collectionByDecadeAria}
          ></canvas>
        </div>
      </div>
    </div>
  )}
</div>

<script type="application/json" id="stats-charts-labels" set:html={JSON.stringify({ albumsLabel: charts.albumsLabel })}></script>

<!-- Load Chart.js and initialize charts -->
<script>
  const chartInstances = new Map()
  const labelsEl = document.getElementById('stats-charts-labels')
  const chartsLabels = labelsEl ? JSON.parse(labelsEl.textContent || '{}') : {}
  const albumsLabel = chartsLabels.albumsLabel || 'Albums'

  async function loadCharts() {
    try {
      // Import Chart.js/auto which auto-registers all components
      const { Chart } = await import('chart.js/auto')

      // Format Pie Chart
      const formatCanvas = document.querySelector<HTMLCanvasElement>('#format-chart')
      if (formatCanvas) {
        // Destroy existing chart if it exists
        if (chartInstances.has('format-chart')) {
          chartInstances.get('format-chart').destroy()
          chartInstances.delete('format-chart')
        }

        const formatData = JSON.parse(formatCanvas.getAttribute('data-chart') || '{}')
        if (formatData && formatData.data && formatData.data.some((count: number) => count > 0)) {
          const chart = new Chart(formatCanvas, {
            type: 'pie',
            data: {
              labels: formatData.labels || [],
              datasets: [
                {
                  data: formatData.data || [],
                  backgroundColor: formatData.colors || [],
                  borderColor: 'rgba(255, 255, 255, 0.1)',
                  borderWidth: 2,
                },
              ],
            },
            options: {
              responsive: true,
              maintainAspectRatio: true,
              plugins: {
                legend: {
                  position: 'bottom',
                  labels: {
                    color: getComputedStyle(document.documentElement).getPropertyValue('--color-neutral') || '#fff',
                    padding: 15,
                    font: { size: 12 },
                  },
                },
                tooltip: {
                  backgroundColor: 'rgba(0, 0, 0, 0.8)',
                  titleColor: '#fff',
                  bodyColor: '#fff',
                  padding: 12,
                },
              },
            },
          })
          chartInstances.set('format-chart', chart)
        }
      }

      // Genre Bar Chart
      const genreCanvas = document.querySelector<HTMLCanvasElement>('#genre-chart')
      if (genreCanvas) {
        // Destroy existing chart if it exists
        if (chartInstances.has('genre-chart')) {
          chartInstances.get('genre-chart').destroy()
          chartInstances.delete('genre-chart')
        }

        const genreData = JSON.parse(genreCanvas.getAttribute('data-chart') || '{}')
        if (genreData && genreData.labels && genreData.labels.length > 0) {
          const chart = new Chart(genreCanvas, {
            type: 'bar',
            data: {
              labels: genreData.labels || [],
              datasets: [
                {
                  label: albumsLabel,
                  data: genreData.data || [],
                  backgroundColor: 'rgba(234, 88, 12, 0.6)',
                  borderColor: 'rgb(234, 88, 12)',
                  borderWidth: 1,
                },
              ],
            },
            options: {
              responsive: true,
              maintainAspectRatio: true,
              scales: {
                y: {
                  beginAtZero: true,
                  ticks: {
                    color: getComputedStyle(document.documentElement).getPropertyValue('--color-muted') || '#999',
                    stepSize: 1,
                  },
                  grid: { color: 'rgba(255, 255, 255, 0.05)' },
                },
                x: {
                  ticks: {
                    color: getComputedStyle(document.documentElement).getPropertyValue('--color-muted') || '#999',
                    maxRotation: 45,
                    minRotation: 45,
                  },
                  grid: { display: false },
                },
              },
              plugins: {
                legend: { display: false },
                tooltip: {
                  backgroundColor: 'rgba(0, 0, 0, 0.8)',
                  titleColor: '#fff',
                  bodyColor: '#fff',
                  padding: 12,
                },
              },
            },
          })
          chartInstances.set('genre-chart', chart)
        }
      }

      // Decades Bar Chart
      const decadesCanvas = document.querySelector<HTMLCanvasElement>('#decades-chart')
      if (decadesCanvas) {
        // Destroy existing chart if it exists
        if (chartInstances.has('decades-chart')) {
          chartInstances.get('decades-chart').destroy()
          chartInstances.delete('decades-chart')
        }

        const decadesData = JSON.parse(decadesCanvas.getAttribute('data-chart') || '{}')
        if (decadesData && decadesData.labels && decadesData.labels.length > 0) {
          const chart = new Chart(decadesCanvas, {
            type: 'bar',
            data: {
              labels: decadesData.labels || [],
              datasets: [
                {
                  label: albumsLabel,
                  data: decadesData.data || [],
                  backgroundColor: 'rgba(16, 185, 129, 0.6)',
                  borderColor: 'rgb(16, 185, 129)',
                  borderWidth: 1,
                },
              ],
            },
            options: {
              responsive: true,
              maintainAspectRatio: true,
              scales: {
                y: {
                  beginAtZero: true,
                  ticks: {
                    color: getComputedStyle(document.documentElement).getPropertyValue('--color-muted') || '#999',
                    stepSize: 1,
                  },
                  grid: { color: 'rgba(255, 255, 255, 0.05)' },
                },
                x: {
                  ticks: {
                    color: getComputedStyle(document.documentElement).getPropertyValue('--color-muted') || '#999',
                  },
                  grid: { display: false },
                },
              },
              plugins: {
                legend: { display: false },
                tooltip: {
                  backgroundColor: 'rgba(0, 0, 0, 0.8)',
                  titleColor: '#fff',
                  bodyColor: '#fff',
                  padding: 12,
                },
              },
            },
          })
          chartInstances.set('decades-chart', chart)
        }
      }
    } catch (error) {
      console.error('Error loading Chart.js:', error)
    }
  }

  function scheduleLoadCharts() {
    requestAnimationFrame(() => {
      setTimeout(loadCharts, 50)
    })
  }

  document.addEventListener('profile-tab-statistics-visible', scheduleLoadCharts)

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      const params = new URLSearchParams(window.location.search)
      if (params.get('tab') === 'statistics') scheduleLoadCharts()
    })
  } else {
    const params = new URLSearchParams(window.location.search)
    if (params.get('tab') === 'statistics') scheduleLoadCharts()
  }

  document.addEventListener('astro:page-load', () => {
    const params = new URLSearchParams(window.location.search)
    if (params.get('tab') === 'statistics') scheduleLoadCharts()
  })
</script>

