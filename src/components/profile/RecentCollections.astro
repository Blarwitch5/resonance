---
import Folder from '@lucide/astro/icons/folder'
import { collectionRepository } from '../../repositories/collection-repository'
import CollectionCard from '../collections/CollectionCard.astro'
import EmptyState from '../ui/EmptyState.astro'

type RecentCollectionsLabels = {
  emptyTitle: string
  emptyDescription: string
  createAction: string
}

type RecentCollectionsProps = {
  userId: string
  labels?: RecentCollectionsLabels
}

const defaultLabels: RecentCollectionsLabels = {
  emptyTitle: 'No collections yet',
  emptyDescription: 'Create your first collection to organize and group your albums by theme, genre, or era.',
  createAction: 'Create a collection',
}

const { userId, labels = defaultLabels } = Astro.props as RecentCollectionsProps
const collections = await collectionRepository.getRecentCollections(userId, 10)
---

<div class="min-w-0 space-y-6">
  {collections.length === 0 ? (
    <EmptyState
      title={labels.emptyTitle}
      description={labels.emptyDescription}
      icon={Folder}
      action={{
        label: labels.createAction,
        href: '/collections/new',
      }}
      size="sm"
    />
  ) : (
    <div class="grid min-w-0 grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {collections.map((collection) => (
        <CollectionCard collection={collection} />
      ))}
    </div>
  )}
</div>

