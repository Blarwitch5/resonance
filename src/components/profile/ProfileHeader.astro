---
import Settings from '@lucide/astro/icons/settings'
import type { User } from '@prisma/client'
import Avatar from '../ui/Avatar.astro'

type ProfileHeaderProps = {
  user: User
  settingsLabel: string
  stats: {
    totalItems: number
    vinyls: number
    cds: number
    cassettes: number
  }
}

const { user, stats, settingsLabel } = Astro.props as ProfileHeaderProps

// Générer gradient basé sur les formats de la collection
type StatsType = {
  totalItems: number
  vinyls: number
  cds: number
  cassettes: number
}
function generateGradient(stats: StatsType) {
  const colors = []
  if (stats.vinyls > 0) colors.push('oklch(0.55 0.25 280)') // violet
  if (stats.cassettes > 0) colors.push('oklch(0.65 0.15 45)') // cuivre
  if (stats.cds > 0) colors.push('oklch(0.85 0.02 280)') // gris-bleu

  return colors.length > 0
    ? `linear-gradient(135deg, ${colors.join(', ')})`
    : 'linear-gradient(135deg, oklch(0.55 0.25 280), oklch(0.65 0.15 45))'
}

const gradientBg = generateGradient(stats)
const hasUserImage = !!user.imageUrl && user.imageUrl.trim() !== ''
---

<header class="glass-card relative overflow-hidden rounded-2xl">
  <!-- Gradient background -->
  <div
    class="absolute inset-0 opacity-10"
    style={`background: ${gradientBg}`}
    aria-hidden="true"
  ></div>

  <div class="relative p-4 sm:p-6 md:p-8">
    <div class="flex min-w-0 flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <!-- Avatar + Info -->
      <div class="flex min-w-0 shrink-0 grow-0 items-center gap-4 sm:gap-6">
        <div class="relative shrink-0">
          <Avatar
            userName={user.name}
            userEmail={user.email}
            imageUrl={user.imageUrl}
            size="2xl"
            class="rounded-2xl"
          />
          <!-- Pulse uniquement sans image utilisateur -->
          {!hasUserImage && stats.totalItems > 0 && (
            <div
              class="animate-resonance-pulse absolute -inset-2 rounded-2xl opacity-20"
              style={`background: ${gradientBg}`}
              aria-hidden="true"
            ></div>
          )}
        </div>

        <div class="min-w-0 flex-1">
          <h1 class="truncate text-2xl font-bold text-neutral sm:text-3xl" title={user.name || user.email.split('@')[0]}>
            {user.name || user.email.split('@')[0]}
          </h1>
          <p class="truncate text-muted" title={user.email}>{user.email}</p>
          <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-sm">
            <span>{stats.totalItems} albums</span>
            <span class="text-muted">•</span>
            <span>
              Membre depuis{' '}
              {new Date(user.createdAt).toLocaleDateString('fr-FR', {
                month: 'long',
                year: 'numeric',
              })}
            </span>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex shrink-0 gap-3">
        <a
          href="/settings"
          class="btn-secondary-surface flex items-center gap-2 rounded-lg px-4 py-2"
        >
          <Settings size={20} />
          <span class="hidden sm:inline">{settingsLabel}</span>
        </a>
      </div>
    </div>
  </div>
</header>

