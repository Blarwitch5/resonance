---
import Settings from '@lucide/astro/icons/settings'
import UserPlus from '@lucide/astro/icons/user-plus'
import UserMinus from '@lucide/astro/icons/user-minus'
import type { User } from '@prisma/client'
import Avatar from '../ui/Avatar.astro'

type ProfileStats = {
  totalItems: number
  totalLists: number
  followerCount: number
  followingCount: number
  dominantFormat: { name: string; percentage: number } | null
  averageRating: number | null
}

type ProfileHeaderProps = {
  profileUser: User
  stats: ProfileStats
  isOwnProfile: boolean
  isFollowing: boolean
}

const { profileUser, stats, isOwnProfile, isFollowing } = Astro.props as ProfileHeaderProps

const displayName = profileUser.name || profileUser.username
---

<header class="glass-card relative overflow-hidden rounded-2xl p-5 sm:p-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">

    <!-- Avatar + identité -->
    <div class="flex items-center gap-4">
      <Avatar
        userName={profileUser.name}
        userEmail={profileUser.email}
        imageUrl={profileUser.imageUrl}
        size="2xl"
        class="rounded-2xl shrink-0"
      />
      <div class="min-w-0">
        <h1 class="truncate text-xl font-bold text-neutral sm:text-2xl">{displayName}</h1>
        <p class="text-sm text-muted">@{profileUser.username}</p>
        {profileUser.bio && (
          <p class="mt-1 text-sm text-neutral line-clamp-2">{profileUser.bio}</p>
        )}
      </div>
    </div>

    <!-- Actions -->
    <div class="flex shrink-0 gap-2">
      {isOwnProfile ? (
        <a
          href="/settings"
          class="inline-flex items-center gap-2 rounded-xl border border-border bg-surface-elevated px-4 py-2 text-sm font-medium text-neutral transition-colors hover:bg-primary/10 hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50"
        >
          <Settings size={16} class="stroke-2 shrink-0" />
          Paramètres
        </a>
      ) : (
        <button
          type="button"
          id="follow-btn"
          class={`inline-flex items-center gap-2 rounded-xl px-4 py-2 text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 ${
            isFollowing
              ? 'border border-border bg-surface-elevated text-neutral hover:border-red-500/50 hover:text-red-500'
              : 'bg-primary text-white hover:bg-primary/90'
          }`}
          data-target-username={profileUser.username}
          data-is-following={isFollowing ? 'true' : 'false'}
          aria-pressed={isFollowing ? 'true' : 'false'}
        >
          {isFollowing ? (
            <>
              <UserMinus size={16} class="stroke-2 shrink-0" />
              <span>Abonné</span>
            </>
          ) : (
            <>
              <UserPlus size={16} class="stroke-2 shrink-0" />
              <span>Suivre</span>
            </>
          )}
        </button>
      )}
    </div>
  </div>

  <!-- Stats row -->
  <div class="mt-5 grid grid-cols-3 gap-3 border-t border-border pt-5 sm:grid-cols-6">
    <div class="text-center">
      <p class="text-lg font-bold text-neutral">{stats.totalItems}</p>
      <p class="text-xs text-muted">Albums</p>
    </div>
    <div class="text-center">
      <p class="text-lg font-bold text-neutral">{stats.totalLists}</p>
      <p class="text-xs text-muted">Listes</p>
    </div>
    <div class="text-center">
      <p class="text-lg font-bold text-neutral">{stats.averageRating ?? '—'}</p>
      <p class="text-xs text-muted">Note moy.</p>
    </div>
    <div class="text-center">
      <p class="text-lg font-bold text-neutral">
        {stats.dominantFormat ? `${stats.dominantFormat.name} ${stats.dominantFormat.percentage}%` : '—'}
      </p>
      <p class="text-xs text-muted">Format</p>
    </div>
    <div class="text-center">
      <p class="text-lg font-bold text-neutral" id="follower-count">{stats.followerCount}</p>
      <p class="text-xs text-muted">Abonnés</p>
    </div>
    <div class="text-center">
      <p class="text-lg font-bold text-neutral">{stats.followingCount}</p>
      <p class="text-xs text-muted">Abonnements</p>
    </div>
  </div>
</header>

<script>
  import { onAstroPageLoad, onDomReady } from '../../scripts/client/runtime'

  function initFollowButton(): void {
    const followButton = document.getElementById('follow-btn')
    if (!(followButton instanceof HTMLButtonElement)) return

    followButton.addEventListener('click', async () => {
      const targetUsername = followButton.dataset.targetUsername
      if (!targetUsername) return

      const isCurrentlyFollowing = followButton.dataset.isFollowing === 'true'

      followButton.disabled = true

      try {
        const response = await fetch(`/api/users/${targetUsername}/follow`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
        })

        if (!response.ok) throw new Error('Follow request failed')

        const data = (await response.json()) as { following: boolean }
        const isNowFollowing = data.following

        // Mettre à jour l'état du bouton
        followButton.dataset.isFollowing = isNowFollowing ? 'true' : 'false'
        followButton.setAttribute('aria-pressed', isNowFollowing ? 'true' : 'false')

        // Mettre à jour le contenu du bouton
        const userMinusIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="22" x2="16" y1="11" y2="11"/></svg>'
        const userPlusIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>'

        followButton.innerHTML = isNowFollowing
          ? `${userMinusIcon}<span>Abonné</span>`
          : `${userPlusIcon}<span>Suivre</span>`

        // Mettre à jour les classes
        followButton.className = followButton.className
          .replace(/border border-border bg-surface-elevated text-neutral hover:border-red-500\/50 hover:text-red-500|bg-primary text-white hover:bg-primary\/90/g, '')
          .trim()

        if (isNowFollowing) {
          followButton.classList.add('border', 'border-border', 'bg-surface-elevated', 'text-neutral', 'hover:border-red-500/50', 'hover:text-red-500')
        } else {
          followButton.classList.add('bg-primary', 'text-white', 'hover:bg-primary/90')
        }

        // Mettre à jour le compteur d'abonnés
        const followerCountEl = document.getElementById('follower-count')
        if (followerCountEl) {
          const currentCount = Number.parseInt(followerCountEl.textContent ?? '0')
          followerCountEl.textContent = String(isNowFollowing ? currentCount + 1 : currentCount - 1)
        }
      } catch {
        // Silently revert — le bouton reprend son état initial
      } finally {
        followButton.disabled = false
      }
    })
  }

  onDomReady(initFollowButton)
  onAstroPageLoad(initFollowButton)
</script>
