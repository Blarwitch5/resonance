---
// Composant pour l'import/export de collections
type ImportExportLabels = {
  title: string
  description: string
  exportButton: string
  importButton: string
  exporting: string
  exportSuccess: string
  exportError: string
  importing: string
  importSuccess: string
  importError: string
}

const defaultLabels: ImportExportLabels = {
  title: 'Import / Export',
  description: 'Export your collections and items as JSON, or import them from a backup file.',
  exportButton: 'Export Collections',
  importButton: 'Import Collections',
  exporting: 'Exporting...',
  exportSuccess: 'Collections exported successfully!',
  exportError: 'Failed to export collections',
  importing: 'Importing collections...',
  importSuccess: 'Import completed! {collectionsCreated} collections created, {itemsCreated} items imported, {itemsSkipped} items skipped.',
  importError: 'Failed to import collections',
}

type ImportExportProps = {
  labels?: ImportExportLabels
}

const { labels = defaultLabels } = Astro.props as ImportExportProps
---

<div class="glass-card min-w-0 rounded-xl p-4 sm:p-6 border-2 border-emerald-500/20">
  <h3 class="mb-4 text-lg font-semibold text-neutral">{labels.title}</h3>
  <p class="mb-6 text-sm text-muted">
    {labels.description}
  </p>

  <div class="flex flex-col gap-4 sm:flex-row">
    <!-- Export : icône upload (flèche haut), pas de fill blanc -->
    <button
      id="export-btn"
      type="button"
      class="btn-primary-gradient flex-1 py-3 px-4 rounded-lg flex items-center justify-center gap-2"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="shrink-0 fill-none stroke-currentColor"
        aria-hidden="true"
      >
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="17 8 12 3 7 8"></polyline>
        <line x1="12" y1="3" x2="12" y2="15"></line>
      </svg>
      {labels.exportButton}
    </button>

    <!-- Import : icône download (flèche bas) -->
    <label
      for="import-file"
      class="btn-secondary-surface flex-1 py-3 px-4 rounded-lg flex items-center justify-center gap-2 cursor-pointer"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="shrink-0"
        aria-hidden="true"
      >
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
      </svg>
      {labels.importButton}
      <input
        type="file"
        id="import-file"
        accept=".json"
        class="hidden"
      />
    </label>
  </div>
</div>

<script type="application/json" id="import-export-messages" set:html={JSON.stringify({
  exporting: labels.exporting,
  exportSuccess: labels.exportSuccess,
  exportError: labels.exportError,
  importing: labels.importing,
  importSuccess: labels.importSuccess,
  importError: labels.importError,
})}></script>

<script>
  import './ImportExport.client'
</script>
