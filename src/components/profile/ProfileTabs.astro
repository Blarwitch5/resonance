---
import Heart from '@lucide/astro/icons/heart'
import Bookmark from '@lucide/astro/icons/bookmark'
import BarChart from '@lucide/astro/icons/chart-bar'
import Library from '@lucide/astro/icons/library'
import type { ComponentProps } from 'astro/types'

type ProfileTabsProps = {
  activeTab?: string
  slot?: string
  tabsAriaLabel?: string
  favoritesLabel?: string
  wishlistLabel?: string
  statisticsLabel?: string
  allFormatsLabel?: string
}

const {
  activeTab = 'favorites',
  slot: defaultSlot,
  tabsAriaLabel = 'Profile sections',
  favoritesLabel = 'Favorites',
  wishlistLabel = 'Wishlist',
  statisticsLabel = 'Statistics',
  allFormatsLabel = 'All Formats',
} = Astro.props as ProfileTabsProps
---

<div class="min-w-0 space-y-6">
  <!-- Tabs -->
  <div class="border-b border-border pb-0">
    <div
      id="profile-tablist"
      class="flex min-w-0 gap-2 overflow-x-auto px-4 -mx-4 pb-1 no-scrollbar snap-x snap-mandatory md:mx-0 md:px-0 md:overflow-visible md:snap-none"
      role="tablist"
      aria-label={tabsAriaLabel}
    >
      <button
        type="button"
        data-tab="favorites"
        class="tab-btn flex shrink-0 items-center gap-2 rounded-full border border-transparent px-4 py-2 text-sm font-medium transition-all hover:bg-surface hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-background md:rounded-t-lg md:border-b-2 md:border-b-transparent md:border-none md:px-6 md:py-3"
        role="tab"
        id="tab-favorites"
        aria-controls="panel-favorites"
        aria-selected="false"
        tabindex="-1"
      >
        <Heart size={18} class="fill-none stroke-2" />
        <span>{favoritesLabel}</span>
      </button>

      <button
        type="button"
        data-tab="wishlist"
        class="tab-btn flex shrink-0 items-center gap-2 rounded-full border border-transparent px-4 py-2 text-sm font-medium transition-all hover:bg-surface hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-background md:rounded-t-lg md:border-b-2 md:border-b-transparent md:border-none md:px-6 md:py-3"
        role="tab"
        id="tab-wishlist"
        aria-controls="panel-wishlist"
        aria-selected="false"
        tabindex="-1"
      >
        <Bookmark size={18} class="fill-none stroke-2" />
        <span>{wishlistLabel}</span>
      </button>

      <button
        type="button"
        data-tab="statistics"
        class="tab-btn flex shrink-0 items-center gap-2 rounded-full border border-transparent px-4 py-2 text-sm font-medium transition-all hover:bg-surface hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-background md:rounded-t-lg md:border-b-2 md:border-b-transparent md:border-none md:px-6 md:py-3"
        role="tab"
        id="tab-statistics"
        aria-controls="panel-statistics"
        aria-selected="false"
        tabindex="-1"
      >
        <BarChart size={18} class="fill-none stroke-2" />
        <span>{statisticsLabel}</span>
      </button>

      <button
        type="button"
        data-tab="all-formats"
        class="tab-btn flex shrink-0 items-center gap-2 rounded-full border border-transparent px-4 py-2 text-sm font-medium transition-all hover:bg-surface hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-background md:rounded-t-lg md:border-b-2 md:border-b-transparent md:border-none md:px-6 md:py-3"
        role="tab"
        id="tab-all-formats"
        aria-controls="panel-all-formats"
        aria-selected="false"
        tabindex="-1"
      >
        <Library size={18} class="fill-none stroke-2" />
        <span>{allFormatsLabel}</span>
      </button>
    </div>
  </div>

  <!-- Tab content -->
  <div id="tab-content" class="min-w-0">
    <div
      id="panel-favorites"
      data-tab-content="favorites"
      role="tabpanel"
      aria-labelledby="tab-favorites"
      tabindex="0"
      style="display: none;"
    >
      <slot name="favorites" />
    </div>
    <div
      id="panel-wishlist"
      data-tab-content="wishlist"
      role="tabpanel"
      aria-labelledby="tab-wishlist"
      tabindex="0"
      style="display: none;"
    >
      <slot name="wishlist" />
    </div>
    <div
      id="panel-statistics"
      data-tab-content="statistics"
      role="tabpanel"
      aria-labelledby="tab-statistics"
      tabindex="0"
      style="display: none;"
    >
      <slot name="statistics" />
    </div>
    <div
      id="panel-all-formats"
      data-tab-content="all-formats"
      role="tabpanel"
      aria-labelledby="tab-all-formats"
      tabindex="0"
      style="display: none;"
    >
      <slot name="all-formats" />
    </div>
  </div>
</div>

<script>
  import './ProfileTabs.client'
</script>

<style>
  .tab-btn {
    color: var(--color-muted);
  }
  
  .tab-btn.active {
    border-bottom-color: var(--color-primary) !important;
    color: var(--color-primary);
    background-color: transparent;
  }
  
  .tab-btn:hover {
    background-color: var(--color-surface);
  }
  
  .tab-btn.active:hover {
    background-color: transparent;
  }
  
  .tab-btn svg {
    fill: none;
    stroke-width: 2;
    stroke: currentColor;
  }
  
  .tab-btn.active svg {
    stroke: var(--color-primary);
  }
  
  /* Amélioration desktop pour les tabs */
  @media (min-width: 768px) {
    .tab-btn {
      padding: 0.75rem 1.5rem;
    }
    
    .tab-btn:hover {
      background-color: var(--color-surface);
    }
  }
  
  /* Cacher tous les slots par défaut */
  #tab-content > [data-tab-content],
  #tab-content > [slot] {
    display: none;
  }
  
  /* Afficher le slot actif */
  #tab-content > [data-tab-content].active,
  #tab-content > [slot].active {
    display: block !important;
  }
  
  /* Fallback: afficher le premier slot (favorites) par défaut si le script ne s'exécute pas */
  #tab-content > [data-tab-content="favorites"]:not(.active),
  #tab-content > [slot="favorites"]:not(.active) {
    display: block;
  }
</style>

