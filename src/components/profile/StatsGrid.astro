---
import CassetteTape from '@lucide/astro/icons/cassette-tape'
import Disc from '@lucide/astro/icons/disc'
import Heart from '@lucide/astro/icons/heart'
import Music4 from '@lucide/astro/icons/music-4'
import Turntable from '@lucide/astro/icons/turntable'
import Users from '@lucide/astro/icons/users'

type StatsGridProps = {
  stats: {
    totalItems: number
    vinyls: number
    cds: number
    cassettes: number
    favorites: number
    genres: number
    artists?: number
  }
}

const { stats } = Astro.props as StatsGridProps
---

<div class="grid min-w-0 grid-cols-2 gap-3 sm:gap-4 md:grid-cols-3 lg:grid-cols-6">
  <!-- Total albums -->
  <div class="glass-card rounded-xl p-4 text-center">
    <div
      class="bg-gradient-resonance-subtle mx-auto mb-2 flex h-10 w-10 items-center justify-center rounded-lg"
    >
      <Music4 size={20} class="text-primary" />
    </div>
    <div class="text-2xl font-bold text-neutral">{stats.totalItems}</div>
    <div class="text-xs text-muted">Albums</div>
  </div>

  <!-- Vinyls -->
  <div class="glass-card rounded-xl p-4 text-center">
    <div
      class="bg-gradient-resonance-subtle mx-auto mb-2 flex h-10 w-10 items-center justify-center rounded-lg"
    >
      <Turntable size={20} class="fill-none stroke-2 text-format-vinyl stroke-format-vinyl" />
    </div>
    <div class="text-2xl font-bold text-format-vinyl">{stats.vinyls}</div>
    <div class="text-xs text-muted">Vinyls</div>
  </div>

  <!-- Cassettes -->
  <div class="glass-card rounded-xl p-4 text-center">
    <div
      class="bg-gradient-resonance-subtle mx-auto mb-2 flex h-10 w-10 items-center justify-center rounded-lg"
    >
      <CassetteTape size={20} class="fill-none stroke-2 text-format-cassette stroke-format-cassette" />
    </div>
    <div class="text-2xl font-bold text-format-cassette">{stats.cassettes}</div>
    <div class="text-xs text-muted">Cassettes</div>
  </div>

  <!-- CDs -->
  <div class="glass-card rounded-xl p-4 text-center">
    <div
      class="bg-gradient-resonance-subtle mx-auto mb-2 flex h-10 w-10 items-center justify-center rounded-lg"
    >
      <Disc size={20} class="fill-none stroke-2 text-format-cd stroke-format-cd" />
    </div>
    <div class="text-2xl font-bold text-format-cd">{stats.cds}</div>
    <div class="text-xs text-muted">CDs</div>
  </div>

  <!-- Favoris -->
  <div class="glass-card rounded-xl p-4 text-center">
    <div
      class="bg-gradient-resonance-subtle mx-auto mb-2 flex h-10 w-10 items-center justify-center rounded-lg"
    >
      <Heart size={20} class="fill-none stroke-2 text-red-500 stroke-red-500" />
    </div>
    <div class="text-2xl font-bold text-red-500">{stats.favorites}</div>
    <div class="text-xs text-muted">Favoris</div>
  </div>

  <!-- Genres -->
  <div class="glass-card rounded-xl p-4 text-center">
    <div
      class="bg-gradient-resonance-subtle mx-auto mb-2 flex h-10 w-10 items-center justify-center rounded-lg"
    >
      <Users size={20} class="fill-none stroke-2 text-secondary stroke-secondary" />
    </div>
    <div class="text-2xl font-bold text-secondary">{stats.genres}</div>
    <div class="text-xs text-muted">Genres</div>
  </div>
</div>

<style>
  .glass-card {
    transition: all 0.3s ease;
  }

  .glass-card:hover {
    transform: translateY(-4px);
  }
</style>

