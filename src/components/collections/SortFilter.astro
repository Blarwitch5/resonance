---
// Component for advanced sorting and filters
import ArrowUpDown from '@lucide/astro/icons/arrow-up-down'
import Funnel from '@lucide/astro/icons/funnel'
import X from '@lucide/astro/icons/x'
import Heart from '@lucide/astro/icons/heart'
import Calendar from '@lucide/astro/icons/calendar'
import Music from '@lucide/astro/icons/music'
import Folder from '@lucide/astro/icons/folder'

type SortOption = 'addedAt-desc' | 'addedAt-asc' | 'title-asc' | 'title-desc' | 'artist-asc' | 'artist-desc' | 'year-desc' | 'year-asc'

const currentSort = (Astro.url.searchParams.get('sort') || 'addedAt-desc') as SortOption
const currentGenre = Astro.url.searchParams.get('genre') || ''
const currentYear = Astro.url.searchParams.get('year') || ''
const currentCollection = Astro.url.searchParams.get('collection') || ''
const showFavorites = Astro.url.searchParams.get('favorites') === 'true'
const isUncategorizedFilter = currentCollection === 'none'

type SortFilterLabels = {
  title: string
  description: string
  clearAll: string
  clearAllTitle: string
  sortBy: string
  sortAddedAtDesc: string
  sortAddedAtAsc: string
  sortTitleAsc: string
  sortTitleDesc: string
  sortArtistAsc: string
  sortArtistDesc: string
  sortYearDesc: string
  sortYearAsc: string
  genre: string
  allGenres: string
  year: string
  allYears: string
  collection: string
  allCollections: string
  uncategorized: string
  collectionFallback: string
  favoritesOnly: string
  favoritesOnlyDescription: string
}

const defaultSortFilter: SortFilterLabels = {
  title: 'Filters and sort',
  description: 'Organize your collection',
  clearAll: 'Clear',
  clearAllTitle: 'Clear all filters',
  sortBy: 'Sort by',
  sortAddedAtDesc: 'Recently added',
  sortAddedAtAsc: 'Oldest first',
  sortTitleAsc: 'Title A-Z',
  sortTitleDesc: 'Title Z-A',
  sortArtistAsc: 'Artist A-Z',
  sortArtistDesc: 'Artist Z-A',
  sortYearDesc: 'Newest year',
  sortYearAsc: 'Oldest year',
  genre: 'Genre',
  allGenres: 'All genres',
  year: 'Year',
  allYears: 'All years',
  collection: 'Collection',
  allCollections: 'All collections',
  uncategorized: 'Uncategorized',
  collectionFallback: 'Collection',
  favoritesOnly: 'Favorites only',
  favoritesOnlyDescription: 'Show only your favorites',
}

type SortFilterProps = {
  genres?: string[]
  years?: number[]
  collections?: Array<{ id: string; name: string }>
  sortFilter?: SortFilterLabels
}

const { genres = [], years = [], collections = [], sortFilter: sortFilterLabels = defaultSortFilter } = Astro.props as SortFilterProps
const sortFilter = sortFilterLabels

const sortOptions: Array<{ value: SortOption; labelKey: keyof SortFilterLabels }> = [
  { value: 'addedAt-desc', labelKey: 'sortAddedAtDesc' },
  { value: 'addedAt-asc', labelKey: 'sortAddedAtAsc' },
  { value: 'title-asc', labelKey: 'sortTitleAsc' },
  { value: 'title-desc', labelKey: 'sortTitleDesc' },
  { value: 'artist-asc', labelKey: 'sortArtistAsc' },
  { value: 'artist-desc', labelKey: 'sortArtistDesc' },
  { value: 'year-desc', labelKey: 'sortYearDesc' },
  { value: 'year-asc', labelKey: 'sortYearAsc' },
]

const hasActiveFilters = currentGenre || currentYear || currentCollection || showFavorites

function buildUrl(params: Record<string, string | null>) {
  const url = new URL(Astro.url)
  // Preserve format if it exists
  const format = url.searchParams.get('format') || 'ALL'
  
  Object.entries(params).forEach(([key, value]) => {
    if (value) {
      url.searchParams.set(key, value)
    } else {
      url.searchParams.delete(key)
    }
  })
  
  // Preserve format
  if (format) {
    url.searchParams.set('format', format)
  }
  
  // Reset to page 1 when filters change
  url.searchParams.set('page', '1')
  return url.pathname + url.search
}
---

<div class="glass-card rounded-2xl border border-border p-5">
  <div class="flex flex-col gap-6">
    <!-- Header with active filter badges -->
    <div class="flex flex-wrap items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
          <Funnel size={20} class="fill-none stroke-2 text-primary stroke-primary" />
        </div>
        <div>
          <h3 class="text-sm font-semibold text-neutral">{sortFilter.title}</h3>
          <p class="text-xs text-muted">{sortFilter.description}</p>
        </div>
      </div>

      <!-- Active filter badges -->
      {hasActiveFilters && (
        <div class="flex flex-wrap items-center gap-2">
          {currentGenre && (
            <span class="inline-flex items-center gap-1.5 rounded-full bg-primary/20 px-3 py-1 text-xs font-medium text-primary">
              <Music size={12} />
              {currentGenre}
            </span>
          )}
          {currentYear && (
            <span class="inline-flex items-center gap-1.5 rounded-full bg-primary/20 px-3 py-1 text-xs font-medium text-primary">
              <Calendar size={12} />
              {currentYear}
            </span>
          )}
          {currentCollection && (
            <span class="inline-flex items-center gap-1.5 rounded-full bg-primary/20 px-3 py-1 text-xs font-medium text-primary">
              <Folder size={12} />
              {isUncategorizedFilter ? sortFilter.uncategorized : collections.find((c) => c.id === currentCollection)?.name || sortFilter.collectionFallback}
            </span>
          )}
          {showFavorites && (
            <span class="inline-flex items-center gap-1.5 rounded-full bg-primary/20 px-3 py-1 text-xs font-medium text-primary">
              <Heart size={12} />
              {sortFilter.favoritesOnly}
            </span>
          )}
          <a
            href={buildUrl({ genre: null, year: null, collection: null, favorites: null })}
            class="inline-flex min-h-9 items-center gap-1 rounded-full bg-surface-elevated px-3 py-1 text-xs font-medium text-muted transition-colors hover:bg-surface hover:text-neutral focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/60 focus-visible:ring-offset-2 focus-visible:ring-offset-surface"
            title={sortFilter.clearAllTitle}
          >
            <X size={12} />
            {sortFilter.clearAll}
          </a>
        </div>
      )}
    </div>

    <!-- Sorting and filter controls -->
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Sort -->
      <div class="flex flex-col gap-2">
        <label for="sort-select" class="flex items-center gap-2 text-xs font-medium text-muted">
          <ArrowUpDown size={14} class="fill-none stroke-2" />
          {sortFilter.sortBy}
        </label>
        <select
          id="sort-select"
          class="h-11 w-full rounded-xl border border-border bg-surface px-4 text-sm text-neutral transition-all focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
          onchange="window.location.href = this.value"
        >
          {sortOptions.map((option) => (
            <option value={buildUrl({ sort: option.value })} selected={currentSort === option.value}>
              {sortFilter[option.labelKey]}
            </option>
          ))}
        </select>
      </div>

      <!-- Genre filter -->
      {genres.length > 0 && (
        <div class="flex flex-col gap-2">
          <label for="genre-select" class="flex items-center gap-2 text-xs font-medium text-muted">
            <Music size={14} />
            {sortFilter.genre}
          </label>
          <select
            id="genre-select"
            class="h-11 w-full rounded-xl border border-border bg-surface px-4 text-sm text-neutral transition-all focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            onchange="window.location.href = this.value"
          >
            <option value={buildUrl({ genre: null })}>{sortFilter.allGenres}</option>
            {genres.map((genre) => (
              <option value={buildUrl({ genre })} selected={currentGenre === genre}>
                {genre}
              </option>
            ))}
          </select>
        </div>
      )}

      <!-- Year filter -->
      {years.length > 0 && (
        <div class="flex flex-col gap-2">
          <label for="year-select" class="flex items-center gap-2 text-xs font-medium text-muted">
            <Calendar size={14} class="fill-none stroke-2" />
            {sortFilter.year}
          </label>
          <select
            id="year-select"
            class="h-11 w-full rounded-xl border border-border bg-surface px-4 text-sm text-neutral transition-all focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            onchange="window.location.href = this.value"
          >
            <option value={buildUrl({ year: null })}>{sortFilter.allYears}</option>
            {years
              .sort((a, b) => b - a)
              .map((year) => (
                <option value={buildUrl({ year: year.toString() })} selected={currentYear === year.toString()}>
                  {year}
                </option>
              ))}
          </select>
        </div>
      )}

      <!-- Collection filter -->
      {collections.length > 0 && (
        <div class="flex flex-col gap-2">
          <label for="collection-select" class="flex items-center gap-2 text-xs font-medium text-muted">
            <Folder size={14} class="fill-none stroke-2" />
            {sortFilter.collection}
          </label>
          <select
            id="collection-select"
            class="h-11 w-full rounded-xl border border-border bg-surface px-4 text-sm text-neutral transition-all focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            onchange="window.location.href = this.value"
          >
            <option value={buildUrl({ collection: null })} selected={!currentCollection}>{sortFilter.allCollections}</option>
            <option value={buildUrl({ collection: 'none' })} selected={isUncategorizedFilter}>{sortFilter.uncategorized}</option>
            {collections.map((collection) => (
              <option value={buildUrl({ collection: collection.id })} selected={currentCollection === collection.id && !isUncategorizedFilter}>
                {collection.name}
              </option>
            ))}
          </select>
        </div>
      )}
    </div>

      <!-- Favorites filter -->
    <div class="favorites-filter-card flex items-center justify-between rounded-xl border border-border p-4">
      <div class="flex items-center gap-3">
        <div class={`flex h-10 w-10 items-center justify-center rounded-lg transition-colors ${
          showFavorites ? 'bg-primary' : 'bg-surface-elevated'
        }`}>
          <Heart size={18} class={`fill-none stroke-2 ${showFavorites ? 'text-white stroke-white' : 'text-muted stroke-muted'}`} />
        </div>
        <div>
          <label for="favorites-filter" class="text-sm font-medium text-neutral cursor-pointer">
            {sortFilter.favoritesOnly}
          </label>
          <p class="text-xs text-muted">{sortFilter.favoritesOnlyDescription}</p>
        </div>
      </div>
      <label class="relative inline-flex cursor-pointer items-center">
        <input
          type="checkbox"
          id="favorites-filter"
          checked={showFavorites}
          data-favorites-url={buildUrl({ favorites: showFavorites ? null : 'true' })}
          onchange="window.location.href = this.dataset.favoritesUrl"
          class="peer sr-only"
          role="switch"
          aria-checked={showFavorites ? 'true' : 'false'}
        />
        <div class="favorites-switch-track h-6 w-11 rounded-full border border-border transition-colors peer-checked:bg-primary peer-checked:border-primary peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary/20"></div>
        <div class="favorites-switch-thumb absolute left-1 top-1 h-4 w-4 rounded-full border border-border transition-transform peer-checked:translate-x-5"></div>
      </label>
    </div>
  </div>
</div>

<style>
  .favorites-filter-card {
    background-color: var(--color-surface);
  }

  .favorites-switch-track {
    background-color: var(--color-surface-elevated);
  }

  .favorites-switch-thumb {
    background-color: #ffffff;
  }

  .peer:checked + .favorites-switch-track {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
  }

  [data-theme='dark'] .favorites-filter-card {
    background-color: var(--color-surface);
    border-color: var(--color-border);
  }

  [data-theme='dark'] .favorites-switch-track {
    background-color: var(--color-surface-elevated);
    border-color: rgba(255, 255, 255, 0.22);
  }

  [data-theme='dark'] .favorites-switch-thumb {
    background-color: rgba(255, 255, 255, 0.95);
    border-color: rgba(255, 255, 255, 0.32);
  }
</style>
