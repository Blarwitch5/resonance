---
import Search from '@lucide/astro/icons/search'
import X from '@lucide/astro/icons/x'

type CollectionSearchLabels = {
  label: string
  placeholder: string
  clearAria: string
  noResults: string
  noResultsForQuery: string
}

const defaultLabels: CollectionSearchLabels = {
  label: 'Search your collection (title, artist, genre)',
  placeholder: 'Search by title, artist, genre...',
  clearAria: 'Clear search',
  noResults: 'No results',
  noResultsForQuery: 'No album matches "{query}"',
}

type CollectionSearchProps = {
  labels?: CollectionSearchLabels
}

const { labels = defaultLabels } = Astro.props as CollectionSearchProps
---

<div class="relative">
  <label for="collection-search" class="sr-only">
    {labels.label}
  </label>
  <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
    <Search size={20} class="fill-none stroke-2 text-muted stroke-muted" />
  </div>
  <input
    type="text"
    id="collection-search"
    placeholder={labels.placeholder}
    class="h-11 w-full rounded-xl border border-border bg-surface pl-12 pr-12 text-neutral placeholder-muted transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
    autocomplete="off"
  />
  <button
    type="button"
    id="clear-search"
    class="absolute inset-y-0 right-0 hidden min-w-11 items-center justify-center px-3 text-muted transition-colors hover:text-neutral focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/60 focus-visible:ring-offset-2 focus-visible:ring-offset-surface"
    aria-label={labels.clearAria}
  >
    <X size={20} />
  </button>
</div>

<script
  type="application/json"
  id="collection-search-messages"
  set:html={JSON.stringify({
    noResultsLabel: labels.noResults,
    noResultsForQueryTemplate: labels.noResultsForQuery,
  }).replace(/<\/script/gi, '<\\/script')}
></script>

<script>
  import './CollectionSearch.client'
</script>
