---
import Folder from '@lucide/astro/icons/folder'
import Trash2 from '@lucide/astro/icons/trash-2'
import Pencil from '@lucide/astro/icons/pencil'
import Disc3 from '@lucide/astro/icons/disc-3'
import Disc2 from '@lucide/astro/icons/disc-2'
import CassetteTape from '@lucide/astro/icons/cassette-tape'
import OptimizedImage from '../ui/OptimizedImage.astro'
import type { Collection } from '@prisma/client'
import type { CollectionsMessages } from '../../i18n/collections'

type CollectionHeaderProps = {
  collection: Collection & {
    itemCount?: number
    vinylCount?: number
    cdCount?: number
    cassetteCount?: number
    coverImage?: string | null
  }
  collectionT?: CollectionsMessages
}

const { collection, collectionT } = Astro.props as CollectionHeaderProps
const itemCount =
  collection.itemCount ??
  (collection.vinylCount ?? 0) + (collection.cdCount ?? 0) + (collection.cassetteCount ?? 0)
const header = collectionT?.header ?? {
  editButton: 'Edit',
  editCollection: 'Edit collection',
  editCollectionAria: 'Edit collection',
  deleteCollectionAria: 'Delete collection',
  countAlbums: 'albums',
  countVinyls: 'vinyls',
  countCds: 'CDs',
  countCassettes: 'cassettes',
  editModal: {
    nameLabel: 'Collection name *',
    descriptionLabel: 'Description (optional)',
    coverLabel: 'Cover image',
    coverOptional: 'JPEG, PNG, WebP or GIF, max 5MB',
    removeCover: 'Remove cover',
    coverFileTooLarge: 'Cover image is too large (max 5MB).',
    coverUploadError: 'Error while uploading cover image.',
    save: 'Save',
    cancel: 'Cancel',
    saving: 'Saving...',
    updatedSuccess: 'Collection updated successfully!',
    errorUpdating: 'Error while updating',
    errorGeneric: 'An error occurred',
    deleteTitle: 'Delete collection',
    deleteMessage: 'Are you sure you want to delete the collection "{name}"? This action is irreversible.',
    deleteConfirm: 'Delete',
    deleteCancel: 'Cancel',
    deleting: 'Deleting...',
    deletedSuccess: 'Collection deleted successfully!',
    errorDeleting: 'Error while deleting',
  },
}
---

<div class="glass-card mb-8 overflow-hidden rounded-2xl">
  <!-- Cover -->
  <div class="aspect-video overflow-hidden bg-linear-to-br from-primary/20 to-secondary/20">
    {collection.coverImage ? (
      <OptimizedImage
        src={collection.coverImage}
        alt={collection.name}
        width={1200}
        height={675}
        loading="eager"
        aspectRatio="auto"
        class="h-full w-full object-cover"
      />
    ) : (
      <div class="flex h-full items-center justify-center">
        <Folder size={64} class="fill-none stroke-2 text-primary stroke-primary opacity-50" />
      </div>
    )}
  </div>

  <!-- Info -->
  <div class="p-8">
    <div class="flex items-start justify-between">
      <div class="flex-1">
        <h1 class="mb-2 text-3xl font-bold text-neutral">{collection.name}</h1>

        <!-- Stats -->
        <div class="flex flex-wrap items-center gap-2 text-sm">
          <span class="text-2xl font-bold text-primary">
            {itemCount}
          </span>
          <span class="text-sm text-muted">{header.countAlbums}</span>
          <span class="text-muted">|</span>
          <div class="flex items-center gap-1.5" title={header.countVinyls}>
            <Disc3 size={20} class="fill-none stroke-2 text-format-vinyl stroke-format-vinyl shrink-0" aria-hidden="true" />
            <span class="font-medium text-neutral">{collection.vinylCount ?? 0} {header.countVinyls}</span>
          </div>
          <span class="text-muted">|</span>
          <div class="flex items-center gap-1.5" title={header.countCds}>
            <Disc2 size={20} class="fill-none stroke-2 text-format-cd stroke-format-cd shrink-0" aria-hidden="true" />
            <span class="font-medium text-neutral">{collection.cdCount ?? 0} {header.countCds}</span>
          </div>
          <span class="text-muted">|</span>
          <div class="flex items-center gap-1.5" title={header.countCassettes}>
            <CassetteTape size={20} class="fill-none stroke-2 text-format-cassette stroke-format-cassette shrink-0" aria-hidden="true" />
            <span class="font-medium text-neutral">{collection.cassetteCount ?? 0} {header.countCassettes}</span>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex gap-3">
        <button
          type="button"
          id="edit-collection-btn"
          data-collection-id={collection.id}
          class="btn-secondary-surface flex items-center gap-2 rounded-lg px-4 py-2"
          aria-label={header.editCollectionAria}
        >
          <Pencil size={18} class="fill-none stroke-2" />
          <span class="hidden sm:inline">{header.editButton}</span>
        </button>
        <button
          type="button"
          id="delete-collection-btn"
          data-collection-id={collection.id}
          data-collection-name={collection.name}
          class="btn-danger flex items-center gap-2 rounded-lg px-4 py-2"
          aria-label={header.deleteCollectionAria}
        >
          <Trash2 size={18} class="fill-none stroke-2" />
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Edit modal -->
<div id="edit-collection-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-md">
  <div class="glass-card mx-4 w-full max-w-lg rounded-2xl p-6">
    <h2 class="mb-4 text-xl font-bold text-neutral">{header.editCollection}</h2>
    <form id="edit-collection-form" class="space-y-4" data-initial-cover={collection.coverImage ?? ''}>
      <div>
        <label for="edit-name" class="mb-2 block text-sm font-medium text-neutral">
          {header.editModal.nameLabel}
        </label>
        <input
          type="text"
          id="edit-name"
          name="name"
          required
          class="w-full rounded-xl border border-border bg-surface p-3 text-neutral placeholder-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
        />
      </div>
      <div>
        <label for="edit-description" class="mb-2 block text-sm font-medium text-neutral">
          {header.editModal.descriptionLabel}
        </label>
        <textarea
          id="edit-description"
          name="description"
          rows={4}
          class="w-full rounded-xl border border-border bg-surface p-3 text-neutral placeholder-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
        ></textarea>
      </div>
      <div>
        <label for="edit-cover-upload" class="mb-2 block text-sm font-medium text-neutral">
          {header.editModal.coverLabel}
        </label>
        <p class="mb-2 text-xs text-muted">{header.editModal.coverOptional}</p>
        <div class="flex flex-wrap items-center gap-3">
          <input
            type="file"
            id="edit-cover-upload"
            accept="image/jpeg,image/png,image/webp,image/gif"
            class="flex-1 rounded-xl border border-border bg-surface p-3 text-neutral file:mr-3 file:rounded-lg file:border-0 file:bg-primary file:px-4 file:py-2 file:text-sm file:font-medium file:text-primary-foreground"
          />
          <button
            type="button"
            id="edit-cover-remove"
            class="btn-secondary-surface rounded-xl px-4 py-2 text-sm"
          >
            {header.editModal.removeCover}
          </button>
        </div>
        <div id="edit-cover-preview-wrapper" class="mt-3 hidden">
          <img
            id="edit-cover-preview"
            src=""
            alt=""
            class="max-h-40 rounded-xl border border-border object-cover"
          />
        </div>
      </div>
      <div class="flex gap-3">
        <button
          type="submit"
          class="btn-primary-gradient flex flex-1 items-center justify-center gap-2 rounded-xl px-6 py-3"
        >
          {header.editModal.save}
        </button>
        <button
          type="button"
          id="cancel-edit-btn"
          class="btn-secondary-surface flex items-center justify-center rounded-xl px-6 py-3"
        >
          {header.editModal.cancel}
        </button>
      </div>
    </form>
  </div>
</div>

<script type="application/json" id="edit-collection-messages" set:html={JSON.stringify({
  savingLabel: header.editModal.saving,
  updatedSuccessMsg: header.editModal.updatedSuccess,
  errorUpdatingMsg: header.editModal.errorUpdating,
  errorGenericMsg: header.editModal.errorGeneric,
  deleteTitleLabel: header.editModal.deleteTitle,
  deleteMessageTemplate: header.editModal.deleteMessage,
  deleteConfirmLabel: header.editModal.deleteConfirm,
  deleteCancelLabel: header.editModal.deleteCancel,
  deletingLabel: header.editModal.deleting,
  deletedSuccessMsg: header.editModal.deletedSuccess,
  errorDeletingMsg: header.editModal.errorDeleting,
  coverFileTooLargeMsg: header.editModal.coverFileTooLarge,
  coverUploadErrorMsg: header.editModal.coverUploadError,
}).replace(/<\/script/gi, '<\\/script')}></script>

<script>
  import './CollectionHeader.client'
</script>
