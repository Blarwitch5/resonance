---
import Folder from '@lucide/astro/icons/folder'
import Trash2 from '@lucide/astro/icons/trash-2'
import Pencil from '@lucide/astro/icons/pencil'
import Disc3 from '@lucide/astro/icons/disc-3'
import Disc2 from '@lucide/astro/icons/disc-2'
import CassetteTape from '@lucide/astro/icons/cassette-tape'
import OptimizedImage from '../ui/OptimizedImage.astro'
import type { Collection } from '@prisma/client'
import type { CollectionsMessages } from '../../i18n/collections'

type CollectionHeaderProps = {
  collection: Collection & {
    itemCount?: number
    vinylCount?: number
    cdCount?: number
    cassetteCount?: number
    coverImage?: string | null
  }
  collectionT?: CollectionsMessages
}

const { collection, collectionT } = Astro.props as CollectionHeaderProps
const itemCount =
  collection.itemCount ??
  (collection.vinylCount ?? 0) + (collection.cdCount ?? 0) + (collection.cassetteCount ?? 0)
const header = collectionT?.header ?? {
  editButton: 'Edit',
  editCollection: 'Edit collection',
  editCollectionAria: 'Edit collection',
  deleteCollectionAria: 'Delete collection',
  countAlbums: 'albums',
  countVinyls: 'vinyls',
  countCds: 'CDs',
  countCassettes: 'cassettes',
  editModal: {
    nameLabel: 'Collection name *',
    descriptionLabel: 'Description (optional)',
    coverLabel: 'Cover image',
    coverOptional: 'JPEG, PNG, WebP or GIF, max 5MB',
    removeCover: 'Remove cover',
    coverFileTooLarge: 'Cover image is too large (max 5MB).',
    coverUploadError: 'Error while uploading cover image.',
    save: 'Save',
    cancel: 'Cancel',
    saving: 'Saving...',
    updatedSuccess: 'Collection updated successfully!',
    errorUpdating: 'Error while updating',
    errorGeneric: 'An error occurred',
    deleteTitle: 'Delete collection',
    deleteMessage: 'Are you sure you want to delete the collection "{name}"? This action is irreversible.',
    deleteConfirm: 'Delete',
    deleteCancel: 'Cancel',
    deleting: 'Deleting...',
    deletedSuccess: 'Collection deleted successfully!',
    errorDeleting: 'Error while deleting',
  },
}
---

<div class="glass-card mb-8 overflow-hidden rounded-2xl">
  <!-- Cover -->
  <div class="aspect-video overflow-hidden bg-linear-to-br from-primary/20 to-secondary/20">
    {collection.coverImage ? (
      <OptimizedImage
        src={collection.coverImage}
        alt={collection.name}
        width={1200}
        height={675}
        loading="eager"
        aspectRatio="auto"
        class="h-full w-full object-cover"
      />
    ) : (
      <div class="flex h-full items-center justify-center">
        <Folder size={64} class="fill-none stroke-2 text-primary stroke-primary opacity-50" />
      </div>
    )}
  </div>

  <!-- Info -->
  <div class="p-8">
    <div class="flex items-start justify-between">
      <div class="flex-1">
        <h1 class="mb-2 text-3xl font-bold text-neutral">{collection.name}</h1>
        {collection.description && (
          <p class="mb-4 text-muted">{collection.description}</p>
        )}

        <!-- Stats -->
        <div class="flex flex-wrap gap-4">
          <div>
            <span class="text-2xl font-bold text-primary">
              {itemCount}
            </span>
            <span class="text-sm text-muted"> {header.countAlbums}</span>
          </div>
          <div class="flex items-center gap-1.5" title={header.countVinyls}>
            <Disc3 size={20} class="fill-none stroke-2 text-format-vinyl stroke-format-vinyl shrink-0" aria-hidden="true" />
            <span class="text-xl font-bold text-format-vinyl">{collection.vinylCount ?? 0}</span>
            <span class="text-sm text-muted">{header.countVinyls}</span>
          </div>
          <div class="flex items-center gap-1.5" title={header.countCds}>
            <Disc2 size={20} class="fill-none stroke-2 text-format-cd stroke-format-cd shrink-0" aria-hidden="true" />
            <span class="text-xl font-bold text-format-cd">{collection.cdCount ?? 0}</span>
            <span class="text-sm text-muted">{header.countCds}</span>
          </div>
          <div class="flex items-center gap-1.5" title={header.countCassettes}>
            <CassetteTape size={20} class="fill-none stroke-2 text-format-cassette stroke-format-cassette shrink-0" aria-hidden="true" />
            <span class="text-xl font-bold text-format-cassette">{collection.cassetteCount ?? 0}</span>
            <span class="text-sm text-muted">{header.countCassettes}</span>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex gap-3">
        <button
          type="button"
          id="edit-collection-btn"
          data-collection-id={collection.id}
          class="btn-secondary-surface flex items-center gap-2 rounded-lg px-4 py-2"
          aria-label={header.editCollectionAria}
        >
          <Pencil size={18} class="fill-none stroke-2" />
          <span class="hidden sm:inline">{header.editButton}</span>
        </button>
        <button
          type="button"
          id="delete-collection-btn"
          data-collection-id={collection.id}
          data-collection-name={collection.name}
          class="btn-danger flex items-center gap-2 rounded-lg px-4 py-2"
          aria-label={header.deleteCollectionAria}
        >
          <Trash2 size={18} class="fill-none stroke-2" />
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Edit modal -->
<div id="edit-collection-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-md">
  <div class="glass-card mx-4 w-full max-w-lg rounded-2xl p-6">
    <h2 class="mb-4 text-xl font-bold text-neutral">{header.editCollection}</h2>
    <form id="edit-collection-form" class="space-y-4" data-initial-cover={collection.coverImage ?? ''}>
      <div>
        <label for="edit-name" class="mb-2 block text-sm font-medium text-neutral">
          {header.editModal.nameLabel}
        </label>
        <input
          type="text"
          id="edit-name"
          name="name"
          required
          class="w-full rounded-xl border border-border bg-surface p-3 text-neutral placeholder-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
        />
      </div>
      <div>
        <label for="edit-description" class="mb-2 block text-sm font-medium text-neutral">
          {header.editModal.descriptionLabel}
        </label>
        <textarea
          id="edit-description"
          name="description"
          rows={4}
          class="w-full rounded-xl border border-border bg-surface p-3 text-neutral placeholder-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
        ></textarea>
      </div>
      <div>
        <label for="edit-cover-upload" class="mb-2 block text-sm font-medium text-neutral">
          {header.editModal.coverLabel}
        </label>
        <p class="mb-2 text-xs text-muted">{header.editModal.coverOptional}</p>
        <div class="flex flex-wrap items-center gap-3">
          <input
            type="file"
            id="edit-cover-upload"
            accept="image/jpeg,image/png,image/webp,image/gif"
            class="flex-1 rounded-xl border border-border bg-surface p-3 text-neutral file:mr-3 file:rounded-lg file:border-0 file:bg-primary file:px-4 file:py-2 file:text-sm file:font-medium file:text-primary-foreground"
          />
          <button
            type="button"
            id="edit-cover-remove"
            class="btn-secondary-surface rounded-xl px-4 py-2 text-sm"
          >
            {header.editModal.removeCover}
          </button>
        </div>
        <div id="edit-cover-preview-wrapper" class="mt-3 hidden">
          <img
            id="edit-cover-preview"
            src=""
            alt=""
            class="max-h-40 rounded-xl border border-border object-cover"
          />
        </div>
      </div>
      <div class="flex gap-3">
        <button
          type="submit"
          class="btn-primary-gradient flex flex-1 items-center justify-center gap-2 rounded-xl px-6 py-3"
        >
          {header.editModal.save}
        </button>
        <button
          type="button"
          id="cancel-edit-btn"
          class="btn-secondary-surface flex items-center justify-center rounded-xl px-6 py-3"
        >
          {header.editModal.cancel}
        </button>
      </div>
    </form>
  </div>
</div>

<script type="application/json" id="edit-collection-messages" set:html={JSON.stringify({
  savingLabel: header.editModal.saving,
  updatedSuccessMsg: header.editModal.updatedSuccess,
  errorUpdatingMsg: header.editModal.errorUpdating,
  errorGenericMsg: header.editModal.errorGeneric,
  deleteTitleLabel: header.editModal.deleteTitle,
  deleteMessageTemplate: header.editModal.deleteMessage,
  deleteConfirmLabel: header.editModal.deleteConfirm,
  deleteCancelLabel: header.editModal.deleteCancel,
  deletingLabel: header.editModal.deleting,
  deletedSuccessMsg: header.editModal.deletedSuccess,
  errorDeletingMsg: header.editModal.errorDeleting,
  coverFileTooLargeMsg: header.editModal.coverFileTooLarge,
  coverUploadErrorMsg: header.editModal.coverUploadError,
}).replace(/<\/script/gi, '<\\/script')}></script>

<script is:inline>
  (function() {
    var editMessages = { savingLabel: '', updatedSuccessMsg: '', errorUpdatingMsg: '', errorGenericMsg: '', deleteTitleLabel: '', deleteMessageTemplate: '', deleteConfirmLabel: '', deleteCancelLabel: '', deletingLabel: '', deletedSuccessMsg: '', errorDeletingMsg: '', coverFileTooLargeMsg: '', coverUploadErrorMsg: '' }
    try {
      var el = document.getElementById('edit-collection-messages')
      if (el && el.textContent) { editMessages = JSON.parse(el.textContent) }
    } catch (e) { console.warn('Could not parse edit-collection-messages', e) }

    const editBtn = document.getElementById('edit-collection-btn')
    const deleteBtn = document.getElementById('delete-collection-btn')
    const collectionId = editBtn && editBtn.dataset && editBtn.dataset.collectionId
    const collectionName = deleteBtn && deleteBtn.dataset && deleteBtn.dataset.collectionName
    const editModal = document.getElementById('edit-collection-modal')
    const editForm = document.getElementById('edit-collection-form')
    const cancelEditBtn = document.getElementById('cancel-edit-btn')
    const editNameInput = document.getElementById('edit-name')
    const editDescriptionInput = document.getElementById('edit-description')
    const editCoverUpload = document.getElementById('edit-cover-upload')
    const editCoverRemove = document.getElementById('edit-cover-remove')
    const editCoverPreviewWrapper = document.getElementById('edit-cover-preview-wrapper')
    const editCoverPreview = document.getElementById('edit-cover-preview')

    let pendingCoverUrl = null

    const ALLOWED_COVER_TYPES = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp', 'image/gif']
    const MAX_COVER_SIZE = 5 * 1024 * 1024

    function syncEditCoverPreview() {
      if (!editCoverPreview || !editCoverPreviewWrapper) return
      if (pendingCoverUrl) {
        editCoverPreview.src = pendingCoverUrl
        editCoverPreview.alt = 'Cover preview'
        editCoverPreviewWrapper.classList.remove('hidden')
      } else {
        editCoverPreview.src = ''
        editCoverPreviewWrapper.classList.add('hidden')
      }
    }

    function loadCollectionData() {
      const nameElement = document.querySelector('h1.text-3xl')
      const descElement = document.querySelector('p.text-muted')
      
      if (nameElement && editNameInput) {
        editNameInput.value = nameElement.textContent || ''
      }
      if (descElement && editDescriptionInput) {
        editDescriptionInput.value = descElement.textContent || ''
      }
      if (editForm && editForm.dataset.initialCover) {
        pendingCoverUrl = editForm.dataset.initialCover
      } else {
        pendingCoverUrl = null
      }
      if (editCoverUpload) editCoverUpload.value = ''
      syncEditCoverPreview()
    }

    // Open edit modal
    editBtn?.addEventListener('click', function() {
      loadCollectionData()
      if (editModal) {
        editModal.classList.remove('hidden')
        editModal.classList.add('flex')
      }
    })

    // Close edit modal
    cancelEditBtn?.addEventListener('click', function() {
      if (editModal) {
        editModal.classList.add('hidden')
        editModal.classList.remove('flex')
      }
    })

    // Fermer le modal en cliquant sur l'overlay
    editModal?.addEventListener('click', function(event) {
      if (event.target === editModal) {
        editModal.classList.add('hidden')
        editModal.classList.remove('flex')
      }
    })

    // Edit cover: upload
    editCoverUpload?.addEventListener('change', async function(event) {
      const target = event.target
      const file = target.files?.[0]
      if (!file) return
      if (!ALLOWED_COVER_TYPES.includes(file.type)) {
        if (window.toast) window.toast.error(editMessages.coverUploadErrorMsg)
        target.value = ''
        return
      }
      if (file.size > MAX_COVER_SIZE) {
        if (window.toast) window.toast.error(editMessages.coverFileTooLargeMsg)
        target.value = ''
        return
      }
      const formDataUpload = new FormData()
      formDataUpload.append('cover', file)
      try {
        const response = await fetch('/api/collections/upload-cover', {
          method: 'POST',
          body: formDataUpload,
          credentials: 'include',
        })
        const data = await response.json()
        if (response.ok && data.imageUrl) {
          pendingCoverUrl = data.imageUrl
          syncEditCoverPreview()
        } else {
          if (window.toast) window.toast.error(data.error || editMessages.coverUploadErrorMsg)
          target.value = ''
        }
      } catch (error) {
        if (window.toast) window.toast.error(editMessages.coverUploadErrorMsg)
        target.value = ''
      }
    })

    // Edit cover: remove
    editCoverRemove?.addEventListener('click', function() {
      pendingCoverUrl = null
      if (editCoverUpload) editCoverUpload.value = ''
      syncEditCoverPreview()
    })

    // Submit edit form
    editForm?.addEventListener('submit', async function(event) {
      event.preventDefault()
      
      if (!editForm) return
      
      const formData = new FormData(editForm)
      const collectionData = {
        name: formData.get('name'),
        description: formData.get('description') || null,
        coverImage: pendingCoverUrl,
      }

      const submitBtn = editForm.querySelector('button[type="submit"]')
      const originalText = submitBtn?.textContent || ''
      if (submitBtn) {
        submitBtn.disabled = true
        submitBtn.textContent = editMessages.savingLabel
      }

      try {
        const response = await fetch('/api/collections/' + collectionId + '/update', {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(collectionData),
        })

        const responseData = await response.json()

        if (response.ok) {
          if (window.toast) {
            window.toast.success(editMessages.updatedSuccessMsg)
          }
          setTimeout(function() {
            window.location.reload()
          }, 500)
        } else {
          if (window.toast) {
            window.toast.error(responseData.error || errorUpdatingMsg)
          }
        }
      } catch (error) {
        console.error('Error updating collection:', error)
        if (window.toast) {
          window.toast.error(editMessages.errorGenericMsg)
        }
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false
          submitBtn.textContent = originalText
        }
      }
    })

    // Supprimer la collection
    deleteBtn?.addEventListener('click', async function() {
      const deleteMessage = editMessages.deleteMessageTemplate.replace('{name}', collectionName || '')
      const confirmed = await window.confirmDialog?.(
        editMessages.deleteTitleLabel,
        deleteMessage,
        editMessages.deleteConfirmLabel,
        editMessages.deleteCancelLabel
      )
      
      if (!confirmed) {
        return
      }

      const button = deleteBtn
      const originalText = button.textContent || ''
      button.disabled = true
      button.textContent = editMessages.deletingLabel

      try {
        const response = await fetch('/api/collections/' + collectionId + '/delete', {
          method: 'DELETE',
        })

        if (response.ok || response.status === 204) {
          if (window.toast) {
            window.toast.success(editMessages.deletedSuccessMsg)
          }
          setTimeout(function() {
            window.location.href = '/collections'
          }, 500)
        } else {
          const responseData = await response.json()
          if (window.toast) {
            window.toast.error(responseData.error || editMessages.errorDeletingMsg)
          }
        }
      } catch (error) {
        console.error('Error deleting collection:', error)
        if (window.toast) {
          window.toast.error(editMessages.errorGenericMsg)
        }
      } finally {
        button.disabled = false
        button.textContent = originalText
      }
    })
  })()
</script>
