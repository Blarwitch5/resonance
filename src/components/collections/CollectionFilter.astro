---
import Filter from '@lucide/astro/icons/funnel'
import type { Collection } from '@prisma/client'

type CollectionFilterLabels = {
  filterAria: string
  filterButton: string
  allCollections: string
}

const defaultLabels: CollectionFilterLabels = {
  filterAria: 'Filter by collection',
  filterButton: 'Filter',
  allCollections: 'All collections',
}

type CollectionFilterProps = {
  collections: Collection[]
  currentCollection?: string | null
  labels?: CollectionFilterLabels
}

const props = Astro.props as CollectionFilterProps
const labels = props.labels ?? defaultLabels
---

<div class="relative">
  <button
    type="button"
    class="btn-primary-gradient flex items-center gap-2 rounded-xl px-4 py-2"
    aria-label={labels.filterAria}
  >
    <Filter size={18} />
    <span class="hidden sm:inline">{labels.filterButton}</span>
  </button>

  <!-- Dropdown (sera implémenté avec JS) -->
  <div class="glass-card absolute right-0 top-full z-10 mt-2 hidden min-w-64 p-2">
    <button
      class="w-full rounded-lg p-2 text-left hover:bg-surface"
      data-filter="all"
    >
      {labels.allCollections}
    </button>
    {props.collections.map((collection) => (
      <button
        class="w-full rounded-lg p-2 text-left hover:bg-surface"
        data-filter={collection.id}
      >
        {collection.name}
      </button>
    ))}
  </div>
</div>

<script>
  // Logique de filtrage à implémenter
</script>

