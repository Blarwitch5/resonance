---
import Logo from './Logo.astro'
import ThemeSwitcher from './ThemeSwitcher.astro'
import LanguageSwitcher from './LanguageSwitcher.astro'
import type { Locale } from '../../i18n/config'

type AppHeaderProps = {
  userName?: string | null
  userEmail?: string | null
  userImageUrl?: string | null
  currentLocale?: Locale
  languageLabel?: string
  backToLibraryAria?: string
  myProfileLabel?: string
  settingsLabel?: string
  signOutLabel?: string
  signInLabel?: string
  themeChangeAria?: string
  openProfileMenuAria?: string
  profileMenuAria?: string
  profileTitle?: string
}

const {
  userName,
  userEmail,
  userImageUrl,
  currentLocale = 'en',
  languageLabel = 'Language',
  backToLibraryAria = 'Back to my library',
  myProfileLabel = 'My profile',
  settingsLabel = 'Settings',
  signOutLabel = 'Sign out',
  signInLabel = 'Sign in',
  themeChangeAria = 'Change theme',
  openProfileMenuAria = 'Open profile menu',
  profileMenuAria = 'Profile menu',
  profileTitle = 'Profile',
} = Astro.props as AppHeaderProps
const hasUser = !!userName || !!userEmail
---

<header
  role="banner"
  class="sticky top-0 z-40 border-b border-border bg-background/80 backdrop-blur-xl transition-colors duration-200"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo à gauche -->
      <div class="flex items-center">
        <a href="/library" aria-label={backToLibraryAria}>
          <Logo size="md" showText={true} noHover={false} />
        </a>
      </div>

      <!-- Actions à droite (mobile seulement) -->
      <div class="flex items-center gap-2 md:hidden">
        {hasUser ? (
          <>
            <!-- Theme toggle (mobile seulement) -->
            <ThemeSwitcher size="md" variant="icon-only" ariaLabel={themeChangeAria} />
            <!-- Langue (mobile) -->
            <LanguageSwitcher currentLocale={currentLocale} variant="navbar" languageLabel={languageLabel} />
          </>
        ) : (
          <>
            <!-- Theme toggle (mobile only) -->
            <ThemeSwitcher size="md" variant="icon-only" ariaLabel={themeChangeAria} />
            
            <!-- Sign in -->
            <a
              href="/login"
              class="btn-secondary-surface px-4 py-2 rounded-xl text-sm"
            >
              {signInLabel}
            </a>
          </>
        )}
      </div>
    </div>
  </div>
</header>
