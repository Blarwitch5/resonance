---
// Toast notification component
// Usage: Add <ToastContainer /> to your layout, then use showToast() function
//
// Accessibilité:
// - conteneur avec aria-live pour annoncer les messages
// - chaque toast a un role adapté (status / alert) selon le type
type ToastProps = {
  closeAria?: string
}
const { closeAria = 'Close' } = Astro.props as ToastProps
---

<div
  id="toast-container"
  class="fixed top-4 right-4 z-50 flex flex-col gap-3 pointer-events-none"
  aria-live="polite"
  aria-atomic="false"
>
  <!-- Toasts will be dynamically added here -->
</div>

<script type="application/json" id="toast-messages" set:html={JSON.stringify({ closeAriaLabel: closeAria })}></script>
<script>
  import './Toast.client'
</script>

<style>
  .toast {
    min-width: 300px;
    max-width: 400px;
  }

  @media (max-width: 640px) {
    #toast-container {
      top: 1rem;
      right: 1rem;
      left: 1rem;
    }

    .toast {
      min-width: auto;
      max-width: 100%;
    }
  }
</style>
