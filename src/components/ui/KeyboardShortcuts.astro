---
// Composant pour gérer les raccourcis clavier
// Visible uniquement sur desktop (lg+)
type KeyboardShortcutsProps = {
  shortcutsHint?: string
}
const { shortcutsHint = 'Shortcuts: ⌘K (Search), ⌘N (New), Esc (Close), →/← (Navigate)' } = Astro.props as KeyboardShortcutsProps
---

<div class="hidden lg:block">
  <script type="application/json" id="keyboard-shortcuts-hint" set:html={JSON.stringify({ shortcutsHint })}></script>
  <script>
    import './KeyboardShortcuts.client'
  </script>
</div>
