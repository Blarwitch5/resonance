---
import X from '@lucide/astro/icons/x'
import Camera from '@lucide/astro/icons/camera'
import Pencil from '@lucide/astro/icons/pencil'
import ScanBarcode from '@lucide/astro/icons/scan-barcode'
import { getLayoutMessages } from '../../i18n/layout'

type BarcodeMessages = ReturnType<typeof getLayoutMessages>['barcodeScanner']
type Props = { barcodeMessages?: BarcodeMessages; hideFab?: boolean }
const defaultMessages = getLayoutMessages('en').barcodeScanner
const { barcodeMessages, hideFab = false } = Astro.props as Props
const msg = barcodeMessages ?? defaultMessages
---

<!-- Barcode Scanner Button/Modal (mobile + desktop) -->
<div id="barcode-scanner-container" class={`fixed right-4 z-40 md:bottom-8 md:right-8${hideFab ? ' hidden' : ''}`}>
  <!-- Scanner Button (FAB) -->
  <button
    id="barcode-scanner-btn"
    type="button"
    class="barcode-fab flex h-14 w-14 items-center justify-center rounded-full bg-primary text-white transition-all duration-300 hover:scale-110 hover:bg-primary-hover md:h-12 md:w-12"
    style="box-shadow: 0 4px 16px rgba(107,63,245,.4), 0 2px 8px rgba(0,0,0,.15)"
    aria-label={msg.scanAria}
  >
    <ScanBarcode size={24} class="h-6 w-6 md:h-5 md:w-5" aria-hidden="true" />
  </button>
</div>

<!-- Choice modal: camera or manual input -->
<div
  id="barcode-choice-modal"
  class="barcode-modal fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4 opacity-0 pointer-events-none invisible transition-opacity data-[open=true]:opacity-100 data-[open=true]:pointer-events-auto data-[open=true]:visible"
  data-open="false"
  role="dialog"
  aria-labelledby="barcode-choice-title"
  aria-modal="true"
>
  <div class="w-full max-w-sm rounded-2xl border border-border/30 bg-surface-elevated p-6 shadow-xl">
    <h2 id="barcode-choice-title" class="text-lg font-semibold text-neutral mb-2">{msg.choiceTitle}</h2>
    <p class="text-sm text-muted mb-6">{msg.choiceDescription}</p>
    <div class="flex flex-col gap-3">
      <button
        type="button"
        id="barcode-choice-camera"
        class="btn-primary w-full rounded-xl py-3 text-white flex items-center justify-center gap-2 group"
      >
        <Camera
          size={18}
          class="fill-none stroke-2 text-white stroke-white group-hover:text-neutral group-hover:stroke-neutral"
        />
        <span class="text-white group-hover:text-neutral">{msg.useCamera}</span>
      </button>
      <button
        type="button"
        id="barcode-choice-manual"
        class="btn-secondary-surface w-full rounded-xl py-3 flex items-center justify-center gap-2"
      >
        <Pencil size={18} class="fill-none stroke-2" />
        <span>{msg.enterManually}</span>
      </button>
    </div>
    <button
      type="button"
      id="barcode-choice-close"
      class="mt-4 w-full text-sm text-muted hover:text-neutral transition-colors"
      aria-label={msg.closeAria}
    >
      {msg.cancel}
    </button>
  </div>
</div>

<!-- Manual input modal -->
<div
  id="barcode-manual-modal"
  class="barcode-modal fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4 opacity-0 pointer-events-none invisible transition-opacity data-[open=true]:opacity-100 data-[open=true]:pointer-events-auto data-[open=true]:visible"
  data-open="false"
  role="dialog"
  aria-labelledby="barcode-manual-title"
  aria-modal="true"
>
  <div class="w-full max-w-sm rounded-2xl border border-border/30 bg-surface-elevated p-6 shadow-xl">
    <h2 id="barcode-manual-title" class="text-lg font-semibold text-neutral mb-2">{msg.manualTitle}</h2>
    <p class="text-sm text-muted mb-4">{msg.manualHint}</p>
    <input
      type="text"
      id="barcode-manual-input"
      class="input w-full rounded-xl border border-border bg-background px-4 py-3 text-neutral placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
      placeholder={msg.manualPlaceholder}
      inputmode="numeric"
      autocomplete="off"
      aria-label={msg.manualAria}
    />
    <p id="barcode-manual-error" class="mt-2 text-sm text-error hidden" role="alert"></p>
    <div class="mt-6 flex gap-3">
      <button type="button" id="barcode-manual-cancel" class="btn-secondary-surface flex-1 rounded-xl py-3">
        {msg.cancel}
      </button>
      <button type="button" id="barcode-manual-submit" class="btn-primary flex-1 rounded-xl py-3">
        {msg.search}
      </button>
    </div>
  </div>
</div>

<!-- Scanner Modal -->
<div
  id="barcode-scanner-modal"
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/90 backdrop-blur-sm p-4 opacity-0 pointer-events-none invisible transition-opacity data-[open=true]:opacity-100 data-[open=true]:pointer-events-auto data-[open=true]:visible"
  data-open="false"
  role="dialog"
  aria-modal="true"
  aria-labelledby="barcode-scanner-title"
>
  <!-- Close Button -->
  <button
    type="button"
    id="close-scanner"
    class="absolute right-4 top-4 z-10 rounded-full bg-white/10 p-3 text-white backdrop-blur-sm transition-all hover:bg-white/20"
    aria-label={msg.closeScannerAria}
  >
    <X size={24} />
  </button>

  <!-- Scanner View -->
  <div class="relative w-full max-w-md md:max-w-lg">
    <h2 id="barcode-scanner-title" class="sr-only">{msg.scannerTitle}</h2>
    <!-- Video Container -->
    <div id="scanner-video-container" class="relative aspect-square overflow-hidden rounded-2xl">
      <video
        id="scanner-video"
        class="h-full w-full object-cover"
        autoplay
        playsinline
        muted
      ></video>
      <!-- Scanning Overlay -->
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="relative">
          <!-- Scanning Frame -->
          <div class="h-64 w-64 rounded-lg border-4 border-primary shadow-2xl">
            <div class="absolute -top-1 left-1/2 h-2 w-16 -translate-x-1/2 rounded-full bg-primary"></div>
            <div class="absolute -bottom-1 left-1/2 h-2 w-16 -translate-x-1/2 rounded-full bg-primary"></div>
            <div class="absolute -left-1 top-1/2 h-16 w-2 -translate-y-1/2 rounded-full bg-primary"></div>
            <div class="absolute -right-1 top-1/2 h-16 w-2 -translate-y-1/2 rounded-full bg-primary"></div>
          </div>
        </div>
      </div>
      <!-- Instructions -->
      <div class="absolute bottom-4 left-1/2 -translate-x-1/2 text-center text-white">
        <p class="text-sm font-medium">{msg.placeInFrame}</p>
      </div>
    </div>

    <!-- Result Display -->
    <div id="scanner-result" class="mt-4 hidden">
      <div class="glass-card rounded-xl p-4">
        <p class="text-sm text-muted">{msg.detectedBarcode}</p>
        <p id="scanned-barcode" class="mt-1 text-lg font-bold text-neutral"></p>
      </div>
    </div>
  </div>
</div>

<script type="application/json" id="barcode-scanner-messages" set:html={JSON.stringify(msg)}></script>
<script>
  import './BarcodeScanner.client'
</script>

<style>
  .barcode-fab {
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.3);
  }

  .barcode-fab:active {
    transform: scale(0.95);
  }

  #barcode-scanner-container {
    bottom: calc(var(--mobile-scanner-fab-offset, 6rem) + env(safe-area-inset-bottom, 0px));
  }

  #scanner-video-container {
    position: relative;
  }

  /* Scanning animation */
  @keyframes scanLine {
    0% {
      top: 0;
    }
    100% {
      top: 100%;
    }
  }

  #scanner-video-container::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(to bottom, transparent, var(--color-primary), transparent);
    animation: scanLine 2s linear infinite;
    pointer-events: none;
  }

  /* Modals visibles quand data-open="true" */
  #barcode-scanner-modal[data-open='true'],
  .barcode-modal[data-open='true'] {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
  }

</style>
