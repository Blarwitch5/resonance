---
import ImageOff from '@lucide/astro/icons/image-off'

type OptimizedImageProps = {
  src: string | null | undefined
  alt: string
  width?: number
  height?: number
  loading?: 'lazy' | 'eager'
  class?: string
  aspectRatio?: 'square' | 'auto'
}

const {
  src,
  alt,
  width = 400,
  height = 400,
  loading = 'lazy',
  class: className = '',
  aspectRatio = 'square',
} = Astro.props as OptimizedImageProps

const isValidUrl = src && src.trim() !== '' && (src.startsWith('http://') || src.startsWith('https://') || src.startsWith('/'))
const hasImage = isValidUrl
const aspectClass = aspectRatio === 'square' ? 'aspect-square' : ''
---

{hasImage ? (
  <>
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding="async"
      class={`${aspectClass} ${className}`}
      style={aspectRatio === 'square' ? undefined : `aspect-ratio: ${width}/${height}`}
      onerror="this.style.display='none'; if(this.nextElementSibling) this.nextElementSibling.style.display='flex';"
    />
    <div class={`${aspectClass} ${className} flex items-center justify-center bg-surface text-muted`} style="display: none;">
      <ImageOff size={48} class="opacity-50" aria-hidden="true" />
    </div>
  </>
) : (
  <div class={`${aspectClass} ${className} flex items-center justify-center bg-surface text-muted`}>
    <ImageOff size={48} class="opacity-50" aria-hidden="true" />
  </div>
)}
