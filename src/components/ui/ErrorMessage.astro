---
/**
 * Composant pour afficher les messages d'erreur contextuels
 */
import AlertCircle from '@lucide/astro/icons/circle-alert'
import X from '@lucide/astro/icons/x'

type ErrorMessageProps = {
  message: string
  dismissible?: boolean
  class?: string
  closeAria?: string
}

const { message, dismissible = false, class: className = '', closeAria = 'Close' } = Astro.props as ErrorMessageProps
---

<div 
  class={`flex items-start gap-3 rounded-xl border border-error/30 bg-error/10 p-4 text-error ${className}`}
  role="alert"
  aria-live="assertive"
>
  <AlertCircle size={20} class="fill-none stroke-2 shrink-0 mt-0.5" />
  <p class="flex-1 text-sm font-medium">{message}</p>
  {dismissible && (
    <button
      type="button"
      class="shrink-0 rounded p-1 transition-colors hover:bg-error/20"
      aria-label={closeAria}
      onclick="this.closest('[role=alert]')?.remove()"
    >
      <X size={16} />
    </button>
  )}
</div>
