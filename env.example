# Variables d'environnement — Application Resonance
# Fichier unique : créer app/.env (copie de ce fichier). Aucun .env à la racine du monorepo pour l'app.
# En dev : lancer depuis app/ (pnpm dev) pour que Vite charge app/.env.

# ─── Bases Neon : dev vs prod ─────────────────────────────────────────────────
# • PROD : Vercel injecte DATABASE_URL (branche Neon prod). Ne pas mettre l’URL prod dans app/.env.
# • DEV  : Dans app/.env, mettre UNIQUEMENT l’URL de la branche Neon DEV (créer une branche "dev" dans Neon).
# Ainsi migrations et données de test restent sur la base dev, la prod reste intacte.

# Clés API Discogs
# Obtenez vos clés sur https://www.discogs.com/settings/developers
DISCOGS_CONSUMER_KEY="your_discogs_consumer_key_here"
DISCOGS_CONSUMER_SECRET="your_discogs_consumer_secret_here"

# Base de données — en local (app/.env) : URL Neon DEV uniquement
# Prisma et l'app n'utilisent que DATABASE_URL. Préférer l'URL "pooled" (-pooler) pour Neon.
# Exemple (branche dev) : postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST_DEV/neondb?sslmode=require"

# Configuration générale
NODE_ENV="development"

# Port optionnel
PORT="4321"

# better-auth (requis pour l'authentification)
# Générer un secret avec: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-key-here-minimum-32-characters"
BETTER_AUTH_URL="http://localhost:4321"

# Notification nouvel utilisateur (optionnel)
# Quand un utilisateur s'inscrit, un POST JSON est envoyé à cette URL.
# - Discord : créer un webhook sur le serveur (Paramètres du canal → Intégrations → Webhooks) puis coller l'URL
# - Slack : créer une "Incoming Webhook" et coller l'URL
# Laisser vide pour désactiver.
# NEW_USER_WEBHOOK_URL="https://discord.com/api/webhooks/..."

# OAuth Providers (optionnel - laisser vide pour désactiver)
# 
# 📖 Guide complet : voir docs/OAUTH_SETUP_GUIDE.md
#
# Redirect URIs à configurer pour chaque provider :
# - Dev: http://localhost:4321/api/auth/oauth/{provider}/callback
# - Prod: https://votre-domaine.com/api/auth/oauth/{provider}/callback

# Discord OAuth
# Guide: https://discord.com/developers/applications
# 1. Créer une application sur https://discord.com/developers/applications
# 2. Aller dans "OAuth2" > "General"
# 3. Copier le Client ID et générer un Client Secret
# 4. Ajouter les Redirect URIs dans "OAuth2" > "General" > "Redirects"
#    Coller exactement ces URLs (une par ligne) :
#    Dev:  http://localhost:4321/api/auth/oauth/discord/callback
#    Prod: https://VOTRE-DOMAINE.com/api/auth/oauth/discord/callback
#    (Staging: https://resonance-staging.vercel.app/api/auth/oauth/discord/callback)
DISCORD_CLIENT_ID="your.discord.client.id"
DISCORD_CLIENT_SECRET="your.discord.client.secret"

# Google OAuth
# Guide: https://console.cloud.google.com/apis/credentials
# 1. Créer un projet Google Cloud
# 2. Activer l'API OAuth
# 3. Configurer l'écran de consentement
# 4. Créer des credentials OAuth 2.0 Client ID
# 5. Dans "Authorized redirect URIs" ajouter :
#    Dev:  http://localhost:4321/api/auth/oauth/google/callback
#    Prod: https://VOTRE-DOMAINE.com/api/auth/oauth/google/callback
#    Staging: https://resonance-staging.vercel.app/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID="xxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxx"

# Spotify OAuth
# Guide: https://developer.spotify.com/dashboard
# 1. Créer une app sur le dashboard Spotify
# 2. Configurer les Redirect URIs dans les paramètres de l'app :
#    Dev:  http://localhost:4321/api/auth/oauth/spotify/callback
#    Prod: https://VOTRE-DOMAINE.com/api/auth/oauth/spotify/callback
#    Staging: https://resonance-staging.vercel.app/api/auth/oauth/spotify/callback
SPOTIFY_CLIENT_ID="your.spotify.client.id"
SPOTIFY_CLIENT_SECRET="your.spotify.client.secret"

# Spotify API (pour les previews audio)
# Les mêmes credentials que pour OAuth peuvent être utilisés
# Utilise Client Credentials Flow pour les previews publiques