{
  "name": "resonance-app",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "astro dev",
    "dev:clean": "pkill -f 'astro dev' || true && rm -rf .astro node_modules/.astro node_modules/.vite .vite dist && pnpm dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write . --ignore-path .prettierignore",
    "format:check": "prettier --check . --ignore-path .prettierignore",
    "a11y": "playwright test --config playwright.config.cjs",
    "covers:update": "tsx scripts/update-covers-hq.ts",
    "covers:clean": "tsx scripts/clean-covers.ts",
    "seed:test": "tsx scripts/seed-test-data.ts",
    "clean:cache": "pkill -f 'astro dev' || true && rm -rf .astro node_modules/.astro node_modules/.vite .vite dist"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.0",
    "@astrojs/vercel": "^10.0.0",
    "@lucide/astro": "^0.562.0",
    "@prisma/client": "^6.19.2",
    "astro": "^6.0.0",
    "better-auth": "^1.4.19",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^4.1.0",
    "piccolore": "^0.1.3",
    "pnpm": "^10.30.2",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "prettier": "latest",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.2.1",
    "tsx": "latest"
  }
}
