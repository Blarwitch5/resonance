## Context

- Astro allows creating API endpoints in the `src/pages/api/` directory
- These endpoints are server-side functions that can be called from the client or other services

## Endpoint Structure

API endpoints in Astro export named functions for each HTTP method:

```typescript
// src/pages/api/users.ts
import type { APIRoute } from "astro";

export const GET: APIRoute = async ({ params, request, cookies, redirect, url }) => {
  // Your logic here
  return new Response(JSON.stringify({ data: "response" }), {
    status: 200,
    headers: { "Content-Type": "application/json" },
  });
};

export const POST: APIRoute = async ({ params, request, cookies }) => {
  const body = await request.json();
  // Process the body
  return new Response(JSON.stringify({ success: true }), {
    status: 201,
    headers: { "Content-Type": "application/json" },
  });
};
```

## Available Parameters

### `request`

- Access headers: `request.headers.get("user-agent")`
- Body: `await request.json()`, `await request.formData()`, `await request.text()`
- URL: `request.url`

### `cookies`

```typescript
export const GET: APIRoute = async ({ cookies }) => {
  // Read a cookie
  const theme = cookies.get("theme");

  // Set a cookie
  cookies.set("name", "value", {
    httpOnly: true,
    secure: true,
    sameSite: "strict",
    maxAge: 60 * 60 * 24, // 1 day
    path: "/",
  });

  // Delete a cookie
  cookies.delete("name");
};
```

### `params`

For dynamic routes: `/api/users/[id].ts`

```typescript
export const GET: APIRoute = async ({ params }) => {
  const userId = params.id; // string | undefined
  // ...
};
```

### `redirect`

```typescript
export const GET: APIRoute = async ({ redirect }) => {
  return redirect("/login", 302);
};
```

### `url`

```typescript
export const GET: APIRoute = async ({ url }) => {
  const searchParams = url.searchParams;
  const page = searchParams.get("page");
  // ...
};
```

## Complete Example

```typescript
// src/pages/api/users/[id].ts
import type { APIRoute } from "astro";
import { db } from "../../../lib/db";
import { auth } from "../../../lib/auth";

export const GET: APIRoute = async ({ params, request }) => {
  const userId = params.id;

  if (!userId) {
    return new Response(JSON.stringify({ error: "User ID required" }), {
      status: 400,
      headers: { "Content-Type": "application/json" },
    });
  }

  // Check authentication via better-auth
  const session = await auth.api.getSession({
    headers: request.headers,
  });

  if (!session) {
    return new Response(JSON.stringify({ error: "Unauthorized" }), {
      status: 401,
      headers: { "Content-Type": "application/json" },
    });
  }

  try {
    const user = await db.user.findUnique({ where: { id: userId } });

    if (!user) {
      return new Response(JSON.stringify({ error: "User not found" }), {
        status: 404,
        headers: { "Content-Type": "application/json" },
      });
    }

    return new Response(JSON.stringify(user), {
      status: 200,
      headers: { "Content-Type": "application/json" },
    });
  } catch (error) {
    return new Response(JSON.stringify({ error: "Internal server error" }), {
      status: 500,
      headers: { "Content-Type": "application/json" },
    });
  }
};

export const PUT: APIRoute = async ({ params, request }) => {
  const userId = params.id;
  const body = await request.json();

  // Validation and update
  // ...

  return new Response(JSON.stringify({ success: true }), {
    status: 200,
    headers: { "Content-Type": "application/json" },
  });
};
```

