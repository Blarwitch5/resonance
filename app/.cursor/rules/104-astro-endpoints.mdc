## Integration with better-auth

For protected endpoints, use better-auth:

```typescript
import type { APIRoute } from "astro";
import { auth } from "../../../lib/auth";
import { db } from "../../../lib/db";

export const GET: APIRoute = async ({ request }) => {
  // Check session
  const session = await auth.api.getSession({
    headers: request.headers,
  });

  if (!session) {
    return new Response(JSON.stringify({ error: "Unauthorized" }), {
      status: 401,
      headers: { "Content-Type": "application/json" },
    });
  }

  // Use user from session
  const user = await db.user.findUnique({
    where: { id: session.user.id },
  });

  return new Response(JSON.stringify(user), {
    status: 200,
    headers: { "Content-Type": "application/json" },
  });
};
```

## Integration with Prisma and Neon

```typescript
import type { APIRoute } from "astro";
import { db } from "../../../lib/db";

export const GET: APIRoute = async ({ params }) => {
  try {
    const users = await db.user.findMany({
      take: 10,
      orderBy: { createdAt: 'desc' },
    });

    return new Response(JSON.stringify(users), {
      status: 200,
      headers: { "Content-Type": "application/json" },
    });
  } catch (error) {
    console.error('Database error:', error);
    return new Response(JSON.stringify({ error: "Internal server error" }), {
      status: 500,
      headers: { "Content-Type": "application/json" },
    });
  }
};
```

## Important Rules

1. Always return a `Response` object with appropriate headers
2. Handle errors and return appropriate status codes
3. Use TypeScript to type parameters and responses
4. Validate input data before processing
5. Use better-auth for authentication and authorization
6. Use Prisma with Neon PostgreSQL for all database queries
7. Handle database errors with try/catch
