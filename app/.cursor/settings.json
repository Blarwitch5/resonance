{
  // Garder le syntax highlighting Astro
  "files.associations": {
    "*.astro": "astro"
  },
  // Désactiver TOUT le formatage pour Astro
  "[astro]": {
    "editor.defaultFormatter": null,
    "editor.formatOnSave": false,
    "editor.formatOnPaste": false,
    "editor.formatOnType": false,
    "editor.codeActionsOnSave": {
      "source.organizeImports": false,
      "source.fixAll": false
    },
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": false
    }
  },
  // Désactiver Prettier pour Astro
  "prettier.enable": false,
  "prettier.disableLanguages": ["astro"],
  "prettier.ignorePath": ".prettierignore",
  "prettier.documentSelectors": ["!**/*.astro"],
  // Désactiver le formatage global
  "editor.formatOnSave": false,
  "editor.formatOnPaste": false,
  "editor.formatOnType": false,
  "editor.codeActionsOnSave": {
    "source.organizeImports": false,
    "source.fixAll": false
  },
  // Désactiver l'organisation automatique des imports
  "typescript.preferences.organizeImports": false,
  "javascript.preferences.organizeImports": false,
  // Désactiver les fonctionnalités problématiques de l'extension Astro
  "astro.autoRenameTags": false,
  "astro.format.enabled": false,
  "astro.format.formatter": "none",
  // Désactiver les diagnostics TypeScript problématiques (faux positifs sur imports)
  "astro.typescript.diagnostics.enabled": true,
  "astro.typescript.tsdk": "",
  // Désactiver les warnings spécifiques qui causent des faux positifs
  "typescript.validate.enable": true,
  "typescript.suggest.autoImports": true,
  // Désactiver complètement Biome pour ce projet
  "biome.enabled": false,
  "biome.requireConfiguration": true,
  // Désactiver Biome spécifiquement pour les fichiers Astro
  "[astro]": {
    "editor.codeActionsOnSave": {
      "quickfix.biome": "never",
      "source.organizeImports.biome": "never"
    }
  }
}
