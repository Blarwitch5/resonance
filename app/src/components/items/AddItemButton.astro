---
import Plus from '@lucide/astro/icons/plus'

type AddItemButtonProps = {
  format: 'VINYL' | 'CD' | 'CASSETTE'
  href?: string
}

const props = Astro.props as AddItemButtonProps
const href = props.href ?? '/explorer'
---

<a
  href={href}
  class="bg-gradient-resonance hover:bg-gradient-resonance-hover flex items-center gap-2 rounded-xl px-4 py-2 text-white transition-all duration-300"
  aria-label={`Add ${props.format}`}
>
  <Plus size={20} />
  <span class="hidden sm:inline">Add</span>
</a>

