---
import Skeleton from '../ui/Skeleton.astro'
---

<div class="space-y-6 animate-pulse">
  <!-- Bouton retour skeleton -->
  <Skeleton width="150px" height="24px" rounded="md" />

  <!-- Header skeleton -->
  <div class="glass-card rounded-2xl p-6">
    <div class="flex flex-col gap-6 md:flex-row">
      <!-- Cover skeleton -->
      <div class="shrink-0">
        <Skeleton width="300px" height="300px" rounded="lg" />
      </div>

      <!-- Infos skeleton -->
      <div class="flex-1 space-y-4">
        <div>
          <Skeleton width="60%" height="36px" rounded="md" class="mb-2" />
          <Skeleton width="40%" height="24px" rounded="md" />
        </div>

        <!-- Métadonnées skeleton -->
        <div class="flex flex-wrap gap-4">
          <Skeleton width="80px" height="20px" rounded="md" />
          <Skeleton width="60px" height="20px" rounded="md" />
          <Skeleton width="100px" height="20px" rounded="md" />
        </div>

        <!-- Actions skeleton -->
        <div class="pt-4 border-t border-border">
          <Skeleton width="200px" height="40px" rounded="lg" />
        </div>
      </div>
    </div>
  </div>

  <!-- Tracklist skeleton -->
  <div class="glass-card rounded-2xl p-6">
    <Skeleton width="150px" height="28px" rounded="md" class="mb-4" />
    <div class="space-y-3">
      {Array.from({ length: 5 }).map(() => (
        <div class="flex items-center justify-between py-2">
          <div class="flex items-center gap-3 flex-1">
            <Skeleton width="30px" height="20px" rounded="md" />
            <Skeleton width="60%" height="20px" rounded="md" />
          </div>
          <Skeleton width="80px" height="32px" rounded="md" />
        </div>
      ))}
    </div>
  </div>

  <!-- Métadonnées Discogs skeleton -->
  <div class="glass-card rounded-2xl p-6">
    <Skeleton width="200px" height="28px" rounded="md" class="mb-4" />
    <div class="space-y-3">
      <Skeleton width="100%" height="20px" rounded="md" />
      <Skeleton width="80%" height="20px" rounded="md" />
      <Skeleton width="90%" height="20px" rounded="md" />
    </div>
  </div>

  <!-- Données personnelles skeleton -->
  <div class="glass-card rounded-2xl p-6">
    <Skeleton width="180px" height="28px" rounded="md" class="mb-4" />
    <div class="space-y-4">
      <Skeleton width="100%" height="100px" rounded="md" />
      <div class="grid grid-cols-2 gap-4">
        <Skeleton width="100%" height="40px" rounded="md" />
        <Skeleton width="100%" height="40px" rounded="md" />
      </div>
    </div>
  </div>
</div>
