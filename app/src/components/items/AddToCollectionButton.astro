---
import Plus from '@lucide/astro/icons/plus'
import type { Collection } from '@prisma/client'

type AddToCollectionButtonProps = {
  discogsId: number
  collections: Collection[]
  defaultCollectionId?: string | null
}

const { discogsId, collections, defaultCollectionId } = Astro.props as AddToCollectionButtonProps
---

<div class="add-to-collection-wrapper" data-discogs-id={discogsId}>
  <button
    type="button"
    class="add-btn bg-gradient-resonance hover:bg-gradient-resonance-hover flex w-full items-center justify-center gap-2 rounded-xl px-6 py-3 text-base font-medium text-white transition-all duration-300 shadow-lg shadow-primary/20"
    data-discogs-id={discogsId}
    data-action="open-modal"
  >
    <Plus size={20} />
    <span>Add to collection</span>
  </button>

  <!-- Modal d'ajout -->
  <div
    id={`add-modal-${discogsId}`}
    class="add-to-collection-modal fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4"
    data-modal
    role="dialog"
    aria-modal="true"
    aria-labelledby="add-modal-title"
  >
    <div class="glass-card w-full max-w-md rounded-2xl p-6">
      <div class="mb-4 flex items-center justify-between">
        <h3 id="add-modal-title" class="text-lg font-bold text-neutral">Add to collection</h3>
        <button
          type="button"
          class="close-btn flex h-8 w-8 items-center justify-center rounded-lg text-muted transition-colors hover:bg-surface-elevated hover:text-neutral"
          data-action="close"
          aria-label="Fermer"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"
            />
          </svg>
        </button>
      </div>

      <div class="space-y-4">
        <div>
          <label
            for={`collection-select-${discogsId}`}
            class="mb-2 block text-sm font-medium text-neutral"
          >
            Collection
          </label>
          <select
            id={`collection-select-${discogsId}`}
            class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-neutral transition-colors focus:border-primary focus:ring-2 focus:ring-primary/50 focus:outline-none"
          >
            <option value="">Uncategorized</option>
            {collections.map((collection) => (
              <option
                value={collection.id}
                selected={defaultCollectionId === collection.id}
              >
                {collection.name}
              </option>
            ))}
          </select>
        </div>

        <div class="flex gap-3">
          <button
            type="button"
            class="cancel-btn flex-1 rounded-xl border border-border bg-surface px-4 py-2.5 text-sm font-medium text-neutral transition-colors hover:bg-surface-elevated"
            data-action="cancel"
          >
            Annuler
          </button>
          <button
            type="button"
            class="confirm-btn bg-gradient-resonance hover:bg-gradient-resonance-hover flex-1 rounded-xl px-4 py-2.5 text-sm font-medium text-white transition-all duration-300"
            data-action="confirm"
            data-discogs-id={discogsId}
          >
            Ajouter
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .add-to-collection-modal:not(.hidden) {
    display: flex;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const wrapper = document.querySelector('.add-to-collection-wrapper')
    if (!wrapper) return

    const discogsId = wrapper.getAttribute('data-discogs-id')
    const openBtn = wrapper.querySelector('[data-action="open-modal"]')
    const modal = wrapper.querySelector('[data-modal]')
    const closeBtn = wrapper.querySelector('[data-action="close"]')
    const cancelBtn = wrapper.querySelector('[data-action="cancel"]')
    const confirmBtn = wrapper.querySelector('[data-action="confirm"]')
    const select = discogsId ? wrapper.querySelector('#collection-select-' + discogsId) : null

    function openModal() {
      if (modal) {
        modal.classList.remove('hidden')
        modal.style.display = 'flex'
      }
    }

    function closeModal() {
      if (modal) {
        modal.classList.add('hidden')
        modal.style.display = ''
      }
    }

    if (openBtn) {
      openBtn.addEventListener('click', openModal)
    }

    if (closeBtn) {
      closeBtn.addEventListener('click', closeModal)
    }

    if (cancelBtn) {
      cancelBtn.addEventListener('click', closeModal)
    }

    // Fermer en cliquant sur le fond
    if (modal) {
      modal.addEventListener('click', (event) => {
        if (event.target === modal) {
          closeModal()
        }
      })
    }

    // Confirmer l'ajout
    if (confirmBtn) {
      confirmBtn.addEventListener('click', async () => {
        const selectedCollectionId = select?.value || null
        const btnDiscogsId = confirmBtn.getAttribute('data-discogs-id')
        
        if (!btnDiscogsId) {
          console.error('Missing discogsId on confirm button')
          return
        }

        confirmBtn.disabled = true
        const originalText = confirmBtn.textContent
        confirmBtn.textContent = 'Ajout en cours...'

        try {
          const collectionId = selectedCollectionId && selectedCollectionId.trim() !== '' ? selectedCollectionId : null
          const response = await fetch(`/api/explorer/${btnDiscogsId}/add-to-collection`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              collectionId,
            }),
          })

          if (!response.ok) {
            const error = await response.json()
            throw new Error(error.error || 'Erreur lors de l\'ajout')
          }

          const data = await response.json()

          if (window.toast) {
            const collectionName = selectedCollectionId
              ? select?.options[select.selectedIndex]?.text || 'Collection'
              : 'Uncategorized'
            window.toast.success(`Album added to "${collectionName}"`)
          }

          // Redirection vers la page complète
          setTimeout(() => {
            window.location.href = data.redirectTo
          }, 500)
        } catch (error) {
          console.error('Error adding item:', error)
          confirmBtn.disabled = false
          confirmBtn.textContent = originalText || 'Ajouter'

          const errorMessage = error instanceof Error ? error.message : 'Erreur lors de l\'ajout'
          if (window.toast) {
            window.toast.error(errorMessage)
          } else {
            console.error('Erreur:', errorMessage)
          }
        }
      })
    }
  })
</script>
