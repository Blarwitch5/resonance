---
import X from '@lucide/astro/icons/x'
import Heart from '@lucide/astro/icons/heart'
import type { Collection } from '@prisma/client'

type AddToCollectionModalProps = {
  collections: Collection[]
  itemId?: string
}

const { collections, itemId } = Astro.props as AddToCollectionModalProps
---

<!-- Modal backdrop -->
<div
  id="add-to-collection-modal"
  class="add-to-collection-modal fixed inset-0 z-50 hidden items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="add-to-collection-title"
>
  <!-- Overlay glass -->
  <div class="modal-overlay absolute inset-0 bg-black/60 backdrop-blur-md"></div>
  
  <!-- Modal content -->
  <div class="modal-content glass-card relative z-10 w-full max-w-md rounded-2xl p-6 shadow-2xl">
    <div class="mb-6 flex items-center justify-between">
      <h2 id="add-to-collection-title" class="text-2xl font-bold text-neutral">Add to a collection</h2>
      <button type="button" class="close-modal text-muted hover:text-neutral" aria-label="Close the Add to collection window">
        <X size={24} />
      </button>
    </div>

    <div class="space-y-3">
      <!-- Add to wishlist button -->
      <button
        type="button"
        class="wishlist-add-btn w-full rounded-xl border-2 border-pink-500/30 bg-pink-500/10 p-4 text-left transition-all hover:border-pink-500/50 hover:bg-pink-500/20 disabled:opacity-50 disabled:cursor-not-allowed"
        data-original-text="Add to wishlist"
      >
        <div class="flex items-center gap-3">
          <Heart size={20} class="fill-none stroke-2 text-pink-500 stroke-pink-500" />
          <div>
            <h3 class="font-medium text-neutral">Add to wishlist</h3>
            <p class="text-sm text-muted">Save for later</p>
          </div>
        </div>
      </button>

      <div class="my-4 border-t border-border"></div>

      {collections.length === 0 ? (
        <div class="rounded-xl border border-dashed border-border bg-surface p-8 text-center">
          <p class="mb-4 font-medium text-neutral">No collection available</p>
          <p class="mb-4 text-sm text-muted">
            Create your first collection to organize your albums.
          </p>
          <a
            href="/collections/new"
            class="btn-primary-gradient inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm"
          >
            Create a collection
          </a>
        </div>
      ) : (
        collections.map((collection) => (
          <button
            type="button"
            class="collection-add-btn btn-secondary-surface w-full rounded-xl p-4 text-left disabled:opacity-50 disabled:cursor-not-allowed"
            data-collection-id={collection.id}
            data-original-text="Ajouter"
          >
            <h3 class="font-medium">{collection.name}</h3>
            {collection.description && (
              <p class="text-sm text-muted">{collection.description}</p>
            )}
          </button>
        ))
      )}
    </div>

    <div class="mt-6 flex justify-end gap-3">
      <button
        type="button"
        class="btn-secondary-surface close-modal rounded-xl px-4 py-2"
      >
        Cancel
      </button>
      <a
        href="/collections/new"
        class="btn-primary-gradient rounded-xl px-4 py-2"
      >
        New collection
      </a>
    </div>
  </div>
</div>

<script>
  // TypeScript fonctionne nativement dans les scripts Astro !
  (function() {
    // Gestion ouverture/fermeture modal
    const modal = document.getElementById('add-to-collection-modal')
    if (!modal) return

    const closeButtons = document.querySelectorAll('.close-modal')
    let lastActiveElement: HTMLElement | null = null

    function closeModal(): void {
      const currentModal = document.getElementById('add-to-collection-modal')
      if (!currentModal) return
      currentModal.classList.add('hidden')
      currentModal.style.display = ''
      currentModal.removeAttribute('data-redirect-on-success')

      if (lastActiveElement && typeof lastActiveElement.focus === 'function') {
        lastActiveElement.focus()
      }
      lastActiveElement = null
    }

    closeButtons.forEach(function(btn) {
      btn.addEventListener('click', closeModal)
    })

    // Fermer avec Escape (uniquement quand le modal est ouvert) + piège de focus
    modal.addEventListener('keydown', function(event: KeyboardEvent) {
      if (event.key === 'Escape') {
        event.stopPropagation()
        if (!modal.classList.contains('hidden')) {
          closeModal()
        }
        return
      }

      if (event.key === 'Tab') {
        const focusableSelectors = [
          'button',
          '[href]',
          'input',
          'select',
          'textarea',
          '[tabindex]:not([tabindex="-1"])',
        ]
        const focusable = Array.from(
          modal.querySelectorAll(focusableSelectors.join(','))
        ).filter((element) => {
          const htmlElement = element
          return (
            htmlElement instanceof HTMLElement &&
            !htmlElement.hasAttribute('disabled') &&
            htmlElement.tabIndex !== -1 &&
            htmlElement.offsetParent !== null
          )
        })

        if (focusable.length === 0) {
          event.preventDefault()
          return
        }

        const firstElement = focusable[0]
        const lastElement = focusable[focusable.length - 1]
        const current = document.activeElement

        if (event.shiftKey) {
          if (current === firstElement || !modal.contains(current)) {
            event.preventDefault()
            ;(lastElement as HTMLElement).focus()
          }
        } else {
          if (current === lastElement || !modal.contains(current)) {
            event.preventDefault()
            ;(firstElement as HTMLElement).focus()
          }
        }
      }
    })

    // Fermer en cliquant sur l'overlay
    const modalOverlay = document.querySelector('.modal-overlay')
    if (modalOverlay) {
      modalOverlay.addEventListener('click', closeModal)
    }

    // Empêcher la fermeture en cliquant sur le contenu du modal
    const modalContent = document.querySelector('.modal-content')
    if (modalContent) {
      modalContent.addEventListener('click', (event: Event) => {
        event.stopPropagation()
      })
    }

    // Fonction pour attacher les listeners aux boutons
    function attachButtonListeners(): void {
      // Bouton wishlist
      const wishlistButton = document.querySelector('.wishlist-add-btn') as HTMLButtonElement | null
      if (wishlistButton && !wishlistButton.hasAttribute('data-listener-attached')) {
        wishlistButton.setAttribute('data-listener-attached', 'true')
        wishlistButton.addEventListener('click', async function(event: Event) {
          event.preventDefault()
          event.stopPropagation()
          
          if (!modal) return
          const discogsId = modal.getAttribute('data-discogs-id')
          if (!discogsId) {
            console.warn('No discogsId set on modal')
            return
          }

          // Set loading state
          const originalText = wishlistButton.getAttribute('data-original-text') || 'Add to wishlist'
          if (window.setButtonLoading) {
            window.setButtonLoading(wishlistButton, true, originalText)
          } else {
            wishlistButton.disabled = true
            wishlistButton.textContent = 'Ajout en cours...'
          }

          try {
            // Récupérer les détails de la release Discogs
            const releaseResponse = await fetch(`/api/discogs/release/${discogsId}`)
            if (!releaseResponse.ok) {
              throw new Error('Failed to fetch release details')
            }

            const release = await releaseResponse.json()

            // Déterminer le format
            let format: 'VINYL' | 'CD' | 'CASSETTE' = 'VINYL'
            const formatNames = release.formats?.map((formatItem: { name: string }) => formatItem.name.toUpperCase()) || []
            if (formatNames.some((formatName: string) => formatName.includes('CD'))) {
              format = 'CD'
            } else if (formatNames.some((formatName: string) => formatName.includes('CASSETTE'))) {
              format = 'CASSETTE'
            }

            const primaryArtist = release.artists?.[0]?.name || 'Unknown Artist'
            const year = release.year || parseInt(release.released || '0') || null

            // Extraire la meilleure cover
            type DiscogsImage = { type?: string; uri?: string; resource_url?: string }
            type DiscogsRelease = { images?: DiscogsImage[]; cover_image?: string; thumb?: string }
            const getBestCoverUrl = (release: DiscogsRelease): string | null => {
              if (release.images && release.images.length > 0) {
                const primaryImage = release.images.find((image: DiscogsImage) => image.type === 'primary') || release.images[0]
                return primaryImage.uri || primaryImage.resource_url || null
              }
              return release.cover_image || release.thumb || null
            }

            // Add to wishlist
            const wishlistResponse = await fetch('/api/wishlist/create', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                discogsId: release.id,
                title: release.title,
                artist: primaryArtist,
                year,
                genre: release.genres?.[0] || release.styles?.[0] || null,
                coverUrl: getBestCoverUrl(release),
                format,
                priority: 1,
              }),
            })

            if (!wishlistResponse.ok) {
              const error = await wishlistResponse.json()
              throw new Error(error.error || 'Failed to add to wishlist')
            }

            // Success
            modal.classList.add('hidden')
            modal.style.display = ''
            modal.removeAttribute('data-discogs-id')
            modal.removeAttribute('data-redirect-on-success')
            
            if (window.toast) {
              window.toast.success('Album successfully added to wishlist!')
            }
          } catch (error) {
            console.error('Error adding to wishlist:', error)
            if (window.toast) {
              window.toast.error('Error: ' + (error instanceof Error ? error.message : 'An unexpected error occurred'))
            }
            // Reset loading state
            if (window.setButtonLoading) {
              window.setButtonLoading(wishlistButton, false)
            } else {
              wishlistButton.disabled = false
              wishlistButton.textContent = originalText
            }
          }
        })
      }

      // Boutons de collection
      const collectionButtons = document.querySelectorAll('.collection-add-btn')
      collectionButtons.forEach((button) => {
        if (button.hasAttribute('data-listener-attached')) {
          return
        }
        button.setAttribute('data-listener-attached', 'true')
        
        button.addEventListener('click', async function(event: Event) {
          event.preventDefault()
          event.stopPropagation()
          
          if (!modal) return
          const collectionId = button.getAttribute('data-collection-id')
          const discogsId = modal.getAttribute('data-discogs-id')

          if (!collectionId || !discogsId) {
            console.warn('Missing collectionId or discogsId', { collectionId, discogsId })
            return
          }

          // Set loading state
          const originalText = button.getAttribute('data-original-text') || 'Add'
          if (window.setButtonLoading) {
            window.setButtonLoading(button as HTMLElement, true, originalText)
          } else {
            (button as HTMLButtonElement).disabled = true
            button.textContent = 'Ajout en cours...'
          }

          try {
            // Récupérer les détails de la release Discogs
            const releaseResponse = await fetch(`/api/discogs/release/${discogsId}`)
            if (!releaseResponse.ok) {
              throw new Error('Failed to fetch release details')
            }

            const release = await releaseResponse.json()

            // Déterminer le format
            let format: 'VINYL' | 'CD' | 'CASSETTE' = 'VINYL'
            const formatNames = release.formats?.map((formatItem: { name: string }) => formatItem.name.toUpperCase()) || []
            if (formatNames.some((formatName: string) => formatName.includes('CD'))) {
              format = 'CD'
            } else if (formatNames.some((formatName: string) => formatName.includes('CASSETTE'))) {
              format = 'CASSETTE'
            }

            const primaryArtist = release.artists?.[0]?.name || 'Unknown Artist'
            const year = release.year || parseInt(release.released || '0') || null

            // Extraire la meilleure cover
            type DiscogsImage = { type?: string; uri?: string; resource_url?: string }
            type DiscogsRelease = { images?: DiscogsImage[]; cover_image?: string; thumb?: string }
            const getBestCoverUrl = (release: DiscogsRelease): string | null => {
              if (release.images && release.images.length > 0) {
                const primaryImage = release.images.find((image: DiscogsImage) => image.type === 'primary') || release.images[0]
                return primaryImage.uri || primaryImage.resource_url || null
              }
              return release.cover_image || release.thumb || null
            }

            // Create item
            const createResponse = await fetch('/api/items/create', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                discogsId: release.id,
                title: release.title,
                artist: primaryArtist,
                year,
                genre: release.genres?.[0] || release.styles?.[0] || null,
                country: release.country || null,
                label: release.labels?.[0]?.name || null,
                format,
                barcode: release.identifiers?.find((id: { type: string; value: string }) => id.type === 'Barcode')?.value || null,
                coverUrl: getBestCoverUrl(release),
              }),
            })

            if (!createResponse.ok) {
              const error = await createResponse.json()
              throw new Error(error.error || 'Failed to create item')
            }

            const item = await createResponse.json()

            // Add item to collection
            const addResponse = await fetch(`/api/collections/${collectionId}/add-item`, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({ itemId: item.id }),
            })

            if (!addResponse.ok) {
              const error = await addResponse.json()
              throw new Error(error.error || 'Failed to add item to collection')
            }

            // Success
            if (!modal) return
            const redirectOnSuccess = modal.getAttribute('data-redirect-on-success')
            modal.classList.add('hidden')
            modal.style.display = ''
            modal.removeAttribute('data-discogs-id')
            modal.removeAttribute('data-redirect-on-success')
            
            if (window.toast) {
              window.toast.success('Album successfully added to collection!')
            }
            if (redirectOnSuccess === 'true' && item && item.slug) {
              setTimeout(function() {
                window.location.href = '/items/' + item.slug
              }, 500)
            }
          } catch (error) {
            console.error('Error adding to collection:', error)
            if (window.toast) {
              window.toast.error('Erreur : ' + (error instanceof Error ? error.message : 'Une erreur est survenue'))
            }
            // Reset loading state
            if (window.setButtonLoading) {
              window.setButtonLoading(button as HTMLElement, false)
            } else {
              (button as HTMLButtonElement).disabled = false
              button.textContent = originalText
            }
          }
        })
      })
    }

    // Attacher les listeners au chargement initial
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', attachButtonListeners)
    } else {
      attachButtonListeners()
    }

    // Réattacher les listeners quand le modal s'ouvre (au cas où les boutons seraient re-rendus)
    const observer = new MutationObserver(() => {
      if (modal && !modal.classList.contains('hidden')) {
        // Mémoriser l'élément actif à l'ouverture si ce n'est pas déjà fait
        if (!lastActiveElement && document.activeElement instanceof HTMLElement) {
          lastActiveElement = document.activeElement
        }

        // Focus initial sur le premier bouton interactif du contenu
        const firstInteractive =
          modal.querySelector('.wishlist-add-btn') ||
          modal.querySelector('.collection-add-btn') ||
          modal.querySelector('button')
        if (firstInteractive instanceof HTMLElement && typeof firstInteractive.focus === 'function') {
          firstInteractive.focus()
        }

        attachButtonListeners()
      }
    })
    if (modal) {
      observer.observe(modal, { attributes: true, attributeFilter: ['class'], childList: true, subtree: true })
    }
  })()
</script>

<style>
  .add-to-collection-modal:not(.hidden) {
    display: flex;
  }

  .modal-overlay {
    transition: opacity 0.3s ease, backdrop-filter 0.3s ease;
  }

  .modal-content {
    animation: modalSlideIn 0.3s ease-out;
    transform-origin: center;
  }

  @keyframes modalSlideIn {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(-10px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  #add-to-collection-modal:not(.hidden) .modal-overlay {
    animation: fadeIn 0.3s ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>
