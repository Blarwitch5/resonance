---
import { ClientRouter } from 'astro:transitions'
import BottomBar from '../ui/BottomBar.astro'
import Footer from '../ui/Footer.astro'
import Header from '../ui/Header.astro'
import '../../styles/global.css'

type LayoutProps = {
  title?: string
  description?: string
  canonical?: string
  showDashboardHeader?: boolean
  sectionTitle?: string
  sectionDescription?: string
  showBottomBar?: boolean
  showFooter?: boolean
}

const props = Astro.props as LayoutProps
const title = props.title ?? 'Resonance - Where your music resonates'
const description =
  props.description ??
  'Manage your multi-format music collection with Resonance. Vinyl, CD, Cassette - all in one place.'
const canonical = props.canonical ?? Astro.url?.href ?? '/'
const showDashboardHeader = props.showDashboardHeader ?? false
const showBottomBar = props.showBottomBar ?? false
const showFooter = props.showFooter ?? true
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    
    <link rel="canonical" href={canonical} />

    <!-- Preload critical fonts for better performance -->
    <link
      rel="preload"
      href="/fonts/Poppins-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Social media meta tags -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/og-image.jpg" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.jpg" />

    <!-- PWA Meta -->
    <meta name="theme-color" content="#6B4EFF" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Resonance" />

    <title>{title}</title>

    <!-- View Transitions -->
    <ClientRouter />

    <!-- Theme initialization script to prevent flash (based on Tailwind 4) -->
    <script is:inline>
      ;(function () {
        const html = document.documentElement
        // matchMedia est disponible globalement dans les navigateurs modernes
        const prefersDark =
          typeof matchMedia !== 'undefined'
            ? matchMedia('(prefers-color-scheme: dark)').matches
            : false

        const theme =
          localStorage.theme === 'dark' || (!('theme' in localStorage) && prefersDark)
            ? 'dark'
            : 'light'
        html.setAttribute('data-theme', theme)
      })()
    </script>

    <!-- Preload critical fonts -->
    <link
      rel="preload"
      href="/fonts/Poppins-Medium.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body
    class="bg-background font-sans text-neutral antialiased transition-colors duration-200"
  >
    <div id="app" class="flex min-h-screen flex-col">
      {
        showDashboardHeader && props.sectionTitle && props.sectionDescription && (
          <Header sectionTitle={props.sectionTitle} sectionDescription={props.sectionDescription} />
        )
      }

      <!-- Main content -->
      <main
        class={`flex-1 transition-colors duration-200 ${showBottomBar ? 'pb-20 md:pb-8' : ''} global-audio-main`}
        transition:animate="fade"
      >
        <slot />
      </main>

      <!-- Barre d’extrait audio flottante en bas (remplie par TrackList) -->
      <div
        id="global-audio-bar"
        class="global-audio-bar hidden fixed inset-x-0 bottom-20 z-40 flex justify-center pointer-events-none border-t border-border bg-surface-elevated shadow-lg backdrop-blur-sm md:bottom-6 md:border-none md:bg-transparent md:shadow-none"
        aria-live="polite"
        aria-label="Extrait en cours"
      >
        <div
          class="pointer-events-auto mx-auto max-w-3xl px-4"
          data-global-audio-slot
        ></div>
      </div>

      {showBottomBar && <BottomBar />}

      {showFooter && <Footer />}
    </div>
  </body>
</html>
<script>
  function applyTheme() {
    const html = document.documentElement
    const prefersDark =
      typeof matchMedia !== 'undefined' ? matchMedia('(prefers-color-scheme: dark)').matches : false

    const theme =
      localStorage.theme === 'dark' || (!('theme' in localStorage) && prefersDark)
        ? 'dark'
        : 'light'
    html.setAttribute('data-theme', theme)
  }

  document.addEventListener('astro:before-swap', function (event: Event) {
    const newDoc = (event as CustomEvent<{ newDocument?: Document }>).detail?.newDocument
    if (newDoc) {
      const prefersDark =
        typeof matchMedia !== 'undefined'
          ? matchMedia('(prefers-color-scheme: dark)').matches
          : false

      const theme =
        localStorage.theme === 'dark' || (!('theme' in localStorage) && prefersDark)
          ? 'dark'
          : 'light'
      newDoc.documentElement.setAttribute('data-theme', theme)
    }
  })

  // Sidebar : délégation d’événements pour survivre aux View Transitions (changement de thème, navigation)
  document.addEventListener('click', async function (event) {
    const target = event.target instanceof Node ? event.target : null
    if (!target) return

    if ((target as Element).closest?.('#sidebar-toggle-btn')) {
      document.body.classList.toggle('sidebar-open')
      const open = document.body.classList.contains('sidebar-open')
      const button = document.getElementById('sidebar-toggle-btn')
      if (button) {
        button.setAttribute('aria-expanded', String(open))
        button.setAttribute('aria-label', open ? 'Fermer le menu' : 'Ouvrir le menu')
      }
      return
    }

    if ((target as Element).closest?.('#sidebar-close-btn') || (target as Element).closest?.('[data-sidebar-backdrop]')) {
      document.body.classList.remove('sidebar-open')
      return
    }

    if ((target as Element).closest?.('#sidebar-signout-btn')) {
      event.preventDefault()
      event.stopPropagation()
      try {
        const win = typeof window !== 'undefined' ? window : null
        if (win?.toast?.info) win.toast.info('Déconnexion en cours...', 2000)
        const { signOut } = await import('../../lib/auth-client')
        await signOut()
        sessionStorage.setItem('showLogoutToast', 'true')
        setTimeout(() => { window.location.href = '/login' }, 500)
      } catch (error) {
        console.error('Error signing out:', error)
        const winErr = typeof window !== 'undefined' ? window : null
        if (winErr?.toast?.error) winErr.toast.error('Erreur lors de la déconnexion')
        setTimeout(() => { window.location.href = '/login' }, 1000)
      }
    }
  })
</script>
