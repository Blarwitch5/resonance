---
import { ClientRouter } from 'astro:transitions'
import BottomBar from '../ui/BottomBar.astro'
import Footer from '../ui/Footer.astro'
import Header from '../ui/Header.astro'
import { getLayoutMessages } from '../../i18n/layout'
import { normalizeLocale } from '../../i18n/config'
import '../../styles/global.css'

type LayoutProps = {
  title?: string
  description?: string
  canonical?: string
  showDashboardHeader?: boolean
  sectionTitle?: string
  sectionDescription?: string
  showBottomBar?: boolean
  showFooter?: boolean
}

const props = Astro.props as LayoutProps
const title = props.title ?? 'Resonance - Where your music resonates'
const description =
  props.description ??
  'Manage your multi-format music collection with Resonance. Vinyl, CD, Cassette - all in one place.'
const canonical = props.canonical ?? Astro.url?.href ?? '/'
const showDashboardHeader = props.showDashboardHeader ?? false
const showBottomBar = props.showBottomBar ?? false
const showFooter = props.showFooter ?? true
const userPreferences = Astro.locals.userPreferences
const htmlLang = userPreferences?.locale ?? 'en'
const preferredTheme = userPreferences?.theme ?? ''
const locale = normalizeLocale(userPreferences?.locale ?? Astro.cookies.get('locale')?.value ?? Astro.request.headers.get('accept-language')?.split(',')[0]?.slice(0, 2))
const layoutT = getLayoutMessages(locale)
---

<!doctype html>
<html lang={htmlLang} class="scroll-smooth" data-preferred-theme={preferredTheme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    
    <link rel="canonical" href={canonical} />

    <!-- Social media meta tags -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/og-image.jpg" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.jpg" />

    <!-- PWA Meta -->
    <meta name="theme-color" content="#6B4EFF" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Resonance" />

    <title>{title}</title>

    <!-- View Transitions -->
    <ClientRouter />

    <!-- Apply saved user theme from server before reading localStorage -->
    <script is:inline>
      ;(function () {
        const preferred = document.documentElement.getAttribute('data-preferred-theme')
        if (preferred === 'light' || preferred === 'dark') {
          try { localStorage.setItem('theme', preferred) } catch (e) {}
        }
      })()
    </script>
    <!-- Theme initialization script to prevent flash (based on Tailwind 4) -->
    <script is:inline>
      ;(function () {
        const html = document.documentElement
        const prefersDark =
          typeof matchMedia !== 'undefined'
            ? matchMedia('(prefers-color-scheme: dark)').matches
            : false

        const theme =
          localStorage.theme === 'dark' || (!('theme' in localStorage) && prefersDark)
            ? 'dark'
            : 'light'
        html.setAttribute('data-theme', theme)
      })()
    </script>
  </head>
  <body
    class="bg-background font-sans text-neutral antialiased transition-colors duration-200"
  >
    <a
      href="#main-content"
      class="skip-link fixed left-4 top-4 z-[100] -translate-y-[9999px] rounded-lg bg-primary px-4 py-2 text-white shadow-lg transition-transform duration-200 focus:translate-y-0 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
    >
      {layoutT.common.skipToMainContent}
    </a>
    <div id="app" class="flex min-h-screen flex-col">
      {
        showDashboardHeader && props.sectionTitle && props.sectionDescription && (
          <Header sectionTitle={props.sectionTitle} sectionDescription={props.sectionDescription} searchAria={layoutT.appHeader.searchAria} />
        )
      }

      <!-- Main content -->
      <main
        id="main-content"
        class={`flex-1 transition-colors duration-200 ${showBottomBar ? 'pb-20 md:pb-8' : ''} global-audio-main`}
        transition:animate="fade"
        tabindex="-1"
      >
        <slot />
      </main>

      <!-- Barre d’extrait audio flottante en bas (remplie par TrackList) -->
      <div
        id="global-audio-bar"
        class="global-audio-bar hidden fixed inset-x-0 bottom-20 z-40 flex justify-center pointer-events-none border-t border-border bg-surface-elevated shadow-lg backdrop-blur-sm md:bottom-6 md:border-none md:bg-transparent md:shadow-none"
        aria-live="polite"
        aria-label={layoutT.common.nowPlayingAria}
      >
        <div
          class="pointer-events-auto mx-auto max-w-3xl px-4"
          data-global-audio-slot
        ></div>
      </div>

      {showBottomBar && <BottomBar mainNavAria={layoutT.bottomBar.mainNavAria} libraryLabel={layoutT.bottomBar.library} exploreLabel={layoutT.bottomBar.explore} profileLabel={layoutT.bottomBar.profile} />}

      {showFooter && <Footer navAria={layoutT.footer.navAria} />}
    </div>
    <!-- Labels en script text/plain (base64) pour éviter guillemets/apostrophes et = dans les attributs -->
    <script type="text/plain" id="layout-sidebar-messages" data-encoding="base64">
      {Buffer.from(JSON.stringify({
        sidebarOpenLabel: layoutT.sidebar.openMenuLabel,
        sidebarCloseLabel: layoutT.sidebar.closeMenuLabel,
        signingOutLabel: layoutT.common.signingOut,
        signOutErrorLabel: layoutT.common.signOutError,
      }), 'utf8').toString('base64')}
    </script>
  </body>
</html>
<script>
  import '../../scripts/loading-utils';
</script>
<script is:inline>
  (function () {
    var sidebarOpenLabel = 'Open menu'
    var sidebarCloseLabel = 'Close menu'
    var signingOutLabel = 'Signing out...'
    var signOutErrorLabel = 'Error while signing out'
    try {
      var el = document.getElementById('layout-sidebar-messages')
      var raw = el && el.textContent && el.textContent.trim()
      if (raw) {
        raw = raw.replace(/\s/g, '')
        if (/^[A-Za-z0-9+/=]+$/.test(raw)) {
          var decoded = JSON.parse(atob(raw))
          if (decoded.sidebarOpenLabel) sidebarOpenLabel = decoded.sidebarOpenLabel
          if (decoded.sidebarCloseLabel) sidebarCloseLabel = decoded.sidebarCloseLabel
          if (decoded.signingOutLabel) signingOutLabel = decoded.signingOutLabel
          if (decoded.signOutErrorLabel) signOutErrorLabel = decoded.signOutErrorLabel
        }
      }
    } catch (e) {
      console.warn('Could not parse layout-sidebar-messages', e)
    }

    function applyTheme() {
      var html = document.documentElement
      var prefersDark =
        typeof matchMedia !== 'undefined' ? matchMedia('(prefers-color-scheme: dark)').matches : false
      var theme =
        localStorage.theme === 'dark' || (!('theme' in localStorage) && prefersDark)
          ? 'dark'
          : 'light'
      html.setAttribute('data-theme', theme)
    }

    document.addEventListener('astro:before-swap', function (event) {
      var newDoc = event.detail && event.detail.newDocument
      if (newDoc) {
        var prefersDark =
          typeof matchMedia !== 'undefined'
            ? matchMedia('(prefers-color-scheme: dark)').matches
            : false
        var theme =
          localStorage.theme === 'dark' || (!('theme' in localStorage) && prefersDark)
            ? 'dark'
            : 'light'
        newDoc.documentElement.setAttribute('data-theme', theme)
      }
    })

    document.addEventListener('click', async function (event) {
      var target = event.target instanceof Element ? event.target : null
      if (!target || !target.closest) return

      if (target.closest('#sidebar-toggle-btn')) {
        document.body.classList.toggle('sidebar-open')
        var open = document.body.classList.contains('sidebar-open')
        var button = document.getElementById('sidebar-toggle-btn')
        if (button) {
          button.setAttribute('aria-expanded', String(open))
          button.setAttribute('aria-label', open ? sidebarCloseLabel : sidebarOpenLabel)
        }
        return
      }

      if (target.closest('#sidebar-close-btn') || target.closest('[data-sidebar-backdrop]')) {
        document.body.classList.remove('sidebar-open')
        return
      }

      if (target.closest('#sidebar-signout-btn')) {
        event.preventDefault()
        event.stopPropagation()
        try {
          var win = typeof window !== 'undefined' ? window : null
          if (win && win.toast && win.toast.info) win.toast.info(signingOutLabel, 2000)
          var auth = await import('../../lib/auth-client')
          await auth.signOut()
          sessionStorage.setItem('showLogoutToast', 'true')
          setTimeout(function () { window.location.href = '/login' }, 500)
        } catch (error) {
          console.error('Error signing out:', error)
          var winErr = typeof window !== 'undefined' ? window : null
          if (winErr && winErr.toast && winErr.toast.error) winErr.toast.error(signOutErrorLabel)
          setTimeout(function () { window.location.href = '/login' }, 1000)
        }
      }
    })
  })()
</script>
