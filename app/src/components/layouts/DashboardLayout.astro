---
import Layout from './Layout.astro'
import Toast from '../ui/Toast.astro'
import Sidebar from '../ui/Sidebar.astro'
import AppHeader from '../ui/AppHeader.astro'
import Logo from '../ui/Logo.astro'
import Menu from '@lucide/astro/icons/menu'
import KeyboardShortcuts from '../ui/KeyboardShortcuts.astro'
import BarcodeScanner from '../ui/BarcodeScanner.astro'
import ConfirmDialog from '../ui/ConfirmDialog.astro'
import { getLayoutMessages } from '../../i18n/layout'
import { normalizeLocale } from '../../i18n/config'

// Utiliser la session depuis le middleware (Astro.locals)
const session = Astro.locals.session
const user = Astro.locals.user
const locale = normalizeLocale(Astro.locals.userPreferences?.locale ?? Astro.cookies.get('locale')?.value ?? Astro.request.headers.get('accept-language')?.split(',')[0]?.slice(0, 2))
const layoutT = getLayoutMessages(locale)

type SectionConfig = {
  title: string
  description: string
  icon: string
  color: string
}

type DashboardLayoutProps = {
  title?: string
  description?: string
  currentPath?: string
}

// Fonction pour déterminer la section active
function getActiveSection(path: string): string {
  if (path.includes('/vinyl')) return 'vinyl'
  if (path.includes('/cassette')) return 'cassette'
  if (path.includes('/cd')) return 'cd'
  if (path.includes('/explorer')) return 'explorer'
  if (path.includes('/profile')) return 'profile'
  return 'vinyl'
}

const props = Astro.props as DashboardLayoutProps
const title = props.title ?? 'Resonance - Dashboard'
const description = props.description ?? 'Manage your music collection with Resonance'
const currentPath = props.currentPath ?? Astro.url?.pathname ?? '/'

const activeSection = getActiveSection(currentPath)
const isHomePage = currentPath === '/' || currentPath === '/index'

// Section configuration (titres et descriptions traduits via layout i18n)
const dashboardSections = layoutT.dashboard.sections
const sections: Record<string, SectionConfig> = {
  vinyl: {
    title: dashboardSections.vinyl.title,
    description: dashboardSections.vinyl.description,
    icon: '💿',
    color: 'format-vinyl',
  },
  cassette: {
    title: dashboardSections.cassette.title,
    description: dashboardSections.cassette.description,
    icon: '📼',
    color: 'format-cassette',
  },
  cd: {
    title: dashboardSections.cd.title,
    description: dashboardSections.cd.description,
    icon: '💽',
    color: 'format-cd',
  },
  explorer: {
    title: dashboardSections.explorer.title,
    description: dashboardSections.explorer.description,
    icon: '🔍',
    color: 'format-explorer',
  },
  profile: {
    title: dashboardSections.profile.title,
    description: dashboardSections.profile.description,
    icon: '👤',
    color: 'format-profile',
  },
}

const currentSection = sections[activeSection]

// Generate a personalized welcome message
function getWelcomeMessage(userName: string | null | undefined, userEmail: string | null | undefined, greetings: { goodMorning: string; goodAfternoon: string; goodEvening: string; goodNight: string }): string {
  const name = userName || userEmail?.split('@')[0] || 'User'
  const hour = new Date().getHours()
  
  let greeting: string
  if (hour >= 5 && hour < 12) {
    greeting = greetings.goodMorning
  } else if (hour >= 12 && hour < 18) {
    greeting = greetings.goodAfternoon
  } else if (hour >= 18 && hour < 22) {
    greeting = greetings.goodEvening
  } else {
    greeting = greetings.goodNight
  }
  
  const messages = [
    `${greeting} ${name}! Ready to explore your collection?`,
    `${greeting} ${name}! What would you like to listen to today?`,
    `${greeting} ${name}! Your music is waiting for you.`,
    `${greeting} ${name}! Let us keep growing your collection.`,
  ]
  
  return messages[Math.floor(Math.random() * messages.length)]
}
---

<Layout
  title={title}
  description={description}
  showDashboardHeader={false}
  sectionTitle={currentSection.title}
  sectionDescription={currentSection.description}
  showBottomBar={true}
  showFooter={false}
>
  <!-- App Header (mobile seulement) -->
  <div class="md:hidden">
    <AppHeader
      userName={user?.name || null}
      userEmail={user?.email || null}
      userImageUrl={user?.image || null}
      currentLocale={locale}
      languageLabel={layoutT.appHeader.language}
      backToLibraryAria={layoutT.appHeader.backToLibraryAria}
      myProfileLabel={layoutT.appHeader.myProfile}
      settingsLabel={layoutT.appHeader.settings}
      signOutLabel={layoutT.appHeader.signOut}
      signInLabel={layoutT.appHeader.signIn}
      themeChangeAria={layoutT.sidebar.themeChangeAria}
      openProfileMenuAria={layoutT.appHeader.openProfileMenuAria}
      profileMenuAria={layoutT.appHeader.profileMenuAria}
      profileTitle={layoutT.appHeader.profileTitle}
    />
  </div>

  <div class="flex">
    <!-- Sidebar (desktop only) -->
    <Sidebar
      userName={user?.name || null}
      userEmail={user?.email || null}
      userImageUrl={user?.image || null}
      currentLocale={locale}
      languageLabel={layoutT.appHeader.language}
      themeTitle={layoutT.sidebar.themeTitle}
      themeDescription={layoutT.sidebar.themeDescription}
      settingsLabel={layoutT.sidebar.settings}
      signOutLabel={layoutT.sidebar.signOut}
      userFallback={layoutT.sidebar.userFallback}
      closeMenuLabel={layoutT.sidebar.closeMenuLabel}
      themeChangeAria={layoutT.sidebar.themeChangeAria}
      siteNavAria={layoutT.sidebar.siteNavAria}
      navLabels={layoutT.nav}
    />

    <!-- Main content area (min-w-0 allows flex child to shrink on mobile, avoiding horizontal overflow) -->
    <div class="min-w-0 flex-1 lg:ml-0">
      <div class="mx-auto w-full max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
        <!-- Toggle sidebar (tablette uniquement : 768–1024) -->
        <div class="hidden md:flex lg:hidden mb-4">
          <button
            type="button"
            id="sidebar-toggle-btn"
            class="flex items-center justify-center gap-2 rounded-xl border border-border/30 bg-surface-elevated/95 px-4 py-2.5 text-sm font-medium text-neutral shadow-sm transition-colors hover:bg-primary/10 hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50"
            aria-label={layoutT.sidebar.openMenuLabel}
            aria-expanded="false"
          >
            <Menu size={20} class="fill-none stroke-2 shrink-0" />
            <span>{layoutT.sidebar.menuLabel}</span>
          </button>
        </div>
        <!-- Logo et titre (desktop seulement) -->
        <div class="hidden md:block mb-6">
          <!-- Logo animé -->
          <div class="flex flex-col items-center mb-4">
            <a href="/library" aria-label={layoutT.appHeader.backToLibraryAria} class="logo-animated">
              <Logo size="2xl" showText={false} animated={true} noHover={false} backToHomeAria={layoutT.common.backToHome} />
            </a>
          </div>
          {!isHomePage && (
            <>
              <!-- Titre de section -->
              <h1 class="text-3xl md:text-4xl font-bold text-neutral text-center mb-2">
                {currentSection.title}
              </h1>
              {currentSection.description && (
                <p class="text-muted text-center">
                  {currentSection.description}
                </p>
              )}
            </>
          )}
        </div>

        <!-- Message de bienvenue personnalisé (desktop seulement) -->
        {user && (
          <div class="hidden md:block mb-6">
            <div class="glass-card rounded-xl p-4 bg-gradient-resonance-subtle border border-primary/20">
              <p class="text-center text-neutral font-medium">
                {getWelcomeMessage(user.name, user.email, layoutT.common.greetings)}
              </p>
            </div>
          </div>
        )}

        <!-- Page content -->
        <div class="fade-in transition-colors duration-200">
          <slot />
        </div>
      </div>
    </div>
  </div>

  <!-- Toast notifications -->
  <Toast closeAria={layoutT.common.closeAria} />

  <!-- Confirm Dialog -->
  <ConfirmDialog />

  <!-- Keyboard shortcuts -->
  <KeyboardShortcuts shortcutsHint={layoutT.common.shortcutsHint} />

  <!-- Barcode Scanner (mobile only) -->
  <BarcodeScanner barcodeMessages={layoutT.barcodeScanner} />

  </Layout>

<style>
  /* Styles spécifiques au dashboard */
  .fade-in {
    animation: fadeIn 0.6s ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Animation du logo sur desktop */
  .logo-animated {
    animation: logoFloat 3s ease-in-out infinite;
  }

  @keyframes logoFloat {
    0%, 100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-10px) scale(1.05);
    }
  }

  .logo-animated:hover {
    animation-play-state: paused;
    transform: scale(1.1);
  }
</style>
