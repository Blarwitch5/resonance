---
import Heart from '@lucide/astro/icons/heart'
import ShoppingCart from '@lucide/astro/icons/shopping-cart'
import BarChart from '@lucide/astro/icons/chart-bar'
import Library from '@lucide/astro/icons/library'
import type { ComponentProps } from 'astro/types'

type ProfileTabsProps = {
  activeTab?: string
  slot?: string
}

const { activeTab = 'favorites', slot: defaultSlot } = Astro.props as ProfileTabsProps
---

<div class="min-w-0 space-y-6">
  <!-- Tabs -->
  <div class="border-b border-border pb-0">
    <div
      id="profile-tablist"
      class="flex min-w-0 gap-2 overflow-x-auto px-4 -mx-4 pb-1 no-scrollbar snap-x snap-mandatory md:mx-0 md:px-0 md:overflow-visible md:snap-none"
      role="tablist"
      aria-label="Sections du profil"
    >
      <button
        type="button"
        data-tab="favorites"
        class="tab-btn flex shrink-0 items-center gap-2 rounded-full border border-transparent px-4 py-2 text-sm font-medium transition-all hover:bg-surface hover:text-primary md:rounded-t-lg md:border-b-2 md:border-b-transparent md:border-none md:px-6 md:py-3"
        role="tab"
        id="tab-favorites"
        aria-controls="panel-favorites"
        aria-selected="false"
        tabindex="-1"
      >
        <Heart size={18} class="fill-none stroke-2" />
        <span>Favorites</span>
      </button>

      <button
        type="button"
        data-tab="wishlist"
        class="tab-btn flex shrink-0 items-center gap-2 rounded-full border border-transparent px-4 py-2 text-sm font-medium transition-all hover:bg-surface hover:text-primary md:rounded-t-lg md:border-b-2 md:border-b-transparent md:border-none md:px-6 md:py-3"
        role="tab"
        id="tab-wishlist"
        aria-controls="panel-wishlist"
        aria-selected="false"
        tabindex="-1"
      >
        <ShoppingCart size={18} class="fill-none stroke-2" />
        <span>Wishlist</span>
      </button>

      <button
        type="button"
        data-tab="statistics"
        class="tab-btn flex shrink-0 items-center gap-2 rounded-full border border-transparent px-4 py-2 text-sm font-medium transition-all hover:bg-surface hover:text-primary md:rounded-t-lg md:border-b-2 md:border-b-transparent md:border-none md:px-6 md:py-3"
        role="tab"
        id="tab-statistics"
        aria-controls="panel-statistics"
        aria-selected="false"
        tabindex="-1"
      >
        <BarChart size={18} class="fill-none stroke-2" />
        <span>Statistics</span>
      </button>

      <button
        type="button"
        data-tab="all-formats"
        class="tab-btn flex shrink-0 items-center gap-2 rounded-full border border-transparent px-4 py-2 text-sm font-medium transition-all hover:bg-surface hover:text-primary md:rounded-t-lg md:border-b-2 md:border-b-transparent md:border-none md:px-6 md:py-3"
        role="tab"
        id="tab-all-formats"
        aria-controls="panel-all-formats"
        aria-selected="false"
        tabindex="-1"
      >
        <Library size={18} class="fill-none stroke-2" />
        <span>All Formats</span>
      </button>
    </div>
  </div>

  <!-- Tab content -->
  <div id="tab-content" class="min-w-0">
    <div
      id="panel-favorites"
      data-tab-content="favorites"
      role="tabpanel"
      aria-labelledby="tab-favorites"
      tabindex="0"
      style="display: none;"
    >
      <slot name="favorites" />
    </div>
    <div
      id="panel-wishlist"
      data-tab-content="wishlist"
      role="tabpanel"
      aria-labelledby="tab-wishlist"
      tabindex="0"
      style="display: none;"
    >
      <slot name="wishlist" />
    </div>
    <div
      id="panel-statistics"
      data-tab-content="statistics"
      role="tabpanel"
      aria-labelledby="tab-statistics"
      tabindex="0"
      style="display: none;"
    >
      <slot name="statistics" />
    </div>
    <div
      id="panel-all-formats"
      data-tab-content="all-formats"
      role="tabpanel"
      aria-labelledby="tab-all-formats"
      tabindex="0"
      style="display: none;"
    >
      <slot name="all-formats" />
    </div>
  </div>
</div>

<script>
  (function() {
    function initTabs() {
      const tabList = document.getElementById('profile-tablist')
      const tabs = tabList ? tabList.querySelectorAll('.tab-btn') : document.querySelectorAll('.tab-btn')
      const tabContent = document.getElementById('tab-content')
      
      if (!tabContent) {
        setTimeout(initTabs, 100)
        return
      }
      
      // Chercher les slots par data-tab-content (plus fiable que [slot])
      const slotElements = tabContent.querySelectorAll('[data-tab-content]')
      
      // Si aucun slot trouvé, essayer avec [slot] comme fallback
      if (slotElements.length === 0) {
        const fallbackSlots = tabContent.querySelectorAll('[slot]')
        if (fallbackSlots.length > 0) {
          fallbackSlots.forEach(function(slot) {
            const slotName = slot.getAttribute('slot')
            if (slotName) {
              slot.setAttribute('data-tab-content', slotName)
            }
          })
        }
      }
      
      // Récupérer les slots (peut-être mis à jour)
      const finalSlots = tabContent.querySelectorAll('[data-tab-content]')
      
      const showTab = (tabName: string | null, focusTab: boolean = false) => {
        if (!tabName) return
        
        // Mettre à jour les boutons
        tabs.forEach(function(tab) {
          const icon = tab.querySelector('svg')
          if (tab.getAttribute('data-tab') === tabName) {
            tab.classList.add('active')
            tab.classList.add('border-primary')
            tab.classList.add('text-primary')
            tab.classList.remove('border-transparent')
            tab.setAttribute('aria-selected', 'true')
            tab.setAttribute('tabindex', '0')
            if (focusTab && tab instanceof HTMLElement) {
              tab.focus()
            }
            if (icon) {
              icon.classList.add('fill-none', 'stroke-2', 'text-primary', 'stroke-primary')
              icon.classList.remove('text-muted', 'stroke-muted')
            }
          } else {
            tab.classList.remove('active')
            tab.classList.remove('border-primary')
            tab.classList.remove('text-primary')
            tab.classList.add('border-transparent')
            tab.setAttribute('aria-selected', 'false')
            tab.setAttribute('tabindex', '-1')
            if (icon) {
              icon.classList.add('fill-none', 'stroke-2', 'text-muted', 'stroke-muted')
              icon.classList.remove('text-primary', 'stroke-primary')
            }
          }
        })

        // Afficher le contenu correspondant
        ;(finalSlots as NodeListOf<HTMLElement>).forEach(function(slot) {
          const slotName = slot.getAttribute('data-tab-content')
          const element = slot
          if (slotName === tabName) {
            element.classList.remove('hidden')
            element.classList.add('active')
            element.style.display = 'block'
          } else {
            element.classList.add('hidden')
            element.classList.remove('active')
            element.style.display = 'none'
          }
        })
      }

      // Récupérer le tab depuis l'URL ou utiliser le premier par défaut
      function getTabFromURL() {
        const urlParams = new URLSearchParams(window.location.search)
        const tabParam = urlParams.get('tab')
        if (tabParam) {
          // Vérifier que le tab existe
          const tabExists = Array.from(tabs).some(function(tab) {
            return tab.getAttribute('data-tab') === tabParam
          })
          if (tabExists) {
            return tabParam
          }
        }
        return null
      }

      // Initialiser avec le tab de l'URL ou le premier tab par défaut
      const urlTab = getTabFromURL()
      const defaultTab = tabs.length > 0 ? tabs[0].getAttribute('data-tab') : null
      const initialTab = urlTab || defaultTab
      
      if (initialTab) {
        showTab(initialTab)
      }

      // Gérer les clics
      tabs.forEach(function(tab) {
        tab.addEventListener('click', function() {
          const tabName = tab.getAttribute('data-tab')
          if (tabName) {
            showTab(tabName, true)
            // Mettre à jour l'URL sans recharger la page
            const url = new URL(window.location.href)
            url.searchParams.set('tab', tabName)
            window.history.pushState({}, '', url.toString())
          }
        })
      })

      // Navigation clavier entre onglets (flèches, Home, End)
      if (tabList) {
        tabList.addEventListener('keydown', function(event: KeyboardEvent) {
          const currentTab = document.activeElement
          const tabArray = Array.from(tabs) as HTMLElement[]
          const currentIndex = tabArray.indexOf(currentTab as HTMLElement)

          if (currentIndex === -1) return

          let nextIndex = currentIndex

          switch (event.key) {
            case 'ArrowRight':
            case 'Right':
              event.preventDefault()
              nextIndex = (currentIndex + 1) % tabArray.length
              break
            case 'ArrowLeft':
            case 'Left':
              event.preventDefault()
              nextIndex = (currentIndex - 1 + tabArray.length) % tabArray.length
              break
            case 'Home':
              event.preventDefault()
              nextIndex = 0
              break
            case 'End':
              event.preventDefault()
              nextIndex = tabArray.length - 1
              break
            default:
              return
          }

          const nextTab = tabArray[nextIndex]
          const nextTabName = nextTab.getAttribute('data-tab')
          if (nextTabName) {
            showTab(nextTabName, true)
            const url = new URL(window.location.href)
            url.searchParams.set('tab', nextTabName)
            window.history.pushState({}, '', url.toString())
          }
        })
      }
    }

    // Initialiser au chargement
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTabs)
    } else {
      initTabs()
    }

    // Réinitialiser lors de la navigation Astro
    document.addEventListener('astro:page-load', initTabs)
  })()
</script>

<style>
  .tab-btn {
    color: var(--color-muted);
  }
  
  .tab-btn.active {
    border-bottom-color: var(--color-primary) !important;
    color: var(--color-primary);
    background-color: transparent;
  }
  
  .tab-btn:hover {
    background-color: var(--color-surface);
  }
  
  .tab-btn.active:hover {
    background-color: transparent;
  }
  
  .tab-btn svg {
    fill: none;
    stroke-width: 2;
    stroke: currentColor;
  }
  
  .tab-btn.active svg {
    stroke: var(--color-primary);
  }
  
  /* Amélioration desktop pour les tabs */
  @media (min-width: 768px) {
    .tab-btn {
      padding: 0.75rem 1.5rem;
    }
    
    .tab-btn:hover {
      background-color: var(--color-surface);
    }
  }
  
  /* Cacher tous les slots par défaut */
  #tab-content > [data-tab-content],
  #tab-content > [slot] {
    display: none;
  }
  
  /* Afficher le slot actif */
  #tab-content > [data-tab-content].active,
  #tab-content > [slot].active {
    display: block !important;
  }
  
  /* Fallback: afficher le premier slot (favorites) par défaut si le script ne s'exécute pas */
  #tab-content > [data-tab-content="favorites"]:not(.active),
  #tab-content > [slot="favorites"]:not(.active) {
    display: block;
  }
</style>

