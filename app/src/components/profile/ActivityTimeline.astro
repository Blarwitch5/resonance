---
import Plus from '@lucide/astro/icons/plus'
import Library from '@lucide/astro/icons/library'
import Heart from '@lucide/astro/icons/heart'
import Star from '@lucide/astro/icons/star'
import OptimizedImage from '../ui/OptimizedImage.astro'

type Activity =
  | { type: 'item_added'; date: Date | string; data: { id: string; title: string; artist: string; coverUrl: string | null; collection?: { name: string; slug: string } } }
  | { type: 'collection_created'; date: Date | string; data: { id: string; name: string; slug: string } }
  | { type: 'wishlist_added'; date: Date | string; data: { id: string; title: string; artist: string; coverUrl: string | null } }
  | { type: 'item_favorited'; date: Date | string; data: { id: string; title: string; artist: string; coverUrl: string | null; collection?: { name: string; slug: string } } }

type ActivityTimelineProps = {
  activities: Activity[]
}

const { activities } = Astro.props as ActivityTimelineProps

function formatRelativeTime(date: Date | string): string {
  const now = new Date()
  const diffMs = now.getTime() - new Date(date).getTime()
  const diffMinutes = Math.floor(diffMs / 60000)
  const diffHours = Math.floor(diffMs / 3600000)
  const diffDays = Math.floor(diffMs / 86400000)

  if (diffMinutes < 1) return "Just now"
  if (diffMinutes < 60) return `${diffMinutes} min ago`
  if (diffHours < 24) return `${diffHours}h ago`
  if (diffDays < 7) return `${diffDays}d ago`
  return new Date(date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' })
}

function getActivityIcon(type: Activity['type']) {
  switch (type) {
    case 'item_added':
      return Plus
    case 'collection_created':
      return Library
    case 'wishlist_added':
      return Heart
    case 'item_favorited':
      return Star
    default:
      return Plus
  }
}

function getActivityLabel(type: Activity['type']): string {
  switch (type) {
    case 'item_added':
      return 'Album added'
    case 'collection_created':
      return 'Collection created'
    case 'wishlist_added':
      return 'Added to wishlist'
    case 'item_favorited':
      return 'Added to favorites'
    default:
      return 'Activity'
  }
}

function getActivityColor(type: Activity['type']): string {
  switch (type) {
    case 'item_added':
      return 'bg-primary/20 text-primary border-primary/30'
    case 'collection_created':
      return 'bg-accent2/20 text-accent2 border-accent2/30'
    case 'wishlist_added':
      return 'bg-pink-500/20 text-pink-400 border-pink-500/30'
    case 'item_favorited':
      return 'bg-yellow-500/20 text-yellow-400 border-yellow-500/30'
    default:
      return 'bg-surface text-muted border-border'
  }
}
---

{activities.length === 0 ? (
  <div class="rounded-xl border border-dashed border-border bg-surface p-8 text-center">
    <p class="text-muted">No recent activity.</p>
    <p class="mt-1 text-sm text-muted">Your additions and creations will appear here.</p>
  </div>
) : (
  <ul class="space-y-0" role="list" aria-label="Recent activity">
    {activities.map((activity, index) => {
      const Icon = getActivityIcon(activity.type)
      const label = getActivityLabel(activity.type)
      const colorClass = getActivityColor(activity.type)
      const dateLabel = formatRelativeTime(activity.date)

      return (
        <li
          class="relative flex gap-4 pb-6 last:pb-0"
          style={index < activities.length - 1 ? 'border-left: 2px solid var(--color-border); margin-left: 11px; padding-left: 24px;' : 'margin-left: 11px; padding-left: 24px;'}
        >
          <span
            class={`flex h-6 w-6 shrink-0 items-center justify-center rounded-full border ${colorClass}`}
            aria-hidden="true"
          >
            <Icon size={12} class="fill-none stroke-2" />
          </span>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium text-neutral">
              {label}
              {activity.type === 'item_added' && activity.data.collection && (
                <span class="text-muted"> → {activity.data.collection.name}</span>
              )}
              {activity.type === 'item_favorited' && activity.data.collection && (
                <span class="text-muted"> → {activity.data.collection.name}</span>
              )}
            </p>
            <p class="mt-0.5 text-xs text-muted">{dateLabel}</p>
            {(activity.type === 'item_added' || activity.type === 'wishlist_added' || activity.type === 'item_favorited') && (
              <div class="mt-2 flex items-center gap-3">
                {(activity.data as { coverUrl?: string | null }).coverUrl ? (
                  <div class="h-10 w-10 shrink-0 overflow-hidden rounded bg-surface">
                    <OptimizedImage
                      src={(activity.data as { coverUrl: string }).coverUrl}
                      alt={`Cover: ${(activity.data as { title: string }).title} by ${(activity.data as { artist: string }).artist}`}
                      width={40}
                      height={40}
                      loading="lazy"
                      class="h-full w-full object-cover"
                    />
                  </div>
                ) : (
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded bg-surface text-muted">
                    <Library size={18} class="fill-none stroke-2" />
                  </div>
                )}
                <div class="min-w-0">
                  <p class="truncate text-sm text-neutral">{(activity.data as { title: string }).title}</p>
                  <p class="truncate text-xs text-muted">{(activity.data as { artist: string }).artist}</p>
                </div>
              </div>
            )}
            {activity.type === 'collection_created' && (
              <a
                href={`/collections/${(activity.data as { slug: string }).slug}`}
                class="mt-2 inline-block text-sm font-medium text-primary hover:underline"
              >
                {(activity.data as { name: string }).name}
              </a>
            )}
          </div>
        </li>
      )
    })}
  </ul>
)}