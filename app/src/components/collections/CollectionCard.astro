---
import Folder from '@lucide/astro/icons/folder'
import Disc3 from '@lucide/astro/icons/disc-3'
import Disc2 from '@lucide/astro/icons/disc-2'
import CassetteTape from '@lucide/astro/icons/cassette-tape'
import type { Collection } from '@prisma/client'
import type { CollectionsMessages } from '../../i18n/collections'
import OptimizedImage from '../ui/OptimizedImage.astro'

type CollectionCardProps = {
  collection: Collection & {
    itemCount?: number
    vinylCount?: number
    cdCount?: number
    cassetteCount?: number
    favoriteCount?: number
    coverImage?: string | null
  }
  cardLabels?: CollectionsMessages['card']
}

const defaultCardLabels = {
  album: 'album',
  albums: 'albums',
  vinylTitle: 'Vinyl',
  cdTitle: 'CD',
  cassetteTitle: 'Cassette',
} as const

const { collection, cardLabels = defaultCardLabels } = Astro.props as CollectionCardProps
const card = cardLabels
const totalItems =
  collection.itemCount ??
  (collection.vinylCount ?? 0) + (collection.cdCount ?? 0) + (collection.cassetteCount ?? 0)
---

<a
  href={`/collections/${collection.slug}`}
  class="group glass-card overflow-hidden rounded-2xl transition-all hover:scale-105"
>
  <!-- Cover ou placeholder -->
  <div class="aspect-video overflow-hidden bg-linear-to-br from-primary/20 to-secondary/20">
    {collection.coverImage ? (
      <OptimizedImage
        src={collection.coverImage}
        alt={collection.name}
        width={800}
        height={450}
        loading="lazy"
        aspectRatio="auto"
        class="h-full w-full object-cover"
      />
    ) : (
      <div class="flex h-full items-center justify-center">
        <Folder size={48} class="fill-none stroke-2 text-primary stroke-primary opacity-50" />
      </div>
    )}
  </div>

  <!-- Info -->
  <div class="p-6">
    <h3 class="mb-2 text-xl font-semibold text-neutral line-clamp-1">{collection.name}</h3>
    {collection.description && (
      <p class="mb-4 line-clamp-2 text-sm text-muted">{collection.description}</p>
    )}

    <!-- Stats -->
    <div class="flex flex-wrap items-center gap-3 text-sm">
      <span class="font-medium text-neutral">
        {totalItems} {totalItems === 1 ? card.album : card.albums}
      </span>
      <span class="text-muted">•</span>
      <span class="flex items-center gap-1" title={card.vinylTitle}>
        <Disc3 size={16} class="fill-none stroke-2 text-format-vinyl stroke-format-vinyl" aria-hidden="true" />
        <span class="text-muted">{collection.vinylCount ?? 0}</span>
      </span>
      <span class="flex items-center gap-1" title={card.cdTitle}>
        <Disc2 size={16} class="fill-none stroke-2 text-format-cd stroke-format-cd" aria-hidden="true" />
        <span class="text-muted">{collection.cdCount ?? 0}</span>
      </span>
      <span class="flex items-center gap-1" title={card.cassetteTitle}>
        <CassetteTape size={16} class="fill-none stroke-2 text-format-cassette stroke-format-cassette" aria-hidden="true" />
        <span class="text-muted">{collection.cassetteCount ?? 0}</span>
      </span>
    </div>
  </div>
</a>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

