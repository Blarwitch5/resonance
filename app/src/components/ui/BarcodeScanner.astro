---
import X from '@lucide/astro/icons/x'
import Camera from '@lucide/astro/icons/camera'
import Pencil from '@lucide/astro/icons/pencil'
import { getLayoutMessages } from '../../i18n/layout'

type BarcodeMessages = ReturnType<typeof getLayoutMessages>['barcodeScanner']
type Props = { barcodeMessages?: BarcodeMessages }
const defaultMessages = getLayoutMessages('en').barcodeScanner
const msg = (Astro.props as Props).barcodeMessages ?? defaultMessages
---

<!-- Barcode Scanner Button/Modal (mobile + desktop) -->
<div id="barcode-scanner-container" class="fixed bottom-24 right-4 z-40 md:bottom-8 md:right-8">
  <!-- Scanner Button (FAB) -->
  <button
    id="barcode-scanner-btn"
    type="button"
    class="barcode-fab bg-gradient-resonance hover:bg-gradient-resonance-hover flex h-14 w-14 items-center justify-center rounded-full shadow-lg transition-all duration-300 hover:scale-110 md:h-12 md:w-12"
    aria-label={msg.scanAria}
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-white stroke-white md:h-5 md:w-5" aria-hidden="true">
      <path d="M3 7V5a2 2 0 0 1 2-2h2"/>
      <path d="M17 3h2a2 2 0 0 1 2 2v2"/>
      <path d="M21 17v2a2 2 0 0 1-2 2h-2"/>
      <path d="M7 21H5a2 2 0 0 1-2-2v-2"/>
      <path d="M8 7v10"/>
      <path d="M12 7v10"/>
      <path d="M17 7v10"/>
    </svg>
  </button>
</div>

<!-- Choice modal: camera or manual input -->
<div
  id="barcode-choice-modal"
  class="barcode-modal fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4 opacity-0 pointer-events-none invisible transition-opacity data-[open=true]:opacity-100 data-[open=true]:pointer-events-auto data-[open=true]:visible"
  data-open="false"
  role="dialog"
  aria-labelledby="barcode-choice-title"
  aria-modal="true"
>
  <div class="w-full max-w-sm rounded-2xl border border-border/30 bg-surface-elevated p-6 shadow-xl">
    <h2 id="barcode-choice-title" class="text-lg font-semibold text-neutral mb-2">{msg.choiceTitle}</h2>
    <p class="text-sm text-muted mb-6">{msg.choiceDescription}</p>
    <div class="flex flex-col gap-3">
      <button
        type="button"
        id="barcode-choice-camera"
        class="btn-primary w-full rounded-xl py-3 text-white flex items-center justify-center gap-2 group"
      >
        <Camera
          size={18}
          class="fill-none stroke-2 text-white stroke-white group-hover:text-neutral group-hover:stroke-neutral"
        />
        <span class="text-white group-hover:text-neutral">{msg.useCamera}</span>
      </button>
      <button
        type="button"
        id="barcode-choice-manual"
        class="btn-secondary-surface w-full rounded-xl py-3 flex items-center justify-center gap-2"
      >
        <Pencil size={18} class="fill-none stroke-2" />
        <span>{msg.enterManually}</span>
      </button>
    </div>
    <button
      type="button"
      id="barcode-choice-close"
      class="mt-4 w-full text-sm text-muted hover:text-neutral transition-colors"
      aria-label={msg.closeAria}
    >
      {msg.cancel}
    </button>
  </div>
</div>

<!-- Manual input modal -->
<div
  id="barcode-manual-modal"
  class="barcode-modal fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4 opacity-0 pointer-events-none invisible transition-opacity data-[open=true]:opacity-100 data-[open=true]:pointer-events-auto data-[open=true]:visible"
  data-open="false"
  role="dialog"
  aria-labelledby="barcode-manual-title"
  aria-modal="true"
>
  <div class="w-full max-w-sm rounded-2xl border border-border/30 bg-surface-elevated p-6 shadow-xl">
    <h2 id="barcode-manual-title" class="text-lg font-semibold text-neutral mb-2">{msg.manualTitle}</h2>
    <p class="text-sm text-muted mb-4">{msg.manualHint}</p>
    <input
      type="text"
      id="barcode-manual-input"
      class="input w-full rounded-xl border border-border bg-background px-4 py-3 text-neutral placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
      placeholder={msg.manualPlaceholder}
      inputmode="numeric"
      autocomplete="off"
      aria-label={msg.manualAria}
    />
    <p id="barcode-manual-error" class="mt-2 text-sm text-error hidden" role="alert"></p>
    <div class="mt-6 flex gap-3">
      <button type="button" id="barcode-manual-cancel" class="btn-secondary-surface flex-1 rounded-xl py-3">
        {msg.cancel}
      </button>
      <button type="button" id="barcode-manual-submit" class="btn-primary flex-1 rounded-xl py-3">
        {msg.search}
      </button>
    </div>
  </div>
</div>

<!-- Scanner Modal -->
<div
  id="barcode-scanner-modal"
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/90 backdrop-blur-sm p-4 opacity-0 pointer-events-none invisible transition-opacity data-[open=true]:opacity-100 data-[open=true]:pointer-events-auto data-[open=true]:visible"
  data-open="false"
  role="dialog"
  aria-modal="true"
  aria-labelledby="barcode-scanner-title"
>
  <!-- Close Button -->
  <button
    type="button"
    id="close-scanner"
    class="absolute right-4 top-4 z-10 rounded-full bg-white/10 p-3 text-white backdrop-blur-sm transition-all hover:bg-white/20"
    aria-label={msg.closeScannerAria}
  >
    <X size={24} />
  </button>

  <!-- Scanner View -->
  <div class="relative w-full max-w-md md:max-w-lg">
    <h2 id="barcode-scanner-title" class="sr-only">{msg.scannerTitle}</h2>
    <!-- Video Container -->
    <div id="scanner-video-container" class="relative aspect-square overflow-hidden rounded-2xl">
      <video
        id="scanner-video"
        class="h-full w-full object-cover"
        autoplay
        playsinline
        muted
      ></video>
      <!-- Scanning Overlay -->
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="relative">
          <!-- Scanning Frame -->
          <div class="h-64 w-64 rounded-lg border-4 border-primary shadow-2xl">
            <div class="absolute -top-1 left-1/2 h-2 w-16 -translate-x-1/2 rounded-full bg-primary"></div>
            <div class="absolute -bottom-1 left-1/2 h-2 w-16 -translate-x-1/2 rounded-full bg-primary"></div>
            <div class="absolute -left-1 top-1/2 h-16 w-2 -translate-y-1/2 rounded-full bg-primary"></div>
            <div class="absolute -right-1 top-1/2 h-16 w-2 -translate-y-1/2 rounded-full bg-primary"></div>
          </div>
        </div>
      </div>
      <!-- Instructions -->
      <div class="absolute bottom-4 left-1/2 -translate-x-1/2 text-center text-white">
        <p class="text-sm font-medium">{msg.placeInFrame}</p>
      </div>
    </div>

    <!-- Result Display -->
    <div id="scanner-result" class="mt-4 hidden">
      <div class="glass-card rounded-xl p-4">
        <p class="text-sm text-muted">{msg.detectedBarcode}</p>
        <p id="scanned-barcode" class="mt-1 text-lg font-bold text-neutral"></p>
      </div>
    </div>
  </div>
</div>

<script type="application/json" id="barcode-scanner-messages" set:html={JSON.stringify(msg)}></script>
<script>
  const barcodeMsgEl = document.getElementById('barcode-scanner-messages')
  const parsed = (barcodeMsgEl && JSON.parse(barcodeMsgEl.textContent || '{}')) || {}
  const barcodeMsg = {
    noSupport: parsed.noSupport || 'Your browser does not support automatic scanning. Manual input is available.',
    cameraDenied: parsed.cameraDenied || 'Camera access denied.',
    cameraError: parsed.cameraError || 'Cannot access the camera.',
    albumFound: parsed.albumFound || 'Album found!',
    albumNotFound: parsed.albumNotFound || 'Album not found. Redirecting to explorer...',
    searchError: parsed.searchError || 'Search failed.',
    enterBarcode: parsed.enterBarcode || 'Please enter a barcode.',
    ...parsed,
  }
  let BarcodeDetector: unknown = null
  let stream: MediaStream | null = null
  let lastActiveElement: HTMLElement | null = null

  const hasNativeBarcodeDetector = 'BarcodeDetector' in window

  function rememberLastActiveElement() {
    if (!lastActiveElement && document.activeElement instanceof HTMLElement) {
      lastActiveElement = document.activeElement
    }
  }

  function restoreLastActiveElement() {
    if (lastActiveElement && typeof lastActiveElement.focus === 'function') {
      lastActiveElement.focus()
    }
    lastActiveElement = null
  }

  function trapFocusInModal(modalElement: HTMLElement, event: KeyboardEvent) {
    if (event.key !== 'Tab') return

    const focusableSelectors = [
      'button',
      '[href]',
      'input',
      'select',
      'textarea',
      '[tabindex]:not([tabindex="-1"])',
    ]

    const focusable = Array.from(
      modalElement.querySelectorAll(focusableSelectors.join(','))
    ).filter((element) => {
      const htmlElement = element
      return (
        htmlElement instanceof HTMLElement &&
        !htmlElement.hasAttribute('disabled') &&
        htmlElement.tabIndex !== -1 &&
        htmlElement.offsetParent !== null
      )
    })

    if (focusable.length === 0) {
      event.preventDefault()
      return
    }

    const firstElement = focusable[0] as HTMLElement
    const lastElement = focusable[focusable.length - 1] as HTMLElement
    const current = document.activeElement

    if (event.shiftKey) {
      if (current === firstElement || !modalElement.contains(current)) {
        event.preventDefault()
        lastElement.focus()
      }
    } else {
      if (current === lastElement || !modalElement.contains(current)) {
        event.preventDefault()
        firstElement.focus()
      }
    }
  }

  function openChoiceModal() {
    const choiceModal = document.getElementById('barcode-choice-modal')
    rememberLastActiveElement()
    choiceModal?.setAttribute('data-open', 'true')
    choiceModal?.setAttribute('aria-hidden', 'false')
    const primaryButton = document.getElementById('barcode-choice-camera')
    if (primaryButton && typeof primaryButton.focus === 'function') {
      primaryButton.focus()
    }
  }
  function closeChoiceModal() {
    const choiceModal = document.getElementById('barcode-choice-modal')
    choiceModal?.setAttribute('data-open', 'false')
    choiceModal?.setAttribute('aria-hidden', 'true')
    restoreLastActiveElement()
  }
  function openManualModal() {
    const manualModal = document.getElementById('barcode-manual-modal')
    const manualInput = document.getElementById('barcode-manual-input') as HTMLInputElement | null
    const manualError = document.getElementById('barcode-manual-error')
    rememberLastActiveElement()
    manualModal?.setAttribute('data-open', 'true')
    manualModal?.setAttribute('aria-hidden', 'false')
    if (manualInput) { manualInput.value = ''; manualInput.focus() }
    if (manualError) { manualError.classList.add('hidden'); manualError.textContent = '' }
  }
  function closeManualModal() {
    const manualModal = document.getElementById('barcode-manual-modal')
    manualModal?.setAttribute('data-open', 'false')
    manualModal?.setAttribute('aria-hidden', 'true')
    restoreLastActiveElement()
  }
  function closeScanner() {
    if (stream) {
      stream.getTracks().forEach((track: MediaStreamTrack) => track.stop())
      stream = null
    }
    const video = document.getElementById('scanner-video') as HTMLVideoElement | null
    const scannerModal = document.getElementById('barcode-scanner-modal')
    const scannerResult = document.getElementById('scanner-result')
    if (video) video.srcObject = null
    scannerModal?.setAttribute('data-open', 'false')
    scannerModal?.setAttribute('aria-hidden', 'true')
    scannerResult?.classList.add('hidden')
    restoreLastActiveElement()
  }

  async function runCameraFlow() {
    const video = document.getElementById('scanner-video') as HTMLVideoElement | null
    const scannerModal = document.getElementById('barcode-scanner-modal')
    if (!video || !scannerModal) return
    try {
      const tryConstraints = [
        { video: { facingMode: 'environment', width: { ideal: 1280 }, height: { ideal: 720 } } },
        { video: { facingMode: 'user', width: { ideal: 1280 }, height: { ideal: 720 } } },
        { video: { width: { ideal: 1280 }, height: { ideal: 720 } } },
      ]
      let lastError = null
      for (const constraints of tryConstraints) {
        try {
          stream = await navigator.mediaDevices.getUserMedia(constraints)
          break
        } catch (err) { lastError = err }
      }
      if (!stream) throw lastError ?? new Error('Camera access denied')
      video.srcObject = stream
      scannerModal.setAttribute('data-open', 'true')
      scannerModal.setAttribute('aria-hidden', 'false')
      rememberLastActiveElement()
      const closeButton = document.getElementById('close-scanner')
      if (closeButton && typeof closeButton.focus === 'function') {
        closeButton.focus()
      }
      if (hasNativeBarcodeDetector) {
        const BD = (window as Window & { BarcodeDetector?: new (opts: { formats: string[] }) => unknown }).BarcodeDetector
        if (BD) BarcodeDetector = new BD({ formats: ['ean_13', 'ean_8', 'upc_a', 'upc_e', 'code_128'] })
        startNativeDetection(video)
      } else {
        if (window.toast) window.toast.info(barcodeMsg.noSupport)
        closeScanner()
        openManualModal()
      }
    } catch (error: unknown) {
      const err = error as { name?: string; message?: string } | undefined
      const isDenied = err?.name === 'NotAllowedError' || (typeof err?.message === 'string' && err.message.includes('Permission denied'))
      const toastMessage = isDenied ? barcodeMsg.cameraDenied : barcodeMsg.cameraError
      if (window.toast) window.toast.error(toastMessage)
      console.error('Error accessing camera:', err)
      openManualModal()
    }
  }

  function startNativeDetection(videoEl: HTMLVideoElement) {
    if (!BarcodeDetector) return
    const detector = BarcodeDetector as { detect: (el: HTMLVideoElement) => Promise<Array<{ rawValue: string }>> }
    const detectBarcode = async () => {
      try {
        if (!detector || !videoEl) return
        const barcodes = await detector.detect(videoEl)
        if (barcodes.length > 0) {
          handleBarcodeDetected(barcodes[0].rawValue)
        }
      } catch (error) { console.error('Barcode detection error:', error) }
      requestAnimationFrame(detectBarcode)
    }
    videoEl.addEventListener('loadedmetadata', () => detectBarcode())
  }

  async function handleBarcodeDetected(barcodeValue: string) {
    const scannedBarcode = document.getElementById('scanned-barcode')
    const scannerResult = document.getElementById('scanner-result')
    if (scannedBarcode) scannedBarcode.textContent = barcodeValue
    scannerResult?.classList.remove('hidden')
    if (stream) {
      stream.getTracks().forEach((track: MediaStreamTrack) => track.stop())
    }
    try {
      const searchResponse = await fetch(`/api/discogs/search-by-barcode?barcode=${encodeURIComponent(barcodeValue)}`)
      if (searchResponse.ok) {
        const data = await searchResponse.json()
        if (data.found && data.result) {
          const modal = document.getElementById('add-to-collection-modal')
          if (modal) {
            modal.setAttribute('data-discogs-id', data.result.id.toString())
            modal.classList.remove('hidden')
            closeScanner()
            if (window.toast) window.toast.success(barcodeMsg.albumFound)
          } else {
            closeScanner()
            window.location.href = `/explorer?discogs=${data.result.id}`
          }
        } else {
          if (window.toast) window.toast.info(barcodeMsg.albumNotFound)
          setTimeout(() => {
            window.location.href = `/explorer?barcode=${encodeURIComponent(barcodeValue)}`
            closeScanner()
          }, 2000)
        }
      }
    } catch (error) {
      console.error('Error searching for barcode:', error)
      if (window.toast) window.toast.error(barcodeMsg.searchError)
      setTimeout(() => {
        window.location.href = `/explorer?barcode=${encodeURIComponent(barcodeValue)}`
        closeScanner()
      }, 2000)
    }
  }

  document.addEventListener('click', async function(event: MouseEvent) {
    const target = event.target instanceof HTMLElement ? event.target : null
    if (!target) return
    if (target.closest('#barcode-scanner-btn')) {
      event.preventDefault()
      openChoiceModal()
      return
    }
    if (target.closest('#barcode-choice-camera')) {
      event.preventDefault()
      closeChoiceModal()
      await runCameraFlow()
      return
    }
    if (target.closest('#barcode-choice-manual')) {
      event.preventDefault()
      closeChoiceModal()
      openManualModal()
      return
    }
    if (target.closest('#barcode-choice-close') || target.id === 'barcode-choice-modal') {
      event.preventDefault()
      closeChoiceModal()
      return
    }
    if (target.closest('#barcode-manual-submit')) {
      event.preventDefault()
      const manualInput = document.getElementById('barcode-manual-input')
      const manualError = document.getElementById('barcode-manual-error')
      const value = (manualInput instanceof HTMLInputElement ? manualInput.value : '').trim()
      if (!value) {
        if (manualError) {
          manualError.textContent = barcodeMsg.enterBarcode
          manualError.classList.remove('hidden')
        }
        return
      }
      closeManualModal()
      window.location.href = `/explorer?barcode=${encodeURIComponent(value)}`
      return
    }
    if (target.closest('#barcode-manual-cancel') || target.id === 'barcode-manual-modal') {
      event.preventDefault()
      closeManualModal()
      return
    }
    if (target.closest('#close-scanner') || target.id === 'barcode-scanner-modal') {
      event.preventDefault()
      closeScanner()
    }
  })

  document.addEventListener('keydown', function(event: KeyboardEvent) {
    const target = event.target instanceof HTMLElement ? event.target : null
    if (target?.id === 'barcode-manual-input' && event.key === 'Enter') {
      event.preventDefault()
      document.getElementById('barcode-manual-submit')?.click()
    }
    const choiceModal = document.getElementById('barcode-choice-modal')
    const manualModal = document.getElementById('barcode-manual-modal')
    const scannerModal = document.getElementById('barcode-scanner-modal')
    const openModal =
      choiceModal?.getAttribute('data-open') === 'true' ? choiceModal :
      manualModal?.getAttribute('data-open') === 'true' ? manualModal :
      scannerModal?.getAttribute('data-open') === 'true' ? scannerModal : null
    if (event.key === 'Escape' && openModal) {
      event.preventDefault()
      if (openModal === choiceModal) closeChoiceModal()
      else if (openModal === manualModal) closeManualModal()
      else if (openModal === scannerModal) closeScanner()
      return
    }
    if (openModal instanceof HTMLElement) trapFocusInModal(openModal, event)
  })
</script>

<style>
  .barcode-fab {
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.3);
  }

  .barcode-fab:active {
    transform: scale(0.95);
  }

  #scanner-video-container {
    position: relative;
  }

  /* Scanning animation */
  @keyframes scanLine {
    0% {
      top: 0;
    }
    100% {
      top: 100%;
    }
  }

  #scanner-video-container::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(to bottom, transparent, var(--color-primary), transparent);
    animation: scanLine 2s linear infinite;
    pointer-events: none;
  }

  /* Modals visibles quand data-open="true" */
  #barcode-scanner-modal[data-open='true'],
  .barcode-modal[data-open='true'] {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
  }
</style>
