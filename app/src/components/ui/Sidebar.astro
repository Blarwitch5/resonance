---
import Library from '@lucide/astro/icons/library'
import Search from '@lucide/astro/icons/scan-search'
import User from '@lucide/astro/icons/user'
import ChevronRight from '@lucide/astro/icons/chevron-right'
import Settings from '@lucide/astro/icons/settings'
import LogOut from '@lucide/astro/icons/log-out'
import Layers from '@lucide/astro/icons/layers'
import Disc3 from '@lucide/astro/icons/disc-3'
import Disc2 from '@lucide/astro/icons/disc-2'
import CassetteTape from '@lucide/astro/icons/cassette-tape'
import Heart from '@lucide/astro/icons/heart'
import Bookmark from '@lucide/astro/icons/bookmark'
import BarChart3 from '@lucide/astro/icons/chart-bar'
import FolderOpen from '@lucide/astro/icons/folder-open'
import Logo from './Logo.astro'
import ThemeSwitcher from './ThemeSwitcher.astro'
import LanguageSwitcher from './LanguageSwitcher.astro'
import Avatar from './Avatar.astro'
import X from '@lucide/astro/icons/x'

type SidebarProps = {
  userName?: string | null
  userEmail?: string | null
  userImageUrl?: string | null
  currentLocale?: string
}

const { userName, userEmail, userImageUrl, currentLocale = 'en' } = Astro.props as SidebarProps

type NavItem = {
  id: string
  label: string
  icon: typeof Library
  href: string
  badge?: number
  children?: Array<{
    id: string
    label: string
    href: string
    icon?: typeof Layers
    badge?: number
  }>
}

// Fonction pour déterminer l'item actif
function getActiveItem(path: string): { parent: string | null; child: string | null } {
  if (path === '/' || path === '/index') {
    return { parent: null, child: null }
  }

  // Library
  if (path.startsWith('/library')) {
    if (path.includes('format=vinyl')) return { parent: 'library', child: 'vinyl' }
    if (path.includes('format=cassette')) return { parent: 'library', child: 'cassette' }
    if (path.includes('format=cd')) return { parent: 'library', child: 'cd' }
    return { parent: 'library', child: 'all' }
  }

  // Redirect from legacy /collection route
  if (path.startsWith('/collection') && !path.startsWith('/collections')) {
    if (path.includes('format=vinyl')) return { parent: 'library', child: 'vinyl' }
    if (path.includes('format=cassette')) return { parent: 'library', child: 'cassette' }
    if (path.includes('format=cd')) return { parent: 'library', child: 'cd' }
    return { parent: 'library', child: 'all' }
  }

  // Collections
  if (path.startsWith('/collections')) {
    return { parent: 'collections', child: null }
  }

  // Explorer
  if (path.includes('/explorer')) {
    return { parent: 'explorer', child: null }
  }

  // Profile
  if (path.includes('/profile')) {
    if (path.includes('tab=favorites')) return { parent: 'profile', child: 'favorites' }
    if (path.includes('tab=wishlist')) return { parent: 'profile', child: 'wishlist' }
    if (path.includes('tab=statistics')) return { parent: 'profile', child: 'statistics' }
    if (path.includes('tab=all-formats')) return { parent: 'profile', child: 'all-formats' }
    return { parent: 'profile', child: null }
  }

  return { parent: null, child: null }
}

const currentPath = Astro.url.pathname + Astro.url.search
const activeItem = getActiveItem(currentPath)

const navItems: NavItem[] = [
  {
    id: 'library',
    label: 'Library',
    icon: Library,
    href: '/library',
    children: [
      { id: 'all', label: 'All formats', href: '/library', icon: Layers },
      { id: 'vinyl', label: 'Vinyl', href: '/library?format=vinyl', icon: Disc3 },
      { id: 'cd', label: 'CD', href: '/library?format=cd', icon: Disc2 },
      { id: 'cassette', label: 'Cassette', href: '/library?format=cassette', icon: CassetteTape },
    ],
  },
  {
    id: 'collections',
    label: 'Collections',
    icon: FolderOpen,
    href: '/collections',
  },
  {
    id: 'explorer',
    label: 'Explore',
    icon: Search,
    href: '/explorer',
  },
  {
    id: 'profile',
    label: 'Profile',
    icon: User,
    href: '/profile',
    children: [
      { id: 'favorites', label: 'Favorites', href: '/profile?tab=favorites', icon: Heart },
      { id: 'wishlist', label: 'Wishlist', href: '/profile?tab=wishlist', icon: Bookmark },
      { id: 'statistics', label: 'Statistics', href: '/profile?tab=statistics', icon: BarChart3 },
      { id: 'all-formats', label: 'All formats', href: '/profile?tab=all-formats', icon: Layers },
    ],
  },
]
---

    <!-- Backdrop (tablet only, when sidebar is open) -->
<div
  data-sidebar-backdrop
  class="sidebar-backdrop fixed inset-0 z-30 hidden bg-black/20 backdrop-blur-sm"
  aria-hidden="true"
></div>

<aside
  id="sidebar"
  role="complementary"
  aria-label="Site navigation"
  class="sidebar fixed left-4 top-4 bottom-4 z-40 hidden h-[calc(100vh-2rem)] w-64 flex-col rounded-2xl border border-border/30 bg-surface-elevated/95 shadow-[0_8px_32px_-8px_rgba(0,0,0,0.15),0_0_0_1px_rgba(255,255,255,0.05)_inset] backdrop-blur-md transition-transform duration-300 md:!flex lg:translate-x-0 dark:shadow-[0_8px_32px_-8px_rgba(0,0,0,0.4),0_0_0_1px_rgba(255,255,255,0.06)_inset]"
  data-sidebar-panel
>
  <div class="flex h-full flex-col overflow-hidden rounded-2xl">
    <!-- En-tête : logo + bouton fermer (tablette) -->
    <div class="flex items-center justify-between gap-2 p-4">
      <div class="min-w-0 flex-1">
        <Logo size="md" showText={true} noHover={true} />
      </div>
      <button
        type="button"
        id="sidebar-close-btn"
        class="sidebar-close-btn -mr-1 flex h-9 w-9 shrink-0 items-center justify-center rounded-xl text-neutral transition-colors hover:bg-surface hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 lg:hidden"
        aria-label="Close menu"
      >
        <X size={20} class="fill-none stroke-2" />
      </button>
    </div>

    <!-- Navigation -->
    <nav class="flex-1 overflow-y-auto px-3 py-4">
      <ul class="space-y-1">
        {navItems.map((item) => {
          const IconComponent = item.icon
          const isParentActive = activeItem.parent === item.id
          const hasChildren = item.children && item.children.length > 0

          return (
            <li class={hasChildren ? 'sidebar-item sidebar-item-has-children' : 'sidebar-item'}>
              <a
                href={item.href}
                class={`group flex items-center justify-between rounded-lg px-3 py-2 text-sm font-medium transition-colors duration-150 ${
                  isParentActive && !activeItem.child
                    ? 'border-l-2 border-primary bg-primary/10 text-primary'
                    : 'border-l-2 border-transparent text-neutral hover:bg-primary/10 hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:ring-offset-2'
                }`}
                aria-current={isParentActive && !activeItem.child ? 'page' : undefined}
              >
                <div class="flex items-center gap-3">
                  <IconComponent 
                    size={20} 
                    class={`fill-none stroke-2 transition-colors duration-150 ${
                      isParentActive && !activeItem.child 
                        ? 'text-primary stroke-primary' 
                        : 'text-neutral stroke-neutral group-hover:text-primary group-hover:stroke-primary'
                    }`} 
                  />
                  <span class="transition-colors duration-150">{item.label}</span>
                </div>
                {hasChildren && (
                  <ChevronRight
                    size={16}
                    class={`fill-none stroke-2 transition-all duration-150 ${
                      isParentActive 
                        ? 'rotate-90 text-primary stroke-primary' 
                        : 'text-muted stroke-muted group-hover:text-primary group-hover:stroke-primary'
                    }`}
                  />
                )}
              </a>

              {/* Children */}
              {hasChildren && (
                <ul class={`mt-1 space-y-1 pl-11 sidebar-children ${isParentActive ? 'sidebar-children-active' : ''}`}>
                  {item.children!.map((child) => {
                    const isChildActive = activeItem.child === child.id
                    const ChildIcon = child.icon

                    return (
                      <li>
                        <a
                          href={child.href}
                          class={`group/child flex items-center gap-2 rounded-lg border-l-2 px-3 py-2 text-sm transition-colors duration-150 ${
                            isChildActive
                              ? 'border-primary bg-primary/10 text-primary font-medium'
                              : 'border-transparent text-neutral hover:bg-primary/10 hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:ring-offset-1'
                          }`}
                          aria-current={isChildActive ? 'page' : undefined}
                        >
                          {ChildIcon && (
                            <ChildIcon
                              size={16}
                              class={`fill-none stroke-2 transition-colors duration-150 shrink-0 ${
                                isChildActive
                                  ? 'text-primary stroke-primary'
                                  : 'text-neutral stroke-neutral group-hover/child:text-primary group-hover/child:stroke-primary'
                              }`}
                            />
                          )}
                          <span class="transition-colors duration-150">{child.label}</span>
                        </a>
                      </li>
                    )
                  })}
                </ul>
              )}
            </li>
          )
        })}
      </ul>
    </nav>

    <!-- Footer with theme toggle and user profile -->
    <div class="p-4 space-y-3">
      <!-- Theme toggle -->
      <div class="flex items-center justify-between rounded-lg bg-surface p-3 border border-border/50">
        <div>
          <p class="text-sm font-medium text-neutral mb-0.5">Theme</p>
          <p class="text-xs text-muted">Light / Dark</p>
        </div>
        <ThemeSwitcher size="md" />
      </div>

      <!-- Language -->
      <LanguageSwitcher variant="sidebar" currentLocale={currentLocale} />

      <!-- User profile section links to profile -->
      {userName || userEmail ? (
        <div class="rounded-lg bg-surface overflow-hidden">
          <div class="px-3 py-2">
            <a
              href="/profile"
              class="group flex items-center gap-3 rounded-lg px-3 py-2 transition-colors duration-150 hover:bg-secondary/10 hover:text-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:ring-offset-1"
            >
              <Avatar
                userName={userName}
                userEmail={userEmail}
                imageUrl={userImageUrl}
                size="md"
                class="shrink-0"
              />
              <div class="min-w-0 flex-1">
                <p class="truncate text-sm font-medium text-neutral group-hover:text-secondary">
                  {userName || 'User'}
                </p>
                {userEmail && (
                  <p class="truncate text-xs text-muted">{userEmail}</p>
                )}
              </div>
            </a>
          </div>
          <div class="px-3 py-2 space-y-1">
            <a
              href="/settings"
              class="group flex items-center gap-2 rounded-lg px-3 py-2 text-xs font-medium text-neutral transition-colors duration-150 hover:bg-secondary/10 hover:text-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:ring-offset-1"
            >
              <Settings size={14} class="fill-none stroke-2 transition-colors duration-150 text-neutral stroke-neutral group-hover:text-secondary group-hover:stroke-secondary" />
              <span class="transition-colors duration-150">Settings</span>
            </a>
            <button
              type="button"
              id="sidebar-signout-btn"
              class="group flex w-full items-center gap-2 rounded-lg px-3 py-2 text-xs font-medium text-red-500/80 transition-all duration-200 hover:bg-red-500/10 hover:text-red-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-red-500/50 focus-visible:ring-offset-1"
              aria-label="Sign out"
            >
              <LogOut size={14} class="fill-none stroke-2 transition-colors duration-200 text-red-500/80 stroke-red-500/80 group-hover:text-red-500 group-hover:stroke-red-500" />
              <span class="transition-colors duration-200">Sign out</span>
            </button>
          </div>
        </div>
      ) : null}
    </div>
  </div>
</aside>

<!-- Clics sidebar (toggle, fermer, déconnexion) gérés par délégation dans Layout.astro pour survivre aux View Transitions -->

<!-- Spacer pour la sidebar flottante (desktop) : marge + largeur sidebar -->
<div class="hidden lg:block lg:w-[17rem]"></div>

<style>
  /* Tablette (768–1024) : sidebar fermée par défaut, ouverte au toggle */
  @media (min-width: 768px) and (max-width: 1023px) {
    #sidebar {
      transform: translateX(calc(-100% - 1rem));
    }
    body.sidebar-open #sidebar {
      transform: translateX(0);
    }
    body.sidebar-open .sidebar-backdrop {
      display: block;
    }
  }

  /* Desktop (1024+) : toujours visible */
  @media (min-width: 1024px) {
    #sidebar {
      transform: translateX(0);
    }
  }

  /* Sidebar scrollbar & icons */
  .sidebar {
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }

  .sidebar::-webkit-scrollbar {
    width: 6px;
  }

  .sidebar::-webkit-scrollbar-track {
    background: transparent;
  }

  .sidebar::-webkit-scrollbar-thumb {
    background-color: var(--color-border);
    border-radius: 3px;
  }

  .sidebar::-webkit-scrollbar-thumb:hover {
    background-color: var(--color-muted);
  }

  /* Force fill-none and stroke for icons */
  .sidebar svg {
    fill: none !important;
    stroke-width: 2;
  }

  /* Sous-menus : ouverts si actif, ou au survol sur desktop */
  .sidebar-children {
    display: none;
  }
  .sidebar-children-active {
    display: block;
  }

  @media (hover: hover) and (pointer: fine) {
    .sidebar-item-has-children:hover > .sidebar-children,
    .sidebar-item-has-children:focus-within > .sidebar-children {
      display: block;
    }
  }
</style>
