---
import Library from '@lucide/astro/icons/library'
import Search from '@lucide/astro/icons/scan-search'
import User from '@lucide/astro/icons/user'

type TabItem = {
  id: string
  label: string
  icon: typeof Library
  href: string
}

// Fonction pour déterminer l'onglet actif
function getActiveTab(path: string): string | null {
  // Pas d'onglet actif sur la page d'accueil
  if (path === '/' || path === '/index') return null
  
  // Collection (unified view with format selector)
  if (path.includes('/library') || path.includes('/collection') || path.includes('/vinyl') || path.includes('/cassette') || path.includes('/cd')) {
    return 'collection'
  }
  
  if (path.includes('/explorer')) return 'explorer'
  if (path.includes('/profile')) return 'profile'
  
  return null
}

const currentPath = Astro.url.pathname
const activeTab = getActiveTab(currentPath)

const tabs: TabItem[] = [
  {
    id: 'collection',
    label: 'Library',
    icon: Library,
    href: '/library',
  },
  {
    id: 'explorer',
    label: 'Explore',
    icon: Search,
    href: '/explorer',
  },
  {
    id: 'profile',
    label: 'Profile',
    icon: User,
    href: '/profile',
  },
]
---

<!-- Barre flottante style Floating Bottom Navigation (mobile uniquement) -->
<nav
  aria-label="Navigation principale"
  class="bottom-bar fixed bottom-6 left-4 right-4 z-50 mx-auto max-w-sm rounded-[1.75rem] md:hidden"
>
  <div
    class="flex items-center justify-between gap-1 rounded-[1.75rem] border border-border/30 bg-surface-elevated/95 px-2 py-2 shadow-[0_8px_32px_-8px_rgba(0,0,0,0.2),0_0_0_1px_rgba(255,255,255,0.05)_inset] backdrop-blur-md transition-colors duration-200 dark:shadow-[0_8px_32px_-8px_rgba(0,0,0,0.5),0_0_0_1px_rgba(255,255,255,0.06)_inset]"
  >
    {
      tabs.map((tab: TabItem) => {
        const IconComponent = tab.icon
        const isActive = activeTab === tab.id

        return (
          <a
            href={tab.href}
            class={`group relative flex flex-1 items-center justify-center gap-2 rounded-2xl px-3 py-2.5 transition-all duration-200 ${
              isActive
                ? 'bg-primary/12 text-primary shadow-sm'
                : 'text-neutral hover:bg-primary/10 hover:text-primary active:scale-[0.98]'
            }`}
            aria-label={tab.label}
            aria-current={isActive ? 'page' : undefined}
          >
            <IconComponent
              size={22}
              class={`fill-none stroke-2 shrink-0 ${isActive ? 'text-primary stroke-primary' : 'text-neutral stroke-neutral group-hover:text-primary group-hover:stroke-primary'}`}
              aria-hidden="true"
            />
            <span class="text-sm font-medium whitespace-nowrap hidden sm:inline">
              {tab.label}
            </span>
          </a>
        )
      })
    }
  </div>
</nav>

<!-- Espace réservé pour la barre flottante (éviter que le contenu passe en dessous) -->
<div class="h-24 md:hidden" aria-hidden="true"></div>
