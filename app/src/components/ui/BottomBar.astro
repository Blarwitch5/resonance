---
import Library from '@lucide/astro/icons/library'
import Search from '@lucide/astro/icons/scan-search'
import User from '@lucide/astro/icons/user'

type TabItem = {
  id: string
  label: string
  icon: typeof Library
  href: string
}

// Fonction pour déterminer l'onglet actif
function getActiveTab(path: string): string | null {
  // Pas d'onglet actif sur la page d'accueil
  if (path === '/' || path === '/index') return null
  
  // Collection (unified view with format selector)
  if (path.includes('/bibliotheque') || path.includes('/collection') || path.includes('/vinyl') || path.includes('/cassette') || path.includes('/cd')) {
    return 'collection'
  }
  
  if (path.includes('/explorer') || path.includes('/recherche')) return 'explorer'
  if (path.includes('/profil') || path.includes('/profile')) return 'profile'
  
  return null
}

const currentPath = Astro.url.pathname
const activeTab = getActiveTab(currentPath)

const tabs: TabItem[] = [
  {
    id: 'collection',
    label: 'Résonance',
    icon: Library,
    href: '/bibliotheque',
  },
  {
    id: 'explorer',
    label: 'Explorer',
    icon: Search,
    href: '/explorer',
  },
  {
    id: 'profile',
    label: 'Profile',
    icon: User,
    href: '/profil',
  },
]
---

<nav
  aria-label="Navigation principale"
  class="bottom-bar fixed bottom-0 left-0 right-0 z-50 border-t border-border/20 bg-surface-elevated shadow-lg backdrop-blur-sm transition-colors duration-200 md:hidden"
>
  <div class="mx-auto flex w-full items-center justify-between px-4 py-2 sm:max-w-md sm:justify-center sm:gap-2">
    {
      tabs.map((tab: TabItem) => {
        const IconComponent = tab.icon
        const isActive = activeTab === tab.id

        return (
          <a
            href={tab.href}
            class={`group relative flex flex-1 items-center justify-center gap-2 rounded-xl px-2 py-2 transition-all duration-300 sm:flex-none sm:px-3 ${
              isActive
                ? 'bg-gradient-resonance shadow-primary/25 text-white shadow-lg'
                : 'text-muted hover:bg-surface/50 hover:text-primary'
            }`}
            aria-label={tab.label}
            aria-current={isActive ? 'page' : undefined}
          >
            <IconComponent size={20} class={`fill-none stroke-2 ${isActive ? 'text-white stroke-white' : ''}`} aria-hidden="true" />
            <span class={`text-sm font-medium whitespace-nowrap ${isActive ? 'text-white' : ''} hidden sm:inline`}>
              {tab.label}
            </span>
          </a>
        )
      })
    }
  </div>
</nav>

<!-- Espace pour la bottom bar sur mobile -->
<div class="h-20 md:hidden"></div>
