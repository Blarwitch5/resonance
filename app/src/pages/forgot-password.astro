---
import ArrowLeft from '@lucide/astro/icons/arrow-left'
import Mail from '@lucide/astro/icons/mail'
import Layout from '../components/layouts/Layout.astro'
import Logo from '../components/ui/Logo.astro'
import { getForgotPasswordMessages } from '../i18n/forgotPassword'
import { normalizeLocale } from '../i18n/config'

export const prerender = false

const locale = normalizeLocale(Astro.cookies.get('locale')?.value ?? Astro.request.headers.get('accept-language')?.split(',')[0]?.slice(0, 2))
const t = getForgotPasswordMessages(locale)
---

<Layout
  title={t.meta.title}
  showDashboardHeader={false}
  showBottomBar={false}
  showFooter={false}
>
  <div class="flex min-h-screen items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
      <!-- Logo and slogan -->
      <div class="mb-12 text-center">
        <Logo size="2xl" showSlogan={true} showText={true} noHover={true} className="mb-2" />
      </div>

      <!-- Back button -->
      <div class="mb-8">
        <a
          href="/login"
          class="inline-flex items-center gap-2 text-muted no-underline transition-colors hover:text-primary"
        >
          <ArrowLeft size={18} />
          <span class="text-sm">{t.backToSignIn}</span>
        </a>
      </div>

      <div class="glass-card space-y-6 rounded-2xl p-8">
        <div>
          <h1 class="text-2xl font-bold text-neutral mb-2">
            {t.title}
          </h1>
          <p class="text-sm text-muted">
            {t.description}
          </p>
        </div>

        <form id="forgot-password-form" class="space-y-6">
          <div>
            <label for="email" class="mb-2 block text-sm font-medium text-neutral">
              {t.form.emailLabel}
            </label>
            <div class="relative">
              <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                <Mail size={20} class="text-muted" />
              </div>
              <input
                type="email"
                id="email"
                name="email"
                autocomplete="email"
                required
                class="w-full rounded-xl border border-border bg-surface py-3 pr-4 pl-10 text-neutral placeholder-muted transition-colors focus:border-primary focus:ring-2 focus:ring-primary/50 focus:outline-none"
                placeholder={t.form.emailPlaceholder}
              />
            </div>
          </div>

          <div
            id="error-message"
            class="hidden rounded-lg border border-red-500 bg-red-500/10 p-4 text-red-500"
            role="alert"
            aria-live="assertive"
          ></div>

          <div
            id="success-message"
            class="hidden rounded-lg border border-green-500 bg-green-500/10 p-4 text-green-500"
            role="status"
            aria-live="polite"
          >
            <p class="font-medium">{t.success.title}</p>
            <p class="text-sm mt-1">
              {t.success.description}
            </p>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="bg-gradient-resonance hover:bg-gradient-resonance-hover flex w-full items-center justify-center gap-2 rounded-xl px-4 py-3 font-medium text-white transition-all duration-300"
          >
            {t.form.submit}
          </button>

          <div class="text-center text-sm text-muted">
            {t.footer.rememberPrefix}{' '}
            <a
              href="/login"
              class="font-medium text-primary no-underline hover:text-primary-hover"
            >
              {t.footer.signIn}
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ enterEmailError: t.errors.enterEmail, sendingLabel: t.sending, tryAgainError: t.errors.tryAgain }}>
  const form = document.getElementById('forgot-password-form') as HTMLFormElement
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement
  const errorMessage = document.getElementById('error-message')
  const successMessage = document.getElementById('success-message')
  const emailInputEl = document.getElementById('email') as HTMLInputElement | null

  form?.addEventListener('submit', async (event) => {
    event.preventDefault()

    const formData = new FormData(form)
    const email = formData.get('email') as string

    if (!email) {
      showError(enterEmailError)
      if (emailInputEl) {
        emailInputEl.setAttribute('aria-invalid', 'true')
        emailInputEl.focus()
      }
      return
    }

    // Hide previous messages
    errorMessage?.classList.add('hidden')
    successMessage?.classList.add('hidden')
    if (emailInputEl) {
      emailInputEl.removeAttribute('aria-invalid')
    }

    if (window.setButtonLoading) window.setButtonLoading(submitBtn, true, sendingLabel)
    try {
      // Use Better Auth to send the reset email
      const response = await fetch('/api/auth/forgot-password', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ email }),
      })

      const data = await response.json()

      if (response.ok) {
        // Show success message
        successMessage?.classList.remove('hidden')
        form.reset()

        // In development, log the token to the console if available
        if (import.meta.env.DEV && data.token) {
          console.log('🔑 Reset token (DEV):', data.token)
          console.log('🔗 Reset link:', `${window.location.origin}/reset-password?token=${data.token}`)
        }
      } else {
        // Even in case of error, we display a success message for security
        // (to avoid revealing whether an email exists or not)
        successMessage?.classList.remove('hidden')
        form.reset()
      }
    } catch (error) {
      console.error('Error sending reset email:', error)
      showError(
        error instanceof Error
          ? error.message
          : tryAgainError
      )
    } finally {
      if (window.setButtonLoading) window.setButtonLoading(submitBtn, false)
    }
  })

  function showError(message: string) {
    if (errorMessage) {
      errorMessage.textContent = message
      errorMessage.classList.remove('hidden')
      successMessage?.classList.add('hidden')
      if (emailInputEl) {
        emailInputEl.setAttribute('aria-invalid', 'true')
        emailInputEl.focus()
      }
    }
  }
</script>
