---
import ArrowLeft from '@lucide/astro/icons/arrow-left'
import Mail from '@lucide/astro/icons/mail'
import Layout from '../components/layouts/Layout.astro'
import Logo from '../components/ui/Logo.astro'

export const prerender = false
---

<Layout
  title="Mot de passe oublié - Resonance"
  showDashboardHeader={false}
  showBottomBar={false}
  showFooter={false}
>
  <div class="flex min-h-screen items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
      <!-- Logo and slogan -->
      <div class="mb-12 text-center">
        <Logo size="2xl" showSlogan={true} showText={true} noHover={true} className="mb-2" />
      </div>

      <!-- Back button -->
      <div class="mb-8">
        <a
          href="/login"
          class="inline-flex items-center gap-2 text-muted no-underline transition-colors hover:text-primary"
        >
          <ArrowLeft size={18} />
          <span class="text-sm">Retour à la connexion</span>
        </a>
      </div>

      <div class="glass-card space-y-6 rounded-2xl p-8">
        <div>
          <h1 class="text-2xl font-bold text-neutral mb-2">
            Mot de passe oublié ?
          </h1>
          <p class="text-sm text-muted">
            Entrez votre adresse email et nous vous enverrons un lien pour réinitialiser votre mot de passe.
          </p>
        </div>

        <form id="forgot-password-form" class="space-y-6">
          <div>
            <label for="email" class="mb-2 block text-sm font-medium text-neutral">
              Email
            </label>
            <div class="relative">
              <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                <Mail size={20} class="text-muted" />
              </div>
              <input
                type="email"
                id="email"
                name="email"
                autocomplete="email"
                required
                class="w-full rounded-xl border border-border bg-surface py-3 pr-4 pl-10 text-neutral placeholder-muted transition-colors focus:border-primary focus:ring-2 focus:ring-primary/50 focus:outline-none"
                placeholder="votre@email.com"
              />
            </div>
          </div>

          <div id="error-message" class="hidden rounded-lg border border-red-500 bg-red-500/10 p-4 text-red-500"></div>

          <div id="success-message" class="hidden rounded-lg border border-green-500 bg-green-500/10 p-4 text-green-500">
            <p class="font-medium">✅ Email envoyé !</p>
            <p class="text-sm mt-1">
              Si un compte existe avec cet email, vous recevrez un lien de réinitialisation.
            </p>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="bg-gradient-resonance hover:bg-gradient-resonance-hover flex w-full items-center justify-center gap-2 rounded-xl px-4 py-3 font-medium text-white transition-all duration-300"
          >
            Envoyer le lien de réinitialisation
          </button>

          <div class="text-center text-sm text-muted">
            Vous vous souvenez de votre mot de passe ?{' '}
            <a
              href="/login"
              class="font-medium text-primary no-underline hover:text-primary-hover"
            >
              Se connecter
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('forgot-password-form') as HTMLFormElement
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement
  const errorMessage = document.getElementById('error-message')
  const successMessage = document.getElementById('success-message')

  form?.addEventListener('submit', async (event) => {
    event.preventDefault()

    const formData = new FormData(form)
    const email = formData.get('email') as string

    if (!email) {
      showError('Veuillez entrer votre adresse email.')
      return
    }

    // Masquer les messages précédents
    errorMessage?.classList.add('hidden')
    successMessage?.classList.add('hidden')

    // Désactiver le bouton et afficher le chargement
    submitBtn.disabled = true
    const originalText = submitBtn.innerHTML
    submitBtn.innerHTML = '<span class="animate-spin">⏳</span> Envoi en cours...'

    try {
      // Utiliser Better Auth pour envoyer l'email de réinitialisation
      const response = await fetch('/api/auth/forgot-password', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ email }),
      })

      const data = await response.json()

      if (response.ok) {
        // Afficher le message de succès
        successMessage?.classList.remove('hidden')
        form.reset()

        // En développement, afficher le token dans la console si disponible
        if (import.meta.env.DEV && data.token) {
          console.log('🔑 Token de réinitialisation (DEV):', data.token)
          console.log('🔗 Lien de réinitialisation:', `${window.location.origin}/reset-password?token=${data.token}`)
        }
      } else {
        // Même en cas d'erreur, on affiche un message de succès pour la sécurité
        // (pour ne pas révéler si un email existe ou non)
        successMessage?.classList.remove('hidden')
        form.reset()
      }
    } catch (error) {
      console.error('Error sending reset email:', error)
      showError(
        error instanceof Error
          ? error.message
          : 'Une erreur est survenue. Veuillez réessayer plus tard.'
      )
    } finally {
      submitBtn.disabled = false
      submitBtn.innerHTML = originalText
    }
  })

  function showError(message: string) {
    if (errorMessage) {
      errorMessage.textContent = message
      errorMessage.classList.remove('hidden')
      successMessage?.classList.add('hidden')
    }
  }
</script>
