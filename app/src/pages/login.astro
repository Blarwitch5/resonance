---
import ArrowLeft from '@lucide/astro/icons/arrow-left'
import Lock from '@lucide/astro/icons/lock'
import User from '@lucide/astro/icons/user'
import Eye from '@lucide/astro/icons/eye'
import EyeOff from '@lucide/astro/icons/eye-off'
import Layout from '../components/layouts/Layout.astro'
import Logo from '../components/ui/Logo.astro'
import OAuthButtons from '../components/auth/OAuthButtons.astro'

export const prerender = false
---

<Layout
  title="Sign In - Resonance"
  showDashboardHeader={false}
  showBottomBar={false}
  showFooter={false}
>
  <div class="flex min-h-screen items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
      <!-- Logo and slogan -->
      <div class="mb-12 text-center">
        <Logo size="2xl" showSlogan={true} showText={true} noHover={true} className="mb-2" />
      </div>

      <!-- Back button -->
      <div class="mb-8">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-muted no-underline transition-colors hover:text-primary"
        >
          <ArrowLeft size={18} />
          <span class="text-sm">Back to home</span>
        </a>
      </div>

      <form method="POST" action="/api/auth/sign-in" class="glass-card space-y-6 rounded-2xl p-8">
        <div>
          <label for="email" class="mb-2 block text-sm font-medium text-neutral">
            Email
          </label>
          <div class="relative">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
              <User size={20} class="text-muted" />
            </div>
            <input
              type="email"
              id="email"
              name="email"
              autocomplete="email"
              required
              class="w-full rounded-xl border border-border bg-surface py-3 pr-4 pl-10 text-neutral placeholder-muted transition-colors focus:border-primary focus:ring-2 focus:ring-primary/50 focus:outline-none"
              placeholder="votre@email.com"
            />
          </div>
        </div>

        <div>
          <label for="password" class="mb-2 block text-sm font-medium text-neutral">
            Mot de passe
          </label>
          <div class="relative">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
              <Lock size={20} class="text-muted" />
            </div>
            <input
              type="password"
              id="password"
              name="password"
              autocomplete="current-password"
              required
              class="w-full rounded-xl border border-border bg-surface py-3 pr-12 pl-10 text-neutral placeholder-muted transition-colors focus:border-primary focus:ring-2 focus:ring-primary/50 focus:outline-none"
              placeholder="••••••••"
            />
            <button
              type="button"
              id="toggle-password"
              class="absolute inset-y-0 right-0 flex items-center pr-3 text-muted transition-colors hover:text-neutral"
              aria-label="Show password"
            >
              <Eye id="eye-icon" size={20} class="hidden" />
              <EyeOff id="eye-off-icon" size={20} />
            </button>
          </div>
        </div>

        <button
          type="submit"
          class="bg-gradient-resonance hover:bg-gradient-resonance-hover flex w-full items-center justify-center gap-2 rounded-xl px-4 py-3 font-medium text-white transition-all duration-300"
        >
          Sign In
        </button>

        <OAuthButtons mode="signin" />

        <div class="space-y-3 text-center text-sm">
          <div>
            <a
              href="/forgot-password"
              class="font-medium text-primary no-underline hover:text-primary-hover"
            >
              Mot de passe oublié ?
            </a>
          </div>
          <div class="text-muted">
            Don't have an account?{' '}
            <a
              href="/signup"
              class="font-medium text-primary no-underline hover:text-primary-hover"
            >
              Create an account
            </a>
          </div>
        </div>
      </form>
    </div>
  </div>
</Layout>

<script lang="ts">
  // Toggle password visibility
  const togglePasswordButton = document.getElementById('toggle-password')
  const passwordInput = document.getElementById('password') as HTMLInputElement | null
  const eyeIcon = document.getElementById('eye-icon')
  const eyeOffIcon = document.getElementById('eye-off-icon')

  if (togglePasswordButton && passwordInput) {
    togglePasswordButton.addEventListener('click', function() {
      const isPassword = passwordInput.type === 'password'
      passwordInput.type = isPassword ? 'text' : 'password'

      if (eyeIcon && eyeOffIcon) {
        if (isPassword) {
          eyeIcon.classList.remove('hidden')
          eyeOffIcon.classList.add('hidden')
          togglePasswordButton.setAttribute('aria-label', 'Hide password')
        } else {
          eyeIcon.classList.add('hidden')
          eyeOffIcon.classList.remove('hidden')
          togglePasswordButton.setAttribute('aria-label', 'Show password')
        }
      }
    })
  }

  // Form submission
  const form = document.querySelector('form[action="/api/auth/sign-in"]') as HTMLFormElement | null

  if (form) {
    form.addEventListener('submit', async function(event) {
      event.preventDefault()

      const formData = new FormData(form)
      const email = formData.get('email')
      const password = formData.get('password')

      if (!email || !password) {
        if (window.toast) {
          window.toast.error('Veuillez remplir tous les champs')
        }
        return
      }

      try {
        // Use better-auth client for sign in
        const { signIn } = await import('../lib/auth-client')
        const result = await signIn.email({
          email: String(email),
          password: String(password),
        })

      if (result.error) {
        // Handle better-auth errors
        if (window.toast) {
          window.toast.error(result.error.message || 'Erreur lors de la connexion')
        } else {
          const errorDiv = document.createElement('div')
          errorDiv.className = 'mt-4 rounded-lg border border-red-500 bg-red-500/10 p-4 text-red-500'
          errorDiv.textContent = `Error: ${result.error.message || result.error}`
          form?.insertAdjacentElement('beforebegin', errorDiv)
        }
        return
      }

      // Store login success in sessionStorage for toast on redirect
      sessionStorage.setItem('showWelcomeToast', 'true')
      
        // Redirect to home on success
        document.location.href = '/'
      } catch (error) {
        console.error('Error signing in:', error)
        if (window.toast) {
          const errorMessage = error instanceof Error ? error.message : 'Une erreur est survenue'
          window.toast.error(errorMessage)
        } else {
          const errorDiv = document.createElement('div')
          errorDiv.className = 'mt-4 rounded-lg border border-red-500 bg-red-500/10 p-4 text-red-500'
          const errorMessage = error instanceof Error ? error.message : 'An error occurred'
          errorDiv.textContent = 'Error: ' + errorMessage
          form.insertAdjacentElement('beforebegin', errorDiv)
        }
      }
    })
  }

  // Check for logout toast and OAuth errors
  document.addEventListener('DOMContentLoaded', function() {
    const showLogoutToast = sessionStorage.getItem('showLogoutToast')
    if (showLogoutToast && window.toast) {
      window.toast.info('Vous avez été déconnecté avec succès. À bientôt !', 4000)
      sessionStorage.removeItem('showLogoutToast')
    }

    // Check for OAuth configuration error
    const urlParams = new URLSearchParams(window.location.search)
    const oauthError = urlParams.get('error')
    if (oauthError === 'oauth_not_configured' && window.toast) {
      window.toast.warning('La connexion OAuth n\'est pas encore configurée. Veuillez utiliser la connexion par email.', 5000)
      // Clean URL
      window.history.replaceState({}, document.title, window.location.pathname)
    }
  })
</script>
