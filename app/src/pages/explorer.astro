---
import { statsService } from '../services/stats-service'
import { collectionRepository } from '../repositories/collection-repository'
import { discogsService } from '../services/discogs-service'
import DashboardLayout from '../components/layouts/DashboardLayout.astro'
import SearchBar from '../components/explorer/SearchBar.astro'
import FormatFilter from '../components/explorer/FormatFilter.astro'
import AddToCollectionModal from '../components/explorer/AddToCollectionModal.astro'
import RecommendationGrid from '../components/explorer/RecommendationGrid.astro'
import { getExplorerMessages } from '../i18n/explorer'
import { getLibraryMessages } from '../i18n/library'
import { normalizeLocale } from '../i18n/config'
import Search from '@lucide/astro/icons/search'

export const prerender = false

const session = Astro.locals.session
const user = Astro.locals.user
if (!session || !user) return Astro.redirect('/login')

const locale = normalizeLocale(Astro.locals.userPreferences?.locale ?? Astro.cookies.get('locale')?.value ?? Astro.request.headers.get('accept-language')?.split(',')[0]?.slice(0, 2))
const explorerT = getExplorerMessages(locale)
const libraryT = getLibraryMessages(locale)

const genreStats = await statsService.getRecentItemsByGenre(user.id)
const topGenres = genreStats.slice(0, 3).map((g) => g.genre)
const collections = await collectionRepository.findByUserId(user.id)

let recommendations: Array<{ id: number; title: string; cover_image?: string; thumb?: string; year?: number }> = []
let recommendationsError: string | null = null
if (topGenres.length > 0) {
  try {
    // On demande plus large au service (24) puis on limite l’affichage à 8
    const rawRecommendations = await discogsService.getRecommendations(topGenres, 24)
    recommendations = rawRecommendations.slice(0, 8)
  } catch (error) {
    recommendationsError = error instanceof Error ? error.message : explorerT.client.unknownError
  }
}
---

<DashboardLayout title={explorerT.meta.title}>
  <script type="application/json" id="explorer-page-messages" set:html={JSON.stringify({
    search: explorerT.search,
    client: explorerT.client,
    addToCollection: explorerT.addToCollection,
  }).replace(/<\/script/gi, '<\\/script')}></script>
  <div class="space-y-8">
    <section>
      <h2 class="mb-4 text-xl font-bold">{explorerT.search.title}</h2>
      <div class="mb-4">
        <SearchBar search={explorerT.search} client={explorerT.client} addToCollection={explorerT.addToCollection} />
      </div>
      <FormatFilter formats={{ all: libraryT.formats.all, vinyl: libraryT.formats.vinyl, cassette: libraryT.formats.cassette, cd: libraryT.formats.cd }} />
    </section>

    <!-- Search results (loaded dynamically, champ recherche uniquement) -->
    <section id="search-results-container" class="hidden">
      <div id="search-results-content"></div>
    </section>

    <!-- Barcode results (manual input / scan, independent from search field) -->
    <section id="barcode-results-section" class="hidden">
      <h2 id="barcode-results-title" class="mb-4 text-xl font-bold text-neutral">{explorerT.search.barcodeResultsTitle}</h2>
      <div id="barcode-results-container"></div>
    </section>

    <!-- Personalized recommendations -->
    {topGenres.length > 0 && (
      <section id="recommendations-section">
        <h2 class="mb-4 text-xl font-bold">{explorerT.recommendations.title}</h2>
        <p class="mb-6 text-muted">
          {explorerT.recommendations.descriptionPrefix} {topGenres.join(', ')}
        </p>
        {recommendationsError ? (
          <div class="glass-card rounded-xl p-6 text-center">
            <p class="text-muted mb-2">{explorerT.recommendations.loadErrorTitle}</p>
            <p class="text-sm text-muted">{recommendationsError}</p>
          </div>
        ) : recommendations.length > 0 ? (
          <RecommendationGrid
            recommendations={recommendations}
            addToCollectionAria={explorerT.addToCollection.addToCollectionAria}
            addToWishlistAria={explorerT.addToCollection.addToWishlistAria}
            unknownArtistLabel={explorerT.client.unknownArtist}
            scriptLabels={{
              unknownArtist: explorerT.client.unknownArtist,
              addedToWishlistToast: explorerT.addToCollection.addedToWishlistToast,
              failedToAddToWishlist: explorerT.addToCollection.failedToAddToWishlist,
              fetchReleaseError: explorerT.addToCollection.fetchReleaseError,
              genericError: explorerT.client.genericError,
            }}
          />
        ) : (
          <div class="glass-card rounded-xl p-8 text-center">
            <p class="mb-2 font-medium text-neutral">{explorerT.recommendations.emptyTitle}</p>
            <p class="text-sm text-muted">
              {explorerT.recommendations.emptyDescription}
            </p>
          </div>
        )}
      </section>
    )}

    <!-- General discovery -->
    <section>
      <h2 class="mb-4 text-xl font-bold">{explorerT.discover.title}</h2>
      <p class="mb-6 text-muted">
        {explorerT.discover.subtitle}
      </p>
      <div class="glass-card rounded-2xl p-12 text-center">
        <div
          class="bg-gradient-resonance-subtle mx-auto mb-6 flex h-24 w-24 items-center justify-center rounded-full"
        >
          <Search size={48} class="text-primary" />
        </div>
        <h3 class="font-display mb-4 text-xl font-semibold">
          {explorerT.discover.cardTitle}
        </h3>
        <p class="text-muted mx-auto max-w-md">
          {explorerT.discover.cardDescription}
        </p>
      </div>
    </section>
  </div>

  <!-- Add to Collection Modal -->
  <AddToCollectionModal collections={collections} addToCollection={explorerT.addToCollection} client={explorerT.client} />
</DashboardLayout>

<script is:inline>
  (function() {
    let explorerSearch = {}
    let explorerClient = {}
    try {
      const el = document.getElementById('explorer-page-messages')
      if (el && el.textContent) {
        const parsed = JSON.parse(el.textContent)
        explorerSearch = parsed.search || {}
        explorerClient = parsed.client || {}
      }
    } catch (e) { console.warn('Could not parse explorer-page-messages', e) }

    window.addEventListener('DOMContentLoaded', async function() {
      const params = new URLSearchParams(window.location.search)
      const barcodeParam = params.get('barcode')
      const barcode = (barcodeParam && barcodeParam.trim) ? barcodeParam.trim() : ''
      const qParam = params.get('q')
      const q = (qParam && qParam.trim) ? qParam.trim() : ''

      if (barcode) {
        const section = document.getElementById('barcode-results-section')
        const container = document.getElementById('barcode-results-container')
        const titleEl = document.getElementById('barcode-results-title')
        if (titleEl) titleEl.textContent = (explorerSearch.barcodeResultsTitleWithBarcode || '').replace('{barcode}', barcode)
        if (!section || !container) return
        section.classList.remove('hidden')
        try {
          const response = await fetch('/api/discogs/search-by-barcode?barcode=' + encodeURIComponent(barcode))
          const data = await response.json()
          if (data.found && data.results && data.results.length > 0) {
            const renderRes = await fetch('/api/discogs/render-search-results', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ results: data.results }),
            })
            if (renderRes.ok) {
              container.innerHTML = await renderRes.text()
            } else {
              const p = document.createElement('p')
              p.className = 'text-muted'
              p.textContent = explorerClient.barcodeErrorDisplay || ''
              container.replaceChildren(p)
            }
          } else {
            const wrapper = document.createElement('div')
            wrapper.className = 'glass-card rounded-2xl border border-border/50 p-8 text-center'
            const p1 = document.createElement('p')
            p1.className = 'text-lg font-medium text-neutral mb-2'
            p1.textContent = explorerClient.barcodeNoResults || ''
            const p2 = document.createElement('p')
            p2.className = 'text-sm text-muted'
            p2.textContent = explorerSearch.barcodeNoResultsHint || ''
            wrapper.appendChild(p1)
            wrapper.appendChild(p2)
            container.replaceChildren(wrapper)
          }
        } catch (error) {
          console.error('Barcode search error:', error)
          const errWrapper = document.createElement('div')
          errWrapper.className = 'glass-card rounded-2xl border border-border/50 p-8 text-center'
          const errP = document.createElement('p')
          errP.className = 'text-muted'
          errP.textContent = explorerClient.barcodeErrorSearch || ''
          errWrapper.appendChild(errP)
          container.replaceChildren(errWrapper)
        }
        return
      }

      if (q) {
        window.dispatchEvent(new CustomEvent('explorer-search-from-url', { detail: { query: q } }))
      }
    })
  })()
</script>

<style>
  .glass-card {
    transition: all 0.3s ease;
  }

  .glass-card:hover {
    transform: translateY(-2px);
  }

</style>
