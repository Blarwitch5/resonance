---
import { statsService } from '../services/stats-service'
import { collectionRepository } from '../repositories/collection-repository'
import { discogsService } from '../services/discogs-service'
import DashboardLayout from '../components/layouts/DashboardLayout.astro'
import SearchBar from '../components/explorer/SearchBar.astro'
import FormatFilter from '../components/explorer/FormatFilter.astro'
import AddToCollectionModal from '../components/explorer/AddToCollectionModal.astro'
import RecommendationGrid from '../components/explorer/RecommendationGrid.astro'
import Search from '@lucide/astro/icons/search'

export const prerender = false

const session = Astro.locals.session
const user = Astro.locals.user
if (!session || !user) return Astro.redirect('/login')

const genreStats = await statsService.getRecentItemsByGenre(user.id)
const topGenres = genreStats.slice(0, 3).map((g) => g.genre)
const collections = await collectionRepository.findByUserId(user.id)

let recommendations: Array<{ id: number; title: string; cover_image?: string; thumb?: string; year?: number }> = []
let recommendationsError: string | null = null
if (topGenres.length > 0) {
  try {
    // On demande plus large au service (24) puis on limite l’affichage à 8
    const rawRecommendations = await discogsService.getRecommendations(topGenres, 24)
    recommendations = rawRecommendations.slice(0, 8)
  } catch (error) {
    recommendationsError = error instanceof Error ? error.message : 'Unknown error'
  }
}
---

<DashboardLayout title="Explorer - Resonance">
  <div class="space-y-8">
    <!-- Search -->
    <section>
      <h2 class="mb-4 text-xl font-bold">Search Discogs</h2>
      <div class="mb-4">
        <SearchBar />
      </div>
      <FormatFilter />
    </section>

    <!-- Search results (loaded dynamically, champ recherche uniquement) -->
    <section id="search-results-container" class="hidden">
      <div id="search-results-content"></div>
    </section>

    <!-- Barcode results (manual input / scan, independent from search field) -->
    <section id="barcode-results-section" class="hidden">
      <h2 id="barcode-results-title" class="mb-4 text-xl font-bold text-neutral">Results for barcode</h2>
      <div id="barcode-results-container"></div>
    </section>

    <!-- Personalized recommendations -->
    {topGenres.length > 0 && (
      <section id="recommendations-section">
        <h2 class="mb-4 text-xl font-bold">Recommendations for you</h2>
        <p class="mb-6 text-muted">
          Based on your favorite genres: {topGenres.join(', ')}
        </p>
        {recommendationsError ? (
          <div class="glass-card rounded-xl p-6 text-center">
            <p class="text-muted mb-2">Unable to load recommendations.</p>
            <p class="text-sm text-muted">{recommendationsError}</p>
          </div>
        ) : recommendations.length > 0 ? (
          <RecommendationGrid recommendations={recommendations} />
        ) : (
          <div class="glass-card rounded-xl p-8 text-center">
            <p class="mb-2 font-medium text-neutral">No recommendations yet</p>
            <p class="text-sm text-muted">
              Keep adding albums to your collection to receive personalized recommendations.
            </p>
          </div>
        )}
      </section>
    )}

    <!-- General discovery -->
    <section>
      <h2 class="mb-4 text-xl font-bold">Discover</h2>
      <p class="mb-6 text-muted">
        Search for an album, artist, or label to get started
      </p>
      <div class="glass-card rounded-2xl p-12 text-center">
        <div
          class="bg-gradient-resonance-subtle mx-auto mb-6 flex h-24 w-24 items-center justify-center rounded-full"
        >
          <Search size={48} class="text-primary" />
        </div>
        <h3 class="font-display mb-4 text-xl font-semibold">
          Search Discogs
        </h3>
        <p class="text-muted mx-auto max-w-md">
          Discover over 25 million albums, vinyl records, CDs, and cassettes in the world's largest music database.
        </p>
      </div>
    </section>
  </div>

  <!-- Add to Collection Modal -->
  <AddToCollectionModal collections={collections} />
</DashboardLayout>

<script>
  // Au chargement : ?barcode= → recherche par code-barres uniquement (sans toucher au champ recherche)
  // ?q= → general search from the search field
  window.addEventListener('DOMContentLoaded', async () => {
    const params = new URLSearchParams(window.location.search)
    const barcode = params.get('barcode')?.trim()
    const q = params.get('q')?.trim()

    if (barcode) {
      const section = document.getElementById('barcode-results-section')
      const container = document.getElementById('barcode-results-container')
      const title = document.getElementById('barcode-results-title')
      if (title) title.textContent = `Results for barcode “${barcode}”`
      if (!section || !container) return
      section.classList.remove('hidden')
      try {
        const response = await fetch(`/api/discogs/search-by-barcode?barcode=${encodeURIComponent(barcode)}`)
        const data = await response.json()
        if (data.found && data.results?.length > 0) {
          const renderRes = await fetch('/api/discogs/render-search-results', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ results: data.results }),
          })
          if (renderRes.ok) {
            container.innerHTML = await renderRes.text()
          } else {
            container.innerHTML = '<p class="text-muted">Error while displaying results.</p>'
          }
        } else {
          container.innerHTML = `
            <div class="glass-card rounded-2xl border border-border/50 p-8 text-center">
              <p class="text-lg font-medium text-neutral mb-2">No album found for this barcode.</p>
              <p class="text-sm text-muted">Check the code or try a search by artist/title in the field above.</p>
            </div>
          `
        }
      } catch (error) {
        console.error('Barcode search error:', error)
        container.innerHTML = `
          <div class="glass-card rounded-2xl border border-border/50 p-8 text-center">
            <p class="text-muted">Error while searching by barcode.</p>
          </div>
        `
      }
      return
    }

    if (q) {
      window.dispatchEvent(new CustomEvent('explorer-search-from-url', { detail: { query: q } }))
    }
  })
</script>

<style>
  .glass-card {
    transition: all 0.3s ease;
  }

  .glass-card:hover {
    transform: translateY(-2px);
  }

</style>
