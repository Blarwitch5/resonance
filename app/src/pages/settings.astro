---
import DashboardLayout from '../components/layouts/DashboardLayout.astro'
import ThemeSwitcher from '../components/ui/ThemeSwitcher.astro'
import Avatar from '../components/ui/Avatar.astro'
import Camera from '@lucide/astro/icons/camera'
import Pencil from '@lucide/astro/icons/pencil'
import Check from '@lucide/astro/icons/check'
import X from '@lucide/astro/icons/x'
import ArrowLeft from '@lucide/astro/icons/arrow-left'

const session = Astro.locals.session
const user = Astro.locals.user

if (!session || !user) {
  return Astro.redirect('/login')
}
---

<DashboardLayout title="Settings - Resonance" description="Manage your preferences and account settings">
  <div class="mx-auto max-w-4xl space-y-8">
    <!-- Header -->
    <div>
      <a
        href="/profile"
        class="mb-3 inline-flex items-center gap-2 text-sm text-muted transition-colors hover:text-primary"
      >
        <ArrowLeft size={16} />
        <span>Back to profile</span>
      </a>
      <h1 class="text-3xl font-bold text-neutral mb-1">Settings</h1>
      <p class="text-muted">Manage your preferences and account settings</p>
    </div>

    <!-- Appearance section -->
    <section class="glass-card rounded-2xl p-6">
      <h2 class="text-xl font-semibold text-neutral mb-4">Appearance</h2>
      
      <div class="space-y-4">
        <!-- Theme -->
        <div class="flex items-center justify-between p-4 rounded-xl border border-border/50 bg-surface hover:bg-surface-elevated transition-colors">
          <div>
            <h3 class="font-medium text-neutral mb-1">Theme</h3>
            <p class="text-sm text-muted">Choose between light and dark theme</p>
          </div>
          <div class="shrink-0">
            <ThemeSwitcher size="lg" />
          </div>
        </div>
      </div>
    </section>

    <!-- Account section -->
    <section class="glass-card rounded-2xl p-6">
      <h2 class="text-xl font-semibold text-neutral mb-4">Account</h2>
      
      <div class="space-y-6">
        <!-- Avatar -->
        <div>
          <h3 class="font-medium text-neutral mb-3">Profile picture</h3>
          <div class="flex items-center gap-4">
            <div class="relative" id="user-avatar-container">
              <Avatar
                userName={user.name}
                userEmail={user.email}
                imageUrl={user.image ? `${user.image}?t=${Date.now()}` : undefined}
                size="xl"
                id="user-avatar"
              />
              <label
                for="avatar-upload"
                class="absolute bottom-0 right-0 flex h-8 w-8 cursor-pointer items-center justify-center rounded-full bg-primary text-white shadow-lg transition-all hover:scale-110"
                title="Change profile picture"
              >
                <Camera size={16} />
                <input
                  type="file"
                  id="avatar-upload"
                  name="avatar"
                  accept="image/jpeg,image/jpg,image/png,image/webp,image/gif"
                  class="hidden"
                />
              </label>
            </div>
            <div class="flex-1">
              <p class="text-sm text-muted mb-1">
                Click the icon to change your profile picture
              </p>
              <p class="text-xs text-muted">
                Accepted formats: JPEG, PNG, WebP, GIF (max 5MB)
              </p>
            </div>
          </div>
        </div>

        <!-- User info -->
        <div>
          <h3 class="font-medium text-neutral mb-4">Personal information</h3>
          <div class="space-y-4">
            <!-- Name -->
            <div>
              <label class="block text-sm font-medium text-neutral mb-2">
                Name
              </label>
              <div class="flex items-center gap-2">
                <input
                  type="text"
                  id="profile-name"
                  name="name"
                  value={user.name || ''}
                  placeholder="Your name"
                  readonly
                  class="flex-1 rounded-lg border border-border bg-surface px-4 py-2 text-neutral focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 read-only:cursor-default read-only:opacity-75"
                />
                <button
                  type="button"
                  id="edit-name-btn"
                  class="btn-icon-secondary p-2 rounded-lg"
                  aria-label="Edit name"
                >
                  <Pencil size={18} />
                </button>
                <button
                  type="button"
                  id="save-name-btn"
                  class="btn-icon-colored p-2 rounded-lg hidden"
                  aria-label="Save name"
                >
                  <Check size={18} />
                </button>
                <button
                  type="button"
                  id="cancel-name-btn"
                  class="btn-icon-secondary p-2 rounded-lg hidden"
                  aria-label="Cancel"
                >
                  <X size={18} />
                </button>
              </div>
            </div>

            <!-- Email -->
            <div>
              <label class="block text-sm font-medium text-neutral mb-2">
                Email
              </label>
              <div class="flex items-center gap-2">
                <input
                  type="email"
                  id="profile-email"
                  name="email"
                  value={user.email || ''}
                  placeholder="you@example.com"
                  readonly
                  class="flex-1 rounded-lg border border-border bg-surface px-4 py-2 text-neutral focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 read-only:cursor-default read-only:opacity-75"
                />
                <button
                  type="button"
                  id="edit-email-btn"
                  class="btn-icon-secondary p-2 rounded-lg"
                  aria-label="Edit email"
                >
                  <Pencil size={18} />
                </button>
                <button
                  type="button"
                  id="save-email-btn"
                  class="btn-icon-colored p-2 rounded-lg hidden"
                  aria-label="Save email"
                >
                  <Check size={18} />
                </button>
                <button
                  type="button"
                  id="cancel-email-btn"
                  class="btn-icon-secondary p-2 rounded-lg hidden"
                  aria-label="Cancel"
                >
                  <X size={18} />
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Change password -->
        <div class="border-t border-border pt-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-medium text-neutral">Password</h3>
            <button
              type="button"
              id="show-password-form-btn"
              class="btn-secondary-surface px-4 py-2 rounded-lg text-sm"
            >
              Change password
            </button>
          </div>
          
          <form id="password-form" class="space-y-4 hidden" novalidate>
            <div>
              <label for="current-password" class="block text-sm font-medium text-neutral mb-2">
                Current password
              </label>
              <input
                type="password"
                id="current-password"
                name="currentPassword"
                placeholder="Enter your current password"
                class="w-full rounded-lg border border-border bg-surface px-4 py-2 text-neutral focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                required
              />
            </div>
            <div>
              <label for="new-password" class="block text-sm font-medium text-neutral mb-2">
                New password
              </label>
              <input
                type="password"
                id="new-password"
                name="newPassword"
                placeholder="Enter your new password"
                class="w-full rounded-lg border border-border bg-surface px-4 py-2 text-neutral focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                required
              />
              <p class="mt-2 text-xs text-muted">
                At least 8 characters, with uppercase, lowercase, number and special character.
              </p>
              <div id="password-requirements" class="mt-2 space-y-1 text-xs">
                <div id="req-length" class="text-muted">• At least 8 characters</div>
                <div id="req-lowercase" class="text-muted">• One lowercase letter</div>
                <div id="req-uppercase" class="text-muted">• One uppercase letter</div>
                <div id="req-number" class="text-muted">• One number</div>
                <div id="req-special" class="text-muted">• One special character</div>
              </div>
            </div>
            <div>
              <label for="confirm-password" class="block text-sm font-medium text-neutral mb-2">
                Confirm new password
              </label>
              <input
                type="password"
                id="confirm-password"
                name="confirmPassword"
                placeholder="Confirm your new password"
                class="w-full rounded-lg border border-border bg-surface px-4 py-2 text-neutral focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                required
              />
              <div id="password-match" class="mt-2 text-xs text-muted"></div>
            </div>
            <div
              id="password-error"
              class="hidden rounded-lg border border-red-500 bg-red-500/10 p-3 text-xs text-red-500"
              role="alert"
            ></div>
            <div class="flex justify-end gap-2">
              <button
                type="button"
                id="cancel-password-btn"
                class="btn-secondary-surface px-4 py-2 rounded-lg"
              >
                Cancel
              </button>
              <button
                type="submit"
                id="save-password-btn"
                class="btn-primary-gradient px-6 py-2 rounded-lg"
              >
                Change password
              </button>
            </div>
          </form>
        </div>
      </div>
    </section>

    <!-- Data section -->
    <section class="glass-card rounded-2xl p-6">
      <h2 class="text-xl font-semibold text-neutral mb-4">Data</h2>
      
      <div class="space-y-4">
        <!-- Export data -->
        <div class="flex flex-col gap-3 border-b border-border/60 pb-4 md:flex-row md:items-center md:justify-between md:border-b-0 md:pb-0">
          <div>
            <h3 class="font-medium text-neutral mb-1">Export my data</h3>
            <p class="text-sm text-muted">Download all your collections and data as JSON</p>
          </div>
          <div>
            <button
              id="export-data-btn"
              class="btn-secondary-surface w-full px-4 py-2 rounded-lg md:w-auto"
            >
              Export
            </button>
          </div>
        </div>

        <!-- Delete all data -->
        <div class="flex flex-col gap-3 border-b border-border/60 pt-4 pb-4 md:flex-row md:items-center md:justify-between md:border-b-0 md:pt-4 md:pb-0">
          <div>
            <h3 class="font-medium text-neutral mb-1">Delete all data</h3>
            <p class="text-sm text-muted">Delete all your collections and items, but keep your account</p>
          </div>
          <div>
            <button
              id="delete-all-data-btn"
              class="btn-danger w-full px-4 py-2 rounded-lg md:w-auto"
            >
              Delete data
            </button>
          </div>
        </div>

        <!-- Delete account -->
        <div class="flex flex-col gap-3 border-t border-border pt-4 md:flex-row md:items-center md:justify-between">
          <div>
            <h3 class="font-medium text-neutral mb-1">Delete my account</h3>
            <p class="text-sm text-muted">
              This action is irreversible and will permanently delete your account and all your data.
            </p>
          </div>
          <div>
            <button
              id="delete-account-btn"
              class="btn-danger w-full px-4 py-2 rounded-lg md:w-auto"
            >
              Delete account
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Notifications (coming soon) -->
    <section class="glass-card rounded-2xl p-6 opacity-60">
      <h2 class="text-xl font-semibold text-neutral mb-4">Notifications</h2>
      <p class="text-sm text-muted">Notifications will be available soon.</p>
    </section>

    <!-- About section -->
    <section class="glass-card rounded-2xl p-6">
      <h2 class="text-xl font-semibold text-neutral mb-4">About</h2>
      
      <div class="space-y-2 text-sm text-muted">
        <p><strong class="text-neutral">Resonance</strong> — Music collection manager</p>
        <p>Version 1.0.0</p>
      </div>
    </section>
  </div>
</DashboardLayout>

<script>
  // TypeScript fonctionne nativement dans les scripts Astro !
  (function() {
    // Avatar upload
    const avatarUpload = document.getElementById('avatar-upload') as HTMLInputElement | null
    if (avatarUpload) {
      avatarUpload.addEventListener('change', async function(event: Event) {
        const target = event.target as HTMLInputElement
        const file = target.files?.[0]
        if (!file) return

        if (file.size > 5 * 1024 * 1024) {
          if (window.toast) {
            window.toast.error('File is too large (max 5MB)')
          }
          return
        }

        if (window.toast) {
          window.toast.info('Uploading avatar...', 2000)
        }

        const formData = new FormData()
        formData.append('avatar', file)

        try {
          const response = await fetch('/api/profile/upload-avatar', {
            method: 'POST',
            body: formData,
          })

          const data = await response.json()

          if (response.ok && data.imageUrl) {
            if (window.toast) {
              window.toast.success('Avatar updated successfully!')
            }

            const newSrc = `${data.imageUrl}?t=${Date.now()}`
            const avatarImg = document.getElementById('user-avatar-img') as HTMLImageElement | null
            const container = document.getElementById('user-avatar-container')

            if (avatarImg) {
              avatarImg.src = newSrc
              avatarImg.style.display = ''
            } else if (container) {
              const initialsDiv = container.querySelector('.bg-gradient-resonance') as HTMLElement | null
              const img = document.createElement('img')
              img.id = 'user-avatar-img'
              img.src = newSrc
              img.alt = 'Avatar'
              img.className = 'h-16 w-16 rounded-full object-cover'
              img.width = 64
              img.height = 64
              img.onerror = function () {
                img.style.display = 'none'
                if (initialsDiv) initialsDiv.style.display = 'flex'
              }
              container.insertBefore(img, container.firstChild)
              if (initialsDiv) {
                initialsDiv.classList.add('hidden')
                initialsDiv.style.display = 'none'
              }
            }

            document.querySelectorAll('img[src*="/uploads/avatars/"]').forEach((img) => {
              const el = img as HTMLImageElement
              const baseUrl = el.src.split('?')[0]
              if (baseUrl.includes('/uploads/avatars/')) {
                el.src = `${baseUrl.split('?')[0]}?t=${Date.now()}`
              }
            })
          } else {
            if (window.toast) {
              window.toast.error(data.error || 'Error while uploading avatar')
            }
          }
        } catch (error) {
          console.error('Avatar upload error:', error)
          if (window.toast) {
            window.toast.error('Error while uploading avatar')
          }
        } finally {
          target.value = ''
        }
      })
    }

    // Export data
    const exportBtn = document.getElementById('export-data-btn') as HTMLButtonElement | null
    if (exportBtn) {
      exportBtn.addEventListener('click', async function() {
        const button = exportBtn
        const originalText = button.textContent || ''
        
        button.disabled = true
        button.textContent = 'Exporting...'
        
        try {
          const response = await fetch('/api/collections/export')
          
          if (response.ok) {
            const blob = await response.blob()
            const url = window.URL.createObjectURL(blob)
            const downloadLink = document.createElement('a')
            downloadLink.href = url
            downloadLink.download = `resonance-export-${new Date().toISOString().split('T')[0]}.json`
            document.body.appendChild(downloadLink)
            downloadLink.click()
            document.body.removeChild(downloadLink)
            window.URL.revokeObjectURL(url)
            
            if (window.toast) {
              window.toast.success('Data exported successfully!')
            }
          } else {
            throw new Error('Error while exporting data')
          }
        } catch (error) {
          console.error('Export error:', error)
          if (window.toast) {
            window.toast.error('Error while exporting data')
          }
        } finally {
          button.disabled = false
          button.textContent = originalText
        }
      })
    }

    // Delete all data
    const deleteAllBtn = document.getElementById('delete-all-data-btn') as HTMLButtonElement | null
    if (deleteAllBtn) {
      deleteAllBtn.addEventListener('click', async function() {
        const confirmed = await window.confirmDialog?.(
          'Delete all data',
          'Are you sure you want to delete all your collections and data? This action cannot be undone.',
          'Delete everything',
          'Cancel'
        )
        
        if (!confirmed) {
          return
        }

        const button = deleteAllBtn
        const originalText = button.textContent || ''
        
        button.disabled = true
        button.textContent = 'Deleting...'
        
        try {
          const response = await fetch('/api/dev/purge-collections', {
            method: 'DELETE',
          })
          
          if (response.ok) {
            if (window.toast) {
              window.toast.success('All data has been deleted')
            }
            setTimeout(function() {
              window.location.href = '/collections'
            }, 1000)
          } else {
            throw new Error('Error while deleting data')
          }
        } catch (error) {
          console.error('Delete error:', error)
          if (window.toast) {
            window.toast.error('Error while deleting data')
          }
        } finally {
          button.disabled = false
          button.textContent = originalText
        }
      })
    }

    // Edit name
    const nameInput = document.getElementById('profile-name') as HTMLInputElement | null
    const editNameBtn = document.getElementById('edit-name-btn') as HTMLButtonElement | null
    const saveNameBtn = document.getElementById('save-name-btn') as HTMLButtonElement | null
    const cancelNameBtn = document.getElementById('cancel-name-btn') as HTMLButtonElement | null
    let originalName = nameInput?.value || ''

    if (editNameBtn && nameInput && saveNameBtn && cancelNameBtn) {
      editNameBtn.addEventListener('click', function() {
        originalName = nameInput.value
        nameInput.removeAttribute('readonly')
        nameInput.classList.remove('read-only:cursor-default', 'read-only:opacity-75')
        nameInput.focus()
        editNameBtn.classList.add('hidden')
        saveNameBtn.classList.remove('hidden')
        cancelNameBtn.classList.remove('hidden')
      })

      cancelNameBtn.addEventListener('click', function() {
        nameInput.value = originalName
        nameInput.setAttribute('readonly', '')
        nameInput.classList.add('read-only:cursor-default', 'read-only:opacity-75')
        editNameBtn.classList.remove('hidden')
        saveNameBtn.classList.add('hidden')
        cancelNameBtn.classList.add('hidden')
      })

      saveNameBtn.addEventListener('click', async function() {
        const name = nameInput.value.trim()
        
        if (name === originalName) {
          cancelNameBtn.click()
          return
        }

        if (window.setButtonLoading) window.setButtonLoading(saveNameBtn, true, '')

        try {
          const response = await fetch('/api/profile/update', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ name }),
          })

          const data = await response.json()

          if (response.ok) {
            if (window.toast) {
              window.toast.success('Name updated successfully!')
            }
            originalName = name
            nameInput.setAttribute('readonly', '')
            nameInput.classList.add('read-only:cursor-default', 'read-only:opacity-75')
            editNameBtn.classList.remove('hidden')
            saveNameBtn.classList.add('hidden')
            cancelNameBtn.classList.add('hidden')
          } else {
            if (window.toast) {
              window.toast.error(data.error || 'Error while updating name')
            }
            nameInput.value = originalName
          }
        } catch (error) {
          console.error('Name update error:', error)
          if (window.toast) {
            window.toast.error('Error while updating name')
          }
          nameInput.value = originalName
        } finally {
          if (window.setButtonLoading) window.setButtonLoading(saveNameBtn, false)
        }
      })
    }

    // Edit email
    const emailInput = document.getElementById('profile-email') as HTMLInputElement | null
    const editEmailBtn = document.getElementById('edit-email-btn') as HTMLButtonElement | null
    const saveEmailBtn = document.getElementById('save-email-btn') as HTMLButtonElement | null
    const cancelEmailBtn = document.getElementById('cancel-email-btn') as HTMLButtonElement | null
    let originalEmail = emailInput?.value || ''

    if (editEmailBtn && emailInput && saveEmailBtn && cancelEmailBtn) {
      editEmailBtn.addEventListener('click', function() {
        originalEmail = emailInput.value
        emailInput.removeAttribute('readonly')
        emailInput.classList.remove('read-only:cursor-default', 'read-only:opacity-75')
        emailInput.focus()
        editEmailBtn.classList.add('hidden')
        saveEmailBtn.classList.remove('hidden')
        cancelEmailBtn.classList.remove('hidden')
      })

      cancelEmailBtn.addEventListener('click', function() {
        emailInput.value = originalEmail
        emailInput.setAttribute('readonly', '')
        emailInput.classList.add('read-only:cursor-default', 'read-only:opacity-75')
        editEmailBtn.classList.remove('hidden')
        saveEmailBtn.classList.add('hidden')
        cancelEmailBtn.classList.add('hidden')
      })

      saveEmailBtn.addEventListener('click', async function() {
        const email = emailInput.value.trim().toLowerCase()
        
        if (email === originalEmail) {
          cancelEmailBtn.click()
          return
        }

        if (!email.includes('@')) {
          if (window.toast) {
            window.toast.error('Please enter a valid email')
          }
          return
        }

        if (window.setButtonLoading) window.setButtonLoading(saveEmailBtn, true, '')

        try {
          const response = await fetch('/api/profile/update', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ email }),
          })

          const data = await response.json()

          if (response.ok) {
            if (window.toast) {
              window.toast.success('Email updated successfully!')
            }
            originalEmail = email
            emailInput.setAttribute('readonly', '')
            emailInput.classList.add('read-only:cursor-default', 'read-only:opacity-75')
            editEmailBtn.classList.remove('hidden')
            saveEmailBtn.classList.add('hidden')
            cancelEmailBtn.classList.add('hidden')
          } else {
            if (window.toast) {
              window.toast.error(data.error || 'Error while updating email')
            }
            emailInput.value = originalEmail
          }
        } catch (error) {
          console.error('Email update error:', error)
          if (window.toast) {
            window.toast.error('Error while updating email')
          }
          emailInput.value = originalEmail
        } finally {
          if (window.setButtonLoading) window.setButtonLoading(saveEmailBtn, false)
        }
      })
    }

    // Show/hide password form
    const showPasswordFormBtn = document.getElementById('show-password-form-btn') as HTMLButtonElement | null
    const passwordForm = document.getElementById('password-form') as HTMLFormElement | null
    const cancelPasswordBtn = document.getElementById('cancel-password-btn') as HTMLButtonElement | null
    const passwordError = document.getElementById('password-error') as HTMLDivElement | null

    if (showPasswordFormBtn && passwordForm) {
      showPasswordFormBtn.addEventListener('click', function() {
        passwordForm.classList.remove('hidden')
        showPasswordFormBtn.classList.add('hidden')
        if (passwordError) {
          passwordError.classList.add('hidden')
          passwordError.textContent = ''
        }
      })
    }

    if (cancelPasswordBtn && passwordForm && showPasswordFormBtn) {
      cancelPasswordBtn.addEventListener('click', function() {
        passwordForm.classList.add('hidden')
        showPasswordFormBtn.classList.remove('hidden')
        passwordForm.reset()
        if (passwordError) {
          passwordError.classList.add('hidden')
          passwordError.textContent = ''
        }
      })
    }

    // Delete account
    const deleteAccountBtn = document.getElementById('delete-account-btn') as HTMLButtonElement | null
    if (deleteAccountBtn) {
      deleteAccountBtn.addEventListener('click', async function() {
        const confirmed = await window.confirmDialog?.(
          'Permanently delete your account',
          'This action is irreversible. All your data will be permanently deleted:\n\n• Your user account\n• All your collections\n• All your albums\n• Your wishlist\n• Your statistics\n\nAre you absolutely sure you want to continue?',
          'Yes, delete my account',
          'Cancel'
        )
        
        if (!confirmed) {
          return
        }

        const doubleConfirmed = await window.confirmDialog?.(
          'Final confirmation',
          'You are about to permanently delete your account. This action cannot be undone.\n\nDo you really want to continue?',
          'Confirm deletion',
          'Cancel'
        )

        if (!doubleConfirmed) {
          return
        }

        const button = deleteAccountBtn
        const originalText = button.textContent || ''
        
        button.disabled = true
        button.textContent = 'Deleting...'
        
        try {
          const response = await fetch('/api/profile/delete-account', {
            method: 'DELETE',
          })
          
          if (response.ok) {
            if (window.toast) {
              window.toast.success('Your account has been deleted. You will be redirected...', 3000)
            }
            setTimeout(() => {
              window.location.href = '/'
            }, 2000)
          } else {
            const data = await response.json()
            throw new Error(data.error || 'Error while deleting account')
          }
        } catch (error) {
          console.error('Delete account error:', error)
          if (window.toast) {
            window.toast.error('Error while deleting account: ' + (error instanceof Error ? error.message : 'Unknown error'))
          }
          button.disabled = false
          button.textContent = originalText
        }
      })
    }
  })()
</script>

