---
import ArrowLeft from '@lucide/astro/icons/arrow-left'
import Calendar from '@lucide/astro/icons/calendar'
import Disc from '@lucide/astro/icons/disc'
import Info from '@lucide/astro/icons/info'
import MapPin from '@lucide/astro/icons/map-pin'
import Music from '@lucide/astro/icons/music'
import Tag from '@lucide/astro/icons/tag'
import AddToCollectionModal from '../../components/explorer/AddToCollectionModal.astro'
import NotAddedBadge from '../../components/items/NotAddedBadge.astro'
import Plus from '@lucide/astro/icons/plus'
import DashboardLayout from '../../components/layouts/DashboardLayout.astro'
import OptimizedImage from '../../components/ui/OptimizedImage.astro'
import { db } from '../../lib/db'
import { buildExplorerSlug, parseExplorerSlug } from '../../lib/slug'
import { collectionRepository } from '../../repositories/collection-repository'
import { discogsService } from '../../services/discogs-service'

export const prerender = false

// Utiliser la session depuis le middleware
const session = Astro.locals.session
if (!session) return Astro.redirect('/login')

const slugParam = Astro.params.slug
if (!slugParam) return Astro.redirect('/explorer')

const discogsId = parseExplorerSlug(slugParam)
if (discogsId === null) return Astro.redirect('/explorer')

// Vérifier si l'album existe déjà pour cet utilisateur
// Si oui, rediriger vers la page complète
const existingItem = await db.item.findFirst({
  where: {
    discogsId,
    userId: Astro.locals.user!.id,
  },
  select: {
    slug: true,
  },
})

if (existingItem) {
  return Astro.redirect(`/items/${existingItem.slug}`)
}

// Récupérer les détails depuis Discogs
let release = null
let tracklist: Array<{ position: string; title: string; duration?: string }> = []
let discogsDetails = null

try {
  release = await discogsService.getRelease(discogsId)
  tracklist = release.tracklist || []
  discogsDetails = {
    masterId: release.master_id,
    masterUrl: release.master_url,
    country: release.country,
    released: release.released,
    releasedFormatted: release.released_formatted,
    notes: release.notes,
    genres: release.genres || [],
    styles: release.styles || [],
    labels: release.labels || [],
    formats: release.formats || [],
    identifiers: release.identifiers || [],
    videos: release.videos || [],
    community: release.community,
  }
} catch (error) {
  console.error('Error fetching Discogs release:', error)
  // Si l'album n'existe pas sur Discogs, rediriger vers explorer
  return Astro.redirect('/explorer')
}

// Extraire titre et artiste
const title = release.title || 'Unknown'
const artist = release.artists && release.artists.length > 0
  ? release.artists.map((artistItem) => artistItem.name).join(', ')
  : 'Unknown Artist'

// Redirection vers l’URL canonique (slug lisible) si l’URL était uniquement l’id
const canonicalSlug = buildExplorerSlug(artist, title, release.year ?? null, discogsId)
if (slugParam !== canonicalSlug && /^\d+$/.test(slugParam)) {
  return Astro.redirect(`/explorer/${canonicalSlug}`)
}

// Récupérer les collections de l'utilisateur pour le bouton d'ajout
const userCollections = await collectionRepository.findByUserId(Astro.locals.user!.id)

const coverUrl = release.cover_image || release.thumb || null
---

<DashboardLayout title={`${title} - ${artist} - Explorer - Resonance`}>
  <div class="space-y-6 page-transition">
    <!-- Bouton retour -->
    <a
      href="/explorer"
      class="inline-flex items-center gap-2 text-muted transition-colors hover:text-primary"
    >
      <ArrowLeft size={18} />
      <span>Retour à l'explorateur</span>
    </a>

    <!-- Header avec cover et infos principales -->
    <div class="glass-card rounded-2xl p-4 md:p-6">
      <div class="flex flex-col gap-6 md:flex-row">
        <!-- Cover -->
        <div class="shrink-0">
          <div class="aspect-square w-full max-w-xs overflow-hidden rounded-xl bg-surface">
            {coverUrl ? (
              <OptimizedImage
                src={coverUrl}
                alt={`${title} - ${artist}`}
                width={400}
                height={400}
                loading="eager"
                aspectRatio="square"
                class="h-full w-full object-cover"
              />
            ) : (
              <div class="flex h-full items-center justify-center text-muted">
                <Music size={48} />
              </div>
            )}
          </div>
        </div>

        <!-- Infos principales -->
        <div class="flex-1 space-y-4">
          <div>
            <div class="mb-2">
              <NotAddedBadge />
            </div>
            <h1 class="text-2xl md:text-3xl font-bold text-neutral mb-2">{title}</h1>
            <p class="text-lg md:text-xl text-muted">{artist}</p>
          </div>

          <!-- Métadonnées principales -->
          <div class="flex flex-wrap gap-4 text-sm">
            {release.year && (
              <div class="flex items-center gap-2 text-muted">
                <Calendar size={16} />
                <span>{release.year}</span>
              </div>
            )}
            {release.formats && release.formats.length > 0 && (
              <div class="flex items-center gap-2 text-muted">
                <Disc size={16} />
                <span>{release.formats.map((format) => format.name).join(', ')}</span>
              </div>
            )}
            {release.country && (
              <div class="flex items-center gap-2 text-muted">
                <MapPin size={16} />
                <span>{release.country}</span>
              </div>
            )}
            {release.genres && release.genres.length > 0 && (
              <div class="flex items-center gap-2 text-muted">
                <Tag size={16} />
                <span>{release.genres.join(', ')}</span>
              </div>
            )}
          </div>

          <!-- Bouton d'ajout (ouvre la même modal que les cartes de recherche) -->
          <div class="pt-4 border-t border-border">
            <button
              type="button"
              class="open-add-modal-btn bg-gradient-resonance hover:bg-gradient-resonance-hover flex w-full items-center justify-center gap-2 rounded-xl px-6 py-3 text-base font-medium text-white transition-all duration-300 shadow-lg shadow-primary/20"
              data-discogs-id={discogsId}
              data-redirect-on-success="true"
            >
              <Plus size={20} />
              <span>Ajouter à la collection</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Tracklist (sans previews) -->
    {tracklist.length > 0 && (
      <div class="glass-card rounded-2xl p-4 md:p-6">
        <div class="mb-4 flex items-center gap-2">
          <Music size={20} class="text-primary" />
          <h2 class="text-xl font-bold text-neutral">Tracklist</h2>
          <span class="ml-auto text-sm text-muted">
            {tracklist.length} {tracklist.length === 1 ? 'titre' : 'titres'}
          </span>
        </div>
        <div class="space-y-2">
          {tracklist.map((track, index) => (
            <div
              class="flex items-center justify-between rounded-lg border border-border bg-surface p-3"
            >
              <div class="flex items-center gap-3">
                <span class="text-sm font-medium text-muted w-8">
                  {track.position || `${index + 1}.`}
                </span>
                <span class="text-neutral">{track.title}</span>
              </div>
              {track.duration && (
                <span class="text-sm text-muted">{track.duration}</span>
              )}
            </div>
          ))}
        </div>
        <!-- Message informatif -->
        <div class="mt-4 flex items-start gap-3 rounded-lg border border-primary/20 bg-primary/10 p-4">
          <Info size={20} class="text-primary shrink-0 mt-0.5" />
          <div class="flex-1">
            <p class="text-sm font-medium text-primary mb-1">
              Écoutez les extraits
            </p>
            <p class="text-xs text-muted">
              Ajoutez cet album à votre collection pour écouter des extraits de 30 secondes de chaque titre via Spotify.
            </p>
          </div>
        </div>
      </div>
    )}

    <!-- Détails supplémentaires depuis Discogs -->
    {discogsDetails && (
      <div class="grid gap-6 md:grid-cols-2">
        <!-- Informations détaillées -->
        <div class="glass-card rounded-2xl p-4 md:p-6">
          <h2 class="mb-4 text-xl font-bold text-neutral">Informations</h2>
          <div class="space-y-3 text-sm">
            {discogsDetails.released && (
              <div>
                <span class="font-medium text-muted">Date de sortie :</span>
                <span class="ml-2 text-neutral">
                  {discogsDetails.releasedFormatted || discogsDetails.released}
                </span>
              </div>
            )}
            {discogsDetails.country && (
              <div>
                <span class="font-medium text-muted">Pays :</span>
                <span class="ml-2 text-neutral">{discogsDetails.country}</span>
              </div>
            )}
            {discogsDetails.labels.length > 0 && (
              <div>
                <span class="font-medium text-muted">Label(s) :</span>
                <span class="ml-2 text-neutral">
                  {discogsDetails.labels.map((label) => label.name).join(', ')}
                </span>
              </div>
            )}
            {discogsDetails.genres.length > 0 && (
              <div>
                <span class="font-medium text-muted">Genres :</span>
                <span class="ml-2 text-neutral">
                  {discogsDetails.genres.join(', ')}
                </span>
              </div>
            )}
            {discogsDetails.styles.length > 0 && (
              <div>
                <span class="font-medium text-muted">Styles :</span>
                <span class="ml-2 text-neutral">
                  {discogsDetails.styles.join(', ')}
                </span>
              </div>
            )}
            {discogsDetails.identifiers.length > 0 && (
              <div>
                <span class="font-medium text-muted">Identifiants :</span>
                <div class="mt-1 space-y-1">
                  {discogsDetails.identifiers.map((id) => (
                    <div class="text-neutral">
                      <span class="font-medium">{id.type}:</span> {id.value}
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>

        <!-- Format et communauté -->
        <div class="glass-card rounded-2xl p-4 md:p-6">
          <h2 class="mb-4 text-xl font-bold text-neutral">Format & Communauté</h2>
          <div class="space-y-3 text-sm">
            {discogsDetails.formats.length > 0 && (
              <div>
                <span class="font-medium text-muted">Format(s) :</span>
                <div class="mt-1 space-y-1">
                  {discogsDetails.formats.map((format) => (
                    <div class="text-neutral">
                      {format.name} {format.text && `(${format.text})`}
                    </div>
                  ))}
                </div>
              </div>
            )}
            {discogsDetails.community && (
              <div class="space-y-2">
                <div>
                  <span class="font-medium text-muted">Note moyenne :</span>
                  <span class="ml-2 text-neutral">
                    {discogsDetails.community.rating.average > 0
                      ? `${discogsDetails.community.rating.average.toFixed(1)} / 5`
                      : 'Non noté'}
                    {discogsDetails.community.rating.count > 0 &&
                      ` (${discogsDetails.community.rating.count} avis)`}
                  </span>
                </div>
                <div>
                  <span class="font-medium text-muted">Collectionneurs :</span>
                  <span class="ml-2 text-neutral">
                    {discogsDetails.community.have} ont cet album
                  </span>
                </div>
                <div>
                  <span class="font-medium text-muted">Souhaité par :</span>
                  <span class="ml-2 text-neutral">
                    {discogsDetails.community.want} personnes
                  </span>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    )}

    <!-- Notes Discogs -->
    {discogsDetails?.notes && (
      <div class="glass-card rounded-2xl p-4 md:p-6">
        <h2 class="mb-4 text-xl font-bold text-neutral">Notes</h2>
        <p class="whitespace-pre-wrap text-muted">{discogsDetails.notes}</p>
      </div>
    )}
  </div>

  <AddToCollectionModal collections={userCollections} />
</DashboardLayout>

<script>
  // TypeScript fonctionne nativement dans les scripts Astro !
  document.addEventListener('DOMContentLoaded', function() {
    const btn = document.querySelector('.open-add-modal-btn')
    const modal = document.getElementById('add-to-collection-modal')
    if (!btn || !modal) return

    btn.addEventListener('click', function() {
      const discogsId = btn.getAttribute('data-discogs-id')
      const redirectOnSuccess = btn.getAttribute('data-redirect-on-success')
      if (discogsId) {
        modal.setAttribute('data-discogs-id', discogsId)
        if (redirectOnSuccess) {
          modal.setAttribute('data-redirect-on-success', 'true')
        } else {
          modal.removeAttribute('data-redirect-on-success')
        }
        modal.classList.remove('hidden')
        ;(modal as HTMLElement).style.display = 'flex'
      }
    })
  })
</script>
