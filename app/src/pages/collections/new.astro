---
import DashboardLayout from '../../components/layouts/DashboardLayout.astro'
import Folder from '@lucide/astro/icons/folder'
import Plus from '@lucide/astro/icons/plus'
import { collectionRepository } from '../../repositories/collection-repository'
import EmptyState from '../../components/ui/EmptyState.astro'
import AlertCircle from '@lucide/astro/icons/circle-alert'

export const prerender = false

// Utiliser la session depuis le middleware (Astro.locals)
const session = Astro.locals.session
if (!session) return Astro.redirect('/login')

const MAX_COLLECTIONS = 2
const collectionsCount = await collectionRepository.countByUserId(Astro.locals.user!.id)
const canCreateNewCollection = collectionsCount < MAX_COLLECTIONS

if (!canCreateNewCollection) {
  // Rediriger vers la page des collections si la limite est atteinte
  return Astro.redirect('/collections')
}
---

<DashboardLayout title="New Collection - Resonance">
  <div class="mx-auto max-w-2xl">
    <div class="mb-8">
      <h1 class="text-2xl font-bold">Create a collection</h1>
      <p class="text-muted">Organize your albums into custom collections</p>
    </div>

    <form class="glass-card space-y-6 rounded-2xl p-8" id="create-collection-form">
      <div>
        <label for="name" class="mb-2 block text-sm font-medium text-neutral">
          Collection name *
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full rounded-xl border border-border bg-surface p-3 text-neutral placeholder-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
          placeholder="E.g. Jazz Legends, 80s..."
        />
      </div>

      <div>
        <label for="description" class="mb-2 block text-sm font-medium text-neutral">
          Description (optional)
        </label>
        <textarea
          id="description"
          name="description"
          rows={4}
          class="w-full rounded-xl border border-border bg-surface p-3 text-neutral placeholder-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
          placeholder="Describe your collection..."
        ></textarea>
      </div>

      <div class="flex items-center gap-3">
        <input
          type="checkbox"
          id="isPublic"
          name="isPublic"
          class="h-5 w-5 rounded border-border text-primary focus:ring-2 focus:ring-primary"
        />
        <label for="isPublic" class="text-sm text-neutral">
          Make this collection public
        </label>
      </div>

      <div
        id="create-collection-error"
        class="error-message hidden rounded-lg border border-red-500 bg-red-500/10 p-4 text-sm text-red-500"
        role="alert"
        aria-live="polite"
      ></div>

      <div class="flex gap-3">
        <button
          type="submit"
          class="btn-primary-gradient flex flex-1 items-center justify-center gap-2 rounded-xl px-6 py-3"
        >
          <Plus size={20} />
          <span>Create collection</span>
        </button>
        <a
          href="/collections"
          class="flex items-center justify-center rounded-xl border border-border bg-surface px-6 py-3 font-medium text-neutral transition-colors hover:bg-surface-elevated"
        >
          Cancel
        </a>
      </div>
    </form>
  </div>
</DashboardLayout>

<script is:inline>
  (function() {
  const form = document.getElementById('create-collection-form')
  if (!form) return

  const errorBox = document.getElementById('create-collection-error')
  const nameInput = document.getElementById('name')

  function setFieldError(input, hasError) {
    if (!input) return
    if (hasError) {
      input.setAttribute('aria-invalid', 'true')
      input.classList.add('border-red-500')
    } else {
      input.removeAttribute('aria-invalid')
      input.classList.remove('border-red-500')
    }
  }

  form.addEventListener('submit', async function(event) {
    event.preventDefault()

    if (errorBox) {
      errorBox.classList.add('hidden')
      errorBox.textContent = ''
    }
    setFieldError(nameInput, false)

    const formData = new FormData(form)
    const name = formData.get('name')

    if (!name || String(name).trim().length === 0) {
      if (errorBox) {
        errorBox.textContent = 'Please provide a name for your collection.'
        errorBox.classList.remove('hidden')
      }
      setFieldError(nameInput, true)
      if (nameInput) {
        nameInput.focus()
      }
      if (window.toast) {
        window.toast.error('Please provide a name for your collection')
      }
      return
    }

    const collectionData = {
      name,
      description: formData.get('description'),
      isPublic: formData.get('isPublic') === 'on',
    }

    const submitButton = form.querySelector('button[type="submit"]')
    const originalButtonText = submitButton ? (submitButton.textContent || '') : 'Create collection'
    if (submitButton) {
      submitButton.disabled = true
      submitButton.textContent = 'Creating...'
    }

    try {
      const response = await fetch('/api/collections/create', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(collectionData),
        })

        const responseData = await response.json()

        if (response.ok) {
          if (window.toast) {
            window.toast.success('Collection created successfully!')
          }
          document.location.href = '/collections/' + responseData.slug
        } else {
          const message = responseData.error || 'Error while creating collection'

          if (errorBox) {
            errorBox.textContent = message
            errorBox.classList.remove('hidden')
          }
          setFieldError(nameInput, true)
          if (nameInput) {
            nameInput.focus()
          }
          if (window.toast) {
            window.toast.error(message)
          }

          // If the limit is reached, redirect after 3 seconds
          if (responseData.maxCollections && responseData.currentCount >= responseData.maxCollections) {
            setTimeout(function() {
              window.location.href = '/collections'
            }, 3000)
          }
        }
      } catch (error) {
        console.error('Error creating collection:', error)
        if (window.toast) {
          window.toast.error('An error occurred while creating the collection')
        }
        if (errorBox) {
          errorBox.textContent = 'An error occurred while creating the collection'
          errorBox.classList.remove('hidden')
        }
        setFieldError(nameInput, true)
      }
    } finally {
      const submitButton = form.querySelector('button[type="submit"]')
      if (submitButton) {
        submitButton.disabled = false
        submitButton.textContent = originalButtonText || 'Create collection'
      }
    }
  })
  })()
</script>

<style>
  .glass-card {
    transition: all 0.3s ease;
  }
</style>

