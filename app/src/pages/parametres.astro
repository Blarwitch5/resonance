---
import DashboardLayout from '../components/layouts/DashboardLayout.astro'
import ThemeSwitcher from '../components/ui/ThemeSwitcher.astro'
import Avatar from '../components/ui/Avatar.astro'
import Camera from '@lucide/astro/icons/camera'
import Pencil from '@lucide/astro/icons/pencil'
import Check from '@lucide/astro/icons/check'
import X from '@lucide/astro/icons/x'
import ArrowLeft from '@lucide/astro/icons/arrow-left'

const session = Astro.locals.session
const user = Astro.locals.user

if (!session || !user) {
  return Astro.redirect('/login')
}
---

<DashboardLayout title="Paramètres - Resonance" description="Gérez vos préférences et paramètres">
  <div class="mx-auto max-w-4xl space-y-8">
    <!-- En-tête -->
    <div>
      <a
        href="/profil"
        class="mb-3 inline-flex items-center gap-2 text-sm text-muted transition-colors hover:text-primary"
      >
        <ArrowLeft size={16} />
        <span>Retour au profil</span>
      </a>
      <h1 class="text-3xl font-bold text-neutral mb-1">Paramètres</h1>
      <p class="text-muted">Gérez vos préférences et paramètres de compte</p>
    </div>

    <!-- Section Apparence -->
    <section class="glass-card rounded-2xl p-6">
      <h2 class="text-xl font-semibold text-neutral mb-4">Apparence</h2>
      
      <div class="space-y-4">
        <!-- Thème -->
        <div class="flex items-center justify-between p-4 rounded-xl border border-border/50 bg-surface hover:bg-surface-elevated transition-colors">
          <div>
            <h3 class="font-medium text-neutral mb-1">Thème</h3>
            <p class="text-sm text-muted">Choisissez entre le thème clair et sombre</p>
          </div>
          <div class="shrink-0">
            <ThemeSwitcher size="lg" />
          </div>
        </div>
      </div>
    </section>

    <!-- Section Compte -->
    <section class="glass-card rounded-2xl p-6">
      <h2 class="text-xl font-semibold text-neutral mb-4">Compte</h2>
      
      <div class="space-y-6">
        <!-- Avatar -->
        <div>
          <h3 class="font-medium text-neutral mb-3">Photo de profil</h3>
          <div class="flex items-center gap-4">
            <div class="relative" id="user-avatar-container">
              <Avatar
                userName={user.name}
                userEmail={user.email}
                imageUrl={user.image ? `${user.image}?t=${Date.now()}` : undefined}
                size="xl"
                id="user-avatar"
              />
              <label
                for="avatar-upload"
                class="absolute bottom-0 right-0 flex h-8 w-8 cursor-pointer items-center justify-center rounded-full bg-primary text-white shadow-lg transition-all hover:scale-110"
                title="Changer la photo de profil"
              >
                <Camera size={16} />
                <input
                  type="file"
                  id="avatar-upload"
                  name="avatar"
                  accept="image/jpeg,image/jpg,image/png,image/webp,image/gif"
                  class="hidden"
                />
              </label>
            </div>
            <div class="flex-1">
              <p class="text-sm text-muted mb-1">
                Cliquez sur l'icône pour changer votre photo de profil
              </p>
              <p class="text-xs text-muted">
                Formats acceptés : JPEG, PNG, WebP, GIF (max 5MB)
              </p>
            </div>
          </div>
        </div>

        <!-- Informations utilisateur -->
        <div>
          <h3 class="font-medium text-neutral mb-4">Informations personnelles</h3>
          <div class="space-y-4">
            <!-- Nom -->
            <div>
              <label class="block text-sm font-medium text-neutral mb-2">
                Nom
              </label>
              <div class="flex items-center gap-2">
                <input
                  type="text"
                  id="profile-name"
                  name="name"
                  value={user.name || ''}
                  placeholder="Votre nom"
                  readonly
                  class="flex-1 rounded-lg border border-border bg-surface px-4 py-2 text-neutral focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 read-only:cursor-default read-only:opacity-75"
                />
                <button
                  type="button"
                  id="edit-name-btn"
                  class="btn-icon-secondary p-2 rounded-lg"
                  aria-label="Modifier le nom"
                >
                  <Pencil size={18} />
                </button>
                <button
                  type="button"
                  id="save-name-btn"
                  class="btn-icon-colored p-2 rounded-lg hidden"
                  aria-label="Enregistrer le nom"
                >
                  <Check size={18} />
                </button>
                <button
                  type="button"
                  id="cancel-name-btn"
                  class="btn-icon-secondary p-2 rounded-lg hidden"
                  aria-label="Annuler"
                >
                  <X size={18} />
                </button>
              </div>
            </div>

            <!-- Email -->
            <div>
              <label class="block text-sm font-medium text-neutral mb-2">
                Email
              </label>
              <div class="flex items-center gap-2">
                <input
                  type="email"
                  id="profile-email"
                  name="email"
                  value={user.email || ''}
                  placeholder="votre@email.com"
                  readonly
                  class="flex-1 rounded-lg border border-border bg-surface px-4 py-2 text-neutral focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 read-only:cursor-default read-only:opacity-75"
                />
                <button
                  type="button"
                  id="edit-email-btn"
                  class="btn-icon-secondary p-2 rounded-lg"
                  aria-label="Modifier l'email"
                >
                  <Pencil size={18} />
                </button>
                <button
                  type="button"
                  id="save-email-btn"
                  class="btn-icon-colored p-2 rounded-lg hidden"
                  aria-label="Enregistrer l'email"
                >
                  <Check size={18} />
                </button>
                <button
                  type="button"
                  id="cancel-email-btn"
                  class="btn-icon-secondary p-2 rounded-lg hidden"
                  aria-label="Annuler"
                >
                  <X size={18} />
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Changer le mot de passe -->
        <div class="border-t border-border pt-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-medium text-neutral">Mot de passe</h3>
            <button
              type="button"
              id="show-password-form-btn"
              class="btn-secondary-surface px-4 py-2 rounded-lg text-sm"
            >
              Changer le mot de passe
            </button>
          </div>
          
          <form id="password-form" class="space-y-4 hidden">
            <div>
              <label for="current-password" class="block text-sm font-medium text-neutral mb-2">
                Mot de passe actuel
              </label>
              <input
                type="password"
                id="current-password"
                name="currentPassword"
                placeholder="Entrez votre mot de passe actuel"
                class="w-full rounded-lg border border-border bg-surface px-4 py-2 text-neutral focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                required
              />
            </div>
            <div>
              <label for="new-password" class="block text-sm font-medium text-neutral mb-2">
                Nouveau mot de passe
              </label>
              <input
                type="password"
                id="new-password"
                name="newPassword"
                placeholder="Entrez votre nouveau mot de passe"
                class="w-full rounded-lg border border-border bg-surface px-4 py-2 text-neutral focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                required
              />
              <p class="mt-2 text-xs text-muted">
                Le mot de passe doit contenir au moins 8 caractères, une majuscule, une minuscule, un chiffre et un caractère spécial.
              </p>
              <div id="password-requirements" class="mt-2 space-y-1 text-xs">
                <div id="req-length" class="text-muted">• Au moins 8 caractères</div>
                <div id="req-lowercase" class="text-muted">• Une minuscule</div>
                <div id="req-uppercase" class="text-muted">• Une majuscule</div>
                <div id="req-number" class="text-muted">• Un chiffre</div>
                <div id="req-special" class="text-muted">• Un caractère spécial</div>
              </div>
            </div>
            <div>
              <label for="confirm-password" class="block text-sm font-medium text-neutral mb-2">
                Confirmer le nouveau mot de passe
              </label>
              <input
                type="password"
                id="confirm-password"
                name="confirmPassword"
                placeholder="Confirmez votre nouveau mot de passe"
                class="w-full rounded-lg border border-border bg-surface px-4 py-2 text-neutral focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                required
              />
              <div id="password-match" class="mt-2 text-xs text-muted"></div>
            </div>
            <div class="flex justify-end gap-2">
              <button
                type="button"
                id="cancel-password-btn"
                class="btn-secondary-surface px-4 py-2 rounded-lg"
              >
                Annuler
              </button>
              <button
                type="submit"
                id="save-password-btn"
                class="btn-primary-gradient px-6 py-2 rounded-lg"
              >
                Changer le mot de passe
              </button>
            </div>
          </form>
        </div>
      </div>
    </section>

    <!-- Section Données -->
    <section class="glass-card rounded-2xl p-6">
      <h2 class="text-xl font-semibold text-neutral mb-4">Données</h2>
      
      <div class="space-y-4">
        <!-- Export de données -->
        <div class="flex flex-col gap-3 border-b border-border/60 pb-4 md:flex-row md:items-center md:justify-between md:border-b-0 md:pb-0">
          <div>
            <h3 class="font-medium text-neutral mb-1">Exporter mes données</h3>
            <p class="text-sm text-muted">Téléchargez toutes vos collections et données au format JSON</p>
          </div>
          <div>
            <button
              id="export-data-btn"
              class="btn-secondary-surface w-full px-4 py-2 rounded-lg md:w-auto"
            >
              Exporter
            </button>
          </div>
        </div>

        <!-- Supprimer toutes les données -->
        <div class="flex flex-col gap-3 border-b border-border/60 pt-4 pb-4 md:flex-row md:items-center md:justify-between md:border-b-0 md:pt-4 md:pb-0">
          <div>
            <h3 class="font-medium text-neutral mb-1">Supprimer toutes les données</h3>
            <p class="text-sm text-muted">Supprime toutes vos collections et items, mais conserve votre compte</p>
          </div>
          <div>
            <button
              id="delete-all-data-btn"
              class="btn-danger w-full px-4 py-2 rounded-lg md:w-auto"
            >
              Supprimer les données
            </button>
          </div>
        </div>

        <!-- Supprimer le compte -->
        <div class="flex flex-col gap-3 border-t border-border pt-4 md:flex-row md:items-center md:justify-between">
          <div>
            <h3 class="font-medium text-neutral mb-1">Supprimer mon compte</h3>
            <p class="text-sm text-muted">Cette action est irréversible et supprimera définitivement votre compte et toutes vos données</p>
          </div>
          <div>
            <button
              id="delete-account-btn"
              class="btn-danger w-full px-4 py-2 rounded-lg md:w-auto"
            >
              Supprimer le compte
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Section Notifications (à venir) -->
    <section class="glass-card rounded-2xl p-6 opacity-60">
      <h2 class="text-xl font-semibold text-neutral mb-4">Notifications</h2>
      <p class="text-sm text-muted">Les notifications seront disponibles prochainement</p>
    </section>

    <!-- Section À propos -->
    <section class="glass-card rounded-2xl p-6">
      <h2 class="text-xl font-semibold text-neutral mb-4">À propos</h2>
      
      <div class="space-y-2 text-sm text-muted">
        <p><strong class="text-neutral">Resonance</strong> - Gestionnaire de collection musicale</p>
        <p>Version 1.0.0</p>
      </div>
    </section>
  </div>
</DashboardLayout>

<script>
  // TypeScript fonctionne nativement dans les scripts Astro !
  (function() {
    // Upload d'avatar
    const avatarUpload = document.getElementById('avatar-upload') as HTMLInputElement | null
    if (avatarUpload) {
      avatarUpload.addEventListener('change', async function(event: Event) {
        const target = event.target as HTMLInputElement
        const file = target.files?.[0]
        if (!file) return

        // Vérifier la taille
        if (file.size > 5 * 1024 * 1024) {
          if (window.toast) {
            window.toast.error('Le fichier est trop volumineux (max 5MB)')
          }
          return
        }

        // Afficher un toast de chargement
        if (window.toast) {
          window.toast.info('Upload de l\'avatar en cours...', 2000)
        }

        const formData = new FormData()
        formData.append('avatar', file)

        try {
          const response = await fetch('/api/profile/upload-avatar', {
            method: 'POST',
            body: formData,
          })

          const data = await response.json()

          if (response.ok && data.imageUrl) {
            if (window.toast) {
              window.toast.success('Avatar mis à jour avec succès !')
            }

            const newSrc = `${data.imageUrl}?t=${Date.now()}`
            const avatarImg = document.getElementById('user-avatar-img') as HTMLImageElement | null
            const container = document.getElementById('user-avatar-container')

            if (avatarImg) {
              avatarImg.src = newSrc
              avatarImg.style.display = ''
            } else if (container) {
              const initialsDiv = container.querySelector('.bg-gradient-resonance') as HTMLElement | null
              const img = document.createElement('img')
              img.id = 'user-avatar-img'
              img.src = newSrc
              img.alt = 'Avatar'
              img.className = 'h-16 w-16 rounded-full object-cover'
              img.width = 64
              img.height = 64
              img.onerror = function () {
                img.style.display = 'none'
                if (initialsDiv) initialsDiv.style.display = 'flex'
              }
              container.insertBefore(img, container.firstChild)
              if (initialsDiv) {
                initialsDiv.classList.add('hidden')
                initialsDiv.style.display = 'none'
              }
            }

            document.querySelectorAll('img[src*="/uploads/avatars/"]').forEach((img) => {
              const el = img as HTMLImageElement
              const baseUrl = el.src.split('?')[0]
              if (baseUrl.includes('/uploads/avatars/')) {
                el.src = `${baseUrl.split('?')[0]}?t=${Date.now()}`
              }
            })
          } else {
            if (window.toast) {
              window.toast.error(data.error || 'Erreur lors de l\'upload de l\'avatar')
            }
          }
        } catch (error) {
          console.error('Avatar upload error:', error)
          if (window.toast) {
            window.toast.error('Erreur lors de l\'upload de l\'avatar')
          }
        } finally {
          // Réinitialiser l'input
          target.value = ''
        }
      })
    }

    // Export de données
    const exportBtn = document.getElementById('export-data-btn') as HTMLButtonElement | null
    if (exportBtn) {
      exportBtn.addEventListener('click', async function() {
        const button = exportBtn
        const originalText = button.textContent || ''
        
        button.disabled = true
        button.textContent = 'Exportation...'
        
        try {
          const response = await fetch('/api/collections/export')
          
          if (response.ok) {
            const blob = await response.blob()
            const url = window.URL.createObjectURL(blob)
            const downloadLink = document.createElement('a')
            downloadLink.href = url
            downloadLink.download = `resonance-export-${new Date().toISOString().split('T')[0]}.json`
            document.body.appendChild(downloadLink)
            downloadLink.click()
            document.body.removeChild(downloadLink)
            window.URL.revokeObjectURL(url)
            
            if (window.toast) {
              window.toast.success('Données exportées avec succès !')
            }
          } else {
            throw new Error('Erreur lors de l\'export')
          }
        } catch (error) {
          console.error('Export error:', error)
          if (window.toast) {
            window.toast.error('Erreur lors de l\'export des données')
          }
        } finally {
          button.disabled = false
          button.textContent = originalText
        }
      })
    }

    // Supprimer toutes les données
    const deleteAllBtn = document.getElementById('delete-all-data-btn') as HTMLButtonElement | null
    if (deleteAllBtn) {
      deleteAllBtn.addEventListener('click', async function() {
        const confirmed = await window.confirmDialog?.(
          'Supprimer toutes les données',
          'Êtes-vous sûr de vouloir supprimer toutes vos collections et données ? Cette action est irréversible.',
          'Supprimer tout',
          'Annuler'
        )
        
        if (!confirmed) {
          return
        }

        const button = deleteAllBtn
        const originalText = button.textContent || ''
        
        button.disabled = true
        button.textContent = 'Suppression...'
        
        try {
          const response = await fetch('/api/dev/purge-collections', {
            method: 'DELETE',
          })
          
          if (response.ok) {
            if (window.toast) {
              window.toast.success('Toutes les données ont été supprimées')
            }
            setTimeout(function() {
              window.location.href = '/collections'
            }, 1000)
          } else {
            throw new Error('Erreur lors de la suppression')
          }
        } catch (error) {
          console.error('Delete error:', error)
          if (window.toast) {
            window.toast.error('Erreur lors de la suppression des données')
          }
        } finally {
          button.disabled = false
          button.textContent = originalText
        }
      })
    }

    // Gestion de l'édition du nom
    const nameInput = document.getElementById('profile-name') as HTMLInputElement | null
    const editNameBtn = document.getElementById('edit-name-btn') as HTMLButtonElement | null
    const saveNameBtn = document.getElementById('save-name-btn') as HTMLButtonElement | null
    const cancelNameBtn = document.getElementById('cancel-name-btn') as HTMLButtonElement | null
    let originalName = nameInput?.value || ''

    if (editNameBtn && nameInput && saveNameBtn && cancelNameBtn) {
      editNameBtn.addEventListener('click', function() {
        originalName = nameInput.value
        nameInput.removeAttribute('readonly')
        nameInput.classList.remove('read-only:cursor-default', 'read-only:opacity-75')
        nameInput.focus()
        editNameBtn.classList.add('hidden')
        saveNameBtn.classList.remove('hidden')
        cancelNameBtn.classList.remove('hidden')
      })

      cancelNameBtn.addEventListener('click', function() {
        nameInput.value = originalName
        nameInput.setAttribute('readonly', '')
        nameInput.classList.add('read-only:cursor-default', 'read-only:opacity-75')
        editNameBtn.classList.remove('hidden')
        saveNameBtn.classList.add('hidden')
        cancelNameBtn.classList.add('hidden')
      })

      saveNameBtn.addEventListener('click', async function() {
        const name = nameInput.value.trim()
        
        if (name === originalName) {
          cancelNameBtn.click()
          return
        }

        saveNameBtn.disabled = true
        const originalIcon = saveNameBtn.innerHTML
        saveNameBtn.innerHTML = '<svg class="animate-spin" width="18" height="18" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>'

        try {
          const response = await fetch('/api/profile/update', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ name }),
          })

          const data = await response.json()

          if (response.ok) {
            if (window.toast) {
              window.toast.success('Nom mis à jour avec succès !')
            }
            originalName = name
            nameInput.setAttribute('readonly', '')
            nameInput.classList.add('read-only:cursor-default', 'read-only:opacity-75')
            editNameBtn.classList.remove('hidden')
            saveNameBtn.classList.add('hidden')
            cancelNameBtn.classList.add('hidden')
          } else {
            if (window.toast) {
              window.toast.error(data.error || 'Erreur lors de la mise à jour du nom')
            }
            nameInput.value = originalName
          }
        } catch (error) {
          console.error('Name update error:', error)
          if (window.toast) {
            window.toast.error('Erreur lors de la mise à jour du nom')
          }
          nameInput.value = originalName
        } finally {
          saveNameBtn.disabled = false
          saveNameBtn.innerHTML = originalIcon
        }
      })
    }

    // Gestion de l'édition de l'email
    const emailInput = document.getElementById('profile-email') as HTMLInputElement | null
    const editEmailBtn = document.getElementById('edit-email-btn') as HTMLButtonElement | null
    const saveEmailBtn = document.getElementById('save-email-btn') as HTMLButtonElement | null
    const cancelEmailBtn = document.getElementById('cancel-email-btn') as HTMLButtonElement | null
    let originalEmail = emailInput?.value || ''

    if (editEmailBtn && emailInput && saveEmailBtn && cancelEmailBtn) {
      editEmailBtn.addEventListener('click', function() {
        originalEmail = emailInput.value
        emailInput.removeAttribute('readonly')
        emailInput.classList.remove('read-only:cursor-default', 'read-only:opacity-75')
        emailInput.focus()
        editEmailBtn.classList.add('hidden')
        saveEmailBtn.classList.remove('hidden')
        cancelEmailBtn.classList.remove('hidden')
      })

      cancelEmailBtn.addEventListener('click', function() {
        emailInput.value = originalEmail
        emailInput.setAttribute('readonly', '')
        emailInput.classList.add('read-only:cursor-default', 'read-only:opacity-75')
        editEmailBtn.classList.remove('hidden')
        saveEmailBtn.classList.add('hidden')
        cancelEmailBtn.classList.add('hidden')
      })

      saveEmailBtn.addEventListener('click', async function() {
        const email = emailInput.value.trim().toLowerCase()
        
        if (email === originalEmail) {
          cancelEmailBtn.click()
          return
        }

        if (!email.includes('@')) {
          if (window.toast) {
            window.toast.error('Veuillez entrer un email valide')
          }
          return
        }

        saveEmailBtn.disabled = true
        const originalIcon = saveEmailBtn.innerHTML
        saveEmailBtn.innerHTML = '<svg class="animate-spin" width="18" height="18" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>'

        try {
          const response = await fetch('/api/profile/update', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ email }),
          })

          const data = await response.json()

          if (response.ok) {
            if (window.toast) {
              window.toast.success('Email mis à jour avec succès !')
            }
            originalEmail = email
            emailInput.setAttribute('readonly', '')
            emailInput.classList.add('read-only:cursor-default', 'read-only:opacity-75')
            editEmailBtn.classList.remove('hidden')
            saveEmailBtn.classList.add('hidden')
            cancelEmailBtn.classList.add('hidden')
          } else {
            if (window.toast) {
              window.toast.error(data.error || 'Erreur lors de la mise à jour de l\'email')
            }
            emailInput.value = originalEmail
          }
        } catch (error) {
          console.error('Email update error:', error)
          if (window.toast) {
            window.toast.error('Erreur lors de la mise à jour de l\'email')
          }
          emailInput.value = originalEmail
        } finally {
          saveEmailBtn.disabled = false
          saveEmailBtn.innerHTML = originalIcon
        }
      })
    }

    // Afficher/masquer le formulaire de changement de mot de passe
    const showPasswordFormBtn = document.getElementById('show-password-form-btn') as HTMLButtonElement | null
    const passwordForm = document.getElementById('password-form') as HTMLFormElement | null
    const cancelPasswordBtn = document.getElementById('cancel-password-btn') as HTMLButtonElement | null

    if (showPasswordFormBtn && passwordForm) {
      showPasswordFormBtn.addEventListener('click', function() {
        passwordForm.classList.remove('hidden')
        showPasswordFormBtn.classList.add('hidden')
      })
    }

    if (cancelPasswordBtn && passwordForm && showPasswordFormBtn) {
      cancelPasswordBtn.addEventListener('click', function() {
        passwordForm.classList.add('hidden')
        showPasswordFormBtn.classList.remove('hidden')
        passwordForm.reset()
        // Note: validatePasswordRequirements et checkPasswordMatch sont définis dans le script du formulaire de mot de passe
        // Ces fonctions sont appelées dynamiquement et peuvent ne pas être disponibles au moment de l'annulation
      })
    }

    // Supprimer le compte
    const deleteAccountBtn = document.getElementById('delete-account-btn') as HTMLButtonElement | null
    if (deleteAccountBtn) {
      deleteAccountBtn.addEventListener('click', async function() {
        // Double confirmation avec modal personnalisé
        const confirmed = await window.confirmDialog?.(
          'Supprimer définitivement votre compte',
          'Cette action est irréversible. Toutes vos données seront définitivement supprimées :\n\n• Votre compte utilisateur\n• Toutes vos collections\n• Tous vos albums\n• Votre wishlist\n• Vos statistiques\n\nÊtes-vous absolument sûr de vouloir continuer ?',
          'Oui, supprimer mon compte',
          'Annuler'
        )
        
        if (!confirmed) {
          return
        }

        // Deuxième confirmation pour une action aussi critique
        const doubleConfirmed = await window.confirmDialog?.(
          'Dernière confirmation',
          'Vous êtes sur le point de supprimer définitivement votre compte. Cette action ne peut pas être annulée.\n\nVoulez-vous vraiment continuer ?',
          'Confirmer la suppression',
          'Annuler'
        )

        if (!doubleConfirmed) {
          return
        }

        const button = deleteAccountBtn
        const originalText = button.textContent || ''
        
        button.disabled = true
        button.textContent = 'Suppression...'
        
        try {
          const response = await fetch('/api/profile/delete-account', {
            method: 'DELETE',
          })
          
          if (response.ok) {
            if (window.toast) {
              window.toast.success('Votre compte a été supprimé. Vous allez être redirigé...', 3000)
            }
            // Rediriger vers la page d'accueil après un court délai
            setTimeout(() => {
              window.location.href = '/'
            }, 2000)
          } else {
            const data = await response.json()
            throw new Error(data.error || 'Erreur lors de la suppression du compte')
          }
        } catch (error) {
          console.error('Delete account error:', error)
          if (window.toast) {
            window.toast.error('Erreur lors de la suppression du compte : ' + (error instanceof Error ? error.message : 'Erreur inconnue'))
          }
          button.disabled = false
          button.textContent = originalText
        }
      })
    }
  })()
</script>
