{
  "name": "resonance-app",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "astro dev",
    "dev:clean": "pkill -f 'astro dev' || true && rm -rf .astro node_modules/.astro node_modules/.vite .vite dist && pnpm dev",
    "build": " astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write . --ignore-path .prettierignore",
    "format:check": "prettier --check . --ignore-path .prettierignore",
    "a11y": "playwright test --config playwright.config.cjs",
    "e2e:smoke": "playwright test --config playwright.config.cjs tests/smoke-critical.spec.ts",
    "covers:update": "tsx scripts/update-covers-hq.ts",
    "covers:clean": "tsx scripts/clean-covers.ts",
    "seed:test": "tsx scripts/seed-test-data.ts",
    "seed:dev": "tsx scripts/seed-dev.ts",
    "seed:dev:clean": "tsx scripts/seed-dev-clean.ts",
    "clean:cache": "pkill -f 'astro dev' || true && rm -rf .astro node_modules/.astro node_modules/.vite .vite dist",
    "cap:sync": "astro build && cap sync",
    "cap:ios": "pnpm cap:sync && cap open ios",
    "cap:android": "pnpm cap:sync && cap open android",
    "gen:index": "tsx scripts/gen-codebase-index.ts"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.4",
    "@astrojs/vercel": "^10.0.4",
    "@capacitor/camera": "^8.1.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/push-notifications": "^8.0.3",
    "@lucide/astro": "^0.562.0",
    "@prisma/client": "^6.19.3",
    "@vercel/blob": "^0.26.0",
    "astro": "^6.1.4",
    "better-auth": "^1.6.0",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^4.1.0",
    "piccolore": "^0.1.3",
    "pnpm": "^10.33.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@capacitor/android": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "prettier": "latest",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.2.1",
    "tsx": "latest"
  }
}
